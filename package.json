{
  "name": "bike-app-astro",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "maps:generate": "npx tsx scripts/generate-maps.ts",
    "maps:rebuild": "npx tsx scripts/generate-maps.ts --force",
    "test": "npx vitest run",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:update": "npx playwright test --config e2e/playwright.config.ts --update-snapshots",
    "validate": "npx tsx scripts/validate.ts",
    "capture:production": "npx playwright test --config e2e/capture-production.config.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.0.0-beta.11",
    "@astrojs/node": "^10.0.0-beta.6",
    "@astrojs/preact": "^4.1.3",
    "@mapbox/polyline": "^1.2.1",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vovayatsyuk/photoswipe-object-position": "^1.0.0",
    "astro": "^6.0.0-beta.20",
    "aws4fetch": "^1.0.20",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "exif-reader": "^2.0.3",
    "fast-xml-parser": "^5.4.1",
    "fflate": "^0.8.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "marked": "^17.0.3",
    "photoswipe": "^5.4.4",
    "photoswipe-dynamic-caption-plugin": "^1.2.7",
    "plausible-tracker": "^0.3.9",
    "preact": "^10.28.4",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
