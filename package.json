{
  "name": "whereto-bike",
  "type": "module",
  "version": "0.0.2",
  "description": "Open-source cycling platform — the CMS for cycling",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eljojo/bike-app-astro.git"
  },
  "files": [
    "src/",
    "drizzle/",
    "scripts/",
    "eslint-rules/",
    "public/",
    "sync.js",
    "packages/create-bike-blog/templates/",
    "aws/"
  ],
  "exports": {
    ".": "./src/integration.ts",
    "./loaders/routes": "./src/loaders/routes.ts",
    "./loaders/rides": "./src/loaders/rides.ts",
    "./loaders/pages": "./src/loaders/pages.ts",
    "./schemas": "./src/schemas/index.ts",
    "./plugin": "./src/build-data-plugin.ts",
    "./lib/adapter": "./src/lib/env/adapter.ts",
    "./middleware": "./src/middleware.ts",
    "./content-collections": "./src/content-collections.ts"
  },
  "workspaces": [
    "docs",
    "packages/create-bike-blog"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "tsx scripts/build-map-style.ts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "maps:generate": "npx tsx scripts/generate-maps.ts",
    "maps:rebuild": "npx tsx scripts/generate-maps.ts --force",
    "test": "npx vitest run",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:update": "npx playwright test --config e2e/playwright.config.ts --update-snapshots",
    "validate": "npx tsx scripts/validate.ts",
    "capture:production": "npx playwright test --config e2e/capture-production.config.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.0.0-beta.11",
    "@astrojs/node": "^10.0.0-beta.6",
    "@astrojs/preact": "^4.1.3",
    "@mapbox/polyline": "^1.2.1",
    "@plausible-analytics/tracker": "^0.4.4",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "@vovayatsyuk/photoswipe-object-position": "^1.0.0",
    "astro": "^6.0.0-beta.20",
    "aws4fetch": "^1.0.20",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "exif-reader": "^2.0.3",
    "fast-xml-parser": "^5.4.1",
    "fflate": "^0.8.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "maplibre-gl": "^5.19.0",
    "marked": "^17.0.3",
    "photoswipe": "^5.4.4",
    "photoswipe-dynamic-caption-plugin": "^1.2.7",
    "preact": "^10.28.4",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/mapbox__polyline": "^1.0.5",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
