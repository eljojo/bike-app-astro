# Set to 'local' for offline development (no cloud dependencies)
RUNTIME=local

# Remote dev access — set to your hostname (e.g. Tailscale) to bind 0.0.0.0 and allow the host
# DEV_HOST=your-machine.tail1234.ts.net

CONTENT_DIR=../bike-routes
CITY=ottawa
SITE_URL=https://example.com
CONTACT_EMAIL=bike@example.com
GIT_OWNER=eljojo
GIT_DATA_REPO=bike-routes
GOOGLE_MAPS_STATIC_API_KEY=your-key-here
# Google Places API key — also requires Directions API enabled for route import
GOOGLE_PLACES_API_KEY=your-key-here
R2_PUBLIC_URL=https://example.com

# Admin / Auth (set via wrangler secret for deployed environments)
GITHUB_TOKEN=ghp_your-token
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=whereto-bike
WEBAUTHN_ORIGIN=http://localhost:4321
R2_ACCESS_KEY_ID=your-key-id
R2_SECRET_ACCESS_KEY=your-secret-key
R2_ACCOUNT_ID=your-account-id
R2_BUCKET_NAME=your-bucket-name
STORAGE_KEY_PREFIX=
RWGPS_API_KEY=your-rwgps-api-key
RWGPS_AUTH_TOKEN=your-rwgps-auth-token
THUNDERFOREST_API_KEY=       # Thunderforest API key for vector tile proxy

# Strava (optional — for ride import from Strava)
# Create an app at https://www.strava.com/settings/api
# Set redirect URI to {SITE_URL}/api/auth/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Video uploads (optional — Lambda handles transcoding via S3 trigger)
# Set WEBHOOK_SECRET as a Wrangler secret matching the Lambda's WEBHOOK_SECRET
WEBHOOK_SECRET=
# VIDEO_PREFIX overrides the S3 key prefix (defaults to CITY).
# Set in wrangler.jsonc per env; only needed here if prefix differs from CITY.
# VIDEO_PREFIX=

# Plausible Analytics (optional — for admin stats sync)
# Get your API key from https://plausible.io/settings → API Keys
PLAUSIBLE_API_KEY=
