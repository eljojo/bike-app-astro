---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import adminEvents from 'virtual:bike-app/admin-events';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import { db } from '../../lib/get-db';
import { eventEdits } from '../../db/schema';
import { env } from '../../lib/env';
import '../../styles/admin.scss';

const database = db();
const cachedEdits = await database.select().from(eventEdits).all();
const cacheMap = new Map(cachedEdits.map(e => [e.id, JSON.parse(e.data)]));
const orgMap = new Map(adminOrganizers.map(o => [o.slug, o.name]));
const cdnUrl = env.R2_PUBLIC_URL || 'https://cdn.ottawabybike.ca';

// Merge cached data over build-time data
const events = adminEvents.map(e => {
  const cached = cacheMap.get(e.id);
  if (!cached) return e;
  return { ...e, name: cached.name ?? e.name, start_date: cached.start_date ?? e.start_date };
});

// Resolve organizer display name from either slug or inline object
function orgName(organizer?: string | { name: string }) {
  if (!organizer) return '';
  if (typeof organizer === 'string') return orgMap.get(organizer) || organizer;
  return organizer.name;
}

// Group by month (like public calendar)
function groupByMonth(evts: typeof events) {
  const groups: Record<string, { label: string; events: typeof events }> = {};
  for (const e of evts) {
    const date = new Date(e.start_date + 'T00:00:00');
    const key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
    if (!groups[key]) {
      groups[key] = {
        label: date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),
        events: [],
      };
    }
    groups[key].events.push(e);
  }
  return Object.entries(groups)
    .sort(([a], [b]) => b.localeCompare(a))
    .map(([, group]) => group);
}

const grouped = groupByMonth(events);
const user = Astro.locals.user;
const isStaging = env.ENVIRONMENT === 'staging';
---

<Base title="Events - Admin" admin>
  <div class="admin-page">
    {isStaging && (
      <div class="staging-banner">Staging Environment</div>
    )}
    <div class="admin-header">
      <h1>Events</h1>
      <div class="admin-user">
        {user.displayName}
        <form method="POST" action="/api/auth/logout" class="logout-form">
          <button type="submit" class="btn-logout">Sign out</button>
        </form>
      </div>
    </div>

    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-link">Routes</a>
      <a href="/admin/events" class="admin-nav-link active">Events</a>
    </nav>

    <div class="event-actions-bar">
      <a href="/admin/events/new" class="btn-primary">+ New event</a>
    </div>

    {grouped.map(({ label, events: monthEvents }) => (
      <div class="event-month-group">
        <h2 class="month-header">{label}</h2>
        <div class="event-list">
          {monthEvents.map(e => (
            <a href={`/admin/events/${e.id}`} class="event-list-item">
              {e.poster_key && (
                <img
                  src={`${cdnUrl}/cdn-cgi/image/width=80,height=80,fit=cover/${e.poster_key}`}
                  alt=""
                  loading="lazy"
                  class="event-poster-thumb"
                />
              )}
              <div class="event-card-info">
                <span class="event-card-name">{e.name}</span>
                <span class="event-card-meta">
                  {e.start_date}
                  {orgName(e.organizer) && <> &middot; {orgName(e.organizer)}</>}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    {events.length === 0 && <p class="auth-message">No events found.</p>}
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;

  .staging-banner {
    background: #e3f2fd;
    border: 1px solid #90caf9;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #1565c0;
    text-align: center;

    @media (prefers-color-scheme: dark) {
      background: #0d1b2a;
      border-color: #1565c0;
      color: #90caf9;
    }
  }

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;

    h1 {
      font-family: $font-heading;
      font-size: 1.5rem;
      margin: 0;
    }
  }

  .admin-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .logout-form {
    display: inline;
  }

  .btn-logout {
    background: none;
    border: none;
    color: $color-text-muted;
    cursor: pointer;
    font-size: 0.875rem;
    text-decoration: underline;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .admin-nav {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid $color-border;
    padding-bottom: 0.5rem;

    @media (prefers-color-scheme: dark) {
      border-color: #333;
    }
  }

  .admin-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .event-actions-bar {
    margin-bottom: 1.5rem;
  }

  .event-month-group {
    margin-bottom: 1.5rem;
  }

  .month-header {
    font-family: $font-heading;
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  .event-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @media (prefers-color-scheme: dark) {
      background: #333;
    }
  }

  .event-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @media (prefers-color-scheme: dark) {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @media (prefers-color-scheme: dark) {
        background: $color-card-hover-dark;
      }
    }
  }

  .event-poster-thumb {
    width: 40px;
    height: 40px;
    border-radius: $border-radius;
    object-fit: cover;
    flex-shrink: 0;
  }

  .event-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .event-card-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-card-meta {
    font-size: 0.8125rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }
</style>
