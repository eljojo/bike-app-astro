---
export const prerender = false;

import Base from '../../../layouts/Base.astro';
import RouteEditor from '../../../components/admin/RouteEditor.tsx';
import { GitService } from '../../../lib/git-service';
import yaml from 'js-yaml';
import '../../../styles/admin.scss';

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime.env;
const city = 'ottawa';

if (!slug) {
  return new Response(null, { status: 404 });
}

const git = new GitService({
  token: env.GITHUB_TOKEN,
  owner: 'eljojo',
  repo: 'bike-routes',
});

// Read index.md
const indexFile = await git.readFile(`${city}/routes/${slug}/index.md`);
if (!indexFile) {
  return new Response(null, { status: 404 });
}

// Parse frontmatter and body
const fmMatch = indexFile.content.match(/^---\n([\s\S]*?)\n---\n*([\s\S]*)$/);
const frontmatter: Record<string, any> = {};
let body = '';

if (fmMatch) {
  // Parse YAML frontmatter
  try {
    const parsed = yaml.load(fmMatch[1]);
    if (parsed && typeof parsed === 'object') {
      Object.assign(frontmatter, parsed);
    }
  } catch {
    // Fall back to simple line parsing
    for (const line of fmMatch[1].split('\n')) {
      const colonIdx = line.indexOf(':');
      if (colonIdx > 0) {
        const key = line.slice(0, colonIdx).trim();
        const val = line.slice(colonIdx + 1).trim().replace(/^["']|["']$/g, '');
        frontmatter[key] = val;
      }
    }
  }
  body = fmMatch[2].trim();
}

// Read media.yml
let media: Array<{ key: string; caption?: string; cover?: boolean }> = [];
const mediaFile = await git.readFile(`${city}/routes/${slug}/media.yml`);
if (mediaFile) {
  try {
    const parsed = yaml.load(mediaFile.content);
    if (Array.isArray(parsed)) {
      media = parsed;
    }
  } catch {
    // Ignore parse errors
  }
}

const cdnUrl = env.R2_PUBLIC_URL || 'https://cdn.ottawabybike.ca';

const routeData = {
  slug,
  name: frontmatter.name || frontmatter.title || slug,
  tagline: frontmatter.tagline || '',
  tags: Array.isArray(frontmatter.tags) ? frontmatter.tags : [],
  distance: parseFloat(frontmatter.distance) || 0,
  status: frontmatter.status || 'published',
  body,
  media,
};
---

<Base title={`Edit: ${routeData.name}`}>
  <div class="admin-page">
    <div class="editor-header">
      <a href="/admin" class="back-link">&larr; Back to routes</a>
      <a href={`/routes/${slug}`} class="view-link" target="_blank" rel="noopener">View live &nearr;</a>
    </div>
    <h1>Edit: {routeData.name}</h1>
    <RouteEditor client:load initialData={routeData} cdnUrl={cdnUrl} />
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;

  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }

  .back-link,
  .view-link {
    color: $color-text-muted;
    text-decoration: none;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }

    &:hover {
      text-decoration: underline;
    }
  }

  h1 {
    font-family: $font-heading;
    font-size: 1.25rem;
    margin: 0 0 1.5rem;
  }

  .editor-section {
    margin-bottom: 2rem;

    h2 {
      font-family: $font-heading;
      font-size: 1.1rem;
      margin: 0 0 0.75rem;
      border-bottom: 1px solid $color-border;
      padding-bottom: 0.25rem;

      @media (prefers-color-scheme: dark) {
        border-color: #333;
      }
    }
  }

  .editor-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-start;
    padding: 1rem 0;
    border-top: 1px solid $color-border;

    @media (prefers-color-scheme: dark) {
      border-color: #333;
    }
  }

  .save-success {
    color: green;
    font-size: 0.875rem;

    @media (prefers-color-scheme: dark) {
      color: #8f8;
    }
  }

  textarea {
    font-family: $font-mono;
    font-size: 0.875rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: $color-bg;
    color: $color-text;
    resize: vertical;

    @media (prefers-color-scheme: dark) {
      background: $color-bg-dark;
      color: $color-text-dark;
      border-color: #444;
    }

    &:focus {
      outline: 2px solid $color-accent;
      outline-offset: -1px;
    }
  }

  select {
    font-family: $font-body;
    font-size: 1rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: $color-bg;
    color: $color-text;

    @media (prefers-color-scheme: dark) {
      background: $color-bg-dark;
      color: $color-text-dark;
      border-color: #444;
    }
  }

  .tag-editor {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
    padding: 0.375rem;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: $color-bg;

    @media (prefers-color-scheme: dark) {
      background: $color-bg-dark;
      border-color: #444;
    }
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.5rem;
    background: $color-tag-bg;
    color: $color-tag-text;
    border-radius: $border-radius;
    font-size: 0.8125rem;

    button {
      background: none;
      border: none;
      color: $color-tag-text;
      cursor: pointer;
      padding: 0;
      font-size: 1rem;
      line-height: 1;
    }
  }

  .tag-input {
    border: none;
    outline: none;
    font-size: 0.875rem;
    padding: 0.125rem;
    flex: 1;
    min-width: 80px;
    background: transparent;
    color: $color-text;

    @media (prefers-color-scheme: dark) {
      color: $color-text-dark;
    }
  }

  .drop-zone {
    border: 2px dashed $color-border;
    border-radius: $border-radius;
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
    color: $color-text-muted;
    font-size: 0.875rem;

    @media (prefers-color-scheme: dark) {
      border-color: #444;
      color: #aaa;
    }
  }

  .drop-zone--active {
    border-color: $color-accent;
    background: rgba(255, 165, 0, 0.05);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .photo-card {
    position: relative;
    border-radius: $border-radius;
    overflow: hidden;
    background: $color-card-bg;
    cursor: grab;

    @media (prefers-color-scheme: dark) {
      background: $color-card-bg-dark;
    }

    img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }
  }

  .photo-card--dragging {
    opacity: 0.5;
  }

  .photo-actions {
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    display: flex;
    gap: 0.25rem;
  }

  .btn-star,
  .btn-remove {
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    border-radius: $border-radius;
    width: 24px;
    height: 24px;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-star--active {
    background: rgba(255, 165, 0, 0.8);
  }

  .photo-caption {
    width: 100%;
    border: none;
    border-top: 1px solid $color-border;
    padding: 0.25rem 0.375rem;
    font-size: 0.75rem;
    background: $color-card-bg;
    color: $color-text;

    @media (prefers-color-scheme: dark) {
      background: $color-card-bg-dark;
      color: $color-text-dark;
      border-color: #333;
    }
  }
</style>
