---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import StagingSyncButton from '../../components/admin/StagingSyncButton.tsx';
import adminRoutes from 'virtual:bike-app/admin-routes';
import { env } from '../../lib/env';
import { db } from '../../lib/get-db';
import { contentEdits } from '../../db/schema';
import { eq } from 'drizzle-orm';
import '../../styles/admin.scss';
const user = Astro.locals.user;
const isStaging = env.ENVIRONMENT === 'staging';
const sortBy = Astro.url.searchParams.get('sort') === 'score' ? 'score' : 'alpha';

// Check D1 cache for fresher data, fall back to virtual module
const database = db();
const cachedEdits = await database.select().from(contentEdits).where(eq(contentEdits.contentType, 'routes')).all();
const cacheMap = new Map(cachedEdits.map(e => [e.contentSlug, JSON.parse(e.data)]));

const routes = adminRoutes.map(r => {
  const cached = cacheMap.get(r.slug);
  if (!cached) return r;
  return {
    ...r,
    name: cached.name ?? r.name,
    photoCount: cached.media?.length ?? r.photoCount,
    status: cached.status ?? r.status,
  };
}).sort((a, b) => {
  if (sortBy === 'score') {
    // Routes with scores first (ascending = easiest first), then routes without scores alphabetically
    if (a.difficultyScore != null && b.difficultyScore != null) return a.difficultyScore - b.difficultyScore;
    if (a.difficultyScore != null) return -1;
    if (b.difficultyScore != null) return 1;
    return a.name.localeCompare(b.name);
  }
  return a.name.localeCompare(b.name);
});
---

<Base title="Admin" admin>
  <div class="admin-page">
    {isStaging && (
      <div class="staging-banner">Staging Environment</div>
    )}
    <div class="admin-header">
      <h1>Routes</h1>
      <div class="admin-user">
        {user.displayName}
        <form method="POST" action="/api/auth/logout" class="logout-form">
          <button type="submit" class="btn-logout">Sign out</button>
        </form>
      </div>
    </div>

    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-link active">Routes</a>
      <a href="/admin/events" class="admin-nav-link">Events</a>
    </nav>

    <div class="admin-actions">
      <a href="/admin/routes/new" class="btn-new-route">+ New route</a>
    </div>

    <div class="sort-controls">
      <span class="sort-label">Sort:</span>
      <a href="/admin" class:list={['sort-option', { active: sortBy === 'alpha' }]}>A–Z</a>
      <a href="/admin?sort=score" class:list={['sort-option', { active: sortBy === 'score' }]}>Difficulty</a>
    </div>

    <div class="route-list">
      {routes.map((route) => (
        <a href={`/admin/routes/${route.slug}`} class="route-list-item">
          <span class="route-name">{route.name}</span>
          <span class="route-meta">
            {route.difficultyScore != null && <span class="route-score">{route.difficultyScore}</span>}
            {route.photoCount} photo{route.photoCount !== 1 ? 's' : ''}
            {route.status === 'draft' && <span class="route-draft">draft</span>}
          </span>
        </a>
      ))}
      {routes.length === 0 && (
        <p class="auth-message">No routes found.</p>
      )}
    </div>

    {isStaging && user.role === 'admin' && (
      <div class="admin-section">
        <h2>Sync from production</h2>
        <StagingSyncButton client:load />
      </div>
    )}
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;

  .staging-banner {
    background: #e3f2fd;
    border: 1px solid #90caf9;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #1565c0;
    text-align: center;

    @media (prefers-color-scheme: dark) {
      background: #0d1b2a;
      border-color: #1565c0;
      color: #90caf9;
    }
  }

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;

    h1 {
      font-family: $font-heading;
      font-size: 1.5rem;
      margin: 0;
    }
  }

  .admin-nav {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid $color-border;
    padding-bottom: 0.5rem;

    @media (prefers-color-scheme: dark) {
      border-color: #333;
    }
  }

  .admin-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .admin-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .logout-form {
    display: inline;
  }

  .btn-logout {
    background: none;
    border: none;
    color: $color-text-muted;
    cursor: pointer;
    font-size: 0.875rem;
    text-decoration: underline;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .admin-actions {
    margin-bottom: 0.75rem;
  }

  .btn-new-route {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: $color-accent;
    color: #000;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;

    &:hover {
      opacity: 0.9;
    }
  }

  .sort-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
  }

  .sort-label {
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .sort-option {
    color: $color-text-muted;
    text-decoration: none;
    padding: 0.125rem 0.5rem;
    border-radius: $border-radius;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .route-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @media (prefers-color-scheme: dark) {
      background: #333;
    }
  }

  .route-list-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @media (prefers-color-scheme: dark) {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @media (prefers-color-scheme: dark) {
        background: $color-card-hover-dark;
      }
    }
  }

  .route-name {
    font-weight: 600;
  }

  .route-meta {
    font-size: 0.8125rem;
    color: $color-text-muted;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .route-score {
    font-family: $font-mono;
    font-size: 0.75rem;
    color: $color-text-muted;
    margin-right: 0.25rem;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }
  }

  .route-draft {
    background: $color-accent;
    color: #000;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
    margin-left: 0.5rem;
  }

  .admin-section {
    margin-top: 2rem;

    h2 {
      font-family: $font-heading;
      font-size: 1.25rem;
      margin: 0 0 0.75rem;
    }
  }


</style>
