---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import adminPlaces from 'virtual:bike-app/admin-places';
import { categoryEmoji } from '../../lib/place-categories';
import '../../styles/admin.scss';

const user = Astro.locals.user;

// Group by category
function groupByCategory(places: typeof adminPlaces) {
  const groups: Record<string, { label: string; emoji: string; places: typeof adminPlaces }> = {};
  for (const p of places) {
    if (!groups[p.category]) {
      groups[p.category] = {
        label: p.category.replace(/-/g, ' '),
        emoji: categoryEmoji[p.category] || '📌',
        places: [],
      };
    }
    groups[p.category].places.push(p);
  }
  return Object.entries(groups)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([key, group]) => ({ key, ...group }));
}

const grouped = groupByCategory(adminPlaces);
---

<Base title="Places - Admin" admin>
  <div class="admin-page">
    <AdminHeader user={user} currentTab="places" />

    <div class="place-actions-bar">
      <a href="/admin/places/new" class="btn-primary">+ New place</a>
      <span class="place-count">{adminPlaces.length} places</span>
    </div>

    {grouped.map(({ key, label, emoji, places }) => (
      <div class="place-category-group">
        <h2 class="category-header">{emoji} {label} <span class="category-count">({places.length})</span></h2>
        <div class="place-list">
          {places.map(p => (
            <a href={`/admin/places/${p.id}`} class="place-list-item">
              <span class="place-card-emoji">{categoryEmoji[p.category] || '📌'}</span>
              <div class="place-card-info">
                <span class="place-card-name">{p.name}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    {adminPlaces.length === 0 && <p class="auth-message">No places found. Create one to get started.</p>}
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .place-actions-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .place-count {
    font-size: 0.875rem;
    @include muted-text;
  }

  .place-category-group {
    margin-bottom: 1.5rem;
  }

  .category-header {
    font-family: $font-heading;
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    text-transform: capitalize;
  }

  .category-count {
    font-weight: 400;
    font-size: 0.875rem;
    @include muted-text;
  }

  .place-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: #333;
    }
  }

  .place-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .place-card-emoji {
    font-size: 1.25rem;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }

  .place-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .place-card-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
