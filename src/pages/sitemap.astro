---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '../lib/city-config';
import { paths } from '../lib/paths';

const config = getCityConfig();

const routes = await getCollection('routes');
const guides = await getCollection('guides');

const publishedRoutes = routes
  .filter(r => r.data.status === 'published')
  .sort((a, b) => a.data.distance_km - b.data.distance_km);

const allVideos = publishedRoutes
  .flatMap(r => r.data.media.filter(m => m.type === 'video').map(v => ({ ...v, routeName: r.data.name })));

const publishedGuides = guides
  .filter(g => g.data.status === 'published');
---

<Base title={`Sitemap | ${config.display_name}`} description={`Sitemap for ${config.display_name}`}>
  <h1>Sitemap</h1>
  <ul>
    <li><a href="/">{config.display_name}</a>
      <ul>
        <li><a href="/about">About {config.display_name}</a></li>
        <li><a href="/calendar">Cycling Calendar</a></li>
        <li><a href="/map">Map with cycling routes</a></li>
        <li><a href="/videos">Videos</a>
          <ul>
            {allVideos.map(v => (
              <li><a href={paths.video(v.handle)}>{v.title || v.handle}</a></li>
            ))}
          </ul>
        </li>
      </ul>
    </li>
    {publishedRoutes.map(route => (
      <li>
        <a href={paths.route(route.id)}>{route.data.name}</a>
        <ul>
          <li><a href={paths.routeMap(route.id)}>Map</a></li>
        </ul>
      </li>
    ))}
    <li><a href="/guides">Guides</a>
      <ul>
        {publishedGuides.map(guide => (
          <li><a href={paths.guide(guide.id)}>{guide.data.name}</a></li>
        ))}
      </ul>
    </li>
  </ul>
  <p><a href="/sitemap.xml">sitemap.xml</a></p>
</Base>
