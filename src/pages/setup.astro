---
export const prerender = false;

import Base from '../layouts/Base.astro';
import RegisterForm from '../components/admin/RegisterForm.tsx';
import { env } from '../lib/env';
import { isFirstUser } from '../lib/auth';
import { getDb } from '../db';
import '../styles/admin.scss';

const db = getDb(env.DB);

const first = await isFirstUser(db);
if (!first) {
  return new Response(null, { status: 404 });
}
---

<Base title="Setup">
  <div class="auth-page">
    <div class="auth-card">
      <h1>Setup</h1>
      <p class="auth-message">Create the first admin account. This page is only available once.</p>
      <RegisterForm client:load inviteCode="" isSetup={true} />
    </div>
  </div>
</Base>
