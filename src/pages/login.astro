---
export const prerender = false;

import Base from '../layouts/Base.astro';
import LoginForm from '../components/admin/LoginForm.tsx';
import { validateSession } from '../lib/auth';
import { db } from '../lib/get-db';
import '../styles/admin.scss';

const returnTo = Astro.url.searchParams.get('returnTo') || '/admin';

// If already logged in, redirect
const token = Astro.cookies.get('session_token')?.value;
if (token) {
  const database = db();
  const user = await validateSession(database, token);
  if (user) {
    return Astro.redirect(returnTo);
  }
}
---

<Base title="Sign in">
  <div class="auth-page">
    <div class="auth-card">
      <h1>Sign in</h1>
      <LoginForm client:load returnTo={returnTo} />
    </div>
  </div>
</Base>
