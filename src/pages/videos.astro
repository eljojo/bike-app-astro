---
// src/pages/videos.astro
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { videoPlaybackSources, videoPosterUrl, videoDisplaySize, videoFallbackUrl } from '../lib/video-service';

const routes = await getCollection('routes');
const routesWithVideos = routes
  .filter(r => r.data.status === 'published')
  .filter(r => r.data.media.some(m => m.type === 'video'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title="Videos | Ottawa by Bike">
  <h1>🎥 Videos</h1>

  {routesWithVideos.map(route => {
    const videos = route.data.media.filter(m => m.type === 'video');
    return (
      <section>
        <h2><a href={`/routes/${route.id}`}>{route.data.name}</a></h2>
        <div class="videos-grid">
          {videos.map(video => {
            const sources = videoPlaybackSources(video.key);
            const size = videoDisplaySize(video.width || 640, video.height || 360);
            return (
              <div class="video-item">
                <video
                  controls
                  preload="metadata"
                  width={size.width}
                  height={size.height}
                  poster={video.poster_key ? videoPosterUrl(video.poster_key) : undefined}
                  disablepictureinpicture
                >
                  {sources.map(s => <source src={s.src} type={s.type} />)}
                  <p><a href={videoFallbackUrl(video.key)}>{video.title || 'Download video'}</a></p>
                </video>
                {video.title && <p class="video-title">{video.title}</p>}
              </div>
            );
          })}
        </div>
      </section>
    );
  })}
</Base>
