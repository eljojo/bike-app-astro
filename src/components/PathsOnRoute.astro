---
import { paths as urlPaths } from '@/lib/paths';
import { t } from '@/i18n';

interface Props {
  bikePaths: Array<{ slug: string; name: string }>;
  locale?: string;
}

const { bikePaths, locale } = Astro.props;
---

{bikePaths.length > 0 && (
  <p class="route-place-summary">
    &#x1F6B2; {t('paths.follows', locale)}{' '}
    {bikePaths.map((bp, i) => (
      <>
        <a href={urlPaths.bikePath(bp.slug, locale)}>{bp.name}</a>{i < bikePaths.length - 1 ? (i === bikePaths.length - 2 ? ` ${t('paths.and', locale)} ` : ', ') : ''}
      </>
    ))}
  </p>
)}
