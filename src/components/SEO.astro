---
// src/components/SEO.astro
import { getCityConfig } from '../lib/config/city-config';
import { supportedLocales, defaultLocale } from '../lib/i18n/locale-utils';
import { translatePath, reverseTranslatePath } from '../lib/i18n/path-translations';

const config = getCityConfig();

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  ogVideo?: { url: string; type: string; width?: number; height?: number };
  jsonLd?: Record<string, any> | Record<string, any>[];
  breadcrumbs?: Record<string, any> | null;
  alternateUrls?: Record<string, string>;
  cspNonce?: string;
}

const { title, description, canonical, ogImage, ogImageAlt, ogType, ogVideo, jsonLd, breadcrumbs, alternateUrls, cspNonce } = Astro.props;
const jsonLdEntries = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const siteUrl = config.url;
const fullCanonical = canonical || new URL(Astro.url.pathname, siteUrl).toString();

// Build hreflang alternate URLs for all supported locales
const locales = supportedLocales();
const defLocale = defaultLocale();
const pathname = Astro.url.pathname;

// Strip the locale prefix (e.g. /fr/) from the pathname to get the base path
function stripLocalePrefix(p: string): string {
  for (const locale of locales) {
    if (locale !== defLocale && (p === `/${locale}` || p.startsWith(`/${locale}/`))) {
      const stripped = p.slice(`/${locale}`.length) || '/';
      return reverseTranslatePath(stripped, locale);
    }
  }
  return p;
}

const basePath = stripLocalePrefix(pathname);

// Build the URL for each locale
function urlForLocale(locale: string): string {
  if (alternateUrls?.[locale]) {
    return new URL(alternateUrls[locale], siteUrl).toString();
  }
  if (locale === defLocale) {
    return new URL(basePath, siteUrl).toString();
  }
  const translated = translatePath(basePath, locale);
  const prefixed = translated === '/' ? `/${locale}/` : `/${locale}${translated}`;
  return new URL(prefixed, siteUrl).toString();
}

const hreflangEntries = locales.map(locale => ({
  locale,
  url: urlForLocale(locale),
}));
---

<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="canonical" href={fullCanonical} />

<!-- hreflang alternates -->
{hreflangEntries.map(({ locale, url }) => (
  <link rel="alternate" hreflang={locale} href={url} />
))}
<link rel="alternate" hreflang="x-default" href={urlForLocale(defLocale)} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:url" content={fullCanonical} />
{description && <meta property="og:description" content={description} />}
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:secure_url" content={ogImage} />}
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
<meta property="og:type" content={ogType || 'website'} />
{ogVideo && <meta property="og:video" content={ogVideo.url} />}
{ogVideo && <meta property="og:video:secure_url" content={ogVideo.url} />}
{ogVideo && <meta property="og:video:type" content={ogVideo.type} />}
{ogVideo?.width && <meta property="og:video:width" content={String(ogVideo.width)} />}
{ogVideo?.height && <meta property="og:video:height" content={String(ogVideo.height)} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
{ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

<!-- Site-level -->
<meta property="og:site_name" content={config.display_name} />
<meta name="twitter:creator" content={config.author.twitter} />
<meta name="twitter:site" content={config.author.twitter} />

{jsonLdEntries.map(entry => (
  <script nonce={cspNonce} type="application/ld+json" set:html={JSON.stringify(entry)} />
))}

{breadcrumbs && (
  <script nonce={cspNonce} type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
)}
