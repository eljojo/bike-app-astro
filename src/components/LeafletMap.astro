---
interface Props {
  polylines: { name: string; encoded: string }[];
  center?: [number, number];
  zoom?: number;
}

const { polylines, center, zoom } = Astro.props;
---

<div
  id="route-map"
  class="leaflet-map"
  data-polylines={JSON.stringify(polylines)}
  data-center={JSON.stringify(center)}
  data-zoom={zoom?.toString() || '12'}
></div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import polylineCodec from '@mapbox/polyline';

  const el = document.getElementById('route-map');
  if (el) {
    const polylines = JSON.parse(el.dataset.polylines || '[]');
    const center = JSON.parse(el.dataset.center || '[45.42, -75.69]');
    const zoom = parseInt(el.dataset.zoom || '12');

    const map = L.map(el).setView(center, zoom);

    L.tileLayer('https://tiles.ottawabybike.ca/cycle/{z}/{x}/{y}{r}.png', {
      maxZoom: 20,
      attribution: 'Maps &copy; <a href="https://www.thunderforest.com">Thunderforest</a>, Data &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap contributors</a>',
    }).addTo(map);

    const bounds = L.latLngBounds([]);
    polylines.forEach((pl: any, i: number) => {
      const coords = polylineCodec.decode(pl.encoded);
      const line = L.polyline(coords, {
        color: '#350091',
        weight: 6,
        opacity: 0.9,
      }).addTo(map);

      line.bindPopup(pl.name);
      bounds.extend(line.getBounds());
    });

    if (bounds.isValid()) {
      map.fitBounds(bounds, { padding: [30, 30] });
    }
  }
</script>

<style>
  .leaflet-map {
    width: 100%;
    height: 80vh;
    min-height: 400px;
  }
</style>
