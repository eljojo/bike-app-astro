---
import './SubTabToggle.scss';

interface TabItem {
  label: string;
  href: string;
  active: boolean;
}

interface Props {
  items: TabItem[];
  /** True on index pages — active tab is not clickable. False on detail pages — active tab links back to index. */
  isIndex?: boolean;
}

const { items, isIndex = false } = Astro.props;
---
<div class="sub-tab-toggle">
  {items.map(item => (
    item.active && isIndex
      ? <span class="sub-tab-btn active">{item.label}</span>
      : <a href={item.href} class={`sub-tab-btn ${item.active ? 'active' : ''}`}>{item.label}</a>
  ))}
</div>
