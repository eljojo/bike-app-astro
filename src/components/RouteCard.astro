---
import './RouteCard.scss';
import { imageUrl } from '../lib/media/image-service';
import { mapImageUrl } from '../lib/maps/map-image-url';
import { formatDistance } from '../lib/geo/distance';
import { paths } from '../lib/paths';
import { makePreview } from '../lib/markdown/markdown-preview';
import { tTag } from '../lib/i18n/tag-translations.server';

interface Variant {
  name: string;
  gpx: string;
  distance_km?: number;
}

interface Props {
  slug: string;
  name: string;
  tagline?: string;
  distance_km: number;
  tags: string[];
  body?: string;
  coverKey?: string;
  lazy?: boolean;
  variants?: Variant[];
  /** Translated slug for locale-aware links (falls back to slug if not provided) */
  localeSlug?: string;
  gpxHash?: string;
}

const { slug, name, tagline, distance_km, tags, body, coverKey, lazy = true, variants, localeSlug, gpxHash } = Astro.props;
const linkSlug = localeSlug || slug;
const locale = Astro.currentLocale || 'en';

const variantDistances = variants?.map(v => v.distance_km).filter((d): d is number => d != null) || [];
const distanceTag = variantDistances.length > 0 ? formatDistance(variantDistances) : formatDistance([distance_km]);
const allTags = [distanceTag, ...tags];
const previewParagraphs = makePreview(body);
const loading = lazy ? 'lazy' : 'eager';
---

<li class:list={['route-card', { 'no-cover': !coverKey }]} data-tags={JSON.stringify(tags)} data-slug={slug}>
  <a href={paths.route(linkSlug, locale)} class="route-card--link">
    <div class="route-card--images">
      {coverKey && (
        <img
          src={imageUrl(coverKey, { width: 375, height: 375, fit: 'cover' })}
          srcset={`${imageUrl(coverKey, { width: 750, height: 750, fit: 'cover' })} 2x`}
          alt={name}
          width="300"
          height="300"
          loading={loading}
          class="route-cover"
        />
      )}
      {gpxHash && (
        <img
          src={mapImageUrl('route', slug, 'thumb', { hash: gpxHash, lang: locale })}
          srcset={`${mapImageUrl('route', slug, 'thumb', { hash: gpxHash, lang: locale })} 1x, ${mapImageUrl('route', slug, 'thumb-2x', { hash: gpxHash, lang: locale })} 2x`}
          alt={`map of ${name}`}
          width="300"
          height="300"
          loading={loading}
          class="route-map"
        />
      )}
    </div>
    <span class="route-card--details">
      <span class="route-card--name">{name}</span>
      {tagline && <span class="route-card--tagline">{tagline}</span>}
      <ul class="route-card--tags">
        {allTags.map(tag => <li class="tag-pill">{tTag(tag, locale)}</li>)}
      </ul>
      {previewParagraphs.map(p => (
        <span class="route-card--preview">{p}</span>
      ))}
    </span>
  </a>
</li>
