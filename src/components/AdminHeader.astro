---
import { createHash } from 'node:crypto';
import { env } from '../lib/env/env.service';
import { getCityConfig } from '../lib/config/city-config';
import { getInstanceFeatures } from '../lib/config/instance-features';
import { getContentTypes } from '../lib/content/content-types.server';

interface Props {
  user: { id: string; username: string; role: string; email?: string | null };
  currentTab: string;
  subtitle?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { user, currentTab, subtitle, ctaHref, ctaLabel } = Astro.props;
const isStaging = env.ENVIRONMENT === 'staging';
const features = getInstanceFeatures();
const contentNav = getContentTypes()
  .filter(ct => ct.adminListRoute)
  .map(ct => ({
    href: ct.adminListRoute!.pattern,
    label: ct.label,
    tab: ct.name,
  }));
const cspNonce = Astro.locals.cspNonce;
const avatarHash = user.email
  ? createHash('md5').update(user.email.trim().toLowerCase()).digest('hex')
  : null;
const avatarUrl = avatarHash
  ? `https://www.gravatar.com/avatar/${avatarHash}?d=mp&s=32`
  : 'https://www.gravatar.com/avatar/?d=mp&s=32';

const tabLabel = contentNav.find(n => n.tab === currentTab)?.label
  ?? currentTab.charAt(0).toUpperCase() + currentTab.slice(1);
---

{isStaging && (
  <div class="staging-banner">Staging Environment</div>
)}

<div class="admin-nav-bar">
  <nav class="admin-nav">
    <a href={currentTab === 'home' ? '/' : '/admin'} class:list={['admin-nav-link', { active: currentTab === 'home' }]}>Home</a>
    {contentNav.map(({ href, label, tab }) => (
      <a href={href} class:list={['admin-nav-link', { active: currentTab === tab }]}>{label}</a>
    ))}
    <a href="/admin/history" class:list={['admin-nav-link', { active: currentTab === 'history' }]}>History</a>
    {user.role === 'admin' && features.allowsRegistration && (
      <a href="/admin/users" class:list={['admin-nav-link', { active: currentTab === 'users' }]}>Users</a>
    )}
  </nav>
  {user.id && <div class="admin-user">
    <button type="button" class="admin-user-toggle" id="user-menu-toggle" aria-expanded="false" aria-controls="user-menu-dropdown">
      <img src={avatarUrl} alt="" class="admin-user-avatar" width={24} height={24} />
      {user.username}
      <span class="admin-user-caret">&#9662;</span>
    </button>
    <div class="admin-user-dropdown" id="user-menu-dropdown" role="menu">
      <a href="/admin/settings" class="admin-user-dropdown-item">Settings</a>
      {user.role === 'guest' && features.allowsRegistration && (
        <a href="/login" class="admin-user-dropdown-item">Create account</a>
      )}
      <form method="POST" action="/api/auth/logout" class="logout-form">
        <button type="submit" class="admin-user-dropdown-item">Sign out</button>
      </form>
    </div>
  </div>}
</div>
{currentTab !== 'home' && (
  <div class="admin-header">
    <div class="admin-header-row">
      <h1>{tabLabel}</h1>
      {ctaHref && ctaLabel && (
        <a href={ctaHref} class="admin-header-cta">{ctaLabel}</a>
      )}
    </div>
    {subtitle && <p class="admin-subtitle">{subtitle}</p>}
  </div>
)}
<script is:inline nonce={cspNonce}>
  const toggle = document.getElementById('user-menu-toggle');
  const dropdown = document.getElementById('user-menu-dropdown');
  function setOpen(open) {
    if (open) dropdown?.classList.add('open');
    else dropdown?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', String(open));
  }
  toggle?.addEventListener('click', () => {
    setOpen(!dropdown?.classList.contains('open'));
  });
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target) && !dropdown?.contains(e.target)) {
      setOpen(false);
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .staging-banner {
    background: $color-info-bg;
    border: 1px solid $color-info-border;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: $color-info;
    text-align: center;

    @include dark-mode {
      background: $color-info-bg-dark;
      border-color: $color-info-border-dark;
      color: $color-info-dark;
    }
  }

  .admin-header {
    margin-bottom: 1rem;

    h1 {
      font-family: $font-heading;
      font-size: 1.5rem;
      margin: 0;
    }
  }

  .admin-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .admin-header-cta {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: $color-accent;
    color: #000;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 600;

    &:hover {
      opacity: 0.9;
    }
  }

  .admin-subtitle {
    font-size: 0.875rem;
    margin: 0.25rem 0 0;
    @include muted-text;
  }

  .admin-nav-bar {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid $color-border;
    padding-bottom: 0.5rem;

    @include dark-mode {
      border-color: $color-border-subtle-dark;
    }
  }

  .admin-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .admin-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    white-space: nowrap;
    flex-shrink: 0;
    @include muted-text;

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .admin-user {
    position: relative;
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .admin-user-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    @include muted-text;
  }

  .admin-user-avatar {
    border-radius: 50%;
  }

  .admin-user-caret {
    font-size: 0.625rem;
  }

  .admin-user-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.25rem;
    background: $color-card-bg;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    min-width: 140px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    z-index: 100;

    @include dark-mode {
      background: $color-card-bg-dark;
      border-color: $color-border-dark;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    &.open {
      display: block;
    }
  }

  .admin-user-dropdown-item {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: $color-text;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;

    @include dark-mode {
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .logout-form {
    display: contents;
  }

</style>
