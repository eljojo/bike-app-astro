---
import { env } from '../lib/env';

interface Props {
  user: { displayName: string; role: string };
  currentTab: 'routes' | 'events';
  showEditorMode?: boolean;
  editorModeChecked?: boolean;
}

const { user, currentTab, showEditorMode = false, editorModeChecked = false } = Astro.props;
const isStaging = env.ENVIRONMENT === 'staging';
---

{isStaging && (
  <div class="staging-banner">Staging Environment</div>
)}
<div class="admin-header">
  <h1>{currentTab === 'routes' ? 'Routes' : 'Events'}</h1>
  <div class="admin-user">
    {showEditorMode && (
      <label class="editor-mode-toggle">
        <input type="checkbox" id="editor-mode-checkbox" checked={editorModeChecked} />
        Draft mode
      </label>
    )}
    {user.displayName}
    <form method="POST" action="/api/auth/logout" class="logout-form">
      <button type="submit" class="btn-logout">Sign out</button>
    </form>
  </div>
</div>

<nav class="admin-nav">
  <a href="/admin" class:list={['admin-nav-link', { active: currentTab === 'routes' }]}>Routes</a>
  <a href="/admin/events" class:list={['admin-nav-link', { active: currentTab === 'events' }]}>Events</a>
</nav>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .staging-banner {
    background: #e3f2fd;
    border: 1px solid #90caf9;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #1565c0;
    text-align: center;

    @include dark-mode {
      background: #0d1b2a;
      border-color: #1565c0;
      color: #90caf9;
    }
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;

    h1 {
      font-family: $font-heading;
      font-size: 1.5rem;
      margin: 0;
    }
  }

  .admin-nav {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid $color-border;
    padding-bottom: 0.5rem;

    @include dark-mode {
      border-color: #333;
    }
  }

  .admin-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    @include muted-text;

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .admin-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    @include muted-text;
  }

  .logout-form {
    display: inline;
  }

  .btn-logout {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    text-decoration: underline;
    @include muted-text;
  }

  .editor-mode-toggle {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    cursor: pointer;

    input {
      cursor: pointer;
    }
  }
</style>
