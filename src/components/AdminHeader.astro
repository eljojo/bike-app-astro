---
import { createHash } from 'node:crypto';
import { env } from '../lib/env';
import { CONTACT_EMAIL } from '../lib/config';

interface Props {
  user: { username: string; role: string; email?: string | null };
  currentTab: 'routes' | 'events' | 'history' | 'users' | 'settings';
}

const { user, currentTab } = Astro.props;
const isStaging = env.ENVIRONMENT === 'staging';
const cspNonce = Astro.locals.cspNonce;
const avatarHash = user.email
  ? createHash('md5').update(user.email.trim().toLowerCase()).digest('hex')
  : null;
const avatarUrl = avatarHash
  ? `https://www.gravatar.com/avatar/${avatarHash}?d=mp&s=32`
  : 'https://www.gravatar.com/avatar/?d=mp&s=32';
---

{isStaging && (
  <div class="staging-banner">Staging Environment</div>
)}
<div class="community-banner" id="community-banner">
  This is a community wiki — feel free to browse and edit routes and events.
  Your changes go live within a few minutes.
  Questions? Email <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
  <button type="button" class="community-banner-dismiss" id="community-banner-dismiss" aria-label="Dismiss">{'×'}</button>
</div>
<script nonce={cspNonce}>
  const banner = document.getElementById('community-banner');
  const dismiss = document.getElementById('community-banner-dismiss');
  if (sessionStorage.getItem('community-banner-dismissed')) {
    banner?.remove();
  }
  dismiss?.addEventListener('click', () => {
    sessionStorage.setItem('community-banner-dismissed', '1');
    banner?.remove();
  });
</script>
<script nonce={cspNonce}>
  const toggle = document.getElementById('user-menu-toggle');
  const dropdown = document.getElementById('user-menu-dropdown');
  toggle?.addEventListener('click', () => {
    dropdown?.classList.toggle('open');
  });
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target) && !dropdown?.contains(e.target)) {
      dropdown?.classList.remove('open');
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') dropdown?.classList.remove('open');
  });
</script>
<div class="admin-header">
  <h1>{currentTab === 'routes' ? 'Routes' : currentTab === 'events' ? 'Events' : currentTab === 'history' ? 'History' : currentTab === 'settings' ? 'Settings' : 'Users'}</h1>
  <div class="admin-user">
    <button type="button" class="admin-user-toggle" id="user-menu-toggle">
      <img src={avatarUrl} alt="" class="admin-user-avatar" width={24} height={24} />
      {user.username}
      <span class="admin-user-caret">&#9662;</span>
    </button>
    <div class="admin-user-dropdown" id="user-menu-dropdown">
      <a href="/admin/settings" class="admin-user-dropdown-item">Settings</a>
      {user.role === 'guest' && (
        <a href="/register?join=1" class="admin-user-dropdown-item">Create account</a>
      )}
      <form method="POST" action="/api/auth/logout" class="logout-form">
        <button type="submit" class="admin-user-dropdown-item">Sign out</button>
      </form>
    </div>
  </div>
</div>

{currentTab !== 'settings' && (
<nav class="admin-nav">
  <a href="/admin" class:list={['admin-nav-link', { active: currentTab === 'routes' }]}>Routes</a>
  <a href="/admin/events" class:list={['admin-nav-link', { active: currentTab === 'events' }]}>Events</a>
  <a href="/admin/history" class:list={['admin-nav-link', { active: currentTab === 'history' }]}>History</a>
  {user.role === 'admin' && (
    <a href="/admin/users" class:list={['admin-nav-link', { active: currentTab === 'users' }]}>Users</a>
  )}
</nav>
)}

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .staging-banner {
    background: $color-info-bg;
    border: 1px solid $color-info-border;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: $color-info;
    text-align: center;

    @include dark-mode {
      background: $color-info-bg-dark;
      border-color: $color-info-border-dark;
      color: $color-info-dark;
    }
  }

  .community-banner {
    background: $color-info-bg;
    border: 1px solid $color-info-border;
    border-radius: $border-radius;
    padding: 0.5rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: $color-info;
    position: relative;
    padding-right: 2rem;

    @include dark-mode {
      background: $color-info-bg-dark;
      border-color: $color-info-border-dark;
      color: $color-info-dark;
    }

    a {
      color: inherit;
      font-weight: 600;
    }
  }

  .community-banner-dismiss {
    position: absolute;
    top: 0.375rem;
    right: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.125rem;
    line-height: 1;
    color: inherit;
    opacity: 0.5;

    &:hover {
      opacity: 1;
    }
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;

    h1 {
      font-family: $font-heading;
      font-size: 1.5rem;
      margin: 0;
    }
  }

  .admin-nav {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid $color-border;
    padding-bottom: 0.5rem;

    @include dark-mode {
      border-color: $color-border-subtle-dark;
    }
  }

  .admin-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    @include muted-text;

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .admin-user {
    position: relative;
    display: flex;
    align-items: center;
    font-size: 0.875rem;
  }

  .admin-user-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    @include muted-text;
  }

  .admin-user-avatar {
    border-radius: 50%;
  }

  .admin-user-caret {
    font-size: 0.625rem;
  }

  .admin-user-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.25rem;
    background: $color-card-bg;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    min-width: 140px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    z-index: 100;

    @include dark-mode {
      background: $color-card-bg-dark;
      border-color: $color-border-dark;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    &.open {
      display: block;
    }
  }

  .admin-user-dropdown-item {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: $color-text;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;

    @include dark-mode {
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .logout-form {
    display: contents;
  }

</style>
