---
interface Props {
  highlightGeoIds?: string[];
  center?: [number, number];  // [lat, lng] from anchors
  fallbackCenter: [number, number];  // [lat, lng] from city config
  hintText: string;
  closeLabel: string;
  cdnUrl?: string;
  /** CSS selector for list items with data-slug to wire up hover highlight */
  highlightSelector?: string;
}
const { highlightGeoIds, center, fallbackCenter, hintText, closeLabel, cdnUrl = '', highlightSelector } = Astro.props;
---

<div class="expandable-map-wrapper">
  <div class="expandable-map-overlay" id="bike-path-map-overlay"></div>
  <div
    class="expandable-map-card"
    id="bike-path-map"
    data-highlight-geo-ids={highlightGeoIds && highlightGeoIds.length > 0 ? JSON.stringify(highlightGeoIds) : ''}
    data-center={center ? JSON.stringify(center) : ''}
    data-fallback-center={JSON.stringify(fallbackCenter)}
    data-cdn-url={cdnUrl}
    data-highlight-selector={highlightSelector || ''}
    role="button"
    tabindex="0"
    aria-expanded="false"
  >
    <div class="expandable-map-gl" id="bike-path-map-gl"></div>
    <div class="expandable-map-controls" id="bike-path-map-controls"></div>
    <button class="expandable-map-close" id="bike-path-map-close" aria-label={closeLabel}>✕</button>
    <div class="expandable-map-hint">{hintText}</div>
  </div>
</div>

<script>
  import { setupMapFromElement } from '../lib/maps/map-factory';
  import { createTilePathLayer } from '../lib/maps/layers';
  import { setupPathHighlight } from '../lib/maps/path-highlight';

  const container = document.getElementById('bike-path-map');
  if (container) {
    const rawHighlightGeoIds = container.dataset.highlightGeoIds || '';
    const highlightGeoIds: Set<string> | undefined = rawHighlightGeoIds
      ? new Set<string>(JSON.parse(rawHighlightGeoIds))
      : undefined;
    const highlightSelector = container.dataset.highlightSelector || '';

    const manifestPromise = fetch('/bike-paths/geo/tiles/manifest.json')
      .then(r => r.ok ? r.json() : [])
      .catch(() => []);

    const tilePathLayer = createTilePathLayer({
      manifestPromise,
      fetchPath: '/bike-paths/geo/tiles/',
      highlightGeoIds,
    });

    const { map, expandable, photoLayer } = setupMapFromElement(container, {
      expandable: true,
      primaryLayer: tilePathLayer,
      onReady: () => {
        if (highlightSelector && highlightGeoIds) {
          setupPathHighlight(map, { listSelector: highlightSelector, layerIds: ['paths-network-line'] });
        }
      },
    });

    // "Show photo on map" from the photo grid
    document.addEventListener('map:show-photo', ((e: CustomEvent<{ key: string; lat: number; lng: number }>) => {
      const { key, lat, lng } = e.detail;
      expandable?.expand();
      if (photoLayer) photoLayer.setVisible!(map, true);
      setTimeout(() => {
        map.flyTo({ center: [lng, lat], zoom: 15, duration: 800 });
        map.once('moveend', () => {
          map.once('idle', () => {
            const bubbles = map.getContainer().querySelectorAll('.photo-bubble img');
            for (const img of bubbles) {
              if ((img as HTMLImageElement).src.includes(key)) {
                (img.closest('.photo-bubble') as HTMLElement)?.click();
                break;
              }
            }
          });
        });
      }, 400);
    }) as EventListener);
  }
</script>

<!-- Styles now in src/styles/_expandable-map.scss (shared with RouteDetailMap) -->
