---
import RouteMap from './RouteMap.astro';
import { paths } from '../lib/paths';

/** Same palette as PALETTE in map-init.ts (duplicated to avoid importing client-only module). */
const PALETTE = ['#E6194B', '#3CB44B', '#4363D8', '#F58231', '#911EB4', '#42D4F4', '#F032E6', '#BFEF45'];

interface RouteItem {
  id: string;
  data: {
    name: string;
    distance_km: number;
    variants: { gpx: string; distance_km?: number }[];
    gpxTracks: Record<string, { polyline: string; distance_m: number; elevation_gain_m: number }>;
  };
}

interface Props {
  routes: RouteItem[];
  locale?: string;
}

const { routes, locale } = Astro.props;

// Build polylines from route data — use first variant's track for each route
const polylines = routes.flatMap((route, idx) => {
  const variant = route.data.variants[0];
  if (!variant) return [];
  const track = route.data.gpxTracks[variant.gpx];
  if (!track) return [];
  return [{
    name: route.data.name,
    encoded: track.polyline,
    color: PALETTE[idx % PALETTE.length],
    url: paths.route(route.id, locale),
  }];
});

// Build route info for the legend
const routeInfo = routes.map((route, idx) => {
  const variant = route.data.variants[0];
  const track = variant ? route.data.gpxTracks[variant.gpx] : null;
  return {
    name: route.data.name,
    slug: route.id,
    distance_km: route.data.distance_km,
    elevation_gain_m: track?.elevation_gain_m ?? 0,
    color: PALETTE[idx % PALETTE.length],
  };
});
---

{polylines.length > 0 && (
  <div class="event-route-map">
    <div class="event-route-map-container">
      <RouteMap polylines={polylines} />
    </div>

    {routeInfo.length > 1 && (
      <div class="event-route-legend">
        {routeInfo.map((r) => (
          <a href={paths.route(r.slug, locale)} class="event-route-legend-item">
            <span class="event-route-legend-swatch" style={`background: ${r.color}`} />
            <span class="event-route-legend-name">{r.name}</span>
            <span class="event-route-legend-meta">{r.distance_km} km, {r.elevation_gain_m}m+</span>
          </a>
        ))}
      </div>
    )}

    {routeInfo.length === 1 && (
      <p class="event-route-single">
        <a href={paths.route(routeInfo[0].slug, locale)}>{routeInfo[0].name}</a>
        — {routeInfo[0].distance_km} km, {routeInfo[0].elevation_gain_m}m+
      </p>
    )}
  </div>
)}
