---
import './TagFilter.scss';
import { t } from '../i18n';
import { tTag } from '../lib/i18n/tag-translations.server';

interface Props {
  /** Root element id — consumers listen on this for `tagfilter:change`. */
  id: string;
  /** Pills to render. */
  tags: string[];
  /** Slug → tags map. The component computes enabled slugs from this AND the active pill set. */
  items: Record<string, string[]>;
  /** When set, syncs active tags to `?<urlParam>=…` (e.g. `tags`). Omit to keep state in-memory. */
  urlParam?: string;
}

const { id, tags, items, urlParam } = Astro.props;
const locale = Astro.currentLocale;
---

{/*
  The items map and url-param are stashed on the root as data attributes
  rather than passed via `define:vars` on an inline script — the latter
  would need an unsafe-inline / per-page hash that production CSP doesn't
  grant. The hoisted <script> below is bundled and served from 'self', so
  CSP 'self' allows it without any per-page coordination.
*/}
<ul
  class="tag-filter"
  id={id}
  data-tag-filter
  data-items={JSON.stringify(items)}
  data-url-param={urlParam ?? ''}
>
  <li>
    <button class="tag-filter--btn tag-filter--all active" data-tag="all">{t('filter.all', locale)}</button>
  </li>
  {tags.map(tag => (
    <li>
      <button class="tag-filter--btn" data-tag={tag}>{tTag(tag, locale)}</button>
    </li>
  ))}
</ul>

<script>
  // Hoisted (no `is:inline`) → bundled to an external module served from
  // 'self', which production CSP allows. Each TagFilter root carries its
  // configuration in data attributes so this single bundle handles every
  // instance on the page.
  function setupTagFilter(root: HTMLElement) {
    const allBtn = root.querySelector<HTMLButtonElement>('.tag-filter--all');
    const tagButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('.tag-filter--btn:not(.tag-filter--all)'));
    let items: Record<string, string[]>;
    try {
      items = JSON.parse(root.dataset.items || '{}') as Record<string, string[]>;
    } catch {
      return;
    }
    const slugs = Object.keys(items);
    const urlParam = root.dataset.urlParam || '';

    // Restore filters from URL if `urlParam` was set. The component owns the
    // URL contract so consumers don't need to coordinate.
    const initialTags = urlParam
      ? (new URL(window.location.href).searchParams.get(urlParam)?.split(',').filter(Boolean) ?? [])
      : [];
    if (initialTags.length) {
      allBtn?.classList.remove('active');
      for (const tagName of initialTags) {
        const btn = root.querySelector(`.tag-filter--btn[data-tag="${CSS.escape(tagName)}"]`);
        if (btn) btn.classList.add('active');
      }
    }

    function getActiveTags(): string[] {
      return tagButtons
        .filter(b => b.classList.contains('active'))
        .map(b => b.dataset.tag ?? '')
        .filter(Boolean);
    }

    function computeEnabledSlugs(activeTags: string[]): string[] {
      if (activeTags.length === 0) return slugs.slice();
      // AND-match: a slug is enabled iff its tags include every active tag.
      return slugs.filter(slug => {
        const slugTags = items[slug] ?? [];
        for (const t of activeTags) {
          if (!slugTags.includes(t)) return false;
        }
        return true;
      });
    }

    function applyDimming(activeTags: string[], enabledSlugs: string[]) {
      // Smart visibility: when any tag is active, hide pills that wouldn't
      // narrow further (no enabled slug carries the tag) and dim pills
      // present on every enabled slug (no information value to clicking).
      if (activeTags.length === 0) {
        for (const btn of tagButtons) {
          btn.style.display = '';
          btn.style.opacity = '';
        }
        return;
      }
      const tagFreq = new Map<string, number>();
      for (const slug of enabledSlugs) {
        for (const t of items[slug] ?? []) tagFreq.set(t, (tagFreq.get(t) ?? 0) + 1);
      }
      for (const btn of tagButtons) {
        const tag = btn.dataset.tag ?? '';
        const freq = tagFreq.get(tag) ?? 0;
        if (freq === 0) {
          btn.style.display = 'none';
        } else {
          btn.style.display = '';
          btn.style.opacity = (freq === enabledSlugs.length && !btn.classList.contains('active')) ? '0.5' : '';
        }
      }
    }

    function syncUrl(activeTags: string[]) {
      if (!urlParam) return;
      const url = new URL(window.location.href);
      if (activeTags.length > 0) {
        url.searchParams.set(urlParam, activeTags.join(','));
        window.history.pushState({}, '', url);
      } else {
        url.searchParams.delete(urlParam);
        window.history.replaceState({}, '', url);
      }
    }

    type Action = 'init' | 'add' | 'remove' | 'clear';
    interface Meta { action: Action; lastChangedTag?: string }

    function emit(meta: Meta) {
      const activeTags = getActiveTags();
      const enabledSlugs = computeEnabledSlugs(activeTags);
      applyDimming(activeTags, enabledSlugs);
      root.dispatchEvent(new CustomEvent('tagfilter:change', {
        detail: { enabledSlugs, activeTags, action: meta.action, lastChangedTag: meta.lastChangedTag },
        bubbles: false,
      }));
    }

    root.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('.tag-filter--btn');
      if (!btn) return;

      let action: Action;
      let lastChangedTag: string | undefined;
      if (btn.classList.contains('tag-filter--all')) {
        // "All" clears every other filter.
        for (const b of root.querySelectorAll('.tag-filter--btn')) b.classList.remove('active');
        btn.classList.add('active');
        action = 'clear';
      } else {
        const wasActive = btn.classList.contains('active');
        btn.classList.toggle('active');
        allBtn?.classList.remove('active');
        if (getActiveTags().length === 0) allBtn?.classList.add('active');
        action = wasActive ? 'remove' : 'add';
        lastChangedTag = btn.dataset.tag;
      }
      syncUrl(getActiveTags());
      emit({ action, lastChangedTag });
    });

    // Initial paint: consumers attach their listener via hoisted <script>
    // tags too, and Astro may bundle them as separate modules. setTimeout
    // schedules a macrotask that runs AFTER every module on the page has
    // executed and the microtask queue has drained, so the consumer's
    // listener is definitely attached by the time the event fires —
    // regardless of which module ran first in the bundle.
    setTimeout(() => emit({ action: 'init' }), 0);
  }

  for (const root of document.querySelectorAll<HTMLElement>('[data-tag-filter]')) {
    setupTagFilter(root);
  }
</script>
