---
interface Place {
  name: string;
  emoji: string;
  lat: number;
  lng: number;
  description?: string;
  link?: string;
  google_maps_url?: string;
  address?: string;
  phone?: string;
  photo_key?: string;
  category?: string;
}

interface MapPhoto {
  key: string;
  lat: number;
  lng: number;
  caption?: string;
  width?: number;
  height?: number;
  index: number;
}

interface WaypointMarker {
  lat: number;
  lng: number;
  type: string;
  label: string;
}

interface Props {
  polylines: { name: string; encoded: string; color?: string; url?: string }[];
  places?: Place[];
  photos?: MapPhoto[];
  waypointMarkers?: WaypointMarker[];
  center?: [number, number];
  zoom?: number;
}

import { getCityConfig } from '../lib/city-config';
const { polylines, places = [], photos = [], waypointMarkers = [], center, zoom } = Astro.props;
---

<div class="map-container">
  <div
    id="route-map"
    style="width: 100%; height: 100%;"
    data-polylines={JSON.stringify(polylines)}
    data-places={JSON.stringify(places)}
    data-center={JSON.stringify(center)}
    data-zoom={zoom?.toString() || '12'}
    data-photos={JSON.stringify(photos)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
    data-waypoint-markers={JSON.stringify(waypointMarkers)}
  ></div>
  <div id="route-map-controls"></div>
</div>

<script>
  import { initMap, addPolylines, addMarkers, addPhotoMarkers, addWaypointMarkers, enableElevationCursorSync, showUserLocation, hideUserLocation, setPhotoLayersVisible, setPlaceMarkersVisible } from '../lib/map-init';
  import { buildPlacePopup, html } from '../lib/map-helpers';
  import { loadStylePreference, getStyleUrl, switchStyle, type MapStyleKey } from '../lib/map-style-switch';
  import { render, h } from 'preact';
  import MapControls, { loadToggleState } from './admin/MapControls';
  import polylineCodec from '@mapbox/polyline';

  const el = document.getElementById('route-map');
  const controlsEl = document.getElementById('route-map-controls');
  if (el) {
    const polylines = JSON.parse(el.dataset.polylines || '[]');
    const places = JSON.parse(el.dataset.places || '[]');
    const photos = JSON.parse(el.dataset.photos || '[]');
    const waypointMkrs = JSON.parse(el.dataset.waypointMarkers || '[]');
    const zoom = parseInt(el.dataset.zoom || '12');

    // Compute center from first polyline instead of defaulting to [0, 0]
    let center: [number, number] = JSON.parse(el.dataset.center || 'null');
    if (!center && polylines.length > 0) {
      const points = polylineCodec.decode(polylines[0].encoded);
      const mid = points[Math.floor(points.length / 2)];
      center = [mid[0], mid[1]];
    }
    const cdnUrl = el.dataset.cdnUrl || '';

    const styleKey = loadStylePreference();
    const map = initMap({ el, center, zoom, styleUrl: getStyleUrl(styleKey) });

    const polylineData = polylines.map((pl: any) => ({
      encoded: pl.encoded,
      popup: pl.url
        ? `<a href="${pl.url}" style="font-weight:bold;text-decoration:underline">${html`${pl.name}`}</a>`
        : html`${pl.name}`,
      ...(pl.color && { color: pl.color }),
    }));

    const placeData = places.map((p: any) => ({
      lat: p.lat, lng: p.lng, emoji: p.emoji,
      popup: buildPlacePopup(p, cdnUrl),
    }));

    function setupWebGLLayers(sk: MapStyleKey) {
      const bounds = addPolylines(map, polylineData, sk);

      if (photos.length > 0) {
        addPhotoMarkers(map, photos, cdnUrl, sk);
      }

      addMarkers(map, placeData);

      if (waypointMkrs.length > 0) {
        addWaypointMarkers(map, waypointMkrs);
      }

      return bounds;
    }

    map.on('load', () => {
      const bounds = setupWebGLLayers(styleKey);
      if (bounds) {
        map.fitBounds(bounds.toArray() as [[number, number], [number, number]], { padding: 30 });
      }

      // Enable elevation cursor sync (dot follows hover on elevation chart)
      enableElevationCursorSync(map);

      // Render MapControls island
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: photos.length > 0,
          hasPlaces: places.length > 0,
          onTogglePhotos: (v: boolean) => setPhotoLayersVisible(map, v),
          onTogglePlaces: (v: boolean) => setPlaceMarkersVisible(map, v),
          onToggleGps: (v: boolean) => {
            if (v) showUserLocation(map);
            else hideUserLocation();
          },
          onToggleStyle: (key: MapStyleKey) => switchStyle(map, key, () => {
            setupWebGLLayers(key);
            setPhotoLayersVisible(map, loadToggleState('map-photos', true));
            setPlaceMarkersVisible(map, loadToggleState('map-places', true));
          }),
        }), controlsEl);
      }
    });
  }
</script>
