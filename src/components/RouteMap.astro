---
interface Place {
  name: string;
  emoji: string;
  lat: number;
  lng: number;
  description?: string;
  link?: string;
  google_maps_url?: string;
  address?: string;
  phone?: string;
  photo_key?: string;
  category?: string;
}

interface MapPhoto {
  key: string;
  lat: number;
  lng: number;
  caption?: string;
  width?: number;
  height?: number;
  index: number;
}

interface WaypointMarker {
  lat: number;
  lng: number;
  type: string;
  label: string;
  distance_km?: number;
  opening?: string;
  closing?: string;
  note?: string;
  description?: string;
  address?: string;
  photo_key?: string;
  website?: string;
  google_maps_url?: string;
}

interface Props {
  polylines: { name: string; encoded: string; color?: string; url?: string; distance_km?: number; ride_date?: string; moving_time_s?: number }[];
  places?: Place[];
  photos?: MapPhoto[];
  waypointMarkers?: WaypointMarker[];
  center?: [number, number];
  zoom?: number;
}

import { getCityConfig } from '../lib/config/city-config';
const { polylines, places = [], photos = [], waypointMarkers = [], center, zoom } = Astro.props;
---

<div class="map-container">
  <div
    id="route-map"
    style="width: 100%; height: 100%;"
    data-polylines={JSON.stringify(polylines)}
    data-places={JSON.stringify(places)}
    data-center={JSON.stringify(center)}
    data-zoom={zoom?.toString() || '12'}
    data-photos={JSON.stringify(photos)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
    data-waypoint-markers={JSON.stringify(waypointMarkers)}
  ></div>
  <div id="route-map-controls"></div>
</div>

<script>
  import { createMapSession, createPolylineLayer, createPhotoLayer, createPlaceLayer, createWaypointLayer, createElevationSyncLayer, createGpsLayer, type PolylineLayer } from '../lib/maps/layers';
  import { buildPlacePopup, buildWaypointPopup, html } from '../lib/maps/map-helpers';
  import { buildPolylineFeature } from '../lib/maps/map-init';
  import { loadToggleState } from './admin/MapControls';
  import { render, h } from 'preact';
  import MapControls from './admin/MapControls';
  import polylineCodec from '@mapbox/polyline';

  const el = document.getElementById('route-map');
  const controlsEl = document.getElementById('route-map-controls');
  if (el) {
    const polylines = JSON.parse(el.dataset.polylines || '[]');
    const places = JSON.parse(el.dataset.places || '[]');
    const photos = JSON.parse(el.dataset.photos || '[]');
    const waypointMkrs = JSON.parse(el.dataset.waypointMarkers || '[]');
    const zoom = parseInt(el.dataset.zoom || '12');
    const cdnUrl = el.dataset.cdnUrl || '';

    let center: [number, number] = JSON.parse(el.dataset.center || 'null');
    if (!center && polylines.length > 0) {
      const points = polylineCodec.decode(polylines[0].encoded);
      const mid = points[Math.floor(points.length / 2)];
      center = [mid[0], mid[1]];
    }

    function buildPolylinePopup(pl: any): string {
      const title = pl.url
        ? `<a href="${pl.url}" style="font-weight:bold;text-decoration:underline">${html`${pl.name}`}</a>`
        : html`${pl.name}`;
      if (!pl.distance_km && !pl.ride_date) return title;
      const meta: string[] = [];
      if (pl.ride_date) {
        const [y, m, d] = pl.ride_date.split('-').map(Number);
        meta.push(new Date(y, m - 1, d).toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' }));
      }
      if (pl.distance_km) meta.push(`${Math.round(pl.distance_km)} km`);
      if (pl.moving_time_s) {
        const h = Math.floor(pl.moving_time_s / 3600);
        const m = Math.floor((pl.moving_time_s % 3600) / 60);
        meta.push(h > 0 ? `${h}h${String(m).padStart(2, '0')}m` : `${m}m`);
      }
      return `<div class="ride-popup">${title}<div class="ride-popup-meta">${meta.join(' · ')}</div></div>`;
    }

    const polylineData = polylines.map((pl: any) => ({
      encoded: pl.encoded,
      popup: buildPolylinePopup(pl),
      ...(pl.color && { color: pl.color }),
    }));

    const placeData = places.map((p: any) => ({
      lat: p.lat, lng: p.lng, emoji: p.emoji,
      popup: buildPlacePopup(p, cdnUrl),
    }));

    const waypointData = waypointMkrs.map((wp: any) => ({
      ...wp,
      popup: buildWaypointPopup(wp, cdnUrl),
    }));

    const polylineLayer = createPolylineLayer({ polylines: polylineData }) as PolylineLayer;
    const photoLayer = createPhotoLayer({ photos, cdnUrl });
    const placeLayer = createPlaceLayer({ places: placeData });
    const gpsLayer = createGpsLayer();

    const session = createMapSession({ el, center, zoom })
      .use(polylineLayer)
      .use(photoLayer)
      .use(placeLayer)
      .use(createWaypointLayer({ waypoints: waypointData }))
      .use(createElevationSyncLayer())
      .use(gpsLayer);

    session.start();

    // Route toggle (from EventRouteSelector)
    const hiddenSlugs = new Set<string>();
    window.addEventListener('route:toggle', ((e: CustomEvent) => {
      const { slug, visible: isVisible } = e.detail;
      if (isVisible) hiddenSlugs.delete(slug);
      else hiddenSlugs.add(slug);

      const features = polylineData.map((p: any, i: number) => {
        const feature = buildPolylineFeature(p.encoded, p.popup, p.color);
        const plUrl = polylines[i]?.url || '';
        const plSlug = plUrl.split('/').pop() || '';
        if (hiddenSlugs.has(plSlug)) {
          feature.properties!.hidden = true;
        }
        return feature;
      });
      polylineLayer.updateData(features);
      polylineLayer.setFilter(['!', ['has', 'hidden']]);
    }) as EventListener);

    // Render MapControls after map loads
    session.map.on('load', () => {
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: photos.length > 0,
          hasPlaces: places.length > 0,
          onTogglePhotos: (v: boolean) => photoLayer.setVisible!(session.map, v),
          onTogglePlaces: (v: boolean) => placeLayer.setVisible!(session.map, v),
          onToggleGps: (v: boolean) => gpsLayer.setVisible!(session.map, v),
          onToggleStyle: (key) => session.switchStyle(key, () => {
            photoLayer.setVisible!(session.map, loadToggleState('map-photos', true));
            placeLayer.setVisible!(session.map, loadToggleState('map-places', true));
          }),
        }), controlsEl);
      }
    });
  }
</script>
