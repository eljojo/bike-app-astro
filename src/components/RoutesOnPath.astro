---
import { imageUrl } from '@/lib/media/image-service';
import { formatDistance } from '@/lib/geo/distance';
import { paths } from '@/lib/paths';
import { t } from '@/i18n';

interface RouteCard {
  slug: string;
  name: string;
  distance_km: number;
  coverKey?: string;
  distanceOnPathKm?: number;
}

interface Props {
  routes: RouteCard[];
  locale?: string;
}

const { routes, locale } = Astro.props;
---

{routes.length > 0 && (
  <section class="routes-on-path">
    <h2>{t('paths.routes_on_path', locale)}</h2>
    <ul class="routes-on-path-grid">
      {routes.map(r => (
        <li class="routes-on-path-card">
          <a href={paths.route(r.slug, locale)}>
            {r.coverKey && (
              <img
                src={imageUrl(r.coverKey, { width: 300, height: 200, fit: 'cover' })}
                srcset={`${imageUrl(r.coverKey, { width: 600, height: 400, fit: 'cover' })} 2x`}
                alt={r.name}
                width="300"
                height="200"
                loading="lazy"
              />
            )}
            <span class="routes-on-path-card-name">{r.name}</span>
            <span class="routes-on-path-card-distance">{formatDistance([r.distance_km])}</span>
            {r.distanceOnPathKm && r.distanceOnPathKm > 0 && (
              <span class="routes-on-path-card-on-path">{t('paths.distance_on_path', locale, { distance: `${r.distanceOnPathKm} km` })}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
