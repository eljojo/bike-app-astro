---
import { computeElevationProfile, CHART } from '../lib/elevation-profile';

interface GpxPoint {
  lat: number;
  lon: number;
  ele?: number;
}

interface Props {
  points: GpxPoint[];
  distance_m: number;
}

const { points, distance_m } = Astro.props;
const profile = computeElevationProfile(points, distance_m);
const plotBottom = CHART.height - CHART.bottom;
const plotLeft = CHART.left;
const plotRight = CHART.width - CHART.right;
---

<div class="elevation-profile">
  <div class="elevation-stats">
    <span>&#x2197; {profile.elevGain}m gain</span>
    <span>&#x2195; {profile.minEle}m &ndash; {profile.maxEle}m</span>
    <span>&#x1F4CF; {profile.distanceKm} km</span>
  </div>
  <svg viewBox={`0 0 ${CHART.width} ${CHART.height}`} class="elevation-svg">
    {/* Grid lines */}
    {profile.yTicks.map(tick => (
      <line x1={plotLeft} x2={plotRight} y1={tick.position} y2={tick.position}
            stroke="#ddd" stroke-width="0.5" />
    ))}

    {/* Elevation area + line */}
    <path d={profile.svgArea} fill="rgba(0,102,204,0.15)" />
    <path d={profile.svgPath} fill="none" stroke="#0066cc" stroke-width="2" />

    {/* Y-axis labels (elevation) */}
    {profile.yTicks.map(tick => (
      <text x={plotLeft - 5} y={tick.position + 4} text-anchor="end"
            font-size="11" fill="#666">{tick.label}</text>
    ))}

    {/* X-axis labels (distance) */}
    {profile.xTicks.map(tick => (
      <text x={tick.position} y={plotBottom + 16} text-anchor="middle"
            font-size="11" fill="#666">{tick.label}</text>
    ))}
    <text x={plotRight} y={plotBottom + 16} text-anchor="middle"
          font-size="11" fill="#666">km</text>
  </svg>
</div>
