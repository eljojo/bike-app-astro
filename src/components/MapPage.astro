---
import RouteMap from './RouteMap.astro';
import InteractiveElevation from './InteractiveElevation.tsx';
import { computeElevationPoints } from '../lib/geo/elevation-profile';
import { mapImageUrl } from '../lib/maps/map-image-url';
import { variantKey as variantKeyFromGpx } from '../lib/gpx/filenames';
import { getCityConfig } from '../lib/config/city-config';
import { t } from '../i18n';
import { paths } from '../lib/paths';
import Icon from './Icon.astro';

interface Variant {
  name: string;
  gpx: string;
  strava_url?: string;
  rwgps_url?: string;
  komoot_url?: string;
}


interface GpxPoint {
  lat: number;
  lon: number;
  ele?: number;
}

interface Props {
  routeSlug: string;
  /** Translated slug for locale-aware links (falls back to routeSlug if not provided) */
  routeLocaleSlug?: string;
  routeName: string;
  variant: Variant;
  polyline: string;
  variantLabel?: string;
  elevationGain?: number | null;
  elevationConclusion?: string | null;
  trackPoints?: GpxPoint[];
  trackDistanceM?: number;
  /** Override GPX download path (for blog rides that use /rides/ instead of /routes/) */
  gpxPath?: string;
  /** Override "back to" link path */
  backPath?: string;
  gpxHash?: string;
}

const { routeSlug, routeLocaleSlug, routeName, variant, polyline, variantLabel, elevationGain, elevationConclusion, trackPoints, trackDistanceM, gpxPath, backPath, gpxHash } = Astro.props;
const linkSlug = routeLocaleSlug || routeSlug;
const siteUrl = getCityConfig().url;
const variantKey = variantKeyFromGpx(variant.gpx);
const locale = Astro.currentLocale || 'en';

function gpxStudioUrl(gpxUrl: string): string {
  const urlParam = encodeURIComponent(gpxUrl);
  return `https://gpx.studio/app?files=%5B%22${urlParam}%22%5D`;
}

const gpxUrl = `${siteUrl}${gpxPath || paths.routeGpx(routeSlug, variantKey)}`;
const exploreUrl = gpxStudioUrl(gpxUrl);

const title = variantLabel ? `${routeName} (${variantLabel})` : routeName;
---

<h1><Icon name="map-trifold" size={18} /> {title}</h1>

<p>
  <a href={exploreUrl} class="action-button" target="_blank" rel="nofollow">
    <Icon name="map-trifold" size={18} /> {t('map.explore_gpx', locale)}
  </a>
  {' '}
  <a href={gpxUrl} class="action-button" target="_blank" rel="nofollow" download>
    <Icon name="download-simple" size={18} /> {t('map.download_gpx', locale)}
  </a>
  {variant.strava_url && (
    <Fragment>
      {' '}
      <a href={variant.strava_url} class="action-button --light --logo" target="_blank" rel="noopener">
        <img src="/strava.svg" width="80" alt={t('strava.open', locale)} />
      </a>
    </Fragment>
  )}
  {variant.rwgps_url && (
    <Fragment>
      {' '}
      <a href={variant.rwgps_url} class="action-button --light --logo" target="_blank" rel="noopener">
        <img src="/rwgps.svg" width="78" alt={t('rwgps.open', locale)} />
      </a>
    </Fragment>
  )}
  {variant.komoot_url && (
    <Fragment>
      {' '}
      <a href={variant.komoot_url} class="action-button --light --logo" target="_blank" rel="noopener">
        <img src="/komoot.svg" width="80" alt={t('komoot.open', locale)} />
      </a>
    </Fragment>
  )}
  {gpxHash && (
    <Fragment>
      {' '}
      <a href={mapImageUrl('ride', routeSlug, 'full', { hash: gpxHash, variant: variantKey, lang: locale })} class="action-button" target="_blank" rel="noopener">
        <Icon name="map-trifold" size={18} /> PNG
      </a>
    </Fragment>
  )}
</p>

<RouteMap polylines={[{ name: variantLabel || routeName, encoded: polyline }]} />

{trackPoints && trackPoints.length > 0 && trackDistanceM && (
  <div id="elevation-profile" style="margin-top: 1.5em;">
    <h3>
      <Icon name="bicycle" size={20} />{' '}
      {elevationGain && (
        <Fragment>
          {t('route.elevation_gain', locale)}: {elevationGain} {t('route.meters', locale)}{elevationConclusion && `, ${t('route.this_is', locale)} ${t('elevation.' + elevationConclusion, locale)}`}
        </Fragment>
      )}
    </h3>
    <InteractiveElevation
      client:visible
      points={computeElevationPoints(trackPoints, trackDistanceM)}
    />
  </div>
)}

<p style="margin-top: 1em;">
  <a href={backPath || paths.route(linkSlug, locale)} class="go-back-button"><Icon name="arrow-left" size={16} /> {t('map.back_to', locale, { name: routeName })}</a>
</p>
