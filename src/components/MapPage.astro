---
import LeafletMap from './LeafletMap.astro';
import ElevationProfile from './ElevationProfile.astro';
import { hasCachedMap, variantKeyFromGpx } from '../lib/map-thumbnails';
import { getCityConfig } from '../lib/city-config';
import { t } from '../i18n';
import { paths, assets } from '../lib/paths';

interface Variant {
  name: string;
  gpx: string;
  strava_url?: string;
  rwgps_url?: string;
}

interface MapPlace {
  name: string;
  emoji: string;
  lat: number;
  lng: number;
  description?: string;
  link?: string;
  google_maps_url?: string;
}

interface GpxPoint {
  lat: number;
  lon: number;
  ele?: number;
}

interface Props {
  routeSlug: string;
  /** Translated slug for locale-aware links (falls back to routeSlug if not provided) */
  routeLocaleSlug?: string;
  routeName: string;
  variant: Variant;
  polyline: string;
  variantLabel?: string;
  elevationGain?: number | null;
  elevationConclusion?: string | null;
  places?: MapPlace[];
  trackPoints?: GpxPoint[];
  trackDistanceM?: number;
}

const { routeSlug, routeLocaleSlug, routeName, variant, polyline, variantLabel, elevationGain, elevationConclusion, places = [], trackPoints, trackDistanceM } = Astro.props;
const linkSlug = routeLocaleSlug || routeSlug;
const siteUrl = import.meta.env.SITE || getCityConfig().url;
const variantKey = variantKeyFromGpx(variant.gpx);
const locale = Astro.currentLocale;

function gpxStudioUrl(gpxUrl: string): string {
  const urlParam = encodeURIComponent(gpxUrl);
  return `https://gpx.studio/?state=%7B%22urls%22:%5B%22${urlParam}%22%5D%7D&distance&slope`;
}

const gpxUrl = `${siteUrl}${paths.routeGpx(routeSlug, variantKey)}`;
const exploreUrl = gpxStudioUrl(gpxUrl);
const hasVariantMap = hasCachedMap(routeSlug, variantKey);

const title = variantLabel ? `${routeName} (${variantLabel})` : routeName;
---

<h1>&#x1F5FA;&#xFE0F; {title}</h1>

{elevationGain && (
  <p>
    <span style="font-size: 1.5em;">&#x1F6B5; </span>
    {t('route.elevation_gain', locale)}: <a href={`${paths.routeMap(linkSlug, locale)}#elevation-profile`}>{elevationGain} {t('route.meters', locale)}</a>{elevationConclusion && `, ${t('route.this_is', locale)} ${t('elevation.' + elevationConclusion, locale)}`}
  </p>
)}

<p>
  <a href={exploreUrl} class="action-button" target="_blank" rel="nofollow">
    &#x1F5FA;&#xFE0F; {t('map.explore_gpx', locale)}
  </a>
  {' '}
  <a href={gpxUrl} class="action-button" target="_blank" rel="nofollow" download>
    &#x1F4E1; {t('map.download_gpx', locale)}
  </a>
  {variant.strava_url && (
    <Fragment>
      {' '}
      <a href={variant.strava_url} class="action-button" target="_blank" rel="noopener">
        <img src="/strava.svg" width="80" alt={t('strava.open', locale)} />
      </a>
    </Fragment>
  )}
  {variant.rwgps_url && (
    <Fragment>
      {' '}
      <a href={variant.rwgps_url} class="action-button" target="_blank" rel="noopener">
        <img src="/rwgps.svg" width="78" alt={t('rwgps.open', locale)} />
      </a>
    </Fragment>
  )}
  {hasVariantMap && (
    <Fragment>
      {' '}
      <a href={assets.mapPng(routeSlug, variantKey)} class="action-button" target="_blank" rel="noopener">
        &#x1F5FA;&#xFE0F; PNG
      </a>
    </Fragment>
  )}
</p>

<LeafletMap polylines={[{ name: variantLabel || routeName, encoded: polyline }]} places={places} />

{trackPoints && trackPoints.length > 0 && trackDistanceM && (
  <div id="elevation-profile" style="margin-top: 1.5em;">
    <h2>{t('map.elevation_profile', locale)}</h2>
    <ElevationProfile points={trackPoints} distance_m={trackDistanceM} />
  </div>
)}

<p style="margin-top: 1em;">
  <a href={paths.route(linkSlug, locale)} class="go-back-button">&#x21A9; {t('map.back_to', locale, { name: routeName })}</a>
</p>
