---
import './PhotoGallery.scss';
import './VideoGallery.scss';
import { imageUrl, imageSrcSet2x } from '../lib/media/image-service';
import { videoPlaybackSources, videoPosterUrl, videoFallbackUrl, videoDisplaySize } from '../lib/media/video-service';
import VideoGallery from './VideoGallery';
import type { VideoGalleryItem } from './VideoGallery';
import { paths } from '../lib/paths';
import { isBlogInstance } from '../lib/config/city-config';

const locale = Astro.currentLocale;

interface MediaItem {
  type: string;
  key: string;
  caption?: string;
  title?: string;
  handle?: string;
  width?: number;
  height?: number;
  score?: number;
  duration?: string;
}

interface Props {
  media: MediaItem[];
  name: string;
  youtubeIds?: string[];
  show?: 'all' | 'photos' | 'videos';
}

const { media, name, youtubeIds = [], show = 'all' } = Astro.props;
const showPhotos = show === 'all' || show === 'photos';
const showVideos = show === 'all' || show === 'videos';
const photos = media.filter(m => m.type === 'photo').sort((a, b) => (b.score || 0) - (a.score || 0));
const hostedVideos = media.filter(m => m.type === 'video');

// Photos: scored first, fallback to all
const scored = photos.filter(p => (p.score || 0) >= 1);
const allPhotos = scored.length > 0 ? scored : photos;

// Videos: self-hosted + YouTube combined
const hasVideoPages = !isBlogInstance();
const videoItems: VideoGalleryItem[] = [
  ...hostedVideos.map(v => {
    const sources = videoPlaybackSources(v.key);
    const origW = v.width || 640;
    const origH = v.height || 360;
    const display = videoDisplaySize(origW, origH);
    return {
      type: 'hosted' as const,
      key: v.key,
      sources,
      poster: videoPosterUrl(v.key),
      fallbackUrl: videoFallbackUrl(v.key),
      width: display.width,
      height: display.height,
      aspectW: origW,
      aspectH: origH,
      title: v.title,
      detailUrl: v.handle && hasVideoPages ? paths.video(v.handle, locale) : undefined,
      thumbUrl: videoPosterUrl(v.key),
    };
  }),
  ...youtubeIds.map(id => ({
    type: 'youtube' as const,
    key: `yt-${id}`,
    youtubeId: id,
    title: name,
    thumbUrl: `https://img.youtube.com/vi/${id}/mqdefault.jpg`,
  })),
];
---

{showPhotos && allPhotos.length > 0 && (
  <section class="route-photos" id="photos">
    <div class="photo-gallery">
      {allPhotos.map((photo) => {
        const ratio = (photo.width || 4) / (photo.height || 3);
        return (
          <a
            href={imageUrl(photo.key)}
            data-pswp-width={photo.width}
            data-pswp-height={photo.height}
            data-cropped="true"
            data-photo-key={photo.key}
            class="photo-gallery--image"
            style={`--ratio: ${ratio.toFixed(3)};`}
            target="_blank"
          >
            <img
              src={imageUrl(photo.key, { width: 300 })}
              srcset={imageSrcSet2x(photo.key, { width: 300 })}
              alt={photo.caption || name}
              loading="lazy"
            />
            {photo.caption && (
              <span class="pswp-caption-content">{photo.caption}</span>
            )}
          </a>
        );
      })}
    </div>
  </section>
)}

{showVideos && videoItems.length > 0 && (
  <section class="route-videos" id="videos">
    <VideoGallery client:idle videos={videoItems} />
  </section>
)}

{(showPhotos && allPhotos.length > 0) && (
  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';
    import 'photoswipe-dynamic-caption-plugin/photoswipe-dynamic-caption-plugin.css';
    import PhotoSwipeDynamicCaption from 'photoswipe-dynamic-caption-plugin';
    import ObjectPosition from '@vovayatsyuk/photoswipe-object-position';

    const isMobile = window.innerWidth < 768;
    const lightboxOptions: any = {
      gallery: '.photo-gallery',
      children: 'a.photo-gallery--image',
      pswpModule: () => import('photoswipe'),
    };
    if (!isMobile) {
      lightboxOptions.paddingFn = () => ({ top: 30, bottom: 30, left: 70, right: 70 });
    }

    const lightbox = new PhotoSwipeLightbox(lightboxOptions);
    new ObjectPosition(lightbox);
    new PhotoSwipeDynamicCaption(lightbox, { type: 'auto' });
    lightbox.init();
    lightbox.on('beforeOpen', () => {
      window.BikeApp?.tE?.('gallery open', { props: { page: window.location.pathname } });
    });

    // Cover photo click opens first gallery image
    const coverPhoto = document.querySelector('.gallery-cover-photo');
    const firstPhoto = document.querySelector('.photo-gallery a.photo-gallery--image:first-child');
    if (coverPhoto && firstPhoto) {
      coverPhoto.addEventListener('click', () => {
        window.BikeApp?.tE?.('click cover photo', { props: { page: window.location.pathname } });
        (firstPhoto as HTMLElement).click();
      });
    }

    // Deep-link: ?photo=KEY opens lightbox at that photo
    const photoParam = new URLSearchParams(location.search).get('photo');
    if (photoParam) {
      const allLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.photo-gallery a.photo-gallery--image'));
      const idx = allLinks.findIndex(a => a.dataset.photoKey === photoParam);
      if (idx >= 0) {
        lightbox.loadAndOpen(idx);
      }
    }

    // Desktop drag-to-scroll: grab cursor, drag scrolls, click opens lightbox.
    // On touch devices, native scroll handles everything — no drag logic needed.
    // After hovering still for 1s, cursor switches to pointer to hint "clickable".
    const gallery = document.querySelector<HTMLElement>('.photo-gallery');
    if (gallery && !('ontouchstart' in window)) {
      let isDragging = false;
      let startX = 0;
      let scrollStart = 0;
      let hoverTimer: ReturnType<typeof setTimeout> | null = null;
      const DRAG_THRESHOLD = 5;

      gallery.classList.add('photo-gallery--draggable');

      gallery.addEventListener('mousedown', (e) => {
        e.preventDefault(); // prevent native image/link drag
        isDragging = false;
        startX = e.clientX;
        scrollStart = gallery.scrollLeft;
        gallery.classList.add('photo-gallery--grabbing');
        gallery.classList.remove('photo-gallery--clickable');
        if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
      });

      window.addEventListener('mousemove', (e) => {
        if (!gallery.classList.contains('photo-gallery--grabbing')) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > DRAG_THRESHOLD) isDragging = true;
        if (isDragging) {
          gallery.scrollLeft = scrollStart - dx;
        }
      });

      window.addEventListener('mouseup', () => {
        gallery.classList.remove('photo-gallery--grabbing');
      });

      // Prevent click (PhotoSwipe open + link navigation) if user dragged
      gallery.addEventListener('click', (e) => {
        if (isDragging) {
          e.preventDefault();
          e.stopPropagation();
          isDragging = false;
        }
      }, true); // capture phase — fires before PhotoSwipe's handler

      // After hovering still for 250ms, switch to zoom-in cursor.
      // Any mouse movement resets the timer (debounce — only triggers when still).
      for (const thumb of gallery.querySelectorAll<HTMLElement>('.photo-gallery--image')) {
        thumb.addEventListener('mouseenter', () => {
          hoverTimer = setTimeout(() => {
            gallery.classList.add('photo-gallery--clickable');
          }, 250);
        });
        thumb.addEventListener('mousemove', () => {
          gallery.classList.remove('photo-gallery--clickable');
          if (hoverTimer) clearTimeout(hoverTimer);
          hoverTimer = setTimeout(() => {
            gallery.classList.add('photo-gallery--clickable');
          }, 250);
        });
        thumb.addEventListener('mouseleave', () => {
          if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
          gallery.classList.remove('photo-gallery--clickable');
        });
      }
    }
  </script>
)}
