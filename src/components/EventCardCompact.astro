---
// src/components/EventCardCompact.astro
import './EventCardCompact.scss';
import { getCollection } from 'astro:content';
import ResponsiveImage from './ResponsiveImage.astro';
import { parseLocalDate } from '../lib/date-utils';
import { tagPillColor } from '../lib/event-tags';
import { tTag } from '../lib/i18n/tag-translations.server';
import { paths } from '../lib/paths';
import { eventCoverKey } from '../lib/models/event-model';

interface Props {
  event: {
    id: string;
    data: {
      name: string;
      start_date: string;
      end_date?: string;
      poster_key?: string;
      poster_width?: number;
      poster_height?: number;
      poster_content_type?: string;
      organizer?: string | { name: string };
      tags?: string[];
      distance?: number;
      media?: Array<{ key: string; type?: string }>;
    };
  };
  occurrenceDate?: string;
  occurrenceLocation?: string;
  seriesBadge?: string;
  organizerName?: string;
  muted?: boolean;
  locale?: string;
}

const { event, occurrenceDate, occurrenceLocation, seriesBadge, organizerName: preResolvedOrg, muted = false, locale } = Astro.props;
const { data } = event;
const coverKey = eventCoverKey(data);

let organizerName = preResolvedOrg || '';
if (!organizerName) {
  if (typeof data.organizer === 'string') {
    const organizers = await getCollection('organizers');
    const org = organizers.find(o => o.id === data.organizer);
    organizerName = org?.data.name || data.organizer;
  } else if (data.organizer?.name) {
    organizerName = data.organizer.name;
  }
}

const displayStartDate = occurrenceDate || data.start_date;
const displayEndDate = occurrenceDate ? undefined : data.end_date;
const href = paths.event(event.id, locale);

const firstTag = data.tags?.[0];
const tagColor = firstTag ? tagPillColor(firstTag) : null;
const tagLabel = firstTag ? tTag(firstTag, locale) : null;

const distanceDisplay = data.distance ? `${data.distance} km` : null;

const displayName = data.name;

// Day number for left-column calendar anchor
const dayStart = parseLocalDate(displayStartDate);
const dayNum = dayStart.getDate();
let dayDisplay = `${dayNum}`;
if (displayEndDate && displayEndDate !== displayStartDate) {
  const dayEnd = parseLocalDate(displayEndDate);
  if (dayEnd.getMonth() === dayStart.getMonth() && dayEnd.getDate() !== dayNum) {
    dayDisplay = `${dayNum}–${dayEnd.getDate()}`;
  }
}

const weekday = dayStart.toLocaleString(locale || 'en-CA', { weekday: 'short' }).replace(/\.$/, '');

const meta = [organizerName, distanceDisplay].filter(Boolean).join(' · ');
---

<div class:list={['event-card-compact', { 'event-card-compact--muted': muted }]} data-event-slug={event.id} data-start-date={displayStartDate}>
  <div class="event-card-compact-day">
    <span class="event-card-compact-weekday">{weekday}</span>
    <span class="event-card-compact-daynum">{dayDisplay}</span>
  </div>
  <div class="event-card-compact-body">
    <div class="event-card-compact-line1">
      <a href={href} class="event-card-compact-name">{displayName}</a>
      {seriesBadge && (
        <span class="event-card-compact-series">{seriesBadge}</span>
      )}
      {!muted && tagLabel && tagColor && (
        <span
          class="event-card-compact-tag"
          style={`--pill-bg: ${tagColor.lightBg}; --pill-text: ${tagColor.lightText}; --pill-bg-dark: ${tagColor.darkBg}; --pill-text-dark: ${tagColor.darkText}`}
        >
          {tagLabel}
        </span>
      )}
    </div>
    {!muted && meta && <span class="event-card-compact-meta">{meta}</span>}
  </div>
  {!muted && coverKey && (
    <div class="event-card-compact-thumb">
      <ResponsiveImage
        blobKey={coverKey}
        alt={displayName}
        widths={[56, 112]}
        width={56}
        height={56}
        fit="cover"
      />
    </div>
  )}
</div>
