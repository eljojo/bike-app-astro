---
import './RideCard.scss';
import type { CollectionEntry } from 'astro:content';
import { imageUrl } from '@/lib/media/image-service';
import { mapImageUrl } from '@/lib/maps/map-image-url';
import { formatDuration } from '@/lib/date-utils';
import { formatDistance } from '@/lib/format';
import { paths } from '@/lib/paths';
import { countryToFlag } from '@/lib/country-flags';

interface Props {
  ride: CollectionEntry<'routes'>;
  featured?: boolean;
  badges?: string[];
  lazy?: boolean;
}

const { ride, featured = false, badges = [], lazy = true } = Astro.props;
const cover = ride.data.media.find(m => m.cover);
const gpxHash = ride.data.gpxHash;
const locale = Astro.currentLocale || 'en';
const loadAttr = lazy ? 'lazy' : 'eager';
---

<li class={`ride-card${featured ? ' ride-card--featured' : ''}`}
  data-distance={ride.data.distance_km}
  data-time={ride.data.moving_time_s || 0}
  data-speed={ride.data.average_speed_kmh || 0}
  data-tour={ride.data.tour_slug || ''}
  data-country={ride.data.country || ''}
  data-date={ride.data.ride_date || ''}
>
  <a href={paths.ride(ride.id, ride.data.tour_slug)} class="ride-card--link">
    <div class="ride-card--images">
      {cover && (
        <img
          class="ride-card--cover"
          src={imageUrl(cover.key, { width: 600, height: 600, fit: 'cover' })}
          srcset={`${imageUrl(cover.key, { width: 1200, height: 1200, fit: 'cover' })} 2x`}
          alt={ride.data.name}
          loading={loadAttr}
          width="600"
          height="600"
        />
      )}
      {gpxHash && (
        <img
          class="ride-card--map"
          src={mapImageUrl('ride', ride.id, 'thumb', { hash: gpxHash, lang: locale })}
          srcset={`${mapImageUrl('ride', ride.id, 'thumb', { hash: gpxHash, lang: locale })} 1x, ${mapImageUrl('ride', ride.id, 'thumb-2x', { hash: gpxHash, lang: locale })} 2x`}
          alt={`Map of ${ride.data.name}`}
          loading={loadAttr}
          width="600"
          height="600"
        />
      )}
    </div>
    <div class="ride-card--info">
      <strong class="ride-card--name">{ride.data.name}</strong>
      {badges.length > 0 && (
        <span class="ride-badge">{badges.join(' · ')}</span>
      )}
      <span class="ride-card--meta">
        {ride.data.ride_date}
        {' · '}
        {formatDistance(ride.data.distance_km)}
        {ride.data.moving_time_s ? ` · ${formatDuration(ride.data.moving_time_s)}` : ''}
        {ride.data.country ? ` · ${countryToFlag(ride.data.country) || ride.data.country}` : ''}
      </span>
    </div>
  </a>
</li>
