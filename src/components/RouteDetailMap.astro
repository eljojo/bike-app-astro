---
import { getCityConfig } from '@/lib/config/city-config';
import { t } from '@/i18n';

interface Props {
  polylines: { name: string; encoded: string; key?: string }[];
  places?: { name: string; emoji: string; lat: number; lng: number; description?: string; link?: string; google_maps_url?: string }[];
  photos?: { key: string; lat: number; lng: number; caption?: string; width?: number; height?: number; index: number }[];
  locale?: string;
}

const { polylines, places = [], photos = [], locale } = Astro.props;
const hintText = t('paths.tap_to_explore', locale);
const closeLabel = t('paths.close_map', locale);
const cdnUrl = import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url;
---

<div class="expandable-map-wrapper">
  <div class="expandable-map-overlay" id="route-detail-map-overlay"></div>
  <div
    class="expandable-map-card"
    id="route-detail-map"
    data-polylines={JSON.stringify(polylines)}
    data-places={JSON.stringify(places)}
    data-photos={JSON.stringify(photos)}
    data-cdn-url={cdnUrl}
    role="button"
    tabindex="0"
    aria-expanded="false"
  >
    <div class="expandable-map-gl" id="route-detail-map-gl"></div>
    <div class="expandable-map-controls" id="route-detail-map-controls"></div>
    <button class="expandable-map-close" id="route-detail-map-close" aria-label={closeLabel}>✕</button>
    <div class="expandable-map-hint">{hintText}</div>
  </div>
</div>

<script>
  // Follows the exact same pattern as BikePathMap.astro.
  // Photo/place layers start hidden (defaultVisible: false).
  // MapControls starts with defaultPhotos: false.
  // Controls are CSS-hidden in compact mode — user can only toggle layers when expanded.
  // No clever mode management, no lazy layer creation, no onModeChange callbacks.

  import { createMapSession, createPolylineLayer, createPhotoLayer, createPlaceLayer, createElevationSyncLayer } from '../lib/maps/layers';
  import { buildPlacePopup } from '../lib/maps/map-helpers';
  import { buildPolylineFeature } from '../lib/maps/map-init';
  import { createExpandableMap } from '../lib/maps/expandable-map';
  import { render, h } from 'preact';
  import MapControls from './admin/MapControls';
  import polylineCodec from '@mapbox/polyline';

  const card = document.getElementById('route-detail-map');
  const glEl = document.getElementById('route-detail-map-gl');
  const overlay = document.getElementById('route-detail-map-overlay');
  const closeBtn = document.getElementById('route-detail-map-close');
  const controlsEl = document.getElementById('route-detail-map-controls');

  if (card && glEl && overlay && closeBtn) {
    const polylines: { name: string; encoded: string; key?: string }[] = JSON.parse(card.dataset.polylines || '[]');
    const places: any[] = JSON.parse(card.dataset.places || '[]');
    const photos: any[] = JSON.parse(card.dataset.photos || '[]');
    const cdnUrl = card.dataset.cdnUrl || '';

    // Center from first polyline midpoint
    let center: [number, number] = [0, 0];
    if (polylines.length > 0) {
      const points = polylineCodec.decode(polylines[0].encoded);
      const mid = points[Math.floor(points.length / 2)];
      center = [mid[0], mid[1]];
    }

    // All variant polylines, starting with only the first visible
    const allPolylineData = polylines.map(pl => ({ encoded: pl.encoded, popup: pl.name }));
    const initialPolylineData = allPolylineData.length > 0 ? [allPolylineData[0]] : [];

    const placeData = places.map((p: any) => ({
      lat: p.lat, lng: p.lng, emoji: p.emoji,
      popup: buildPlacePopup(p, cdnUrl),
    }));

    // All layers in session — photos/places start hidden, same as BikePathMap
    const polylineLayer = createPolylineLayer({ polylines: initialPolylineData });
    const photoLayer = createPhotoLayer({ photos, cdnUrl, defaultVisible: false });
    const placeLayer = createPlaceLayer({ places: placeData, defaultVisible: false });

    const session = createMapSession({ el: glEl, center, zoom: 12 })
      .use(polylineLayer)
      .use(photoLayer)
      .use(placeLayer)
      .use(createElevationSyncLayer());

    const { map } = session;

    // Expandable card — handles interactions, close button, overlay, zoom
    createExpandableMap(map, { card, glEl, overlay, closeBtn }, {
      getBounds: () => polylineLayer.getBounds?.() ?? null,
    });

    session.start();

    // Controls — rendered after map loads, hidden until expanded via CSS
    map.on('load', () => {
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: photos.length > 0,
          hasPlaces: places.length > 0,
          defaultPhotos: false,
          defaultPlaces: false,
          onTogglePhotos: (v: boolean) => photoLayer.setVisible!(map, v),
          onTogglePlaces: (v: boolean) => placeLayer.setVisible!(map, v),
          onToggleStyle: (key) => session.switchStyle(key),
        }), controlsEl);
      }
    });

    // Variant switching — swap polyline and re-fit
    window.addEventListener('variant:change', ((e: CustomEvent<{ key: string }>) => {
      const key = e.detail.key;
      const idx = polylines.findIndex(p => p.key === key);
      if (idx >= 0) {
        const selected = allPolylineData[idx];
        const feature = buildPolylineFeature(selected.encoded, selected.popup);
        polylineLayer.updateData([feature]);
        const b = polylineLayer.getBounds?.();
        if (b && !b.isEmpty()) map.fitBounds(b, { padding: 20, animate: true });
      }
    }) as EventListener);
  }
</script>
