---
// src/components/Nav.astro
import { t, localePath } from '../i18n';
import { supportedLocales, defaultLocale } from '../lib/i18n/locale-utils';
import { switchLocalePath as computeSwitchPath } from '../lib/i18n/locale-switcher';
import { getInstanceFeatures } from '../lib/config/instance-features';

interface Props {
  alternateUrls?: Record<string, string>;
}

const { alternateUrls } = Astro.props;
const locale = Astro.currentLocale || defaultLocale();
const locales = supportedLocales();
const showSwitcher = locales.length > 1;
const features = getInstanceFeatures();

const otherLocale = locales.find(l => l !== locale) || locales[0];
const switchPath = computeSwitchPath(Astro.url.pathname, locale, otherLocale, alternateUrls?.[otherLocale]);
---
<nav class="top-nav">
  <ul>
    {features.hasRides ? (
      <>
        <li><a href="/rides">{t('nav.rides', locale)}</a></li>
        <li><a href="/tours">{t('nav.tours', locale)}</a></li>
        <li><a href="/stats">{t('nav.stats', locale)}</a></li>
        <li class="nav-about"><a href={localePath('/about', locale)}>{t('nav.about', locale)}</a></li>
      </>
    ) : features.hasEnrichedEvents ? (
      <>
        <li><a href={localePath('/events', locale)}>{t('nav.events', locale)}</a></li>
        <li><a href={localePath('/places', locale)}>{t('nav.places', locale)}</a></li>
        <li class="nav-about"><a href={localePath('/about', locale)}>{t('nav.about', locale)}</a></li>
      </>
    ) : (
      <>
        <li><a href={`${localePath('/', locale)}#browse`}>{t('nav.routes', locale)}</a></li>
        <li><a href={localePath('/calendar', locale)}>{t('nav.calendar', locale)}</a></li>
        <li><a href={localePath('/map', locale)}>{t('nav.map', locale)}</a></li>
        <li><a href={localePath('/communities', locale)}>{t('nav.communities', locale)}</a></li>
      </>
    )}
    <li class="nav-admin"><a href="/admin">&#x1F527; Admin</a></li>
    {showSwitcher && (
      <li class="nav-lang">
        <a href={switchPath} data-locale={otherLocale}>
          {t('lang.switch', locale)}
        </a>
      </li>
    )}
  </ul>
</nav>
