---
// src/components/Nav.astro
import { t, localePath } from '../i18n';
import { defaultLocale } from '../lib/i18n/locale-utils';
import { getInstanceFeatures } from '../lib/config/instance-features';

const locale = Astro.currentLocale || defaultLocale();
const features = getInstanceFeatures();
const trail = (p: string) => p.endsWith('/') ? p : p + '/';

// Determine active nav item from current URL path
const pathname = Astro.url.pathname;
function isActive(path: string): boolean {
  const resolved = localePath(path, locale);
  return pathname.startsWith(resolved);
}

const isWiki = features.hasRoutes && !features.hasRides && !features.hasEnrichedEvents;
const rideActive = isWiki && (isActive('/routes') || (features.hasPaths && isActive('/bike-paths')));
const communityActive = isWiki && (isActive('/calendar') || isActive('/communities') || isActive('/bike-shops') || isActive('/events'));

// Link to the current sub-section so clicking "Ride" on a bike path page goes to /bike-paths
const rideHref = trail(features.hasPaths && isActive('/bike-paths') ? localePath('/bike-paths', locale) : localePath('/routes', locale));
const mapHref = features.hasPaths && isActive('/bike-paths')
  ? trail(localePath('/map', locale)) + '#paths'
  : trail(localePath('/map', locale));
const communityHref = trail(isActive('/communities') ? localePath('/communities', locale)
  : isActive('/bike-shops') ? localePath('/bike-shops', locale)
  : localePath('/calendar', locale));
---
<nav class="top-nav" aria-label={t('a11y.main_navigation', locale)}>
  <ul>
    {features.hasRides ? (
      <>
        <li><a href="/rides/" aria-current={isActive('/rides') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.rides', locale)}</a></li>
        <li><a href="/tours/" aria-current={isActive('/tours') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.tours', locale)}</a></li>
        <li><a href="/stats/" aria-current={isActive('/stats') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.stats', locale)}</a></li>
        <li class="nav-about"><a href={trail(localePath('/about', locale))} aria-current={isActive('/about') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.about', locale)}</a></li>
      </>
    ) : features.hasEnrichedEvents ? (
      <>
        <li><a href={trail(localePath('/events', locale))} aria-current={isActive('/events') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.events', locale)}</a></li>
        <li><a href={trail(localePath('/places', locale))} aria-current={isActive('/places') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.places', locale)}</a></li>
        <li class="nav-about"><a href={trail(localePath('/about', locale))} aria-current={isActive('/about') ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.about', locale)}</a></li>
      </>
    ) : (
      <>
        <li><a href={rideHref} aria-current={rideActive ? 'page' : undefined} data-nav-ride data-astro-prefetch="hover">{t('nav.ride', locale)}</a></li>
        <li><a href={mapHref} aria-current={isActive('/map') ? 'page' : undefined} data-nav-map data-astro-prefetch="hover">{t('nav.map', locale)}</a></li>
        <li><a href={communityHref} aria-current={communityActive ? 'page' : undefined} data-astro-prefetch="hover">{t('nav.community', locale)}</a></li>
      </>
    )}
    <li class="nav-admin"><a href="/admin/">Admin</a></li>
  </ul>
</nav>
