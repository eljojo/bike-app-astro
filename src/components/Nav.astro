---
// src/components/Nav.astro
import { t, localePath } from '../i18n';
import { defaultLocale } from '../lib/i18n/locale-utils';
import { getInstanceFeatures } from '../lib/config/instance-features';

const locale = Astro.currentLocale || defaultLocale();
const features = getInstanceFeatures();

// Determine active nav item from current URL path
const pathname = Astro.url.pathname;
function isActive(path: string): boolean {
  const resolved = localePath(path, locale);
  return pathname.startsWith(resolved);
}

const isWiki = features.hasRoutes && !features.hasRides && !features.hasEnrichedEvents;
const rideActive = isWiki && (isActive('/routes') || isActive('/bike-paths'));
const communityActive = isWiki && (isActive('/calendar') || isActive('/communities') || isActive('/bike-shops') || isActive('/events'));

// Link to the current sub-section so clicking "Ride" on a bike path page goes to /bike-paths
const rideHref = isActive('/bike-paths') ? localePath('/bike-paths', locale) : localePath('/routes', locale);
const communityHref = isActive('/communities') ? localePath('/communities', locale)
  : isActive('/bike-shops') ? localePath('/bike-shops', locale)
  : localePath('/calendar', locale);
---
<nav class="top-nav">
  <ul>
    {features.hasRides ? (
      <>
        <li><a href="/rides" class={isActive('/rides') ? 'nav-active' : ''}>{t('nav.rides', locale)}</a></li>
        <li><a href="/tours" class={isActive('/tours') ? 'nav-active' : ''}>{t('nav.tours', locale)}</a></li>
        <li><a href="/stats" class={isActive('/stats') ? 'nav-active' : ''}>{t('nav.stats', locale)}</a></li>
        <li class="nav-about"><a href={localePath('/about', locale)} class={isActive('/about') ? 'nav-active' : ''}>{t('nav.about', locale)}</a></li>
      </>
    ) : features.hasEnrichedEvents ? (
      <>
        <li><a href={localePath('/events', locale)} class={isActive('/events') ? 'nav-active' : ''}>{t('nav.events', locale)}</a></li>
        <li><a href={localePath('/places', locale)} class={isActive('/places') ? 'nav-active' : ''}>{t('nav.places', locale)}</a></li>
        <li class="nav-about"><a href={localePath('/about', locale)} class={isActive('/about') ? 'nav-active' : ''}>{t('nav.about', locale)}</a></li>
      </>
    ) : (
      <>
        <li><a href={rideHref} class={rideActive ? 'nav-active' : ''}>{t('nav.ride', locale)}</a></li>
        <li><a href={localePath('/map', locale)} class={isActive('/map') ? 'nav-active' : ''}>{t('nav.map', locale)}</a></li>
        <li><a href={communityHref} class={communityActive ? 'nav-active' : ''}>{t('nav.community', locale)}</a></li>
      </>
    )}
    <li class="nav-admin"><a href="/admin">Admin</a></li>
  </ul>
</nav>
