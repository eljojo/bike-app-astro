---
import './OrganizerSpotlight.scss';
import CommunityCard from './CommunityCard.astro';
import { t } from '../i18n';
import type { OrganizerEntry } from '../lib/models/organizer-model';

interface Props {
  organizers: OrganizerEntry[];
  /**
   * Orgs that don't meet the default spotlight criteria (Instagram + 2+
   * events) but should still be reachable via the calendar's tag filter
   * — e.g. a women-only club with no upcoming women-only events. They
   * render hidden by default; the calendar's filter listener reveals
   * matching fallbacks (capped at `data-show`) when a filter is active.
   */
  fallbackOrganizers?: OrganizerEntry[];
  locale?: string;
}

const { organizers, fallbackOrganizers = [], locale } = Astro.props;
const hasAny = organizers.length > 0 || fallbackOrganizers.length > 0;
---

{hasAny && (
  <section class="organizer-spotlight">
    <h2>{t('calendar.organizer_spotlight', locale)}</h2>
    <div class="organizer-spotlight-strip" data-show="3">
      {organizers.map(org => (
        <CommunityCard
          org={org}
          locale={locale}
          showFeatured={false}
          showEventCount={false}
        />
      ))}
      {fallbackOrganizers.map(org => (
        <CommunityCard
          org={org}
          locale={locale}
          showFeatured={false}
          showEventCount={false}
          dataTagFallback={true}
        />
      ))}
    </div>
  </section>
)}
