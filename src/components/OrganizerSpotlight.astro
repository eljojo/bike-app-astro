---
import './OrganizerSpotlight.scss';
import ResponsiveImage from './ResponsiveImage.astro';
import { t } from '../i18n';
import { organizerLink, organizerInitials, type OrganizerEntry } from '../lib/models/organizer-model';

interface Props {
  organizers: OrganizerEntry[];
  locale?: string;
}

const { organizers, locale } = Astro.props;
---

{organizers.length > 0 && (
  <section class="organizer-spotlight">
    <h2>{t('calendar.organizer_spotlight', locale)}</h2>
    <div class="organizer-spotlight-strip" data-show="3">
      {organizers.map(org => {
        const link = organizerLink(org, locale);
        const isExternal = link.startsWith('http');

        const content = (
          <div class="organizer-spotlight-item">
            {org.data.photo_key ? (
              <ResponsiveImage
                blobKey={org.data.photo_key}
                alt={org.data.name}
                widths={[128]}
                width={64}
                height={64}
                class="organizer-spotlight-avatar"
              />
            ) : (
              <div class="organizer-spotlight-initials">{organizerInitials(org.data.name)}</div>
            )}
            <div class="organizer-spotlight-info">
              <span class="organizer-spotlight-name">{org.data.name}</span>
              {org.data.instagram && (
                <span class="organizer-spotlight-handle">@{org.data.instagram}</span>
              )}
            </div>
          </div>
        );

        return link !== '#' ? (
          <a
            href={link}
            class="organizer-spotlight-link"
            {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {content}
          </a>
        ) : (
          content
        );
      })}
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const strip = document.querySelector<HTMLElement>('.organizer-spotlight-strip[data-show]');
        if (!strip) return;
        const count = parseInt(strip.dataset.show || '3', 10);
        const children = Array.from(strip.children) as HTMLElement[];
        if (children.length <= count) {
          children.forEach(c => c.style.display = '');
          return;
        }
        // Fisher-Yates shuffle to pick `count` random items
        const indices = children.map((_, i) => i);
        for (let i = indices.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [indices[i], indices[j]] = [indices[j], indices[i]];
        }
        const shown = new Set(indices.slice(0, count));
        children.forEach((child, i) => {
          child.style.display = shown.has(i) ? '' : 'none';
        });
      });
    </script>
  </section>
)}
