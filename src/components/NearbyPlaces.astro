---
import { getCollection } from 'astro:content';
import { findNearbyPlaces, type PlaceData } from '../lib/proximity';
import type { GpxPoint } from '../lib/gpx';

interface Props {
  trackPoints: GpxPoint[];
}

const { trackPoints } = Astro.props;

const allPlaces = await getCollection('places');
const placeData: PlaceData[] = allPlaces
  .filter(p => p.data.status === 'published')
  .map(p => ({
    id: p.id,
    name: p.data.name,
    category: p.data.category,
    lat: p.data.lat,
    lng: p.data.lng,
    address: p.data.address,
    website: p.data.website,
    phone: p.data.phone,
    google_maps_url: p.data.google_maps_url,
  }));

import { categoryEmoji } from '../lib/place-categories';

const nearby = findNearbyPlaces(trackPoints, placeData);
---

{nearby.length > 0 && (
  <section class="nearby-places">
    <h2>Nearby Places</h2>
    <ul>
      {nearby.map(place => (
        <li>
          <span class="place-emoji" set:html={categoryEmoji[place.category] || '&#x1F4CD;'} />
          <a href={place.google_maps_url || `https://www.google.com/maps/?q=${place.lat},${place.lng}`}
             target="_blank" rel="noopener" class="place-name">{place.name}</a>
          {place.website && (
            <a href={place.website} target="_blank" rel="noopener" class="place-link">website</a>
          )}
        </li>
      ))}
    </ul>
  </section>
)}
