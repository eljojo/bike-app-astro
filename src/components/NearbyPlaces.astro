---
import type { NearbyPlace } from '../lib/proximity';
import { categoryEmoji } from '../lib/place-categories';

interface Props {
  nearby: NearbyPlace[];
}

const { nearby } = Astro.props;
---

{nearby.length > 0 && (
  <section class="nearby-places">
    <h2>Nearby Places</h2>
    <ul>
      {nearby.map(place => (
        <li>
          <span class="place-emoji" set:html={categoryEmoji[place.category] || '&#x1F4CD;'} />
          <a href={place.google_maps_url || `https://www.google.com/maps/?q=${place.lat},${place.lng}`}
             target="_blank" rel="noopener" class="place-name">{place.name}</a>
          {place.website && (
            <a href={place.website} target="_blank" rel="noopener" class="place-link">website</a>
          )}
        </li>
      ))}
    </ul>
  </section>
)}
