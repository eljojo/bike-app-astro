---
import type { NearbyPlace } from '../lib/geo/proximity';
import { categoryEmoji } from '../lib/place-categories';
import { defaultLocale } from '../lib/i18n/locale-utils';
import { t } from '../i18n';

interface Props {
  nearby: NearbyPlace[];
  limit?: number;
}

const { nearby, limit } = Astro.props;
const locale = Astro.currentLocale;
const hasMore = limit != null && nearby.length > limit;
---

{nearby.length > 0 && (
  <section class="nearby-places">
    <h2>{t('places.nearby', locale)}</h2>
    <ul>
      {nearby.map((place, i) => {
        const placeName = (locale !== defaultLocale() && place.name_fr) ? place.name_fr : place.name;
        return (
        <li itemscope itemtype="https://schema.org/Place" class={limit != null && i >= limit ? 'places-hidden' : ''}>
          <span class="place-emoji" set:html={categoryEmoji[place.category] || '&#x1F4CD;'} />
          <a href={place.google_maps_url || `https://www.google.com/maps/?q=${place.lat},${place.lng}`}
             target="_blank" rel="noopener" class="place-name" itemprop="hasMap">
            <span itemprop="name">{placeName}</span>
          </a>
          {place.website && (
            <a href={place.website} target="_blank" rel="noopener" class="place-link" itemprop="url">{t('places.website', locale)}</a>
          )}
          <div itemprop="geo" itemscope itemtype="https://schema.org/GeoCoordinates">
            <meta itemprop="latitude" content={String(place.lat)} />
            <meta itemprop="longitude" content={String(place.lng)} />
          </div>
          {place.address && <meta itemprop="address" content={place.address} />}
          {place.phone && <meta itemprop="telephone" content={place.phone} />}
        </li>
        );
      })}
    </ul>
    {hasMore && (
      <button class="action-button" id="show-all-places">
        {t('places.show_all', locale, { count: nearby.length })}
      </button>
    )}
  </section>
)}

{hasMore && (
  <script>
    const showAllBtn = document.getElementById('show-all-places');
    if (showAllBtn) {
      showAllBtn.addEventListener('click', () => {
        document.querySelectorAll('.places-hidden').forEach(el => {
          (el as HTMLElement).classList.remove('places-hidden');
        });
        showAllBtn.style.display = 'none';
      });
    }
  </script>
)}
