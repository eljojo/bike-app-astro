---
// src/components/EventCard.astro
import './EventCard.scss';
import { getCollection } from 'astro:content';
import ResponsiveImage from './ResponsiveImage.astro';
import { formatDateRange } from '../lib/date-utils';
import { eventCoverKey } from '../lib/models/event-model';

interface Props {
  name: string;
  start_date: string;
  end_date?: string;
  distances?: string;
  location?: string;
  href?: string;
  registration_url?: string;
  review_url?: string;
  organizer?: string | { name: string; website?: string; instagram?: string };
  poster_key?: string;
  media?: Array<{ key: string; type?: string }>;
  edition?: string;
  eventId?: string;
}

const props = Astro.props;
const coverKey = eventCoverKey(props);

let organizerName = '';
if (typeof props.organizer === 'string') {
  const organizers = await getCollection('organizers');
  const org = organizers.find(o => o.id === props.organizer);
  organizerName = org?.data.name || props.organizer;
} else if (props.organizer?.name) {
  organizerName = props.organizer.name;
}

const dateDisplay = formatDateRange(props.start_date, props.end_date);
---

<div class={`event-card${(props.href || props.registration_url) ? ' event-card--linked' : ''}`}>
  {organizerName && <span class="event-organizer">{organizerName}</span>}
  {props.href
    ? <a href={props.href} class="event-name event-name--stretched">{props.name}</a>
    : props.registration_url
      ? <a href={props.registration_url} class="event-name event-name--stretched" target="_blank" rel="noopener">{props.name}</a>
      : <span class="event-name">{props.name}</span>
  }
  <span class="event-dates">{dateDisplay}</span>
  {props.distances && <span class="event-distances">{props.distances}</span>}
  {coverKey ? (
    <div class="event-card-poster">
      <ResponsiveImage
        blobKey={coverKey}
        alt={props.name}
        widths={[400]}
      />
    </div>
  ) : (
    <div class="event-card-poster event-card-poster--placeholder">🚲</div>
  )}
  {props.edition && <span class="event-edition">{props.edition}</span>}
  {props.review_url && (
    <a href={props.review_url} class="event-review">Read my review!</a>
  )}
</div>
