---
import { t } from '../i18n';
import { paths } from '../lib/paths';
import { variantKey as variantKeyFromGpx } from '../lib/gpx/filenames';

interface Variant {
  name: string;
  gpx: string;
  distance_km: number;
  elevation_gain_m?: number;
  strava_url?: string;
  rwgps_url?: string;
  komoot_url?: string;
}

interface Props {
  variants: Variant[];
  slug: string;
  localeName: string;
  locale: string | undefined;
  elevationConclusions?: Record<string, string>;
  shapes?: Record<string, string>;
}

const { variants, slug, localeName, locale, elevationConclusions, shapes } = Astro.props;
const multiVariant = variants.length > 1;
---

<div class={`variant-cards ${multiVariant ? 'variant-cards--multi' : ''}`}>
  {multiVariant && <h3>{t('route.versions', locale, { count: variants.length })}</h3>}
  <div class="variant-cards-grid">
    {variants.map((v, i) => {
      const vKey = variantKeyFromGpx(v.gpx);
      const shape = shapes?.[vKey];
      const conclusion = elevationConclusions?.[vKey];
      return (
        <div class={`variant-card ${i === 0 ? 'variant-card--primary' : ''}`}>
          {multiVariant && <h4 class="variant-card-name">{v.name}</h4>}
          <div class="variant-card-stats">
            <span>{v.distance_km} km</span>
            {shape && <span class="variant-card-dot">&middot;</span>}
            {shape && <span>{t(`shape.${shape}`, locale)}</span>}
          </div>
          {v.elevation_gain_m != null && (
            <div class="variant-card-stats variant-card-elevation">
              <span>{v.elevation_gain_m} {t('route.meters', locale)}</span>
              {conclusion && (
                <Fragment>
                  <span class="variant-card-dot">&middot;</span>
                  <span>{t('elevation.' + conclusion, locale)}</span>
                </Fragment>
              )}
            </div>
          )}
          <div class="variant-card-actions">
            <a href={paths.route(slug, locale)} class="action-button --primary">
              &#x1F5FA;&#xFE0F; {t('route.view_map', locale, { name: multiVariant ? v.name : localeName })}
            </a>
            <span class="variant-card-external">
              {v.strava_url && (
                <a href={v.strava_url} target="_blank" rel="noopener" class="action-button --light --logo">
                  <img src="/strava.svg" width="70" alt={t('strava.open', locale)} />
                </a>
              )}
              {v.rwgps_url && (
                <a href={v.rwgps_url} target="_blank" rel="noopener" class="action-button --light --logo">
                  <img src="/rwgps.svg" width="68" alt={t('rwgps.open', locale)} />
                </a>
              )}
              {v.komoot_url && (
                <a href={v.komoot_url} target="_blank" rel="noopener" class="action-button --light --logo">
                  {t('komoot.open', locale)}
                </a>
              )}
            </span>
          </div>
        </div>
      );
    })}
  </div>
</div>
