---
// src/components/EventCardFeatured.astro
import './EventCardFeatured.scss';
import { getCollection } from 'astro:content';
import ResponsiveImage from './ResponsiveImage.astro';
import { formatDateRange, parseLocalDate } from '../lib/date-utils';
import { tagPillColor } from '../lib/event-tags';
import { paths } from '../lib/paths';
import { eventCoverKey } from '../lib/models/event-model';

interface Props {
  event: {
    id: string;
    data: {
      name: string;
      start_date: string;
      end_date?: string;
      poster_key?: string;
      poster_width?: number;
      poster_height?: number;
      poster_content_type?: string;
      organizer?: string | { name: string };
      tags?: string[];
      media?: Array<{ key: string; type?: string }>;
    };
  };
  tagLabel?: string;
  seriesBadge?: string;
  occurrenceDate?: string;
  organizerName?: string;
  locale?: string;
}

const { event, tagLabel, seriesBadge, occurrenceDate, organizerName: preResolvedOrg, locale } = Astro.props;
const { data } = event;
const coverKey = eventCoverKey(data);

let organizerName = preResolvedOrg || '';
if (!organizerName) {
  if (typeof data.organizer === 'string') {
    const organizers = await getCollection('organizers');
    const org = organizers.find(o => o.id === data.organizer);
    organizerName = org?.data.name || data.organizer;
  } else if (data.organizer?.name) {
    organizerName = data.organizer.name;
  }
}

const displayStartDate = occurrenceDate || data.start_date;
const displayEndDate = occurrenceDate ? undefined : data.end_date;
const dateDisplay = formatDateRange(displayStartDate, displayEndDate, locale);
const href = paths.event(event.id, locale);

// For series occurrences, append the short date to the name so each card is distinguishable
const isSeriesOccurrence = !!occurrenceDate;
const shortDate = isSeriesOccurrence
  ? (() => {
      const d = parseLocalDate(occurrenceDate);
      const mon = d.toLocaleString(locale || 'en-CA', { month: 'short' });
      return `${mon} ${d.getDate()}`;
    })()
  : '';
const displayName = isSeriesOccurrence ? `${data.name} — ${shortDate}` : data.name;
const displayDate = dateDisplay;

const tagColor = tagLabel && data.tags?.[0] ? tagPillColor(data.tags[0]) : null;
---

<div class="event-card-featured" data-event-slug={event.id}>
  {coverKey && (
    <div class="event-card-featured-poster">
      <ResponsiveImage
        blobKey={coverKey}
        alt={displayName}
        widths={[400, 800]}
        fit="cover"
      />
    </div>
  )}
  <div class="event-card-featured-body">
    {organizerName && <span class="event-card-featured-organizer">{organizerName}</span>}
    <a href={href} class="event-card-featured-name">{displayName}</a>
    {tagLabel && tagColor && (
      <span
        class="event-card-featured-tag"
        style={`--pill-bg: ${tagColor.lightBg}; --pill-text: ${tagColor.lightText}; --pill-bg-dark: ${tagColor.darkBg}; --pill-text-dark: ${tagColor.darkText}`}
      >
        {tagLabel}
      </span>
    )}
    {seriesBadge && (
      <span class="event-card-featured-series">{seriesBadge}</span>
    )}
    <span class="event-card-featured-date">{displayDate}</span>
  </div>
</div>
