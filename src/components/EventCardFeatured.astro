---
// src/components/EventCardFeatured.astro
import './EventCardFeatured.scss';
import { getCollection } from 'astro:content';
import ResponsiveImage from './ResponsiveImage.astro';
import { formatDateRange } from '../lib/date-utils';
import { tagPillColor } from '../lib/event-tags';
import { paths } from '../lib/paths';

interface Props {
  event: {
    id: string;
    data: {
      name: string;
      start_date: string;
      end_date?: string;
      poster_key?: string;
      poster_width?: number;
      poster_height?: number;
      poster_content_type?: string;
      organizer?: string | { name: string };
      tags?: string[];
    };
  };
  tagLabel?: string;
  locale?: string;
}

const { event, tagLabel, locale } = Astro.props;
const { data } = event;

let organizerName = '';
if (typeof data.organizer === 'string') {
  const organizers = await getCollection('organizers');
  const org = organizers.find(o => o.id === data.organizer);
  organizerName = org?.data.name || data.organizer;
} else if (data.organizer?.name) {
  organizerName = data.organizer.name;
}

const dateDisplay = formatDateRange(data.start_date, data.end_date, locale);
const href = paths.event(event.id, locale);

const tagColor = tagLabel && data.tags?.[0] ? tagPillColor(data.tags[0]) : null;
---

<div class="event-card-featured">
  {data.poster_key && (
    <div class="event-card-featured-poster">
      <ResponsiveImage
        blobKey={data.poster_key}
        alt={data.name}
        widths={[400, 800]}
        fit="cover"
      />
    </div>
  )}
  <div class="event-card-featured-body">
    {organizerName && <span class="event-card-featured-organizer">{organizerName}</span>}
    <a href={href} class="event-card-featured-name">{data.name}</a>
    {tagLabel && tagColor && (
      <span
        class="event-card-featured-tag"
        style={`--pill-bg: ${tagColor.lightBg}; --pill-text: ${tagColor.lightText}; --pill-bg-dark: ${tagColor.darkBg}; --pill-text-dark: ${tagColor.darkText}`}
      >
        {tagLabel}
      </span>
    )}
    <span class="event-card-featured-date">{dateDisplay}</span>
  </div>
</div>
