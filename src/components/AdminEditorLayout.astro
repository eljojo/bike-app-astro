---
import Base from '../layouts/Base.astro';
import Toast from './admin/Toast.tsx';
import '../styles/admin.scss';

interface Props {
  title: string;
  backLink: string;
  backLabel?: string;
  viewLink?: string;
  hideTitle?: boolean;
}

const { title, backLink, backLabel = 'Back', viewLink, hideTitle } = Astro.props;
---

<Base title={title} admin>
  <Toast client:load />
  <div class="admin-page">
    <div class="editor-header">
      <a href={backLink} class="back-link">&larr; {backLabel}</a>
      {viewLink && <a href={viewLink} class="view-link" target="_blank" rel="noopener">View live &nearr;</a>}
    </div>
    {!hideTitle && <h1 class="editor-title">{title}</h1>}
    <slot />
  </div>
</Base>

<style lang="scss">
  @use '../styles/editor';
</style>
