---
import Base from '../layouts/Base.astro';
import AdminHeader from './AdminHeader.astro';
import Toast from './admin/Toast.tsx';
import '../styles/admin.scss';

interface Props {
  title: string;
  viewLink?: string;
  hideTitle?: boolean;
  user: { username: string; role: string; email?: string | null };
  currentTab: 'routes' | 'events' | 'places';
}

const { title, viewLink, hideTitle, user, currentTab } = Astro.props;
---

<Base title={title} admin>
  <Toast client:load />
  <div class="admin-page">
    <AdminHeader user={user} currentTab={currentTab} />
    {viewLink && (
      <div class="editor-header">
        <a href={viewLink} class="view-link" target="_blank" rel="noopener">View live &nearr;</a>
      </div>
    )}
    {!hideTitle && <h1 class="editor-title">{title}</h1>}
    <slot />
  </div>
</Base>

<style lang="scss">
  @use '../styles/editor';

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }
</style>
