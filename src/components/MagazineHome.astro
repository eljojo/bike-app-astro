---
import './MagazineHome.scss';
import { t, localePath } from '@/i18n';
import { imageUrl } from '@/lib/media/image-service';
import { videoFallbackUrl, videoPosterUrl } from '@/lib/media/video-service';
import { formatDistance } from '@/lib/geo/distance';
import { formatDateRange } from '@/lib/date-utils';
import { paths } from '@/lib/paths';
import { tTag } from '@/lib/i18n/tag-translations.server';
import type {
  FeaturedRoute,
  UpcomingEvent,
  FeaturedCommunity,
  ExploreMiniCard,
  ResolvedFact,
  HomepageVideo,
} from '@/lib/homepage-data.server';

interface Props {
  featuredRoute: FeaturedRoute | null;
  upcomingEvents: UpcomingEvent[];
  featuredCommunities: FeaturedCommunity[];
  exploreRoutes: ExploreMiniCard[];
  facts: ResolvedFact[];
  video: HomepageVideo | null;
  routeCount: number;
}

const { featuredRoute, upcomingEvents, featuredCommunities, exploreRoutes, facts, video, routeCount } = Astro.props;
const locale = Astro.currentLocale;
---

<div class="magazine-home">
  <div class="magazine-layout">
    <div class="magazine-main">
      {featuredRoute && (
        <section class="magazine-featured">
          <h2>{t('home.featured_ride', locale)}</h2>
          <a href={paths.route(featuredRoute.slug, locale)} class="featured-route-card">
            {featuredRoute.coverKey && (
              <img
                src={imageUrl(featuredRoute.coverKey, { width: 750, height: 420, fit: 'cover' })}
                srcset={`${imageUrl(featuredRoute.coverKey, { width: 1500, height: 840, fit: 'cover' })} 2x`}
                alt={featuredRoute.name}
                width="750"
                height="420"
                loading="eager"
                class="featured-route-img"
              />
            )}
            <div class="featured-route-info">
              <span class="featured-route-name">{featuredRoute.name}</span>
              {featuredRoute.tagline && (
                <span class="featured-route-meta">{featuredRoute.tagline}</span>
              )}
              <div class="featured-route-tags">
                <span class="featured-route-tag distance">{formatDistance([featuredRoute.distance_km])}</span>
                {featuredRoute.tags.map(tag => (
                  <span class="featured-route-tag">{tTag(tag, locale)}</span>
                ))}
              </div>
              {featuredRoute.description && (
                <p class="featured-route-description">{featuredRoute.description}</p>
              )}
              <span class="featured-route-readmore">
                {t('home.read_more', locale)} &rarr;
              </span>
            </div>
          </a>
        </section>
      )}

      {video && (
        <section class="magazine-video">
          <a href={paths.route(video.routeSlug, locale)} class="magazine-video-link">
            <video
              muted
              autoplay
              loop
              playsinline
              poster={videoPosterUrl(video.key)}
              class="magazine-video-player"
            >
              <source src={videoFallbackUrl(video.key)} type="video/mp4" />
            </video>
            <span class="magazine-video-caption">
              {video.caption || video.routeName}
            </span>
          </a>
        </section>
      )}

      {exploreRoutes.length > 0 && (
        <section class="magazine-explore">
          <h2>{t('home.routes_to_explore', locale)}</h2>
          <div class="explore-cards">
            {exploreRoutes.map(route => (
              <a href={paths.route(route.slug, locale)} class="explore-card">
                <div class="explore-card-img-wrap">
                  {route.coverKey && (
                    <img
                      src={imageUrl(route.coverKey, { width: 375, height: 250, fit: 'cover' })}
                      srcset={`${imageUrl(route.coverKey, { width: 750, height: 500, fit: 'cover' })} 2x`}
                      alt={route.name}
                      width="375"
                      height="250"
                      loading="lazy"
                      class="explore-card-img"
                    />
                  )}
                  <span class="explore-card-badge">{formatDistance([route.distance_km])}</span>
                </div>
                <div class="explore-card-info">
                  <span class="explore-card-name">{route.name}</span>
                  {route.tagline && <span class="explore-card-tagline">{route.tagline}</span>}
                </div>
              </a>
            ))}
          </div>
          <a href="#browse" class="magazine-view-all">
            {t('home.view_all_routes', locale, { count: routeCount })} &rarr;
          </a>
        </section>
      )}
    </div>

    <aside class="magazine-sidebar">
      {upcomingEvents.length > 0 && (
        <section class="magazine-events">
          <h2>{t('home.upcoming_events', locale)}</h2>
          <ul class="upcoming-events-list">
            {upcomingEvents.map(event => (
              <li class="upcoming-event">
                <a href={paths.event(event.slug, locale)}>
                  <div class="upcoming-event-thumb">
                    {event.posterKey ? (
                      <img
                        src={imageUrl(event.posterKey, { width: 80, height: 80, fit: 'cover' })}
                        alt=""
                        width="40"
                        height="40"
                      />
                    ) : (
                      <span class="upcoming-event-emoji">🚲</span>
                    )}
                  </div>
                  <div class="upcoming-event-info">
                    <span class="upcoming-event-name">{event.name}</span>
                    <span class="upcoming-event-meta">
                      {formatDateRange(event.startDate, event.endDate)}
                      {event.organizerName && ` · ${event.organizerName}`}
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href={localePath('/calendar', locale)} class="magazine-view-all">
            {t('home.full_calendar', locale)} &rarr;
          </a>
        </section>
      )}

      {facts.length > 0 && (
        <section class="magazine-facts">
          <h2>{t('home.did_you_know', locale)}</h2>
          <ul class="facts-list" data-show-random="3">
            {facts.map(fact => {
              // If link_text is set, only that substring becomes the link
              if (fact.link && fact.link_text) {
                const idx = fact.text.indexOf(fact.link_text);
                if (idx !== -1) {
                  const before = fact.text.slice(0, idx);
                  const after = fact.text.slice(idx + fact.link_text.length);
                  return (
                    <li class="fact-item">
                      <span class="fact-prefix">...</span>{' '}
                      {before}<a href={fact.link}>{fact.link_text}</a>{after}
                    </li>
                  );
                }
              }
              return (
                <li class="fact-item">
                  <span class="fact-prefix">...</span>{' '}
                  {fact.link ? (
                    <a href={fact.link}>{fact.text}</a>
                  ) : (
                    <span>{fact.text}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {featuredCommunities.length > 0 && (
        <section class="magazine-communities">
          <h2>{t('home.local_communities', locale)}</h2>
          <ul class="community-cards" data-show-random="5">
            {featuredCommunities.map(community => (
              <li class="community-card">
                <a href={community.link}>
                  {community.photoKey ? (
                    <img
                      src={imageUrl(community.photoKey, { width: 80, height: 80, fit: 'cover' })}
                      alt={community.name}
                      width="40"
                      height="40"
                      loading="lazy"
                      class="community-avatar"
                    />
                  ) : (
                    <span class="community-initials">{community.initials}</span>
                  )}
                  <div class="community-card-info">
                    <span class="community-card-name">{community.name}</span>
                    {community.tagline && (
                      <span class="community-card-tagline">{community.tagline}</span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href={paths.communities(locale)} class="magazine-view-all">
            {t('home.all_communities', locale)} &rarr;
          </a>
        </section>
      )}
    </aside>
  </div>
</div>
