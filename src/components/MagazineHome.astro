---
import './MagazineHome.scss';
import Icon from './Icon.astro';
import { t, localePath } from '@/i18n';
import { imageUrl, imageSrcSet2x } from '@/lib/media/image-service';
import { videoPlaybackSources, videoPosterUrl } from '@/lib/media/video-service';
import { formatDistance } from '@/lib/geo/distance';
import { formatDateRange } from '@/lib/date-utils';
import { paths } from '@/lib/paths';
import { tTag } from '@/lib/i18n/tag-translations.server';
import type {
  FeaturedRoute,
  UpcomingEvent,
  FeaturedCommunity,
  ExploreMiniCard,
  ResolvedFact,
  HomepageVideo,
} from '@/lib/homepage-data.server';

interface Props {
  featuredRoute: FeaturedRoute | null;
  upcomingEvents: UpcomingEvent[];
  featuredCommunities: FeaturedCommunity[];
  exploreRoutes: ExploreMiniCard[];
  facts: ResolvedFact[];
  video: HomepageVideo | null;
  routeCount: number;
}

const { featuredRoute, upcomingEvents, featuredCommunities, exploreRoutes, facts, video, routeCount } = Astro.props;
const locale = Astro.currentLocale;
---

<div class="magazine-home">
  <div class="magazine-layout">
    <div class="magazine-main">
      {featuredRoute && (
        <section class="magazine-featured">
          <h2>{t('home.featured_ride', locale)}</h2>
          <a href={paths.route(featuredRoute.localeSlug, locale)} class="featured-route-card">
            {featuredRoute.coverKey && (
              <img
                src={imageUrl(featuredRoute.coverKey, { width: 750, height: 420, fit: 'cover' })}
                srcset={`${imageUrl(featuredRoute.coverKey, { width: 1500, height: 840, fit: 'cover' })} 2x`}
                alt={featuredRoute.name}
                width="750"
                height="420"
                loading="eager"
                class="featured-route-img"
              />
            )}
            <div class="featured-route-info">
              <span class="featured-route-name">{featuredRoute.name}</span>
              {featuredRoute.tagline && (
                <span class="featured-route-meta">{featuredRoute.tagline}</span>
              )}
              <div class="featured-route-tags">
                <span class="featured-route-tag distance">{formatDistance([featuredRoute.distance_km])}</span>
                {featuredRoute.tags.map(tag => (
                  <span class="featured-route-tag">{tTag(tag, locale)}</span>
                ))}
              </div>
              {featuredRoute.description && (
                <p class="featured-route-description">{featuredRoute.description}</p>
              )}
              <span class="featured-route-readmore">
                {t('home.read_more', locale)} <Icon name="arrow-right" size={14} />
              </span>
            </div>
          </a>
        </section>
      )}

      {video && (
        <section class="magazine-video">
          <a href={paths.route(video.localeRouteSlug, locale)} class="magazine-video-link">
            <video
              muted
              autoplay
              loop
              playsinline
              poster={videoPosterUrl(video.key)}
              class="magazine-video-player"
            >
              {videoPlaybackSources(video.key).map(source => (
                <source src={source.src} type={source.type} />
              ))}
            </video>
            <span class="magazine-video-caption">
              {video.caption || video.routeName}
            </span>
          </a>
        </section>
      )}

      {exploreRoutes.length > 0 && (
        <section class="magazine-explore">
          <h2>{t('home.routes_to_explore', locale)}</h2>
          <div class="explore-cards">
            {exploreRoutes.map(route => (
              <a href={paths.route(route.localeSlug, locale)} class="explore-card">
                <div class="explore-card-img-wrap">
                  {route.coverKey && (
                    <img
                      src={imageUrl(route.coverKey, { width: 375, height: 250, fit: 'cover' })}
                      srcset={`${imageUrl(route.coverKey, { width: 750, height: 500, fit: 'cover' })} 2x`}
                      alt={route.name}
                      width="375"
                      height="250"
                      loading="lazy"
                      class="explore-card-img"
                    />
                  )}
                  <span class="explore-card-badge">{formatDistance([route.distance_km])}</span>
                </div>
                <div class="explore-card-info">
                  <span class="explore-card-name">{route.name}</span>
                  {route.tagline && <span class="explore-card-tagline">{route.tagline}</span>}
                </div>
              </a>
            ))}
          </div>
          <a href="#browse" class="magazine-view-all">
            {t('home.view_all_routes', locale, { count: routeCount })} <Icon name="arrow-right" size={14} />
          </a>
        </section>
      )}
    </div>

    <aside class="magazine-sidebar">
      {upcomingEvents.length > 0 && (
        <section class="magazine-events">
          <h2>{t('home.upcoming_events', locale)}</h2>
          <ul class="upcoming-events-list">
            {upcomingEvents.map(event => (
              <li class="upcoming-event" data-event-slug={event.slug}>
                <a href={paths.event(event.slug, locale)}>
                  <div class="upcoming-event-thumb">
                    {event.posterKey ? (
                      <img
                        src={imageUrl(event.posterKey, { width: 80, height: 80, fit: 'cover' })}
                        alt=""
                        width="40"
                        height="40"
                      />
                    ) : (
                      <span class="upcoming-event-emoji">🚲</span>
                    )}
                  </div>
                  <div class="upcoming-event-info">
                    <span class="upcoming-event-name">{event.name}</span>
                    <span class="upcoming-event-meta">
                      {formatDateRange(event.startDate, event.endDate)}
                      {event.organizerName && ` · ${event.organizerName}`}
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href={localePath('/calendar', locale)} class="magazine-view-all">
            {t('home.full_calendar', locale)} <Icon name="arrow-right" size={14} />
          </a>
        </section>
      )}

      {facts.length > 0 && (
        <section class="magazine-facts">
          <h2>{t('home.did_you_know', locale)}</h2>
          <ul class="facts-list" data-show-random="3">
            {facts.map(fact => {
              // If link_text is set, only that substring becomes the link
              if (fact.link && fact.link_text) {
                const idx = fact.text.indexOf(fact.link_text);
                if (idx !== -1) {
                  const before = fact.text.slice(0, idx);
                  const after = fact.text.slice(idx + fact.link_text.length);
                  return (
                    <li class="fact-item">
                      <span class="fact-prefix">...</span>{' '}
                      {before}<a href={fact.link}>{fact.link_text}</a>{after}
                    </li>
                  );
                }
              }
              return (
                <li class="fact-item">
                  <span class="fact-prefix">...</span>{' '}
                  {fact.link ? (
                    <a href={fact.link}>{fact.text}</a>
                  ) : (
                    <span>{fact.text}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {featuredCommunities.length > 0 && (
        <section class="magazine-communities">
          <h2>{t('home.local_communities', locale)}</h2>
          <ul class="community-cards" data-show-random="3" data-show-random-desktop="5">
            {featuredCommunities.map(community => (
              <li class="community-card" data-weight={community.featured ? '4' : undefined}>
                <a href={community.link}>
                  {community.photoKey ? (
                    <img
                      src={imageUrl(community.photoKey, { width: 80, height: 80, fit: 'cover' })}
                      srcset={imageSrcSet2x(community.photoKey, { width: 80, height: 80, fit: 'cover' })}
                      alt={community.name}
                      width="40"
                      height="40"
                      loading="lazy"
                      class="community-avatar"
                    />
                  ) : (
                    <span class="community-initials">{community.initials}</span>
                  )}
                  <div class="community-card-info">
                    <span class="community-card-name">{community.name}</span>
                    {community.tagline && (
                      <span class="community-card-tagline">{community.tagline}</span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href={paths.communities(locale)} class="magazine-view-all">
            {t('home.all_communities', locale)} <Icon name="arrow-right" size={14} />
          </a>
        </section>
      )}

      <section id="weather-card" class="magazine-weather" hidden data-locale={locale}>
        <a href={`${localePath('/', locale)}?tags=chill`} class="weather-card-link">
          <span id="weather-icon"></span>
          <span id="weather-text"></span>
        </a>
      </section>
    </aside>
  </div>
</div>

<script>
  // Reorder starred events to top of upcoming events list
  (async () => {
    try {
      const res = await fetch('/api/reactions/event/_starred');
      if (!res.ok) return;
      const data = await res.json();
      const starred: string[] = data.starredSlugs || [];
      if (starred.length === 0) return;

      const list = document.querySelector('.upcoming-events-list');
      if (!list) return;

      const starredSet = new Set(starred);
      const items = [...list.querySelectorAll<HTMLElement>('.upcoming-event[data-event-slug]')];
      const starredItems = items.filter(el => starredSet.has(el.dataset.eventSlug || ''));

      for (const item of starredItems.reverse()) {
        list.prepend(item);
      }
    } catch {
      // Silently fail — starred reordering is progressive enhancement
    }
  })();
</script>

<script>
  (async () => {
    const ICONS: Record<string, string> = {
      'sun': '<path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"/>',
      'cloud-sun': '<path d="M164,72a76.2,76.2,0,0,0-20.26,2.73,55.63,55.63,0,0,0-9.41-11.54l9.51-13.57a8,8,0,1,0-13.11-9.18L121.22,54A55.9,55.9,0,0,0,96,48c-.58,0-1.16,0-1.74,0L91.37,31.71a8,8,0,1,0-15.75,2.77L78.5,50.82A56.1,56.1,0,0,0,55.23,65.67L41.61,56.14a8,8,0,1,0-9.17,13.11L46,78.77A55.55,55.55,0,0,0,40,104c0,.57,0,1.15,0,1.72L23.71,108.6a8,8,0,0,0,1.38,15.88,8.24,8.24,0,0,0,1.39-.12l16.32-2.88a55.74,55.74,0,0,0,5.86,12.42A52,52,0,0,0,84,224h80a76,76,0,0,0,0-152ZM56,104a40,40,0,0,1,72.54-23.24,76.26,76.26,0,0,0-35.62,40,52.14,52.14,0,0,0-31,4.17A40,40,0,0,1,56,104ZM164,208H84a36,36,0,1,1,4.78-71.69c-.37,2.37-.63,4.79-.77,7.23a8,8,0,0,0,16,.92,58.91,58.91,0,0,1,1.88-11.81c0-.16.09-.32.12-.48A60.06,60.06,0,1,1,164,208Z"/>',
      'cloud': '<path d="M160,40A88.09,88.09,0,0,0,81.29,88.67,64,64,0,1,0,72,216h88a88,88,0,0,0,0-176Zm0,160H72a48,48,0,0,1,0-96c1.1,0,2.2,0,3.29.11A88,88,0,0,0,72,128a8,8,0,0,0,16,0,72,72,0,1,1,72,72Z"/>',
      'moon-stars': '<path d="M240,96a8,8,0,0,1-8,8H216v16a8,8,0,0,1-16,0V104H184a8,8,0,0,1,0-16h16V72a8,8,0,0,1,16,0V88h16A8,8,0,0,1,240,96ZM144,56h8v8a8,8,0,0,0,16,0V56h8a8,8,0,0,0,0-16h-8V32a8,8,0,0,0-16,0v8h-8a8,8,0,0,0,0,16Zm72.77,97a8,8,0,0,1,1.43,8A96,96,0,1,1,95.07,37.8a8,8,0,0,1,10.6,9.06A88.07,88.07,0,0,0,209.14,150.33,8,8,0,0,1,216.77,153Zm-19.39,14.88c-1.79.09-3.59.14-5.38.14A104.11,104.11,0,0,1,88,64c0-1.79,0-3.59.14-5.38A80,80,0,1,0,197.38,167.86Z"/>',
    };
    try {
      const card = document.getElementById('weather-card');
      const span = document.getElementById('weather-text');
      const iconSpan = document.getElementById('weather-icon');
      if (!card || !span) return;

      const locale = card.dataset.locale || '';
      const res = await fetch(`/api/weather${locale ? `?locale=${locale}` : ''}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.rideable || !data.text) return;

      if (iconSpan && data.icon && ICONS[data.icon]) {
        iconSpan.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true" style="vertical-align:-0.125em">${ICONS[data.icon]}</svg>`;
      }
      span.textContent = data.sunscreen ? `${data.text}. ${data.sunscreen}` : data.text;
      card.removeAttribute('hidden');
    } catch {
      // Silently fail — weather card is progressive enhancement
    }
  })();
</script>
