---
// src/components/BigMap.astro
import { getCityConfig } from '../lib/city-config';

const config = getCityConfig();

interface RouteOnMap {
  slug: string;
  name: string;
  polyline: string;
  distance_km: number;
}

interface PlaceOnMap {
  name: string;
  category: string;
  emoji: string;
  lat: number;
  lng: number;
  google_maps_url?: string;
}

interface Props {
  routes: RouteOnMap[];
  places: PlaceOnMap[];
  center: [number, number];
}

const { routes, places, center } = Astro.props;
---

<div
  id="big-map"
  class="big-map"
  data-routes={JSON.stringify(routes)}
  data-places={JSON.stringify(places)}
  data-center={JSON.stringify(center)}
  data-tiles-url={config.tiles_url}
></div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import polylineCodec from '@mapbox/polyline';

  const el = document.getElementById('big-map');
  if (el) {
    const routes = JSON.parse(el.dataset.routes || '[]');
    const places = JSON.parse(el.dataset.places || '[]');
    const center = JSON.parse(el.dataset.center || '[0, 0]');

    const map = L.map(el).setView(center, 11);
    const tilesUrl = el.dataset.tilesUrl || '';

    L.tileLayer(tilesUrl, {
      maxZoom: 20,
      attribution: 'Maps &copy; <a href="https://www.thunderforest.com">Thunderforest</a>, Data &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap contributors</a>',
    }).addTo(map);

    // Add route polylines
    routes.forEach((r: any) => {
      const coords = polylineCodec.decode(r.polyline);
      L.polyline(coords, { color: '#350091', weight: 6, opacity: 0.9 })
        .bindPopup(`<a href="/routes/${r.slug}">${r.name}</a><br>${r.distance_km} km`)
        .addTo(map);
    });

    // Add place markers with emoji icons
    places.forEach((p: any) => {
      const emojiIcon = L.divIcon({
        className: 'emoji-icon',
        html: p.emoji,
        iconSize: [25, 25],
      });

      let popupContent = `<strong>${p.name}</strong>`;
      if (p.google_maps_url) {
        popupContent += `<br><a href="${p.google_maps_url}" target="_blank">Google Maps</a>`;
      }

      L.marker([p.lat, p.lng], { icon: emojiIcon })
        .bindPopup(popupContent)
        .addTo(map);
    });

    // Geolocation "Find my location" button
    if ('geolocation' in navigator) {
      const GpsControl = L.Control.extend({
        options: { position: 'topleft' as L.ControlPosition },
        onAdd() {
          const container = L.DomUtil.create('div', 'map-gps-icon');
          const button = L.DomUtil.create('button', 'custom-button', container);
          button.innerHTML = '<span class="custom-icon">📍</span>';
          L.DomEvent.on(button, 'click', () => {
            navigator.geolocation.getCurrentPosition((pos) => {
              const latlng = L.latLng(pos.coords.latitude, pos.coords.longitude);
              L.marker(latlng).addTo(map);
              map.panTo(latlng);
              window.BikeApp?.tE?.('Find my Location in Map');
            });
          });
          return container;
        },
      });
      new GpsControl().addTo(map);
    }
  }
</script>
