---
// src/components/BigMap.astro

interface RouteOnMap {
  url: string;
  name: string;
  polyline: string;
  distance_km: number;
  photo_key?: string;
}

interface PlaceOnMap {
  name: string;
  category: string;
  emoji: string;
  lat: number;
  lng: number;
  google_maps_url?: string;
  address?: string;
  phone?: string;
  photo_key?: string;
  link?: string;
}

interface MapPhoto {
  key: string;
  lat: number;
  lng: number;
  caption?: string;
  width?: number;
  height?: number;
  routeName?: string;
  routeUrl?: string;
  index: number;
}

interface Props {
  routes: RouteOnMap[];
  places: PlaceOnMap[];
  photos?: MapPhoto[];
  center: [number, number];
}

import { getCityConfig } from '../lib/config/city-config';
const { routes, places, photos = [], center } = Astro.props;
---

<div class="big-map">
  <div
    id="big-map"
    style="width: 100%; height: 100%;"
    data-routes={JSON.stringify(routes)}
    data-places={JSON.stringify(places)}
    data-center={JSON.stringify(center)}
    data-photos={JSON.stringify(photos)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
  ></div>
  <div id="big-map-controls"></div>
</div>

<script>
  import { initMap, addPolylines, addMarkers, addPhotoMarkers, showUserLocation, hideUserLocation, setPhotoLayersVisible, setPlaceMarkersVisible } from '../lib/maps/map-init';
  import { buildPlacePopup, html, raw, filterMapByCategory } from '../lib/maps/map-helpers';
  import { buildImageUrl } from '../lib/media/image-service';
  import { loadStylePreference, getStyleUrl, switchStyle, type MapStyleKey } from '../lib/maps/map-style-switch';
  import { render, h } from 'preact';
  import MapControls, { loadToggleState } from './admin/MapControls';

  const el = document.getElementById('big-map');
  const controlsEl = document.getElementById('big-map-controls');
  if (el) {
    const allRoutes = JSON.parse(el.dataset.routes || '[]');
    const allPlaces = JSON.parse(el.dataset.places || '[]');
    const allPhotos = JSON.parse(el.dataset.photos || '[]');
    const center = JSON.parse(el.dataset.center || '[0, 0]');
    const cdnUrl = el.dataset.cdnUrl || '';

    // --- Category filter from URL query param ---
    const categoryFilter = new URLSearchParams(location.search).get('category');

    let places = allPlaces;
    let routes = allRoutes;
    let photos = allPhotos;

    if (categoryFilter) {
      const filtered = filterMapByCategory(allPlaces, allRoutes, categoryFilter);
      places = filtered.places;
      routes = filtered.routes;
      photos = [];
    }

    const styleKey = loadStylePreference();
    const map = initMap({ el, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

    const placeData = places.map((p: any) => ({
      lat: p.lat, lng: p.lng, emoji: p.emoji,
      popup: buildPlacePopup(p, cdnUrl),
    }));

    function setupWebGLLayers(sk: MapStyleKey) {
      addPolylines(map, routes.map((r: any) => {
        const photoHtml = r.photo_key && cdnUrl
          ? html`<a href="${r.url}"><img class="place-popup-photo" src="${raw(buildImageUrl(cdnUrl, r.photo_key, { width: 280, height: 160, fit: 'cover' }))}" alt="" /></a>`
          : '';
        return {
          encoded: r.polyline,
          popup: html`<div class="place-popup">${raw(photoHtml)}<a href="${r.url}">${r.name}</a><br>${r.distance_km} km</div>`,
        };
      }), sk);

      if (photos.length > 0) {
        addPhotoMarkers(map, photos, cdnUrl, sk);
      }

      addMarkers(map, placeData);
    }

    map.on('load', () => {
      setupWebGLLayers(styleKey);

      // Hide photos by default on the big map (unless user previously enabled them)
      if (!loadToggleState('map-photos', false)) {
        setPhotoLayersVisible(map, false);
      }

      // Render MapControls island
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: photos.length > 0,
          hasPlaces: places.length > 0,
          defaultPhotos: false,
          onTogglePhotos: (v: boolean) => setPhotoLayersVisible(map, v),
          onTogglePlaces: (v: boolean) => setPlaceMarkersVisible(map, v),
          onToggleGps: (v: boolean) => {
            if (v) showUserLocation(map);
            else hideUserLocation();
          },
          onToggleStyle: (key: MapStyleKey) => switchStyle(map, key, () => {
            setupWebGLLayers(key);
            setPhotoLayersVisible(map, loadToggleState('map-photos', false));
            setPlaceMarkersVisible(map, loadToggleState('map-places', true));
          }),
        }), controlsEl);
      }
    });
  }
</script>
