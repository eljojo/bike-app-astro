---
// src/components/BigMap.astro

interface RouteOnMap {
  url: string;
  name: string;
  polyline: string;
  distance_km: number;
  photo_key?: string;
}

interface Props {
  routes: RouteOnMap[];
  center: [number, number];
  hasPaths?: boolean;
  routesLabel?: string;
  pathsLabel?: string;
}

import { getCityConfig } from '../lib/config/city-config';
import './SubTabToggle.scss';
const { routes, center, hasPaths = false, routesLabel, pathsLabel } = Astro.props;
---

<div class="big-map">
  {hasPaths && routesLabel && pathsLabel && (
    <div class="sub-tab-toggle map-layer-toggle" id="map-layer-toggle">
      <button type="button" class="sub-tab-btn active" data-map-view="routes">{routesLabel}</button>
      <button type="button" class="sub-tab-btn" data-map-view="paths">{pathsLabel}</button>
    </div>
  )}
  <div
    id="big-map"
    role="img"
    aria-label="Interactive map"
    style="width: 100%; height: 100%;"
    data-routes={JSON.stringify(routes)}
    data-center={JSON.stringify(center)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
    data-has-paths={hasPaths ? 'true' : ''}
  ></div>
  <div id="big-map-controls"></div>
  {import.meta.env.DEV && (
    <div id="map-tuning" style="display:none; position:absolute; bottom:30px; left:10px; z-index:3; background:rgba(255,255,255,0.95); border-radius:6px; padding:8px 14px; box-shadow:0 2px 8px rgba(0,0,0,0.15); font:12px/1.4 sans-serif; width:260px;">
      <div style="font-weight:600; margin-bottom:8px; padding-bottom:4px; border-bottom:1px solid #ddd;">Base map (tile cycling infra)</div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between;"><span>Opacity</span><span id="t-base-opacity-val">0.30</span></label>
        <input type="range" id="t-base-opacity" min="0" max="100" value="30" style="width:100%;">
      </div>
      <div style="font-weight:600; margin:10px 0 8px; padding-bottom:4px; border-bottom:1px solid #ddd;">Foreground paths (overlay)</div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between;"><span>Interactive width</span><span id="t-fg-width-val">4.0</span></label>
        <input type="range" id="t-fg-width" min="10" max="100" value="40" style="width:100%;">
      </div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between;"><span>Interactive opacity</span><span id="t-fg-opacity-val">0.80</span></label>
        <input type="range" id="t-fg-opacity" min="0" max="100" value="80" style="width:100%;">
      </div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between;"><span>Other width</span><span id="t-bg-width-val">2.5</span></label>
        <input type="range" id="t-bg-width" min="5" max="80" value="25" style="width:100%;">
      </div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between;"><span>Other opacity</span><span id="t-bg-opacity-val">0.10</span></label>
        <input type="range" id="t-bg-opacity" min="0" max="100" value="10" style="width:100%;">
      </div>
      <div style="font-weight:600; margin:10px 0 8px; padding-bottom:4px; border-bottom:1px solid #ddd;">Color</div>
      <div style="margin-bottom:6px;">
        <label style="display:flex; justify-content:space-between; align-items:center;"><span>Path overlay</span><input type="color" id="t-path-color" value="#350091" style="width:40px; height:22px; border:1px solid #ccc; border-radius:3px; padding:0;"></label>
      </div>
      <div style="margin-top:10px; padding-top:6px; border-top:1px solid #ddd;">
        <button type="button" id="t-log-values" style="font-size:11px; padding:3px 8px; border:1px solid #ccc; border-radius:3px; background:#f5f5f5; cursor:pointer;">Log current values</button>
      </div>
    </div>
  )}
</div>

<script>
  import { createMapSession, createPolylineLayer, createPhotoLayer, createPlaceLayer, createTilePathLayer, createGpsLayer } from '../lib/maps/layers';
  import { html, raw, buildPathCardContent } from '../lib/maps/map-helpers';
  import { createMapPathCard, type MapPathCardHandle } from '../lib/maps/map-path-card';
  import { setupPathHighlight, type PathHighlightHandle } from '../lib/maps/path-highlight';
  import type { Segment } from '../lib/maps/tile-types';
  import { buildImageUrl } from '../lib/media/image-service';
  import { muteBaseCyclingLayers, restoreBaseCyclingLayers } from '../lib/maps/base-layer-control';
  import { createMtbFilter } from '../lib/maps/map-mtb-toggle';
  import { render, h } from 'preact';
  import MapControls, { loadToggleState, saveToggleState } from './admin/MapControls';

  const el = document.getElementById('big-map');
  const controlsEl = document.getElementById('big-map-controls');
  if (el) {
    const routes = JSON.parse(el.dataset.routes || '[]');
    const center = JSON.parse(el.dataset.center || '[0, 0]');
    const cdnUrl = el.dataset.cdnUrl || '';
    const hasPaths = el.dataset.hasPaths === 'true';

    // Sub-tab toggle
    const toggleEl = document.getElementById('map-layer-toggle');
    const routesBtn = toggleEl?.querySelector('[data-map-view="routes"]');
    const pathsBtn = toggleEl?.querySelector('[data-map-view="paths"]');
    const hashWantsPaths = location.hash === '#paths';
    const savedPathsState = loadToggleState('map-paths', false);
    const initialShowPaths = hasPaths && (hashWantsPaths || savedPathsState);

    function updateToggleUI(showingPaths: boolean) {
      if (!routesBtn || !pathsBtn) return;
      routesBtn.classList.toggle('active', !showingPaths);
      pathsBtn.classList.toggle('active', showingPaths);
    }
    if (initialShowPaths) {
      updateToggleUI(true);
      // Set "Ride" nav link to match initial paths state
      const rideLink = document.querySelector<HTMLAnchorElement>('[data-nav-ride]');
      if (rideLink) rideLink.href = '/bike-paths';
    }

    const polylineData = routes.map((r: any) => {
      const photoHtml = r.photo_key && cdnUrl
        ? html`<a href="${r.url}"><img class="place-popup-photo" src="${raw(buildImageUrl(cdnUrl, r.photo_key, { width: 280, height: 160, fit: 'cover' }))}" alt="" /></a>`
        : '';
      return {
        encoded: r.polyline,
        popup: html`<div class="place-popup">${raw(photoHtml)}<a href="${r.url}">${r.name}</a><br>${r.distance_km} km</div>`,
      };
    });

    // Category filter from URL param (e.g. /map/?category=cafe)
    const categoryFilter = new URLSearchParams(location.search).get('category') || undefined;

    const polylineLayer = createPolylineLayer({ polylines: polylineData });
    const photoLayer = createPhotoLayer({ cdnUrl, defaultVisible: false });
    const placeLayer = createPlaceLayer({ cdnUrl, categoryFilter });
    const gpsLayer = createGpsLayer();

    // Tile path layer (lazy-load manifest eagerly)
    const manifestPromise = hasPaths
      ? fetch('/bike-paths/geo/tiles/manifest.json').then(r => r.ok ? r.json() : []).catch(() => [])
      : Promise.resolve([]);

    // --- Path card + highlight (only when the paths tab is active) ---
    //
    // Clicks on path features route through `onPathClick` to the
    // shared card flow instead of opening a MapLibre popup. Matches
    // the paths-browse-map (bike paths index) behavior: lock the
    // highlight, show a floating card at the bottom. Difference: we
    // deliberately do NOT fitBounds — the user keeps the view they
    // had so the whole map stays visible behind the card.
    let _highlightHandle: PathHighlightHandle | null = null;
    let _pathCard: MapPathCardHandle | null = null;

    function showCardForSlug(slug: string, segment?: Segment) {
      if (!_pathCard || !_highlightHandle) return;
      // Toggle off when clicking the already-locked path.
      if (_highlightHandle.lockedSlug() === slug) {
        _highlightHandle.unlock();
        return;
      }
      const features = tilePathLayer.queryFeaturesBySlug(slug);
      if (features.length === 0) return;
      // BigMap has no server-provided slugInfo, so we build from
      // tile feature properties. URL construction mirrors the fallback
      // branch in tile-path-interactions.ts.
      const props = features[0]?.properties || {};
      const featureName = (props.name as string) || slug;
      const memberOf = (props.memberOf as string) || '';
      let pathUrl = '';
      if (slug && (props.hasPage === true || props.hasPage === 'true')) {
        pathUrl = memberOf ? `/bike-paths/${memberOf}/${slug}` : `/bike-paths/${slug}`;
      } else if (memberOf) {
        pathUrl = `/bike-paths/${memberOf}`;
      }
      const cardHtml = buildPathCardContent({
        name: featureName,
        url: pathUrl || undefined,
        length_km: props.length_km ? Number(props.length_km) : undefined,
        surface: (props.surface as string) || undefined,
        path_type: (props.path_type as string) || undefined,
        segment,
      });
      _highlightHandle.lock(slug);
      _pathCard.show(cardHtml);
      // Deliberately no fitBounds — the map keeps its current view.
    }

    const tilePathLayer = createTilePathLayer({
      manifestPromise,
      fetchPath: '/bike-paths/geo/tiles/',
      foreground: true,
      onPathClick: (slug, segment) => { showCardForSlug(slug, segment); },
    });

    const session = createMapSession({ el, center, zoom: 11, fitBounds: false })
      .use(polylineLayer)
      .use(photoLayer)
      .use(placeLayer)
      .use(gpsLayer);

    if (hasPaths) session.use(tilePathLayer);

    const { map } = session;
    let pathsVisible = initialShowPaths;
    const mtbFilter = hasPaths ? createMtbFilter(map) : null;

    // Create the card eagerly when paths are available — the DOM
    // element sits hidden until a click shows it. Lives in #big-map
    // so `.big-map` can be the outside-click scope: clicks anywhere
    // outside the map container dismiss the card, clicks on the map
    // or card itself do not.
    if (hasPaths) {
      _pathCard = createMapPathCard({
        container: el,
        outsideClickScope: '.big-map',
        onClose: () => { _highlightHandle?.unlock(); },
      });
    }

    session.start(() => {
      // Photos off by default on big map (unless user previously enabled)
      if (!loadToggleState('map-photos', false)) {
        photoLayer.setVisible!(map, false);
      }

      // If initial state wants paths, show them and hide routes
      if (initialShowPaths) {
        polylineLayer.setVisible!(map, false);
        muteBaseCyclingLayers(map);
      } else if (hasPaths) {
        tilePathLayer.setVisible!(map, false);
      }

      // Wire the highlight lock after tile path layers are registered
      // (session.start waits for tilePathLayer.setup). The `listSelector`
      // matches nothing — BigMap has no sidebar list to hover-sync with;
      // only the programmatic lock() call is used here.
      if (hasPaths) {
        _highlightHandle = setupPathHighlight(map, {
          listSelector: '.big-map-has-no-list',
          layerIds: ['paths-network-line', 'paths-network-line-gravel', 'paths-network-line-mtb'],
          queryFeatures: (slug) => tilePathLayer.queryFeaturesBySlug(slug),
          onLockChange: (locked) => {
            if (!locked) _pathCard?.hide();
          },
        });
      }
    });

    // Controls — render on map.on('load'), not session.start().
    // session.start() waits for tile loading (slow); controls don't need tiles.
    function renderControls() {
      if (!controlsEl) return;
      render(h(MapControls, {
        hasPhotos: true,
        hasPlaces: true,
        hasMtbToggle: pathsVisible,
        defaultPhotos: false,
        onTogglePhotos: (v: boolean) => photoLayer.setVisible!(map, v),
        onTogglePlaces: (v: boolean) => placeLayer.setVisible!(map, v),
        onToggleGps: (v: boolean) => gpsLayer.setVisible!(map, v),
        onToggleMtb: mtbFilter ? (v: boolean) => mtbFilter.setVisible(v) : undefined,
        onToggleStyle: (key) => session.switchStyle(key, () => {
          photoLayer.setVisible!(map, loadToggleState('map-photos', false));
          placeLayer.setVisible!(map, loadToggleState('map-places', false));
          // Preserve current view mode after style switch
          if (pathsVisible) {
            polylineLayer.setVisible!(map, false);
            muteBaseCyclingLayers(map);
          } else if (hasPaths) {
            tilePathLayer.setVisible!(map, false);
          }
        }),
      }), controlsEl);
    }

    map.on('load', renderControls);

    // Dev tuning panel — dynamic import, tree-shaken in production
    let showTuning = (_show: boolean) => {};
    if (import.meta.env.DEV) {
      const { initDevTuningPanel } = await import('../lib/maps/dev-tuning-panel');
      showTuning = initDevTuningPanel(map);
      if (initialShowPaths) showTuning(true);
    }

    // Sub-tab toggle
    function switchToView(view: 'routes' | 'paths') {
      const showingPaths = view === 'paths';
      pathsVisible = showingPaths;
      updateToggleUI(showingPaths);
      saveToggleState('map-paths', showingPaths);
      history.replaceState(null, '', showingPaths ? '#paths' : location.pathname);

      // Update "Ride" nav link to match the active tab
      const rideLink = document.querySelector<HTMLAnchorElement>('[data-nav-ride]');
      if (rideLink) {
        rideLink.href = showingPaths ? '/bike-paths' : '/routes';
      }

      if (showingPaths) {
        tilePathLayer.setVisible!(map, true);
        polylineLayer.setVisible!(map, false);
        muteBaseCyclingLayers(map);
        showTuning(true);
      } else {
        tilePathLayer.setVisible!(map, false);
        polylineLayer.setVisible!(map, true);
        restoreBaseCyclingLayers(map);
        showTuning(false);
        // Dismiss any locked path when leaving the paths tab so the
        // card doesn't linger over the routes view.
        _highlightHandle?.unlock();
      }
      renderControls();
    }

    if (toggleEl) {
      toggleEl.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-map-view]') as HTMLElement | null;
        if (!btn) return;
        switchToView(btn.dataset.mapView as 'routes' | 'paths');
      });
    }
  }
</script>
