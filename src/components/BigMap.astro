---
// src/components/BigMap.astro

interface RouteOnMap {
  url: string;
  name: string;
  polyline: string;
  distance_km: number;
  photo_key?: string;
}

interface Props {
  routes: RouteOnMap[];
  center: [number, number];
  hasPaths?: boolean;
  routesLabel?: string;
  pathsLabel?: string;
}

import { getCityConfig } from '../lib/config/city-config';
import './SubTabToggle.scss';
const { routes, center, hasPaths = false, routesLabel, pathsLabel } = Astro.props;
---

<div class="big-map">
  {hasPaths && routesLabel && pathsLabel && (
    <div class="sub-tab-toggle map-layer-toggle" id="map-layer-toggle">
      <button type="button" class="sub-tab-btn active" data-map-view="routes">{routesLabel}</button>
      <button type="button" class="sub-tab-btn" data-map-view="paths">{pathsLabel}</button>
    </div>
  )}
  <div
    id="big-map"
    style="width: 100%; height: 100%;"
    data-routes={JSON.stringify(routes)}
    data-center={JSON.stringify(center)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
    data-has-paths={hasPaths ? 'true' : ''}
  ></div>
  <div id="big-map-controls"></div>
</div>

<script>
  import { createMapSession, createPolylineLayer, createPhotoLayer, createPlaceLayer, createTilePathLayer, createGpsLayer } from '../lib/maps/layers';
  import { html, raw } from '../lib/maps/map-helpers';
  import { buildImageUrl } from '../lib/media/image-service';
  import { render, h } from 'preact';
  import MapControls, { loadToggleState, saveToggleState } from './admin/MapControls';

  const el = document.getElementById('big-map');
  const controlsEl = document.getElementById('big-map-controls');
  if (el) {
    const routes = JSON.parse(el.dataset.routes || '[]');
    const center = JSON.parse(el.dataset.center || '[0, 0]');
    const cdnUrl = el.dataset.cdnUrl || '';
    const hasPaths = el.dataset.hasPaths === 'true';

    // Sub-tab toggle
    const toggleEl = document.getElementById('map-layer-toggle');
    const routesBtn = toggleEl?.querySelector('[data-map-view="routes"]');
    const pathsBtn = toggleEl?.querySelector('[data-map-view="paths"]');
    const hashWantsPaths = location.hash === '#paths';
    const savedPathsState = loadToggleState('map-paths', false);
    const initialShowPaths = hasPaths && (hashWantsPaths || savedPathsState);

    function updateToggleUI(showingPaths: boolean) {
      if (!routesBtn || !pathsBtn) return;
      routesBtn.classList.toggle('active', !showingPaths);
      pathsBtn.classList.toggle('active', showingPaths);
    }
    if (initialShowPaths) {
      updateToggleUI(true);
      // Set "Ride" nav link to match initial paths state
      const rideLink = document.querySelector<HTMLAnchorElement>('[data-nav-ride]');
      if (rideLink) rideLink.href = '/bike-paths';
    }

    const polylineData = routes.map((r: any) => {
      const photoHtml = r.photo_key && cdnUrl
        ? html`<a href="${r.url}"><img class="place-popup-photo" src="${raw(buildImageUrl(cdnUrl, r.photo_key, { width: 280, height: 160, fit: 'cover' }))}" alt="" /></a>`
        : '';
      return {
        encoded: r.polyline,
        popup: html`<div class="place-popup">${raw(photoHtml)}<a href="${r.url}">${r.name}</a><br>${r.distance_km} km</div>`,
      };
    });

    // Category filter from URL param (e.g. /map/?category=cafe)
    const categoryFilter = new URLSearchParams(location.search).get('category') || undefined;

    const polylineLayer = createPolylineLayer({ polylines: polylineData });
    const photoLayer = createPhotoLayer({ cdnUrl, defaultVisible: false });
    const placeLayer = createPlaceLayer({ cdnUrl, categoryFilter });
    const gpsLayer = createGpsLayer();

    // Tile path layer (lazy-load manifest eagerly)
    const manifestPromise = hasPaths
      ? fetch('/bike-paths/geo/tiles/manifest.json').then(r => r.ok ? r.json() : []).catch(() => [])
      : Promise.resolve([]);
    const tilePathLayer = createTilePathLayer({
      manifestPromise,
      fetchPath: '/bike-paths/geo/tiles/',
    });

    const session = createMapSession({ el, center, zoom: 11, fitBounds: false })
      .use(polylineLayer)
      .use(photoLayer)
      .use(placeLayer)
      .use(gpsLayer);

    if (hasPaths) session.use(tilePathLayer);

    const { map } = session;
    let pathsVisible = initialShowPaths;

    session.start(() => {
      // Photos off by default on big map (unless user previously enabled)
      if (!loadToggleState('map-photos', false)) {
        photoLayer.setVisible!(map, false);
      }

      // If initial state wants paths, show them and hide routes
      if (initialShowPaths) {
        polylineLayer.setVisible!(map, false);
      } else if (hasPaths) {
        tilePathLayer.setVisible!(map, false);
      }
    });

    // Controls — render on map.on('load'), not session.start().
    // session.start() waits for tile loading (slow); controls don't need tiles.
    map.on('load', () => {
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: true,
          hasPlaces: true,
          defaultPhotos: false,
          onTogglePhotos: (v: boolean) => photoLayer.setVisible!(map, v),
          onTogglePlaces: (v: boolean) => placeLayer.setVisible!(map, v),
          onToggleGps: (v: boolean) => gpsLayer.setVisible!(map, v),
          onToggleStyle: (key) => session.switchStyle(key, () => {
            photoLayer.setVisible!(map, loadToggleState('map-photos', false));
            placeLayer.setVisible!(map, loadToggleState('map-places', false));
            // Preserve current view mode after style switch
            if (pathsVisible) {
              polylineLayer.setVisible!(map, false);
            } else if (hasPaths) {
              tilePathLayer.setVisible!(map, false);
            }
          }),
        }), controlsEl);
      }
    });

    // Sub-tab toggle
    function switchToView(view: 'routes' | 'paths') {
      const showingPaths = view === 'paths';
      pathsVisible = showingPaths;
      updateToggleUI(showingPaths);
      saveToggleState('map-paths', showingPaths);
      history.replaceState(null, '', showingPaths ? '#paths' : location.pathname);

      // Update "Ride" nav link to match the active tab
      const rideLink = document.querySelector<HTMLAnchorElement>('[data-nav-ride]');
      if (rideLink) {
        rideLink.href = showingPaths ? '/bike-paths' : '/routes';
      }

      if (showingPaths) {
        tilePathLayer.setVisible!(map, true);
        polylineLayer.setVisible!(map, false);
      } else {
        tilePathLayer.setVisible!(map, false);
        polylineLayer.setVisible!(map, true);
      }
    }

    if (toggleEl) {
      toggleEl.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-map-view]') as HTMLElement | null;
        if (!btn) return;
        switchToView(btn.dataset.mapView as 'routes' | 'paths');
      });
    }
  }
</script>
