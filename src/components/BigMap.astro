---
// src/components/BigMap.astro

interface RouteOnMap {
  url: string;
  name: string;
  polyline: string;
  distance_km: number;
  photo_key?: string;
}

interface PlaceOnMap {
  name: string;
  category: string;
  emoji: string;
  lat: number;
  lng: number;
  google_maps_url?: string;
  address?: string;
  phone?: string;
  photo_key?: string;
  link?: string;
}

interface MapPhoto {
  key: string;
  lat: number;
  lng: number;
  caption?: string;
  width?: number;
  height?: number;
  routeName?: string;
  routeUrl?: string;
  index: number;
}

interface PathOnMap {
  relId: string;
  slug: string;
  name: string;
  hasPage: boolean;
  operator?: string;
  surface?: string;
}

interface Props {
  routes: RouteOnMap[];
  places: PlaceOnMap[];
  photos?: MapPhoto[];
  center: [number, number];
  pathGeoFiles?: string[];
  pathMapData?: PathOnMap[];
}

import { getCityConfig } from '../lib/config/city-config';
const { routes, places, photos = [], center, pathGeoFiles = [], pathMapData = [] } = Astro.props;
---

<div class="big-map">
  <div
    id="big-map"
    style="width: 100%; height: 100%;"
    data-routes={JSON.stringify(routes)}
    data-places={JSON.stringify(places)}
    data-center={JSON.stringify(center)}
    data-photos={JSON.stringify(photos)}
    data-cdn-url={import.meta.env.R2_PUBLIC_URL || getCityConfig().cdn_url}
    data-path-geo-files={JSON.stringify(pathGeoFiles)}
    data-path-map-data={JSON.stringify(pathMapData)}
  ></div>
  <div id="big-map-controls"></div>
</div>

<script>
  import { initMap, addPolylines, addMarkers, addPhotoMarkers, showUserLocation, hideUserLocation, setPhotoLayersVisible, setPlaceMarkersVisible, ROUTE_LINE_WIDTH } from '../lib/maps/map-init';
  import { buildPlacePopup, html, raw, filterMapByCategory } from '../lib/maps/map-helpers';
  import { buildImageUrl } from '../lib/media/image-service';
  import { loadStylePreference, getStyleUrl, switchStyle, type MapStyleKey } from '../lib/maps/map-style-switch';
  import { render, h } from 'preact';
  import MapControls, { loadToggleState } from './admin/MapControls';
  import maplibregl from 'maplibre-gl';

  const PATH_COLOR = '#0077BB'; // Distinct from route colour (#350091) but same visual weight

  interface PathFeatureProps {
    slug: string;
    name: string;
    surface: string;
    hasPage: 'true' | '';
    interactive: 'true' | '';
    relId: string;
  }

  const el = document.getElementById('big-map');
  const controlsEl = document.getElementById('big-map-controls');
  if (el) {
    const allRoutes = JSON.parse(el.dataset.routes || '[]');
    const allPlaces = JSON.parse(el.dataset.places || '[]');
    const allPhotos = JSON.parse(el.dataset.photos || '[]');
    const center = JSON.parse(el.dataset.center || '[0, 0]');
    const cdnUrl = el.dataset.cdnUrl || '';
    const pathGeoFiles: string[] = JSON.parse(el.dataset.pathGeoFiles || '[]');
    const pathMapData: Array<{ relId: string; slug: string; name: string; interactive: boolean; surface?: string }> =
      JSON.parse(el.dataset.pathMapData || '[]');

    // --- Category filter from URL query param ---
    const categoryFilter = new URLSearchParams(location.search).get('category');

    let places = allPlaces;
    let routes = allRoutes;
    let photos = allPhotos;

    if (categoryFilter) {
      const filtered = filterMapByCategory(allPlaces, allRoutes, categoryFilter);
      places = filtered.places;
      routes = filtered.routes;
      photos = [];
    }

    const styleKey = loadStylePreference();
    const map = initMap({ el, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

    const placeData = places.map((p: any) => ({
      lat: p.lat, lng: p.lng, emoji: p.emoji,
      popup: buildPlacePopup(p, cdnUrl),
    }));

    // --- Bike paths layer ---
    const pathInfoByRelId = new Map(pathMapData.map(p => [p.relId, p]));

    let pathFeaturesCache: GeoJSON.Feature[] | null = null;

    async function loadPathFeatures(): Promise<GeoJSON.Feature[]> {
      if (pathFeaturesCache) return pathFeaturesCache;
      const allFeatures: GeoJSON.Feature[] = [];
      for (const file of pathGeoFiles) {
        try {
          const res = await fetch(`/paths/geo/${file}`);
          if (!res.ok) continue;
          const geojson = await res.json();
          const relationId = file.replace(/\.geojson$/, '');
          const info = pathInfoByRelId.get(relationId);

          for (const feature of geojson.features) {
            feature.properties = feature.properties || {};
            feature.properties.slug = info?.slug || '';
            feature.properties.name = info?.name || '';
            feature.properties.surface = info?.surface || '';
            feature.properties.hasPage = info?.hasPage ? 'true' : '';
            feature.properties.interactive = info?.interactive ? 'true' : '';
            feature.properties.relId = relationId;
            allFeatures.push(feature);
          }
        } catch { /* skip missing files */ }
      }
      pathFeaturesCache = allFeatures;
      return allFeatures;
    }

    function setupPathsLayer(features: GeoJSON.Feature[]) {
      // Remove existing paths layer/source if present (for style switch replay)
      const style = map.getStyle();
      if (style?.layers) {
        for (const layer of style.layers) {
          if ('source' in layer && layer.source === 'paths-network' && map.getLayer(layer.id)) {
            map.removeLayer(layer.id);
          }
        }
      }
      if (map.getSource('paths-network')) {
        map.removeSource('paths-network');
      }

      if (features.length === 0) return;

      map.addSource('paths-network', {
        type: 'geojson',
        data: { type: 'FeatureCollection', features },
      });

      // Non-interactive paths: thinner, no popup, no cursor change
      map.addLayer({
        id: 'paths-network-bg',
        type: 'line',
        source: 'paths-network',
        filter: ['!=', ['get', 'interactive'], 'true'],
        layout: {
          'line-cap': 'round',
          'line-join': 'round',
          'visibility': 'none',
        },
        paint: {
          'line-color': PATH_COLOR,
          'line-width': Math.max(1, ROUTE_LINE_WIDTH - 2),
          'line-opacity': 0.5,
        },
      });

      // Interactive paths: normal width, clickable
      map.addLayer({
        id: 'paths-network-line',
        type: 'line',
        source: 'paths-network',
        filter: ['==', ['get', 'interactive'], 'true'],
        layout: {
          'line-cap': 'round',
          'line-join': 'round',
          'visibility': 'none',
        },
        paint: {
          'line-color': PATH_COLOR,
          'line-width': ROUTE_LINE_WIDTH,
          'line-opacity': 0.8,
        },
      });

      // Click popup on interactive paths only
      function esc(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      map.on('click', 'paths-network-line', (e) => {
        if (!e.features?.length) return;
        const props = e.features[0].properties as PathFeatureProps;
        const name = esc(props.name);
        let nameLink: string;
        if (props.hasPage === 'true' && props.slug) {
          nameLink = `<a href="/paths/${esc(props.slug)}">${name}</a>`;
        } else if (props.relId && /^\d+$/.test(props.relId)) {
          nameLink = `${name} <a href="https://openstreetmap.org/relation/${esc(props.relId)}" target="_blank" rel="noopener">OSM ↗</a>`;
        } else {
          nameLink = name;
        }
        const surfaceInfo = props.surface ? `<br>${esc(props.surface)}` : '';
        new maplibregl.Popup()
          .setLngLat(e.lngLat)
          .setHTML(`<div class="place-popup">${nameLink}${surfaceInfo}</div>`)
          .addTo(map);
      });
      map.on('mouseenter', 'paths-network-line', () => { map.getCanvas().style.cursor = 'pointer'; });
      map.on('mouseleave', 'paths-network-line', () => { map.getCanvas().style.cursor = ''; });
    }

    function setPathsVisible(visible: boolean) {
      const vis = visible ? 'visible' : 'none';
      if (map.getLayer('paths-network-bg')) {
        map.setLayoutProperty('paths-network-bg', 'visibility', vis);
      }
      if (map.getLayer('paths-network-line')) {
        map.setLayoutProperty('paths-network-line', 'visibility', vis);
      }
    }

    function setRoutePolylinesVisible(visible: boolean) {
      const vis = visible ? 'visible' : 'none';
      for (const layer of map.getStyle()?.layers ?? []) {
        if ('source' in layer && layer.source === 'route-polylines') {
          map.setLayoutProperty(layer.id, 'visibility', vis);
        }
      }
    }

    function setupWebGLLayers(sk: MapStyleKey) {
      addPolylines(map, routes.map((r: any) => {
        const photoHtml = r.photo_key && cdnUrl
          ? html`<a href="${r.url}"><img class="place-popup-photo" src="${raw(buildImageUrl(cdnUrl, r.photo_key, { width: 280, height: 160, fit: 'cover' }))}" alt="" /></a>`
          : '';
        return {
          encoded: r.polyline,
          popup: html`<div class="place-popup">${raw(photoHtml)}<a href="${r.url}">${r.name}</a><br>${r.distance_km} km</div>`,
        };
      }), sk);

      if (photos.length > 0) {
        addPhotoMarkers(map, photos, cdnUrl, sk);
      }

      addMarkers(map, placeData);

      // Replay paths layer after style switch
      if (pathFeaturesCache) {
        setupPathsLayer(pathFeaturesCache);
      }
    }

    map.on('load', async () => {
      setupWebGLLayers(styleKey);

      // Hide photos by default on the big map (unless user previously enabled them)
      if (!loadToggleState('map-photos', false)) {
        setPhotoLayersVisible(map, false);
      }

      // Pre-load paths layer (hidden) so toggling is instant
      const hasPaths = pathGeoFiles.length > 0;
      if (hasPaths) {
        const features = await loadPathFeatures();
        setupPathsLayer(features);
        // If user had paths mode saved, apply it now
        const savedPathsState = loadToggleState('map-paths', false);
        if (savedPathsState) {
          setPathsVisible(true);
          setRoutePolylinesVisible(false);
        }
      }

      // Render MapControls island
      if (controlsEl) {
        render(h(MapControls, {
          hasPhotos: photos.length > 0,
          hasPlaces: places.length > 0,
          hasPaths,
          defaultPhotos: false,
          onTogglePhotos: (v: boolean) => setPhotoLayersVisible(map, v),
          onTogglePlaces: (v: boolean) => setPlaceMarkersVisible(map, v),
          onTogglePaths: (v: boolean) => {
            setPathsVisible(v);
            setRoutePolylinesVisible(!v);
          },
          onToggleGps: (v: boolean) => {
            if (v) showUserLocation(map);
            else hideUserLocation();
          },
          onToggleStyle: (key: MapStyleKey) => switchStyle(map, key, () => {
            setupWebGLLayers(key);
            setPhotoLayersVisible(map, loadToggleState('map-photos', false));
            setPlaceMarkersVisible(map, loadToggleState('map-places', true));
            // Restore paths visibility after style switch
            const pathsOn = loadToggleState('map-paths', false);
            if (pathsOn) {
              setPathsVisible(true);
              setRoutePolylinesVisible(false);
            }
          }),
        }), controlsEl);
      }
    });
  }
</script>
