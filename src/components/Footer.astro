---
// src/components/Footer.astro
import { t, localePath } from '../i18n';
import { supportedLocales, defaultLocale } from '../lib/locale-utils';
import { switchLocalePath as computeSwitchPath } from '../lib/locale-switcher';
import { getCityConfig, isBlogInstance, isClubInstance } from '../lib/city-config';

interface Props {
  alternateUrls?: Record<string, string>;
}

const { alternateUrls } = Astro.props;
const locale = Astro.currentLocale || defaultLocale();
const locales = supportedLocales();
const showSwitcher = locales.length > 1;

const otherLocale = locales.find(l => l !== locale) || locales[0];
const switchPath = computeSwitchPath(Astro.url.pathname, locale, otherLocale, alternateUrls?.[otherLocale]);
const blog = isBlogInstance();
const club = isClubInstance();
const config = (blog || club) ? getCityConfig() : null;
---
<footer class="site-footer">
  {blog && config?.author?.name ? (
    <a href={localePath('/about', locale)}>
      {config.display_name} is curated by {config.author.name}
    </a>
  ) : club && config ? (
    <a href={localePath('/about', locale)}>
      {config.display_name}
      {config.acp_club_code && <span class="footer-acp"> &middot; ACP {config.acp_club_code}</span>}
    </a>
  ) : !blog && !club ? (
    <a href={localePath('/about', locale)}>
      {t('footer.community', locale)}
    </a>
  ) : null}
  <a href="https://whereto.bike" class="powered-by" target="_blank" rel="noopener">
    {t('footer.powered_by', locale)}
  </a>
  {showSwitcher && (
    <a href={switchPath} class="lang-switcher"
       data-locale={otherLocale}>
      {t('lang.switch', locale)}
    </a>
  )}
</footer>
