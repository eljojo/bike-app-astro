---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  name: string;
  weight?: 'regular' | 'fill' | 'bold' | 'duotone' | 'light' | 'thin';
  size?: number;
  class?: string;
}

const { name, weight = 'regular', size = 24, class: className } = Astro.props;

const filename = weight === 'regular' ? `${name}.svg` : `${name}-${weight}.svg`;
const svgPath = path.join(
  process.cwd(),
  'node_modules',
  '@phosphor-icons',
  'core',
  'assets',
  weight,
  filename,
);

const svgContent = fs.readFileSync(svgPath, 'utf-8');
const innerContent = svgContent.replace(/.*<svg[^>]*>(.*)<\/svg>.*/s, '$1');
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 256 256"
  fill="currentColor"
  aria-hidden="true"
  class={className}
  set:html={innerContent}
/>
