---
// src/layouts/Base.astro
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import { getCityConfig } from '../lib/config/city-config';
import { getFontPreloads } from '../lib/fonts.server';
import { fullLocale, defaultLocale, supportedLocales } from '../lib/i18n/locale-utils';
import { switchLocalePath as computeSwitchPath } from '../lib/i18n/locale-switcher';
import { t, localePath } from '../i18n';
import { getInstanceFeatures } from '../lib/config/instance-features';
import LocaleRedirect from '../components/LocaleRedirect.astro';
import '../styles/global.scss';

const config = getCityConfig();
const fontPreloads = getFontPreloads();
const locale = Astro.currentLocale || defaultLocale();
const htmlLang = fullLocale(locale);
const cspNonce = Astro.locals.cspNonce;
const features = getInstanceFeatures();
const isWiki = features.hasRoutes && !features.hasRides && !features.hasEnrichedEvents;

const logoHref = localePath('/', locale);

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  ogVideo?: { url: string; type: string; width?: number; height?: number };
  jsonLd?: Record<string, any> | Record<string, any>[];
  breadcrumbs?: Record<string, any> | null;
  alternateUrls?: Record<string, string>;
  admin?: boolean;
  fullbleed?: boolean;
}

const { title, description, ogImage, ogImageAlt, ogType, ogVideo, jsonLd, breadcrumbs, alternateUrls, admin, fullbleed } = Astro.props;

const locales = supportedLocales();
const showSwitcher = locales.length > 1 && !admin;
const otherLocale = locales.find(l => l !== locale) || locales[0];
const switchPath = computeSwitchPath(Astro.url.pathname, locale, otherLocale, alternateUrls?.[otherLocale]);
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fbfbfc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0c0f" media="(prefers-color-scheme: dark)" />
    <SEO title={title} description={description} ogImage={ogImage} ogImageAlt={ogImageAlt} ogType={ogType} ogVideo={ogVideo} jsonLd={jsonLd} breadcrumbs={breadcrumbs} alternateUrls={alternateUrls} cspNonce={cspNonce} />
    {config.cdn_url && <link rel="preconnect" href={config.cdn_url} />}
    {config.videos_cdn_url && <link rel="preconnect" href={config.videos_cdn_url} />}
    {fontPreloads.map(href => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/bicycle.png" />
    <link rel="apple-touch-icon" href="/bicycle.png" />
    <link rel="alternate" type="application/rss+xml" title={config.display_name} href="/rss.xml" />
    <link rel="llms-txt" href="/llms.txt" />
    {import.meta.env.PROD && <script>import '../lib/external/analytics';</script>}
    {import.meta.env.DISABLE_ANALYTICS === 'true' && <script is:inline nonce={cspNonce}>localStorage.plausible_ignore=true</script>}
    <LocaleRedirect cspNonce={cspNonce} />
  </head>
  <body class:list={[fullbleed && 'fullbleed']}>
    <header class="site-header">
      <a href={logoHref} class="site-title" set:html={config.site_title_html} />
      {isWiki && <p class="site-subtitle">{t('home.subtitle', locale)}</p>}
      {showSwitcher && (
        <a href={switchPath} class="lang-switcher" data-locale={otherLocale}>
          {otherLocale.toUpperCase()}
        </a>
      )}
    </header>
    {!admin && <Nav alternateUrls={alternateUrls} />}
    <main>
      <slot />
    </main>
    {!fullbleed && <Footer alternateUrls={alternateUrls} />}
    <script>
      document.addEventListener('click', (e) => {
        const origin = e.target;
        if (!(origin instanceof Element)) return;
        const target = origin.closest('[data-locale]');
        if (target instanceof HTMLElement) {
          localStorage.setItem('locale-preference', target.dataset.locale || '');
        }
      });
      if (document.cookie.includes('logged_in=1')) {
        document.body.classList.add('admin-visible');
      }
    </script>
  </body>
</html>
