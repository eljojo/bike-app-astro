---
/**
 * Unified bike path detail component — handles standalone, network, and member
 * page types. Page type is derived from the data itself:
 *   - page.memberRefs?.length > 0  -> network
 *   - page.memberOf                -> member
 *   - neither                      -> standalone
 */
import Base from '@/layouts/Base.astro';
import { type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import RoutesOnPath from '@/components/RoutesOnPath.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import NearbyPaths from '@/components/NearbyPaths.astro';
import EditEntryPoint from '@/components/EditEntryPoint.astro';
import { t, localePath } from '@/i18n';
import { paths, assets } from '@/lib/paths';
import { breadcrumbJsonLd } from '@/lib/json-ld';
import { imageUrl } from '@/lib/media/image-service';
import { hasCachedMap } from '@/lib/maps/map-thumbnails';
import { computeCenter, buildPathFacts, buildNetworkFacts, factLabelKey, localizeFactValue, localizeFactSentence, localizeNetworkFactValue, localizeSurface, findNearestMajorPath, type PathMeta } from '@/lib/bike-paths/bike-path-facts';
import { groupPathsByNetwork, type NetworkMeta } from '@/lib/bike-paths/infrastructure-grouping';

interface Props {
  page: BikePathPage;
  networkMeta: Record<string, NetworkMeta>;
  memberMeta?: PathMeta[];                // network only — member metadata for fact aggregation
  networkPage?: BikePathPage;             // member only
}

const { page, networkMeta, memberMeta, networkPage } = Astro.props;
const { overlappingRoutes, nearbyPhotos, nearbyPlaces, nearbyPaths, connectedPaths } = page;
const config = getCityConfig();
const locale = Astro.currentLocale;

// Data-driven rendering — sections render based on what data exists, not page "type"
const hasMembers = (page.memberRefs?.length ?? 0) > 0;
const hasMemberOf = !!page.memberOf;

// Locale-aware content: translation overrides default
const trans = locale ? page.translations[locale] : undefined;
const localeName = trans?.name || page.name;
const localeVibe = trans?.vibe || page.vibe;
const localeBody = trans?.body || page.body;
// Body fallback: markdown → locale-aware wikidata description → YML description
const wikidataMeta_ = page.ymlEntries[0]?.wikidata_meta as Record<string, unknown> | undefined;
const shortLocale = locale?.split('-')[0] ?? 'en';
const wikidataDesc = wikidataMeta_
  ? ((wikidataMeta_[`description_${shortLocale}`] as string) ?? (wikidataMeta_.description_en as string))
  : undefined;
const bodyText = localeBody
  || wikidataDesc
  || page.ymlEntries[0]?.description
  || undefined;
const descriptionHtml = bodyText ? await renderMarkdownHtml(bodyText) : null;

const fallbackCenter: [number, number] = [config.center.lat, config.center.lng];

// --- Structured facts — aggregated from members when available, individual otherwise ---
// Computed early because tiering logic uses networkFacts to detect MTB networks.
const pathFacts = buildPathFacts(page);
const networkFacts = memberMeta ? buildNetworkFacts(memberMeta) : [];
const useNetworkFacts = networkFacts.length > 0;

// --- Network-specific data ---
const MIN_DISPLAY_KM = 0.5;
const allMemberRefs = page.memberRefs ?? [];
const memberRefs = allMemberRefs.filter(m => m.length_km == null || m.length_km >= MIN_DISPLAY_KM);
// Split by primary/secondary network membership, then sort and tier
const TIER1_MIN_KM = 5;
const allPrimary = memberRefs
  .filter(m => !m.memberOf || m.memberOf === page.slug)
  .sort((a, b) => a.name.localeCompare(b.name));
const allSecondary = memberRefs
  .filter(m => m.memberOf && m.memberOf !== page.slug)
  .sort((a, b) => a.name.localeCompare(b.name));
// Long-distance members get their own section regardless of primary/secondary
const longDistanceMembers = [...allPrimary, ...allSecondary]
  .filter(m => m.entryType === 'long-distance');
const longDistanceSlugs = new Set(longDistanceMembers.map(m => m.slug));
// Primary tier 1/2 (excluding long-distance, which are shown separately)
const nonLdPrimary = allPrimary.filter(m => !longDistanceSlugs.has(m.slug));
let primaryMembers = nonLdPrimary.filter(m => m.hasMarkdown || (m.length_km != null && m.length_km >= TIER1_MIN_KM));
let primaryTier2 = nonLdPrimary.filter(m => !m.hasMarkdown && (m.length_km == null || m.length_km < TIER1_MIN_KM));
// If tiering hides everything (all members are short, no markdown), show all instead
if (primaryMembers.length === 0 && primaryTier2.length > 0) {
  primaryMembers = nonLdPrimary;
  primaryTier2 = [];
}
// Secondary (excluding long-distance)
const secondaryMembers = allSecondary.filter(m => !longDistanceSlugs.has(m.slug));

// Group primary members by shared non-cycling relation (e.g. Rideau Trail section)
const overlapGroups = new Map<number, { name: string; route: string; members: typeof primaryMembers }>();
const ungroupedPrimary: typeof primaryMembers = [];
for (const m of primaryMembers) {
  const rels = m.overlappingRelations ?? [];
  if (rels.length > 0) {
    const rel = rels[0]; // group by first overlapping relation
    if (!overlapGroups.has(rel.id)) {
      overlapGroups.set(rel.id, { name: rel.name, route: rel.route, members: [] });
    }
    overlapGroups.get(rel.id)!.members.push(m);
  } else {
    ungroupedPrimary.push(m);
  }
}
// Only show groups with ≥2 members (single member isn't a meaningful group)
const displayOverlapGroups: Array<{ name: string; route: string; members: typeof primaryMembers }> = [];
for (const [, g] of overlapGroups) {
  if (g.members.length >= 2) {
    displayOverlapGroups.push(g);
  } else {
    ungroupedPrimary.push(...g.members);
  }
}
// Sort ungrouped same as before (by length)
ungroupedPrimary.sort((a, b) => a.name.localeCompare(b.name));

const standaloneMemberCount = memberRefs.filter(m => m.standalone).length;
const wikidataMeta = page.ymlEntries[0]?.wikidata_meta;

const highlightGeoIds = page.geoFiles.map(f => f.replace(/\.geojson$/, ''));

// --- Member-specific data ---
const networkName = networkPage
  ? ((locale && networkPage.translations[locale]?.name) || networkPage.name)
  : page.memberOf;

// --- SEO ---
const seoDescription = (() => {
  if (localeVibe) return localeVibe;
  if (hasMembers) {
    const wd = wikidataMeta
      ? (wikidataMeta as Record<string, unknown>)[`description_${locale}`] as string | undefined ?? wikidataMeta.description_en
      : undefined;
    return wd || `${localeName} — ${standaloneMemberCount} ${t('paths.pathways', locale)}`;
  }
  const seoFacts = pathFacts.map(f => localizeFactSentence(f, t, locale));
  return seoFacts.length > 0 ? seoFacts.join('. ') + '.' : `${localeName} — ${t('paths.seo_fallback', locale)}`;
})();

// ogImage: network uses thumbnail_key fallback, standalone/member use route cover photo
const hasMapThumb = hasCachedMap(`path-${page.slug}`);
const mapThumbUrl = hasMapThumb ? assets.mapSocial(`path-${page.slug}`) : undefined;
const firstCoverKey = page.thumbnail_key || overlappingRoutes.find(r => r.coverKey)?.coverKey;
const ogImage = mapThumbUrl || (firstCoverKey ? imageUrl(firstCoverKey, { width: 1200, height: 630, fit: 'cover' }) : undefined);

// Breadcrumbs: member gets 4 levels (home > paths > network > name)
const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('nav.bike_paths', locale), url: `${config.url}${paths.bikePaths(locale)}` },
  ...(hasMemberOf && networkPage ? [{ name: networkName!, url: `${config.url}${paths.bikePath(networkPage.slug, undefined, locale)}` }] : []),
  { name: localeName, url: `${config.url}${paths.bikePath(page.slug, hasMemberOf ? page.memberOf : undefined, locale)}` },
]);

// --- Connected paths (exclude own members and own network siblings) ---
const memberSlugSet = hasMembers ? new Set(memberRefs.map(m => m.slug)) : new Set<string>();
const ownNetwork = page.memberOf;

const externalConnected = connectedPaths.filter(p => {
  if (memberSlugSet.has(p.slug)) return false; // exclude own members
  if (hasMembers && p.memberOf === page.slug) return false; // exclude paths that belong to this network
  if (ownNetwork && p.memberOf === ownNetwork) return false; // exclude siblings in same network
  return true;
});

const showStubCta = !descriptionHtml && (page.stub || !page.hasMarkdown);

// Overlapping non-cycling relations (hiking trails, ski trails sharing this path)
const ROUTE_LABELS: Record<string, string> = { hiking: 'paths.shared_hiking', piste: 'paths.shared_ski', foot: 'paths.shared_walking', ski: 'paths.shared_ski' };
const overlappingRelations = (page.overlapping_relations ?? [])
  .filter(r => ROUTE_LABELS[r.route]);
// Deduplicate by name (same trail can appear via multiple ways)
const seenRelNames = new Set<string>();
const uniqueOverlaps = overlappingRelations.filter(r => {
  if (seenRelNames.has(r.name)) return false;
  seenRelNames.add(r.name);
  return true;
});

// Infrastructure data — what connects to this path/network and what networks are nearby
const filteredNearby = nearbyPaths.filter(p => !memberSlugSet.has(p.slug));
// Connected paths sorted by length (longest first = most significant)
const sortedConnected = [...externalConnected].sort((a, b) => (b.length_km ?? 0) - (a.length_km ?? 0));
// Networks present in connected + nearby paths (deduplicated)
const nearbyNetworkSlugs = new Set<string>();
for (const p of [...externalConnected, ...filteredNearby]) {
  if (p.memberOf && p.memberOf !== page.slug && p.memberOf !== page.memberOf) {
    nearbyNetworkSlugs.add(p.memberOf);
  }
}
// Own network (if this is a member path)
const ownNetworkMeta = page.memberOf ? networkMeta[page.memberOf] : undefined;

// --- Nearest major path — the most significant path close to this one ---
const nearestMajorPath = findNearestMajorPath({
  connectedPaths,
  nearbyPaths,
  pageSlug: page.slug,
  pageLengthKm: page.length_km,
  pageMemberOf: page.memberOf,
  hasMembers,
  memberSlugs: memberSlugSet,
});

// Website resolution (page.website already includes wikidata_meta.website fallback)
const websiteUrl = page.website;
const websiteHostname = websiteUrl ? (() => { try { return new URL(websiteUrl).hostname; } catch { return undefined; } })() : undefined;
---

<Base title={`${localeName} | ${config.display_name}`} description={seoDescription} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <div class:list={['bike-path-detail', { 'has-members': hasMembers }]}>
    <div class="bike-path-title">
      <h1>
        {localeName}
        <a href={`/admin/bike-paths/${page.slug}`} class="admin-edit-link" aria-label="Edit this path">Edit</a>
      </h1>
    </div>

    {hasMemberOf && networkPage && (
      <a href={paths.bikePath(networkPage.slug, undefined, locale)} class="network-badge">
        {t('paths.part_of', locale)} {networkName}
      </a>
    )}

    {localeVibe && <p class="bike-path-vibe">{localeVibe}</p>}

    {/* Full-width map when page has members (networks, trails with sections) */}
    {hasMembers && (
      <div class="network-map-full">
        <BikePathMap
          highlightGeoIds={highlightGeoIds}
          center={computeCenter(page.points)}
          fallbackCenter={fallbackCenter}
          hintText={t('paths.tap_to_explore', locale)}
          closeLabel={t('paths.close_map', locale)}
          cdnUrl={config.cdn_url}
          highlightSelector=".network-members-list li[data-slug]"
        />
      </div>
    )}

    <div class="bike-path-layout">
      {/* ===== Main column ===== */}
      <div class="bike-path-main">
        {showStubCta && (
          <p class="bike-path-stub-cta">
            {t('paths.stub_cta', locale)} <a href={`/admin/bike-paths/${page.slug}`}>{t('paths.stub_cta_link', locale)}</a>
          </p>
        )}

        {descriptionHtml && (
          <div class="bike-path-description" set:html={descriptionHtml} />
        )}

        <div class="bike-path-edit-cta">
          <EditEntryPoint text={t('paths.edit_description', locale)} href={`/admin/bike-paths/${page.slug}`} />
        </div>

        {/* Nearest major path — the most significant path close to this one */}
        {nearestMajorPath && (
          <a href={paths.bikePath(nearestMajorPath.slug, nearestMajorPath.memberOf, locale)} class="nearest-major-path">
            <span class="nearest-major-label">{t('paths.nearest_major', locale)}</span>
            <span class="nearest-major-name">{nearestMajorPath.name}</span>
            <span class="nearest-major-meta">
              {nearestMajorPath.length_km && `${nearestMajorPath.length_km} km`}
              {nearestMajorPath.length_km && nearestMajorPath.surface && ' · '}
              {nearestMajorPath.surface && (localizeSurface(nearestMajorPath.surface, t, locale) || nearestMajorPath.surface)}
            </span>
          </a>
        )}

        {/* Connects to — paths you can ride to from here */}
        {sortedConnected.length > 0 && (
          <section class="connects-to-section">
            <h2>{t('paths.connects_to', locale)}</h2>
            <ul class="connects-to-list">
              {sortedConnected.slice(0, 5).map(p => (
                <li data-relation="connects" data-slug={p.slug}>
                  <a href={paths.bikePath(p.slug, p.memberOf, locale)} class="connects-to-link">
                    <span class="connects-to-name">{p.name}</span>
                    <span class="connects-to-meta">
                      {p.length_km && `${p.length_km} km`}
                      {p.length_km && p.surface && ' · '}
                      {p.surface && (localizeSurface(p.surface, t, locale) || p.surface)}
                    </span>
                  </a>
                  {p.memberOf && networkMeta[p.memberOf] && (
                    <a href={paths.bikePath(p.memberOf, undefined, locale)} class="connects-to-network">{networkMeta[p.memberOf].name}</a>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}

        {/* Networks — one-line summaries of networks in this area */}
        {(ownNetworkMeta || nearbyNetworkSlugs.size > 0) && (
          <section class="networks-here">
            {ownNetworkMeta && page.memberOf && (
              <div class="network-here-own">
                <a href={paths.bikePath(page.memberOf, undefined, locale)} class="network-here-link">
                  {t('paths.on_this_network', locale)}: {ownNetworkMeta.name}
                </a>
                {ownNetworkMeta.length_km && <span class="network-here-meta">{ownNetworkMeta.length_km} km</span>}
              </div>
            )}
            {nearbyNetworkSlugs.size > 0 && <div class="network-here-heading">Nearby networks</div>}
            {[...nearbyNetworkSlugs].map(slug => {
              const meta = networkMeta[slug];
              if (!meta) return null;
              return (
                <div class="network-here-item">
                  <a href={paths.bikePath(slug, undefined, locale)} class="network-here-link">{meta.name}</a>
                  {meta.length_km && <span class="network-here-meta">{meta.length_km} km</span>}
                </div>
              );
            })}
          </section>
        )}

        {/* Member list — shown when this page has members (networks, trails with sections) */}
        {hasMembers && memberRefs.length > 0 && (
          <section class="network-members">
            <h2>{t('paths.member_paths', locale)}</h2>

            {/* Long-distance trails that pass through this network */}
            {longDistanceMembers.length > 0 && (
              <div class="network-members-long-distance">
                {longDistanceMembers.map(m => (
                  <a href={paths.bikePath(m.slug, m.memberOf ?? page.slug, locale)} class="network-member-long-distance" data-slug={m.slug}>
                    <span class="network-member-name">{m.name}</span>
                    <span class="network-member-meta">{m.length_km && `${m.length_km} km`}</span>
                  </a>
                ))}
              </div>
            )}

            {/* Tier 1: significant members (≥5km or has markdown), sorted by length */}
            {ungroupedPrimary.length > 0 && (
              <ul class="network-members-list">
                {ungroupedPrimary.map(m => (
                  <li data-slug={m.slug}>
                    {m.standalone ? (
                      <a href={paths.bikePath(m.slug, m.memberOf ?? page.slug, locale)} class="network-member-link">
                        <span class="network-member-name">{m.name}</span>
                        {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                      </a>
                    ) : (
                      <span class="network-member-no-page">
                        <span class="network-member-name">{m.name}</span>
                        {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            )}

            {/* Overlap groups — members grouped by shared non-cycling relation */}
            {displayOverlapGroups.map(group => (
              <div class="network-overlap-group">
                <h3 class="network-overlap-heading">
                  {group.name}
                  <span class="network-overlap-route-type">({group.route})</span>
                </h3>
                <ul class="network-members-list">
                  {group.members.map(m => (
                    <li data-slug={m.slug}>
                      {m.standalone ? (
                        <a href={paths.bikePath(m.slug, m.memberOf ?? page.slug, locale)} class="network-member-link">
                          <span class="network-member-name">{m.name}</span>
                          {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                        </a>
                      ) : (
                        <span class="network-member-no-page">
                          <span class="network-member-name">{m.name}</span>
                          {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}

            {/* Tier 2: shorter segments, collapsed */}
            {primaryTier2.length > 0 && (
              <div class="network-tier2">
                <span class="network-tier2-label">{t('paths.shorter_segments', locale, { count: String(primaryTier2.length) })}</span>
                <span class="network-tier2-names">
                  {primaryTier2.slice(0, 8).map((m, j) => (
                    <span>{m.name}{j < Math.min(7, primaryTier2.length - 1) ? ', ' : ''}</span>
                  ))}
                  {primaryTier2.length > 8 && <span>&hellip;</span>}
                </span>
              </div>
            )}

            {/* Secondary members — paths that also belong to this network but live under another */}
            {secondaryMembers.length > 0 && <h3>{t('paths.shared_members', locale)}</h3>}
            {secondaryMembers.length > 0 && (
              <ul class="network-members-list network-members-shared">
                {secondaryMembers.map(m => (
                  <li data-slug={m.slug}>
                    {m.standalone ? (
                      <a href={paths.bikePath(m.slug, m.memberOf, locale)} class="network-member-link network-member-secondary">
                        <span class="network-member-name">{m.name}</span>
                        <span class="network-member-meta">
                          {m.length_km ? `${m.length_km} km · ` : ''}{networkMeta[m.memberOf!]?.name ?? m.memberOf}
                        </span>
                      </a>
                    ) : (
                      <span class="network-member-no-page">
                        <span class="network-member-name">{m.name}</span>
                        {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </section>
        )}

        {overlappingRoutes.length > 0 && (
          <section class="bike-path-routes">
            <RoutesOnPath routes={overlappingRoutes} locale={locale} />
          </section>
        )}

        {/* Photos */}
        {nearbyPhotos.length > 0 && (
          <section class="bike-path-photos">
            <h2>{t('paths.photos', locale)}</h2>
            <div class="bike-path-photo-grid">
              {nearbyPhotos.map(photo => (
                <a href={`${paths.route(photo.routeSlug, locale)}?photo=${encodeURIComponent(photo.key)}#photos`} class="bike-path-photo">
                  <img
                    src={imageUrl(photo.key, { width: 300, height: 200, fit: 'cover' })}
                    srcset={`${imageUrl(photo.key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                    alt={photo.caption || localeName}
                    width="300"
                    height="200"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      {/* ===== Sidebar (infobox) ===== */}
      <aside class="bike-path-sidebar">
        {/* Sidebar map: pages without members (map is full-width above when members exist) */}
        {!hasMembers && (
          <div class="bike-path-sidebar-map">
            <BikePathMap
              highlightGeoIds={highlightGeoIds}
              center={computeCenter(page.points)}
              fallbackCenter={fallbackCenter}
              hintText={t('paths.tap_to_explore', locale)}
              closeLabel={t('paths.close_map', locale)}
              cdnUrl={config.cdn_url}
            />
          </div>
        )}

        {/* Facts table — aggregated from members when available, individual otherwise */}
        <table class="bike-path-facts-table">
          {page.length_km && (
            <tr class="fact-length"><td>{t('paths.label.length', locale)}</td><td>{page.length_km} km</td></tr>
          )}
          {hasMembers && <tr><td>{t('paths.pathways', locale)}</td><td>{standaloneMemberCount}</td></tr>}
          {useNetworkFacts ? (
            networkFacts.map(fact => (
              <tr><td>{t(factLabelKey(fact.key), locale)}</td><td>{localizeNetworkFactValue(fact, t, locale)}</td></tr>
            ))
          ) : (
            pathFacts.map(fact => {
              const factClass = fact.key === 'path_info' ? 'fact-path-type'
                : fact.key === 'surface_width' ? 'fact-surface'
                : fact.key.startsWith('smoothness_') ? 'fact-surface-quality'
                : fact.key.startsWith('traffic_') ? 'fact-traffic'
                : fact.key === 'separated_cars' || fact.key === 'separated_peds' ? 'fact-traffic'
                : fact.key === 'lit' || fact.key === 'not_lit' ? 'fact-lighting'
                : fact.key === 'flat' || fact.key === 'gentle_hills' || fact.key === 'hilly' ? 'fact-terrain'
                : fact.key.startsWith('network_') ? 'fact-network'
                : fact.key === 'inception' ? 'fact-established'
                : `fact-${fact.key.replace(/_/g, '-')}`;
              return (
                <tr class={factClass}><td>{t(factLabelKey(fact.key), locale)}</td><td>{localizeFactValue(fact, t, locale)}</td></tr>
              );
            })
          )}
          {page.operator && useNetworkFacts && !networkFacts.some(f => f.key === 'operator') && (
            <tr class="fact-operator"><td>{t('paths.label.operator', locale)}</td><td>{page.operator}</td></tr>
          )}
          {wikidataMeta?.inception && !pathFacts.some(f => f.key === 'inception') && (
            <tr class="fact-established"><td>{t('paths.fact.established', locale)}</td><td>{wikidataMeta.inception}</td></tr>
          )}
        </table>

        {/* Shared with non-cycling routes (hiking trails, ski trails) */}
        {uniqueOverlaps.length > 0 && (
          <div class="shared-routes">
            <h3>{t('paths.shared_with', locale)}</h3>
            <ul>
              {uniqueOverlaps.map(r => (
                <li>
                  <a href={`https://openstreetmap.org/relation/${r.id}`} target="_blank" rel="noopener" class="shared-route-link">
                    {r.name}
                  </a>
                  <span class="shared-route-type">{t(ROUTE_LABELS[r.route], locale)}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {nearbyPlaces.length > 0 && (
          <div>
            <NearbyPlaces nearby={nearbyPlaces} limit={8} />
          </div>
        )}

        {/* Nearby paths — compact sidebar list, max 3, excludes connected and own members */}
        {(() => {
          const connectedSlugs = new Set(connectedPaths.map(p => p.slug));
          const filtered = nearbyPaths.filter(p => !connectedSlugs.has(p.slug) && !memberSlugSet.has(p.slug)).slice(0, 3);
          return filtered.length > 0 ? <NearbyPaths nearbyPaths={filtered} networkMeta={networkMeta} locale={locale} /> : null;
        })()}

        {/* Website link card */}
        {websiteUrl && websiteHostname && (
          <a href={websiteUrl} target="_blank" rel="noopener" class="external-link-card external-link-website">
            <span class="external-link-icon">&#x1f517;</span>
            <span>{websiteHostname}</span>
            <span class="external-link-arrow">&nearr;</span>
          </a>
        )}

        {/* Wikipedia link card */}
        {page.wikipedia && (() => {
          const [lang, ...titleParts] = page.wikipedia.split(':');
          const title = titleParts.join(':');
          const url = `https://${lang}.wikipedia.org/wiki/${encodeURIComponent(title.replace(/ /g, '_'))}`;
          return (
            <a href={url} target="_blank" rel="noopener" class="external-link-card external-link-wikipedia">
              <span class="external-link-icon" style="color: var(--color-text-muted)">W</span>
              <span>{title} — Wikipedia</span>
              <span class="external-link-arrow">&nearr;</span>
            </a>
          );
        })()}

        {/* OSM attribution */}
        {(page.osmRelationIds.length > 0 || page.osmNames.length > 0 || page.ymlEntries.some(e => e.osm_way_ids?.length)) && (
          <div class="bike-path-osm">
            <span>{t('paths.osm_attribution', locale)} <a href="https://openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>.</span>
            {page.ymlEntries.map(entry => (
              entry.osm_relations?.length
                ? entry.osm_relations.map(id => (
                    <a href={`https://openstreetmap.org/relation/${id}`} target="_blank" rel="noopener">
                      {entry.name} — relation {id} ↗
                    </a>
                  ))
                : entry.osm_way_ids?.length
                  ? <a href={`https://openstreetmap.org/way/${entry.osm_way_ids[0]}`} target="_blank" rel="noopener">
                      {entry.name} — way {entry.osm_way_ids[0]} ↗
                    </a>
                  : entry.osm_names?.length
                    ? <a href={`https://openstreetmap.org/search?query=${encodeURIComponent(entry.osm_names[0])}`} target="_blank" rel="noopener">
                        {entry.name} — {t('paths.osm_search', locale)} ↗
                      </a>
                    : null
            ))}
          </div>
        )}
      </aside>
    </div>

    {/* Back link — member goes to network, network is bare <a>, standalone wraps in <p> */}
    <div class="bike-path-back">
      {hasMemberOf && networkPage ? (
        <a href={paths.bikePath(networkPage.slug, undefined, locale)} class="go-back-button">&#x21A9; {networkName}</a>
      ) : (
        <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
      )}
    </div>
  </div>
</Base>

