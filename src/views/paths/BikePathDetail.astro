---
/**
 * Unified bike path detail component — handles standalone, network, and member
 * page types. Page type is derived from the data itself:
 *   - page.memberRefs?.length > 0  -> network
 *   - page.memberOf                -> member
 *   - neither                      -> standalone
 */
import Base from '@/layouts/Base.astro';
import { type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import RoutesOnPath from '@/components/RoutesOnPath.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import NearbyPaths from '@/components/NearbyPaths.astro';
import EditEntryPoint from '@/components/EditEntryPoint.astro';
import { t, localePath } from '@/i18n';
import { paths, assets } from '@/lib/paths';
import { breadcrumbJsonLd } from '@/lib/json-ld';
import { imageUrl } from '@/lib/media/image-service';
import { hasCachedMap } from '@/lib/maps/map-thumbnails';
import { computeCenter, buildPathFacts, buildNetworkFacts, factLabelKey, localizeFactValue, localizeFactSentence, localizeNetworkFactValue, localizeSurface, type PathMeta } from '@/lib/bike-paths/bike-path-facts';
import { groupPathsByNetwork, type NetworkMeta } from '@/lib/bike-paths/infrastructure-grouping';

interface Props {
  page: BikePathPage;
  networkMeta: Record<string, NetworkMeta>;
  memberGeoMap?: Record<string, string>;  // network only
  memberMeta?: PathMeta[];                // network only — member metadata for fact aggregation
  networkPage?: BikePathPage;             // member only
}

const { page, networkMeta, memberGeoMap, memberMeta, networkPage } = Astro.props;
const { overlappingRoutes, nearbyPhotos, nearbyPlaces, nearbyPaths, connectedPaths } = page;
const config = getCityConfig();
const locale = Astro.currentLocale;

// Derive page type from the data
const isNetwork = (page.memberRefs?.length ?? 0) > 0;
const isMember = !isNetwork && !!page.memberOf;
const isStandalone = !isNetwork && !isMember;

// Locale-aware content: translation overrides default
const trans = locale ? page.translations[locale] : undefined;
const localeName = trans?.name || page.name;
const localeVibe = trans?.vibe || page.vibe;
const localeBody = trans?.body || page.body;
const bodyText = localeBody
  || page.wikidata_description
  || page.ymlEntries[0]?.description
  || undefined;
const descriptionHtml = bodyText ? await renderMarkdownHtml(bodyText) : null;

const fallbackCenter: [number, number] = [config.center.lat, config.center.lng];

// --- Network-specific data ---
const MIN_DISPLAY_KM = 0.5;
const allMemberRefs = page.memberRefs ?? [];
const memberRefs = allMemberRefs.filter(m => m.length_km == null || m.length_km >= MIN_DISPLAY_KM);
const primaryMembers = memberRefs.filter(m => !m.memberOf || m.memberOf === page.slug);
const secondaryMembers = memberRefs.filter(m => m.memberOf && m.memberOf !== page.slug);
const standaloneMemberCount = memberRefs.filter(m => m.standalone).length;
const wikidataMeta = page.ymlEntries[0]?.wikidata_meta;

// Maps for clickable paths on the network map
const memberNameMap: Record<string, string> = {};
const memberUrlMap: Record<string, string> = {};
if (isNetwork) {
  for (const m of allMemberRefs) {
    memberNameMap[m.slug] = m.name;
    if (m.standalone) {
      memberUrlMap[m.slug] = paths.bikePath(m.slug, m.memberOf ?? page.slug, locale);
    }
  }
}

// --- Member-specific data ---
const networkName = networkPage
  ? ((locale && networkPage.translations[locale]?.name) || networkPage.name)
  : page.memberOf;

// --- Structured facts from centralized system ---
const pathFacts = !isNetwork ? buildPathFacts(page) : [];
const networkFacts = isNetwork && memberMeta ? buildNetworkFacts(memberMeta) : [];

// --- SEO ---
const seoDescription = (() => {
  if (isNetwork) {
    const wikidataDesc = wikidataMeta
      ? (wikidataMeta as Record<string, unknown>)[`description_${locale}`] as string | undefined
        ?? wikidataMeta.description_en
      : undefined;
    return localeVibe || wikidataDesc || `${localeName} — ${standaloneMemberCount} ${t('paths.pathways', locale)}`;
  }
  if (isMember) {
    return localeVibe || `${localeName} — ${page.length_km ? `${page.length_km} km` : ''} cycling path`;
  }
  // standalone — use sentence form for SEO
  const seoFacts = pathFacts.map(f => localizeFactSentence(f, t, locale));
  return localeVibe || (seoFacts.length > 0 ? seoFacts.join('. ') + '.' : `${localeName} — ${t('paths.seo_fallback', locale)}`);
})();

// ogImage: network uses thumbnail_key fallback, standalone/member use route cover photo
const hasMapThumb = hasCachedMap(`path-${page.slug}`);
const mapThumbUrl = hasMapThumb ? assets.mapSocial(`path-${page.slug}`) : undefined;
const ogImage = (() => {
  if (isNetwork) {
    return mapThumbUrl || (page.thumbnail_key ? imageUrl(page.thumbnail_key, { width: 1200, height: 630, fit: 'cover' }) : undefined);
  }
  const firstCoverKey = overlappingRoutes.find(r => r.coverKey)?.coverKey;
  return mapThumbUrl || (firstCoverKey ? imageUrl(firstCoverKey, { width: 1200, height: 630, fit: 'cover' }) : undefined);
})();

// Breadcrumbs: member gets 4 levels (home > paths > network > name)
const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('nav.bike_paths', locale), url: `${config.url}${paths.bikePaths(locale)}` },
  ...(isMember && networkPage ? [{ name: networkName!, url: `${config.url}${paths.bikePath(networkPage.slug, undefined, locale)}` }] : []),
  { name: localeName, url: `${config.url}${paths.bikePath(page.slug, isNetwork ? undefined : page.memberOf, locale)}` },
]);

// --- Connected paths ---
const memberSlugs = isNetwork ? new Set(memberRefs.map(m => m.slug)) : undefined;
const ownNetwork = page.memberOf;

const externalConnected = isNetwork
  ? connectedPaths.filter(p => !memberSlugs!.has(p.slug) && p.memberOf !== page.slug)
  : connectedPaths.filter(p => p.memberOf !== ownNetwork || !ownNetwork);

const standaloneConnected = externalConnected.filter(p => !p.memberOf);
const connectedByNetwork = new Map<string, typeof connectedPaths>();
for (const p of externalConnected) {
  if (!p.memberOf) continue;
  const list = connectedByNetwork.get(p.memberOf);
  if (list) list.push(p); else connectedByNetwork.set(p.memberOf, [p]);
}
const connectedNetworkEntries = [...connectedByNetwork.entries()];

// Stub CTA condition differs: network checks !descriptionHtml, standalone/member check page.stub || !page.hasMarkdown
const showStubCta = isNetwork ? !descriptionHtml : (page.stub || !page.hasMarkdown);

// Infrastructure grouping for standalone/member pages
const infraGroups = !isNetwork ? groupPathsByNetwork({
  connectedPaths,
  nearbyPaths,
  ownNetwork: page.memberOf,
  networkMeta,
}) : { networkGroups: [], otherPaths: [] };

// Website resolution (page.website already includes wikidata_meta.website fallback)
const websiteUrl = page.website;
const websiteHostname = websiteUrl ? (() => { try { return new URL(websiteUrl).hostname; } catch { return undefined; } })() : undefined;
---

<Base title={`${localeName} | ${config.display_name}`} description={seoDescription} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <div class:list={['bike-path-detail', { 'network-detail': isNetwork }]}>
    <div data-testid="path-title">
      <h1>
        {localeName}
        {!isNetwork && (
          <a href={`/admin/bike-paths/${page.slug}`} class="admin-edit-link" aria-label="Edit this path">Edit</a>
        )}
      </h1>
    </div>

    {isMember && page.memberOf && networkPage && (
      <a data-testid="network-badge" href={paths.bikePath(networkPage.slug, undefined, locale)} class="network-badge">
        {t('paths.part_of', locale)} {networkName}
      </a>
    )}

    {localeVibe && <p data-testid="path-vibe" class="bike-path-vibe">{localeVibe}</p>}

    {/* Network: full-width map ABOVE two-column layout */}
    {isNetwork && memberGeoMap && (
      <div data-testid="path-map" class="network-map-full">
        <BikePathMap
          geoFiles={page.geoFiles}
          center={computeCenter(page.points)}
          fallbackCenter={fallbackCenter}
          hintText={t('paths.tap_to_explore', locale)}
          closeLabel={t('paths.close_map', locale)}
          photos={nearbyPhotos.filter(p => p.lat && p.lng)}
          places={nearbyPlaces.map(p => ({ name: p.name, lat: p.lat, lng: p.lng, category: p.category }))}
          cdnUrl={config.cdn_url}
          slugMap={memberGeoMap}
          nameMap={memberNameMap}
          urlMap={memberUrlMap}
          highlightSelector=".network-members-list li[data-slug]"
        />
      </div>
    )}

    <div class="bike-path-layout">
      {/* ===== Main column ===== */}
      <div class="bike-path-main">
        {showStubCta && (
          <p class="bike-path-stub-cta">
            {t('paths.stub_cta', locale)} <a href={`/admin/bike-paths/${page.slug}`}>{t('paths.stub_cta_link', locale)}</a>
          </p>
        )}

        {descriptionHtml && (
          <div data-testid="path-body" class="bike-path-description" set:html={descriptionHtml} />
        )}

        <div data-testid="edit-cta">
          <EditEntryPoint text={t('paths.edit_description', locale)} href={`/admin/bike-paths/${page.slug}`} />
        </div>

        {/* Infrastructure section — groups connected+nearby paths by network (standalone/member only) */}
        {!isNetwork && (infraGroups.networkGroups.length > 0 || infraGroups.otherPaths.length > 0) && (
          <section data-testid="infrastructure-section" class="infrastructure-section">
            <h2>{t('paths.infrastructure_here', locale)}</h2>

            {infraGroups.networkGroups.map((group, i) => (
              <div data-testid="network-card" data-network={group.slug} class="network-card" style={`border-left-color: var(--network-color-${i})`}>
                <div class="network-card-header">
                  {group.isOwn ? (
                    <span data-testid="network-card-own">
                      <a data-testid="network-card-name" href={paths.bikePath(group.slug, undefined, locale)} class="network-card-name">{group.name}</a>
                    </span>
                  ) : (
                    <a data-testid="network-card-name" href={paths.bikePath(group.slug, undefined, locale)} class="network-card-name">{group.name}</a>
                  )}
                  <span class="network-card-meta">
                    {group.length_km && `${group.length_km} km`}
                    {group.length_km && group.operator && ' · '}
                    {group.operator}
                  </span>
                </div>
                {group.isOwn && <div class="network-card-label">{t('paths.on_this_network', locale)}</div>}
                {!group.isOwn && page.memberOf && group.slug !== page.memberOf && (
                  <div class="network-card-label">{t('paths.also_this_network', locale)}</div>
                )}
                <div class="network-card-paths">
                  {group.paths.map(p => (
                    <div data-testid="network-card-path" data-relation={p.relation} class="network-card-path">
                      <a href={paths.bikePath(p.slug, group.slug, locale)}>{p.name}</a>
                      <span class="network-card-path-relation">
                        {p.surface && `${localizeSurface(p.surface, t, locale) || p.surface} · `}{t(`paths.relation_${p.relation}`, locale)}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            ))}

            {infraGroups.otherPaths.length > 0 && (
              <div data-testid="other-paths" class="network-card" style="border-left-color: var(--color-text-muted)">
                <div class="network-card-label">{t('paths.other_nearby', locale)}</div>
                <div class="network-card-paths">
                  {infraGroups.otherPaths.map(p => (
                    <div data-testid="network-card-path" data-relation={p.relation} class="network-card-path">
                      <a href={paths.bikePath(p.slug, undefined, locale)}>{p.name}</a>
                      <span class="network-card-path-relation">
                        {p.surface && `${localizeSurface(p.surface, t, locale) || p.surface} · `}{t(`paths.relation_${p.relation}`, locale)}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </section>
        )}

        {/* Member list (network only) — primary members nested under this network, secondary members link to their primary network */}
        {isNetwork && memberRefs.length > 0 && (
          <section class="network-members">
            <h2>{t('paths.member_paths', locale)}</h2>
            <ul class="network-members-list">
              {primaryMembers.map(m => (
                <li data-slug={m.slug}>
                  {m.standalone ? (
                    <a href={paths.bikePath(m.slug, m.memberOf ?? page.slug, locale)} class="network-member-link">
                      <span class="network-member-name">{m.name}</span>
                      {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                    </a>
                  ) : (
                    <span class="network-member-no-page">
                      <span class="network-member-name">{m.name}</span>
                      {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                    </span>
                  )}
                </li>
              ))}
            </ul>
            {secondaryMembers.length > 0 && <h3>{t('paths.shared_members', locale)}</h3>}
            {secondaryMembers.length > 0 && (
              <ul class="network-members-list network-members-shared">
                {secondaryMembers.map(m => (
                  <li data-slug={m.slug}>
                    {m.standalone ? (
                      <a href={paths.bikePath(m.slug, m.memberOf, locale)} class="network-member-link network-member-secondary">
                        <span class="network-member-name">{m.name}</span>
                        <span class="network-member-meta">
                          {m.length_km ? `${m.length_km} km · ` : ''}{networkMeta[m.memberOf!]?.name ?? m.memberOf}
                        </span>
                      </a>
                    ) : (
                      <span class="network-member-no-page">
                        <span class="network-member-name">{m.name}</span>
                        {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </section>
        )}

        {overlappingRoutes.length > 0 && (
          <section data-testid="routes-section">
            <RoutesOnPath routes={overlappingRoutes} locale={locale} />
          </section>
        )}

        {/* Photos: network uses <button> (limited to 8), standalone/member use <a> links (unlimited) */}
        {nearbyPhotos.length > 0 && (
          <section data-testid="photos-section" class="bike-path-photos">
            <h2>{t('paths.photos', locale)}</h2>
            <div class="bike-path-photo-grid">
              {isNetwork ? (
                nearbyPhotos.slice(0, 8).map(photo => (
                  <button
                    type="button"
                    class="bike-path-photo"
                    data-photo-key={photo.key}
                    data-photo-lat={photo.lat}
                    data-photo-lng={photo.lng}
                  >
                    <img
                      src={imageUrl(photo.key, { width: 300, height: 200, fit: 'cover' })}
                      srcset={`${imageUrl(photo.key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                      alt={photo.caption || localeName}
                      width="300"
                      height="200"
                      loading="lazy"
                    />
                  </button>
                ))
              ) : (
                nearbyPhotos.map(photo => (
                  <a href={`${paths.route(photo.routeSlug, locale)}?photo=${encodeURIComponent(photo.key)}#photos`} class="bike-path-photo">
                    <img
                      src={imageUrl(photo.key, { width: 300, height: 200, fit: 'cover' })}
                      srcset={`${imageUrl(photo.key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                      alt={photo.caption || localeName}
                      width="300"
                      height="200"
                      loading="lazy"
                    />
                  </a>
                ))
              )}
            </div>
          </section>
        )}
      </div>

      {/* ===== Sidebar (infobox) ===== */}
      <aside class="bike-path-sidebar">
        {/* Sidebar map: standalone + member only (network map is above) */}
        {!isNetwork && (
          <div data-testid="path-map">
            <BikePathMap
              geoFiles={page.geoFiles}
              center={computeCenter(page.points)}
              fallbackCenter={fallbackCenter}
              hintText={t('paths.tap_to_explore', locale)}
              closeLabel={t('paths.close_map', locale)}
              photos={nearbyPhotos.filter(p => p.lat && p.lng)}
              places={nearbyPlaces.map(p => ({ name: p.name, lat: p.lat, lng: p.lng, category: p.category }))}
              cdnUrl={config.cdn_url}
            />
          </div>
        )}

        {/* Facts table — network aggregates from members, standalone/member driven by buildPathFacts */}
        {isNetwork ? (
          <table data-testid="facts-table" class="bike-path-facts-table">
            {page.length_km && (
              <tr><td>{t('paths.label.length', locale)}</td><td>{page.length_km} km</td></tr>
            )}
            <tr><td>{t('paths.pathways', locale)}</td><td>{standaloneMemberCount}</td></tr>
            {networkFacts.map(fact => (
              <tr><td>{t(factLabelKey(fact.key), locale)}</td><td>{localizeNetworkFactValue(fact, t, locale)}</td></tr>
            ))}
            {/* Network's own operator (if not already shown via member aggregation) */}
            {page.operator && !networkFacts.some(f => f.key === 'operator') && (
              <tr><td>{t('paths.label.operator', locale)}</td><td>{page.operator}</td></tr>
            )}
            {wikidataMeta?.inception && (
              <tr><td>{t('paths.fact.established', locale)}</td><td>{wikidataMeta.inception}</td></tr>
            )}
            {wikidataMeta?.website && (
              <tr><td>{t('paths.fact.website', locale)}</td><td><a href={wikidataMeta.website} target="_blank" rel="noopener">{new URL(wikidataMeta.website).hostname}</a></td></tr>
            )}
          </table>
        ) : (
          <table data-testid="facts-table" class="bike-path-facts-table">
            {page.length_km && (
              <tr data-testid="fact-length"><td>{t('paths.label.length', locale)}</td><td>{page.length_km} km</td></tr>
            )}
            {pathFacts.map(fact => {
              const factTestId = fact.key === 'surface_width' ? 'fact-surface'
                : fact.key.startsWith('smoothness_') ? 'fact-surface-quality'
                : fact.key === 'separated_cars' || fact.key === 'separated_peds' ? 'fact-traffic'
                : fact.key === 'lit' || fact.key === 'not_lit' ? 'fact-lighting'
                : fact.key === 'flat' || fact.key === 'gentle_hills' || fact.key === 'hilly' ? 'fact-terrain'
                : fact.key.startsWith('network_') ? 'fact-network'
                : fact.key === 'inception' ? 'fact-established'
                : `fact-${fact.key.replace(/_/g, '-')}`;
              return (
                <tr data-testid={factTestId}><td>{t(factLabelKey(fact.key), locale)}</td><td>{localizeFactValue(fact, t, locale)}</td></tr>
              );
            })}
            {page.parallel_to && (
              <tr data-testid="fact-alongside"><td>{t('paths.label.alongside', locale)}</td><td>{page.parallel_to}</td></tr>
            )}
          </table>
        )}

        {nearbyPlaces.length > 0 && (
          <div data-testid="nearby-places">
            <NearbyPlaces nearby={nearbyPlaces} limit={8} />
          </div>
        )}

        {/* Connected paths — network pages only (standalone/member use infrastructure section in main column) */}
        {isNetwork && externalConnected.length > 0 && (
          <section class="connected-paths">
            <h2>{t('paths.connects_to', locale)}</h2>
            <ul class="connected-paths-list">
              {connectedNetworkEntries.map(([netSlug, members]) => (
                <li>
                  <a href={paths.bikePath(netSlug, undefined, locale)}>{networkMeta[netSlug]?.name ?? netSlug}</a>
                  {members.length > 1 && <span class="path-meta">{members.length} {t('paths.pathways', locale)}</span>}
                </li>
              ))}
              {standaloneConnected.map(p => (
                <li>
                  <a href={paths.bikePath(p.slug, p.memberOf, locale)}>{p.name}</a>
                  {localizeSurface(p.surface, t, locale) && <span class="path-meta">{localizeSurface(p.surface, t, locale)}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}

        {/* NearbyPaths — network pages only */}
        {isNetwork && (() => {
          const connectedSlugs = new Set(connectedPaths.map(p => p.slug));
          const filtered = nearbyPaths.filter(p => !connectedSlugs.has(p.slug));
          return filtered.length > 0 ? <NearbyPaths nearbyPaths={filtered} locale={locale} /> : null;
        })()}

        {/* Website link card */}
        {websiteUrl && websiteHostname && (
          <a data-testid="website-link" href={websiteUrl} target="_blank" rel="noopener" class="external-link-card">
            <span class="external-link-icon">&#x1f517;</span>
            <span>{websiteHostname}</span>
            <span class="external-link-arrow">&nearr;</span>
          </a>
        )}

        {/* Wikipedia link card */}
        {page.wikipedia && (() => {
          const [lang, ...titleParts] = page.wikipedia.split(':');
          const title = titleParts.join(':');
          const url = `https://${lang}.wikipedia.org/wiki/${encodeURIComponent(title.replace(/ /g, '_'))}`;
          return (
            <a data-testid="wikipedia-link" href={url} target="_blank" rel="noopener" class="external-link-card">
              <span class="external-link-icon" style="color: var(--color-text-muted)">W</span>
              <span>{title} — Wikipedia</span>
              <span class="external-link-arrow">&nearr;</span>
            </a>
          );
        })()}

        {/* OSM attribution */}
        {(page.osmRelationIds.length > 0 || page.osmNames.length > 0) && (
          <div data-testid="osm-attribution" class="bike-path-osm">
            <span>{t('paths.osm_attribution', locale)} <a href="https://openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>.</span>
            {page.ymlEntries.map(entry => (
              entry.osm_relations?.length
                ? entry.osm_relations.map(id => (
                    <a href={`https://openstreetmap.org/relation/${id}`} target="_blank" rel="noopener">
                      {entry.name} — relation {id} ↗
                    </a>
                  ))
                : entry.osm_names?.length
                  ? <a href={`https://openstreetmap.org/search?query=${encodeURIComponent(entry.osm_names[0])}`} target="_blank" rel="noopener">
                      {entry.name} — {t('paths.osm_search', locale)} ↗
                    </a>
                  : null
            ))}
          </div>
        )}
      </aside>
    </div>

    {/* Back link — member goes to network, network is bare <a>, standalone wraps in <p> */}
    <div data-testid="back-link">
      {isMember && networkPage ? (
        <a href={paths.bikePath(networkPage.slug, undefined, locale)} class="go-back-button">&#x21A9; {networkName}</a>
      ) : isMember ? (
        <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
      ) : isNetwork ? (
        <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
      ) : (
        <p style="margin-top: 2em;">
          <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
        </p>
      )}
    </div>
  </div>
</Base>

{/* Network-only: photo -> map interaction script */}
{isNetwork && (
  <script>
    document.querySelectorAll<HTMLElement>('.bike-path-photo[data-photo-key]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.photoKey!;
        const lat = Number(btn.dataset.photoLat);
        const lng = Number(btn.dataset.photoLng);
        document.dispatchEvent(new CustomEvent('map:show-photo', { detail: { key, lat, lng } }));
      });
    });
  </script>
)}
