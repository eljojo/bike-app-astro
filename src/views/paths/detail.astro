---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import type { SluggedBikePathYml } from '@/lib/bike-paths/bikepaths-yml';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  return pages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props { page: BikePathPage }
const { page } = Astro.props;
const config = getCityConfig();
const descriptionHtml = page.body ? await renderMarkdownHtml(page.body) : null;

function computeCenter(entries: SluggedBikePathYml[]): [number, number] | undefined {
  const anchors = entries.flatMap(e => e.anchors ?? []);
  if (anchors.length === 0) return undefined;
  const lats = anchors.map(a => typeof a === 'object' && 'lat' in a ? a.lat : a[1]);
  const lngs = anchors.map(a => typeof a === 'object' && 'lng' in a ? a.lng : a[0]);
  return [
    lats.reduce((s, v) => s + v, 0) / lats.length,
    lngs.reduce((s, v) => s + v, 0) / lngs.length,
  ];
}
---

<Base title={`${page.name} | ${config.display_name}`}>
  <div class="bike-path-detail">
    <div class="bike-path-header">
      <div class="bike-path-info">
        <h1>{page.name}</h1>
        {page.vibe && <p class="bike-path-vibe">{page.vibe}</p>}

        <div class="bike-path-facts">
          {page.surface && <span class="fact">Surface: {page.surface}</span>}
          {page.width && <span class="fact">Width: {page.width}m</span>}
          {page.lit && <span class="fact">{page.lit === 'yes' ? 'Lit' : 'Unlit'}</span>}
          {page.operator && <span class="fact">Maintained by {page.operator}</span>}
        </div>

        {page.osmRelationIds.length > 0 && (
          <div class="bike-path-osm">
            <span>Path data from <a href="https://openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>.</span>
            {page.ymlEntries.map(entry => (
              entry.osm_relations?.map(id => (
                <a href={`https://openstreetmap.org/relation/${id}`} target="_blank" rel="noopener">
                  {entry.name} — relation {id} ↗
                </a>
              ))
            ))}
          </div>
        )}
      </div>

      <BikePathMap
        osmRelationIds={page.osmRelationIds}
        center={computeCenter(page.ymlEntries)}
      />
    </div>

    {descriptionHtml && (
      <div class="bike-path-description" set:html={descriptionHtml} />
    )}
  </div>
</Base>
