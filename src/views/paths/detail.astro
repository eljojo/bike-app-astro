---
export const prerender = true;
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { loadBuildPlan, filterByBuildPlan } from '@/lib/content/build-plan.server';
import BikePathDetail from './BikePathDetail.astro';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  // Only standalone pages (destination rule) get their own route — not network pages
  const standalonePaths = pages.filter(p => p.standalone && p.memberOf === undefined && !p.memberRefs);
  const filtered = filterByBuildPlan(
    standalonePaths.map(p => ({ ...p, id: p.slug })),
    loadBuildPlan(),
    'bike-path',
  );
  // Build network slug → name lookup for "Connects to" display
  const networkNames: Record<string, string> = {};
  for (const p of pages) {
    if (p.memberRefs && p.memberRefs.length > 0) networkNames[p.slug] = p.name;
  }
  return filtered.map(page => ({
    params: { slug: page.slug },
    props: { page, networkNames },
  }));
}

interface Props { page: BikePathPage; networkNames: Record<string, string> }
const { page, networkNames } = Astro.props;
---

<BikePathDetail page={page} networkNames={networkNames} />
