---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData, routePassesNearPath, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import RoutesOnPath from '@/components/RoutesOnPath.astro';
import NearbyPaths from '@/components/NearbyPaths.astro';
import { t } from '@/i18n';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { loadRouteData } from '@/lib/route-data';
import { isPublished } from '@/lib/content/content-filters';
import { haversineM, findNearbyPlaces } from '@/lib/geo/proximity';
import type { NearbyPlace } from '@/lib/geo/proximity';

interface RouteCard {
  slug: string;
  name: string;
  distance_km: number;
  coverKey?: string;
}

interface NearbyPathItem {
  slug: string;
  name: string;
  surface?: string;
}

interface ConnectedPathItem {
  slug: string;
  name: string;
  surface?: string;
}

export async function getStaticPaths() {
  const [{ pages }, { routes, placeData }] = await Promise.all([
    loadBikePathData(),
    loadRouteData(),
  ]);

  const publishedRoutes = routes.filter(isPublished);

  return pages.map(page => {
    // page.points has geographic coordinates from YML anchors OR sampled GeoJSON geometry
    const pts = page.points;

    // Find routes that pass near this path
    const overlappingRoutes: RouteCard[] = pts.length > 0
      ? publishedRoutes.filter(r => {
          const gpxKey = r.data.variants?.[0]?.gpx;
          const track = gpxKey ? r.data.gpxTracks[gpxKey] : null;
          if (!track?.points || track.points.length === 0) return false;
          return routePassesNearPath(track.points, pts);
        }).map(r => {
          const cover = r.data.media.find((m: { cover?: boolean }) => m.cover);
          return {
            slug: r.id,
            name: r.data.name,
            distance_km: r.data.distance_km,
            coverKey: cover?.key,
          };
        })
      : [];

    // Find nearby places
    const trackPoints = pts.map(a => ({ lat: a.lat, lon: a.lng }));
    const nearbyPlaces: NearbyPlace[] = trackPoints.length >= 2
      ? findNearbyPlaces(trackPoints, placeData)
      : [];

    // Find nearby paths: other pages whose points are within 2km
    const nearbyPathsList: NearbyPathItem[] = pts.length > 0
      ? pages.filter(other => {
          if (other.slug === page.slug) return false;
          if (other.points.length === 0) return false;
          for (const a of pts) {
            for (const b of other.points) {
              if (haversineM(a.lat, a.lng, b.lat, b.lng) < 2000) return true;
            }
          }
          return false;
        }).map(p => ({ slug: p.slug, name: p.name, surface: p.surface }))
      : [];

    // Connected = another path's first or last point is within 200m of
    // this path's first or last point (they meet at a junction)
    const pathEndpoints = pts.length >= 2
      ? [pts[0], pts[pts.length - 1]]
      : pts.slice(0, 1);

    const connectedPaths: ConnectedPathItem[] = pathEndpoints.length > 0
      ? pages.filter(other => {
          if (other.slug === page.slug) return false;
          if (other.points.length === 0) return false;
          const otherEndpoints = other.points.length >= 2
            ? [other.points[0], other.points[other.points.length - 1]]
            : other.points.slice(0, 1);
          for (const ep of pathEndpoints) {
            for (const oep of otherEndpoints) {
              if (haversineM(ep.lat, ep.lng, oep.lat, oep.lng) < 200) return true;
            }
          }
          return false;
        }).map(p => ({ slug: p.slug, name: p.name, surface: p.surface }))
      : [];

    return {
      params: { slug: page.slug },
      props: { page, overlappingRoutes, nearbyPlaces, nearbyPaths: nearbyPathsList, connectedPaths },
    };
  });
}

interface Props {
  page: BikePathPage;
  overlappingRoutes: RouteCard[];
  nearbyPlaces: NearbyPlace[];
  nearbyPaths: NearbyPathItem[];
  connectedPaths: ConnectedPathItem[];
}
const { page, overlappingRoutes, nearbyPlaces, nearbyPaths, connectedPaths } = Astro.props;
const config = getCityConfig();
const locale = Astro.currentLocale;
const descriptionHtml = page.body ? await renderMarkdownHtml(page.body) : null;

function computeCenter(pts: Array<{ lat: number; lng: number }>): [number, number] | undefined {
  if (pts.length === 0) return undefined;
  const lat = pts.reduce((s, p) => s + p.lat, 0) / pts.length;
  const lng = pts.reduce((s, p) => s + p.lng, 0) / pts.length;
  return [lat, lng];
}

const fallbackCenter: [number, number] = [config.center.lat, config.center.lng];
---

<Base title={`${page.name} | ${config.display_name}`}>
  <div class="bike-path-detail">
    <div class="bike-path-header">
      <div class="bike-path-info">
        <h1>{page.name}</h1>
        {page.vibe && <p class="bike-path-vibe">{page.vibe}</p>}

        <div class="bike-path-facts">
          {page.surface && <span class="fact">{t('paths.surface', locale)}: {page.surface}</span>}
          {page.width && <span class="fact">{t('paths.width', locale)}: {page.width}m</span>}
          {page.lit && <span class="fact">{page.lit === 'yes' ? t('paths.lit', locale) : t('paths.unlit', locale)}</span>}
          {page.operator && <span class="fact">{t('paths.maintained_by', locale, { operator: page.operator })}</span>}
        </div>
      </div>

      <BikePathMap
        osmRelationIds={page.osmRelationIds}
        center={computeCenter(page.points)}
        fallbackCenter={fallbackCenter}
        hintText={t('paths.click_to_explore', locale)}
        closeLabel={t('paths.close_map', locale)}
      />
    </div>

    {descriptionHtml && (
      <div class="bike-path-description" set:html={descriptionHtml} />
    )}

    <RoutesOnPath routes={overlappingRoutes} locale={locale} />

    {overlappingRoutes.some(r => r.coverKey) && (
      <section class="bike-path-photos">
        <h2>{t('paths.photos', locale)}</h2>
        <div class="bike-path-photo-grid">
          {overlappingRoutes.filter(r => r.coverKey).map(r => (
            <a href={paths.route(r.slug, locale)} class="bike-path-photo">
              <img
                src={imageUrl(r.coverKey!, { width: 300, height: 200, fit: 'cover' })}
                srcset={`${imageUrl(r.coverKey!, { width: 600, height: 400, fit: 'cover' })} 2x`}
                alt={r.name}
                width="300"
                height="200"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </section>
    )}

    {nearbyPlaces.length > 0 && (
      <NearbyPlaces nearby={nearbyPlaces} limit={8} />
    )}

    <NearbyPaths nearbyPaths={nearbyPaths} locale={locale} />

    {connectedPaths.length > 0 && (
      <section class="connected-paths">
        <h2>{t('paths.connects_to', locale)}</h2>
        <ul class="connected-paths-list">
          {connectedPaths.map(p => (
            <li>
              <a href={paths.bikePath(p.slug, locale)}>{p.name}</a>
              {p.surface && <span class="path-meta">{p.surface}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {page.osmRelationIds.length > 0 && (
      <div class="bike-path-osm">
        <span>{t('paths.osm_attribution', locale)} <a href="https://openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>.</span>
        {page.ymlEntries.map(entry => (
          entry.osm_relations?.map(id => (
            <a href={`https://openstreetmap.org/relation/${id}`} target="_blank" rel="noopener">
              {entry.name} — relation {id} ↗
            </a>
          ))
        ))}
      </div>
    )}
  </div>
</Base>
