---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import RoutesOnPath from '@/components/RoutesOnPath.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import NearbyPaths from '@/components/NearbyPaths.astro';
import { t } from '@/i18n';
import { paths, assets } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { hasCachedMap } from '@/lib/maps/map-thumbnails';
import EditEntryPoint from '@/components/EditEntryPoint.astro';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  return pages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props { page: BikePathPage }
const { page } = Astro.props;
const { overlappingRoutes, nearbyPhotos, nearbyPlaces, nearbyPaths, connectedPaths } = page;
const config = getCityConfig();
const locale = Astro.currentLocale;
const descriptionHtml = page.body ? await renderMarkdownHtml(page.body) : null;

function computeCenter(pts: Array<{ lat: number; lng: number }>): [number, number] | undefined {
  if (pts.length === 0) return undefined;
  const lat = pts.reduce((s, p) => s + p.lat, 0) / pts.length;
  const lng = pts.reduce((s, p) => s + p.lng, 0) / pts.length;
  return [lat, lng];
}

const fallbackCenter: [number, number] = [config.center.lat, config.center.lng];

// Build factual prose from metadata — no opinions, just what the data says
function buildPathFacts(p: BikePathPage): string[] {
  const facts: string[] = [];

  // Surface + width combined
  const surfaceMap: Record<string, string> = {
    asphalt: t('paths.fact.paved', locale),
    concrete: t('paths.fact.paved', locale),
    fine_gravel: t('paths.fact.gravel', locale),
    gravel: t('paths.fact.gravel', locale),
    ground: t('paths.fact.dirt', locale),
    dirt: t('paths.fact.dirt', locale),
  };
  const surfaceLabel = p.surface ? surfaceMap[p.surface] || p.surface : null;
  if (surfaceLabel && p.width) {
    facts.push(`${surfaceLabel}, ${p.width}m ${t('paths.fact.wide', locale)}`);
  } else if (surfaceLabel) {
    facts.push(surfaceLabel);
  } else if (p.width) {
    facts.push(`${p.width}m ${t('paths.fact.wide', locale)}`);
  }

  // Separated from cars (cycleway = dedicated infrastructure)
  if (p.highway === 'cycleway') {
    facts.push(t('paths.fact.separated_cars', locale));
  }

  // Separated from pedestrians
  if (p.segregated === 'yes') {
    facts.push(t('paths.fact.separated_peds', locale));
  }

  // Lit
  if (p.lit === 'yes') {
    facts.push(t('paths.fact.lit', locale));
  } else if (p.lit === 'no') {
    facts.push(t('paths.fact.not_lit', locale));
  }

  // Elevation
  if (p.elevation_gain_m != null) {
    if (p.elevation_gain_m < 20) {
      facts.push(t('paths.fact.flat', locale));
    } else if (p.elevation_gain_m < 80) {
      facts.push(t('paths.fact.gentle_hills', locale, { meters: String(p.elevation_gain_m) }));
    } else {
      facts.push(t('paths.fact.hilly', locale, { meters: String(p.elevation_gain_m) }));
    }
  }

  // Operator
  if (p.operator) {
    facts.push(t('paths.fact.maintained', locale, { operator: p.operator }));
  }

  // Network
  const networkMap: Record<string, string> = {
    rcn: t('paths.fact.network_regional', locale),
    ncn: t('paths.fact.network_national', locale),
    lcn: t('paths.fact.network_local', locale),
  };
  if (p.network && networkMap[p.network]) {
    facts.push(networkMap[p.network]);
  }

  return facts;
}

const surfaceLabels: Record<string, string> = {
  asphalt: t('paths.fact.paved', locale),
  concrete: t('paths.fact.paved', locale),
  fine_gravel: t('paths.fact.gravel', locale),
  gravel: t('paths.fact.gravel', locale),
  ground: t('paths.fact.dirt', locale),
  dirt: t('paths.fact.dirt', locale),
  compacted: t('paths.fact.gravel', locale),
};
function displaySurface(raw?: string): string | undefined {
  return raw ? surfaceLabels[raw] || raw : undefined;
}

const pathFacts = buildPathFacts(page);

const networkLabels: Record<string, string> = {
  rcn: t('paths.fact.network_regional', locale),
  ncn: t('paths.fact.network_national', locale),
  lcn: t('paths.fact.network_local', locale),
};
const networkLabel = page.network ? (networkLabels[page.network] || page.network) : undefined;

// SEO
const seoDescription = page.vibe || (pathFacts.length > 0 ? pathFacts.join('. ') + '.' : `${page.name} — cycling path`);
// Prefer generated map thumbnail (path-{slug}/map-social.jpg), fall back to route cover photo
const hasMapThumb = hasCachedMap(`path-${page.slug}`);
const mapThumbUrl = hasMapThumb ? assets.mapSocial(`path-${page.slug}`) : undefined;
const firstCoverKey = overlappingRoutes.find(r => r.coverKey)?.coverKey;
const ogImage = mapThumbUrl || (firstCoverKey ? imageUrl(firstCoverKey, { width: 1200, height: 630, fit: 'cover' }) : undefined);
---

<Base title={`${page.name} | ${config.display_name}`} description={seoDescription} ogImage={ogImage}>
  <div class="bike-path-detail">
    <h1>
      {page.name}
      <a href={`/admin/paths/${page.slug}`} class="admin-edit-link" aria-label="Edit this path">Edit</a>
    </h1>
    {page.vibe && <p class="bike-path-vibe">{page.vibe}</p>}

    <div class="bike-path-layout">
      {/* ===== Main column ===== */}
      <div class="bike-path-main">
        {(page.stub || !page.hasMarkdown) && (
          <p class="bike-path-stub-cta">
            {t('paths.stub_cta', locale)} <a href={`/admin/paths/${page.slug}`}>{t('paths.stub_cta_link', locale)}</a>
          </p>
        )}

        {descriptionHtml && (
          <div class="bike-path-description" set:html={descriptionHtml} />
        )}

        <EditEntryPoint text={t('paths.edit_description', locale)} href={`/admin/paths/${page.slug}`} />

        <RoutesOnPath routes={overlappingRoutes} locale={locale} />

        {nearbyPhotos.length > 0 && (
          <section class="bike-path-photos">
            <h2>{t('paths.photos', locale)}</h2>
            <div class="bike-path-photo-grid">
              {nearbyPhotos.map(photo => (
                <a href={`${paths.route(photo.routeSlug, locale)}?photo=${encodeURIComponent(photo.key)}#photos`} class="bike-path-photo">
                  <img
                    src={imageUrl(photo.key, { width: 300, height: 200, fit: 'cover' })}
                    srcset={`${imageUrl(photo.key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                    alt={photo.caption || page.name}
                    width="300"
                    height="200"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      {/* ===== Sidebar (infobox) ===== */}
      <aside class="bike-path-sidebar">
        <BikePathMap
          geoFiles={page.geoFiles}
          center={computeCenter(page.points)}
          fallbackCenter={fallbackCenter}
          hintText={t('paths.click_to_explore', locale)}
          closeLabel={t('paths.close_map', locale)}
          photos={nearbyPhotos.filter(p => p.lat && p.lng)}
          places={nearbyPlaces.map(p => ({ name: p.name, lat: p.lat, lng: p.lng, category: p.category }))}
          cdnUrl={config.cdn_url}
        />

        {/* Facts table */}
        <table class="bike-path-facts-table">
          {page.surface && (
            <tr><td>{t('paths.label.surface', locale)}</td><td>{displaySurface(page.surface)}{page.width ? `, ${page.width}m` : ''}</td></tr>
          )}
          {page.highway === 'cycleway' && (
            <tr><td>{t('paths.label.separated', locale)}</td><td>{t('paths.fact.separated_cars', locale)}</td></tr>
          )}
          {page.lit && (
            <tr><td>{t('paths.label.lit', locale)}</td><td>{page.lit === 'yes' ? t('paths.lit_yes', locale) : t('paths.lit_no', locale)}</td></tr>
          )}
          {page.operator && (
            <tr><td>{t('paths.label.operator', locale)}</td><td>{page.operator}</td></tr>
          )}
          {networkLabel && (
            <tr><td>{t('paths.label.network', locale)}</td><td>{networkLabel}</td></tr>
          )}
        </table>

        {nearbyPlaces.length > 0 && (
          <NearbyPlaces nearby={nearbyPlaces} limit={8} />
        )}

        {connectedPaths.length > 0 && (
          <section class="connected-paths">
            <h2>{t('paths.connects_to', locale)}</h2>
            <ul class="connected-paths-list">
              {connectedPaths.map(p => (
                <li>
                  <a href={paths.bikePath(p.slug, locale)}>{p.name}</a>
                  {displaySurface(p.surface) && <span class="path-meta">{displaySurface(p.surface)}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}

        {(() => {
          const connectedSlugs = new Set(connectedPaths.map(p => p.slug));
          const filtered = nearbyPaths.filter(p => !connectedSlugs.has(p.slug));
          return filtered.length > 0 ? <NearbyPaths nearbyPaths={filtered} locale={locale} /> : null;
        })()}

        {/* External links */}
        <div class="bike-path-links">
          {page.wikipedia && (() => {
            const [lang, ...titleParts] = page.wikipedia.split(':');
            const title = titleParts.join(':');
            const url = `https://${lang}.wikipedia.org/wiki/${encodeURIComponent(title.replace(/ /g, '_'))}`;
            return <a href={url} target="_blank" rel="noopener">{title} — Wikipedia ↗</a>;
          })()}

          {(page.osmRelationIds.length > 0 || page.osmNames.length > 0) && (
            <div class="bike-path-osm">
              <span>{t('paths.osm_attribution', locale)} <a href="https://openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>.</span>
              {page.ymlEntries.map(entry => (
                entry.osm_relations?.length
                  ? entry.osm_relations.map(id => (
                      <a href={`https://openstreetmap.org/relation/${id}`} target="_blank" rel="noopener">
                        {entry.name} — relation {id} ↗
                      </a>
                    ))
                  : entry.osm_names?.length
                    ? <a href={`https://openstreetmap.org/search?query=${encodeURIComponent(entry.osm_names[0])}`} target="_blank" rel="noopener">
                        {entry.name} — {t('paths.osm_search', locale)} ↗
                      </a>
                    : null
              ))}
            </div>
          )}
        </div>
      </aside>
    </div>

    <p style="margin-top: 2em;">
      <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
    </p>
  </div>
</Base>
