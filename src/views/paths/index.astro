---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { hasCachedMap } from '@/lib/maps/map-thumbnails';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { t, localePath } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;
const { pages: allPages } = await loadBikePathData();
// Directory listing: only listed paths (score >= threshold), excluding very short ones
const pages = allPages.filter(p => p.listed && (!p.length_km || p.length_km >= 1));

// Locale-aware accessors
function pathName(p: typeof pages[0]): string {
  return (locale && p.translations[locale]?.name) || p.name;
}
function pathVibe(p: typeof pages[0]): string | undefined {
  return (locale && p.translations[locale]?.vibe) || p.vibe;
}

// All paths are interactive (clickable → navigate to detail page).
// Listed paths render bold; unlisted paths render subtle but still clickable.
const interactiveRelIds = new Set<string>();
const listedRelIds = new Set<string>();
const relationToSlug: Record<string, string> = {};
// Pre-compute slug → URL so client-side click handlers use correct (potentially nested) URLs
const slugToUrl: Record<string, string> = {};
for (const p of allPages) {
  slugToUrl[p.slug] = paths.bikePath(p.slug, p.memberOf, locale);
  for (const relId of p.osmRelationIds) {
    relationToSlug[String(relId)] = p.slug;
    interactiveRelIds.add(String(relId));
    if (p.listed) listedRelIds.add(String(relId));
  }
  // Also map name-based and segment-based geo files
  for (const gf of p.geoFiles) {
    const geoId = gf.replace(/\.geojson$/, '');
    relationToSlug[geoId] = p.slug;
    interactiveRelIds.add(geoId);
    if (p.listed) listedRelIds.add(geoId);
  }
}


// Featured: paths with markdown descriptions, or networks with some content
const featured = pages.filter(p => p.featured
  || (p.memberRefs && p.memberRefs.length > 0 && (p.body || p.vibe || p.thumbnail_key)));

// Separate network pages, member paths, and standalone paths
const networkPages = pages.filter(p => p.memberRefs && p.memberRefs.length > 0);
const memberSlugs = new Set(networkPages.flatMap(n => (n.memberRefs ?? []).map(m => m.slug)));
const standalonePaths = pages.filter(p => !p.memberRefs && !memberSlugs.has(p.slug));

// Group standalone paths by operator
type PathGroup = { label: string; paths: typeof pages; isNetwork?: boolean; networkSlug?: string; memberRefs?: typeof pages[0]['memberRefs'] };
const operatorMap = new Map<string, typeof pages>();

for (const p of standalonePaths) {
  const key = p.operator || '';
  const list = operatorMap.get(key);
  if (list) {
    list.push(p);
  } else {
    operatorMap.set(key, [p]);
  }
}

const groups: PathGroup[] = [];

// Networks first — as expandable sections
for (const net of networkPages) {
  groups.push({
    label: net.name,
    paths: [net],
    isNetwork: true,
    networkSlug: net.slug,
    memberRefs: net.memberRefs,
  });
}

// Then operator groups for standalone paths
const sortedEntries = [...operatorMap.entries()].sort((a, b) => {
  if (a[0] === '') return 1;
  if (b[0] === '') return -1;
  return b[1].length - a[1].length;
});

for (const [operator, pathsList] of sortedEntries) {
  groups.push({
    label: operator || t('paths.other_group', locale),
    paths: pathsList,
  });
}

const surfaceLabels: Record<string, string> = {
  asphalt: t('paths.fact.paved', locale),
  concrete: t('paths.fact.paved', locale),
  fine_gravel: t('paths.fact.gravel', locale),
  gravel: t('paths.fact.gravel', locale),
  ground: t('paths.fact.dirt', locale),
  dirt: t('paths.fact.dirt', locale),
  compacted: t('paths.fact.gravel', locale),
};
function displaySurface(raw?: string): string | undefined {
  return raw ? surfaceLabels[raw] || raw : undefined;
}

const mapCenter: [number, number] = [config.center.lat, config.center.lng];
const seoDescription = t('paths.seo_description', locale, { count: String(pages.length), city: config.name });
const ogImage = config.page_posters?.map ? imageUrl(config.page_posters.map, { width: 1200, height: 630, fit: 'cover' }) : undefined;
---

<Base title={`${t('paths.page_title', locale, { city: config.name })} | ${config.display_name}`} description={seoDescription} ogImage={ogImage}>
  <SubTabToggle items={[
    { label: t('nav.routes', locale), href: localePath('/routes', locale), active: false },
    { label: t('nav.bike_paths', locale), href: paths.bikePaths(locale), active: true },
  ]} />
  <div class="paths-index">
    <h1>{t('paths.heading', locale, { city: config.name })}</h1>

    {featured.length > 0 && (
      <section class="paths-featured">
        <h2>{t('paths.featured', locale)}</h2>
        <div class="featured-cards">
          {featured.map(p => {
            const thumb = p.thumbnail_key;
            const mapThumb = hasCachedMap(`path-${p.slug}`) ? `/maps/path-${p.slug}/map-750.webp` : undefined;
            const thumbSrc = thumb
              ? imageUrl(thumb, { width: 750, height: 375, fit: 'cover' })
              : mapThumb;
            const thumbSrcset = thumb
              ? `${imageUrl(thumb, { width: 1500, height: 750, fit: 'cover' })} 2x`
              : undefined;
            return (
              <a href={paths.bikePath(p.slug, p.memberOf, locale)} class="path-card">
                {thumbSrc && (
                  <img
                    src={thumbSrc}
                    srcset={thumbSrcset}
                    alt={pathName(p)}
                    loading="lazy"
                    class="path-card-photo"
                  />
                )}
                <h3>{pathName(p)}</h3>
                {pathVibe(p) && <p class="path-vibe">{pathVibe(p)}</p>}
                <span class="path-card-meta">
                  {displaySurface(p.surface) && <span class="path-surface">{displaySurface(p.surface)}</span>}
                  {p.routeCount > 0 && <span class="path-routes-count">{t('paths.routes_count', locale, { count: String(p.routeCount) })}</span>}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {/* TODO: add MTB trail filter toggle on the map — entries have mtb: true (125 in Ottawa) */}
    {allPages.length > 0 && (
      <div class="paths-map-hero-wrapper">
        <div
          class="paths-map-hero"
          id="paths-network-map"
          data-center={JSON.stringify(mapCenter)}
          data-relation-slugs={JSON.stringify(relationToSlug)}
          data-slug-urls={JSON.stringify(slugToUrl)}
          data-interactive-ids={JSON.stringify([...interactiveRelIds])}
          data-listed-ids={JSON.stringify([...listedRelIds])}
          style="height: 400px; background: var(--color-surface-alt, #f0f0f0);"
        ></div>
        <div class="map-touch-lock" id="paths-map-touch-lock">
          <span class="map-touch-label">{t('paths.tap_to_explore', locale)}</span>
        </div>
      </div>
    )}

    {groups.map(group => (
      <section class:list={['paths-group', { 'paths-group--network': group.isNetwork }]}>
        {group.isNetwork ? (
          <h2>
            <a href={paths.bikePath(group.networkSlug!, undefined, locale)}>{group.label}</a>
            {group.paths[0]?.length_km && <span class="path-meta">{group.paths[0].length_km} km</span>}
            {group.paths[0]?.operator && <span class="path-meta">{group.paths[0].operator}</span>}
          </h2>
        ) : (
          <h2>{group.label}</h2>
        )}
        {group.isNetwork && group.memberRefs ? (
          <ul class="paths-list paths-list--members">
            {group.memberRefs.map(m => (
              <li>
                {m.standalone ? (
                  <a href={paths.bikePath(m.slug, group.networkSlug, locale)}>{m.name}</a>
                ) : (
                  <span class="non-standalone">{m.name}</span>
                )}
                {m.length_km && <span class="path-meta">{m.length_km} km</span>}
              </li>
            ))}
          </ul>
        ) : (
          <ul class="paths-list">
            {group.paths.map(p => (
              <li data-slug={p.slug} id={`path-${p.slug}`}>
                <a href={paths.bikePath(p.slug, p.memberOf, locale)}>
                  {pathName(p)}
                </a>
                {displaySurface(p.surface) && <span class="path-meta">{displaySurface(p.surface)}</span>}
                {p.routeCount > 0 && <span class="path-meta">{t('paths.routes_count', locale, { count: String(p.routeCount) })}</span>}
              </li>
            ))}
          </ul>
        )}
      </section>
    ))}

    <p class="paths-osm-attribution">
      {t('paths.index_osm_attribution', locale)} <a href="https://www.openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>. {t('paths.index_osm_edit', locale)}
    </p>
  </div>
</Base>

<script>
  import { initMap, ROUTE_COLOR, ROUTE_LINE_WIDTH } from '../../lib/maps/map-init';
  import { loadStylePreference, getStyleUrl } from '../../lib/maps/map-style-switch';
  import { setupMapTouchLock } from '../../lib/maps/map-touch-lock';
  import { createTileLoader, type TileLoader } from '../../lib/maps/tile-loader';
  import maplibregl from 'maplibre-gl';

  const PATH_WIDTH = ROUTE_LINE_WIDTH;
  const PATH_WIDTH_UNLISTED = Math.max(2, ROUTE_LINE_WIDTH - 2);
  const PATH_WIDTH_HOVER = ROUTE_LINE_WIDTH + 2;

  const container = document.getElementById('paths-network-map');
  if (container) {
    const center: [number, number] = JSON.parse(container.dataset.center || '[0,0]');
    const relationSlugs: Record<string, string> = JSON.parse(container.dataset.relationSlugs || '{}');
    const slugUrls: Record<string, string> = JSON.parse(container.dataset.slugUrls || '{}');
    const interactiveIds = new Set<string>(JSON.parse(container.dataset.interactiveIds || '[]'));
    const listedIds = new Set<string>(JSON.parse(container.dataset.listedIds || '[]'));

    const styleKey = loadStylePreference();
    const map = initMap({ el: container, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

    setupMapTouchLock(map, document.getElementById('paths-map-touch-lock'));

    function enrichFeatures(features: GeoJSON.Feature[]) {
      for (const f of features) {
        const geoId = f.properties?._geoId;
        if (!geoId) continue;
        const slug = relationSlugs[geoId] || geoId;
        const interactive = interactiveIds.has(geoId);
        const listed = listedIds.has(geoId);
        f.properties!.slug = slug;
        f.properties!.relationId = geoId;
        f.properties!.interactive = interactive ? 'true' : '';
        f.properties!.listed = listed ? 'true' : '';
      }
    }

    let layersSetUp = false;
    let prevFeatureCount = 0;

    function setupPathsLayers(features: GeoJSON.Feature[]) {
      map.addSource('paths-network', {
        type: 'geojson',
        data: { type: 'FeatureCollection', features },
      });

      // Unlisted paths: thinner, lower opacity, but still clickable
      map.addLayer({
        id: 'paths-network-bg',
        type: 'line',
        source: 'paths-network',
        filter: ['all', ['==', ['get', 'interactive'], 'true'], ['!=', ['get', 'listed'], 'true']],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': ROUTE_COLOR,
          'line-width': PATH_WIDTH_UNLISTED,
          'line-opacity': 0.5,
        },
      });

      // Listed paths: full width, bold
      map.addLayer({
        id: 'paths-network-line',
        type: 'line',
        source: 'paths-network',
        filter: ['==', ['get', 'listed'], 'true'],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': ROUTE_COLOR,
          'line-width': PATH_WIDTH,
          'line-opacity': 0.8,
        },
      });

      // --- Map interaction ---

      // Click on any path → navigate to detail page
      function handlePathClick(e: maplibregl.MapMouseEvent & { features?: maplibregl.MapGeoJSONFeature[] }) {
        if (!e.features?.length) return;
        const slug = e.features[0].properties?.slug;
        if (slug) window.location.href = slugUrls[slug] || `/bike-paths/${slug}`;
      }
      map.on('click', 'paths-network-line', handlePathClick);
      map.on('click', 'paths-network-bg', handlePathClick);

      for (const layerId of ['paths-network-line', 'paths-network-bg']) {
        map.on('mouseenter', layerId, () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', layerId, () => { map.getCanvas().style.cursor = ''; });
      }

      // List hover → highlight path on map
      let hoveredSlug: string | null = null;

      function highlightPath(slug: string | null) {
        if (hoveredSlug === slug) return;
        hoveredSlug = slug;
        if (slug) {
          map.setPaintProperty('paths-network-line', 'line-width', [
            'case',
            ['==', ['get', 'slug'], slug],
            PATH_WIDTH_HOVER,
            PATH_WIDTH,
          ]);
          map.setPaintProperty('paths-network-line', 'line-opacity', [
            'case',
            ['==', ['get', 'slug'], slug],
            1,
            0.4,
          ]);
        } else {
          map.setPaintProperty('paths-network-line', 'line-width', PATH_WIDTH);
          map.setPaintProperty('paths-network-line', 'line-opacity', 0.8);
        }
      }

      document.querySelectorAll<HTMLElement>('.paths-list li[data-slug]').forEach(li => {
        li.addEventListener('mouseenter', () => {
          highlightPath(li.dataset.slug || null);
        });
        li.addEventListener('mouseleave', () => {
          highlightPath(null);
        });
      });

      layersSetUp = true;
    }

    function getMapBounds(): [number, number, number, number] {
      const b = map.getBounds();
      return [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()];
    }

    map.on('load', async () => {
      let tileLoader: TileLoader;
      try {
        const res = await fetch('/bike-paths/geo/tiles/manifest.json');
        if (!res.ok) return;
        const manifest = await res.json();
        tileLoader = createTileLoader(manifest, '/bike-paths/geo/tiles/');
      } catch {
        return;
      }

      // Load initial tiles immediately — this page is about paths
      const features = await tileLoader.loadTilesForBounds(getMapBounds());
      enrichFeatures(features);
      prevFeatureCount = features.length;

      if (features.length > 0) {
        setupPathsLayers(features);
      }

      // On pan/zoom, load new tiles and update source if new features arrived
      map.on('moveend', async () => {
        const updated = await tileLoader.loadTilesForBounds(getMapBounds());
        if (updated.length === prevFeatureCount) return;

        enrichFeatures(updated);
        prevFeatureCount = updated.length;

        if (!layersSetUp) {
          if (updated.length > 0) setupPathsLayers(updated);
          return;
        }

        const source = map.getSource('paths-network') as maplibregl.GeoJSONSource;
        if (source) {
          source.setData({ type: 'FeatureCollection', features: updated });
        }
      });
    });
  }

</script>
