---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { t, localePath } from '@/i18n';
import { buildPathsIndexData } from '@/lib/bike-paths/paths-index-data.server';

const config = getCityConfig();
const locale = Astro.currentLocale;
const { pages: allPages } = await loadBikePathData();
const { categories, uncategorized, map: mapData, pathCount } = buildPathsIndexData({ allPages, locale, t });

const mapCenter: [number, number] = [config.center.lat, config.center.lng];
const seoDescription = t('paths.seo_description', locale, { count: String(pathCount), city: config.name });
const ogImage = config.page_posters?.map ? imageUrl(config.page_posters.map, { width: 1200, height: 630, fit: 'cover' }) : undefined;
---

<Base title={`${t('paths.page_title', locale, { city: config.name })} | ${config.display_name}`} description={seoDescription} ogImage={ogImage}>
  <SubTabToggle isIndex items={[
    { label: t('nav.routes', locale), href: localePath('/routes', locale), active: false },
    { label: t('nav.bike_paths', locale), href: paths.bikePaths(locale), active: true },
  ]} />
  <div class="paths-index">
    <h1>{t('paths.heading', locale, { city: config.name })}</h1>

    {categories.length > 0 && (
      <div class="paths-browse">
        {/* Sticky header: map + tabs stick as you scroll through panels */}
        <div class="paths-browse-header">
          <div class="paths-map-hero-wrapper">
            <div
              class="paths-map-hero"
              id="paths-network-map"
              data-center={JSON.stringify(mapCenter)}
              data-network-geo-ids={JSON.stringify(mapData.networkGeoIds)}
              data-category-geo-ids={JSON.stringify(mapData.categoryGeoIds)}
              data-slug-info={JSON.stringify(mapData.slugInfo)}
              data-slug-to-network={JSON.stringify(mapData.slugToNetwork)}
              data-network-bounds={JSON.stringify(mapData.networkBounds)}
              data-category-bounds={JSON.stringify(mapData.categoryBounds)}
              data-label-view-details={t('paths.view_details', locale)}
              data-label-clear-selection={t('paths.clear_selection', locale)}
              style="height: 400px; background: var(--color-surface-alt, #f0f0f0); transition: height 0.35s ease-out;"
            ></div>
            <div class="map-touch-lock" id="paths-map-touch-lock">
              <span class="map-touch-label">{t('paths.tap_to_explore', locale)}</span>
            </div>
          </div>
          <div class="network-tabs" id="network-tabs">
            {categories.map((cat, i) => (
              <button
                class:list={['network-tab', { active: i === 0 }]}
                data-network={cat.key}
              >{cat.label}</button>
            ))}
            <button class="network-tab network-tab--all" data-network="all">{t('paths.all_paths_tab', locale)}</button>
          </div>
        </div>

        {categories.map((cat, i) => (
          <div class:list={['network-panel', { active: i === 0 }]} data-panel={cat.key}>
            {cat.networks.map(net => (
              <div class="category-network-group">
                <div class="network-panel-header" data-slug={net.slug}>
                  <div class="network-panel-info">
                    <a href={net.url} class="network-panel-name">{net.name}</a>
                    {net.length_km && <span class="path-meta">{net.length_km} km</span>}
                    {net.operator && <span class="path-meta path-meta--operator">{net.operator}</span>}
                  </div>
                  <a href={net.url} class="network-panel-link">
                    {t('paths.view_network', locale)} &rarr;
                  </a>
                </div>

                {net.tier1.length > 0 && (
                  <ul class="paths-list">
                    {net.tier1.map(m => (
                      <li data-slug={m.slug}>
                        {m.url ? (
                          <a href={m.url} class="path-link">
                            <span class="path-link-name">{m.name}</span>
                            {m.length_km && <span class="path-meta">{m.length_km} km</span>}
                          </a>
                        ) : (
                          <span class="path-link">
                            <span class="path-link-name">{m.name}</span>
                            {m.length_km && <span class="path-meta">{m.length_km} km</span>}
                          </span>
                        )}
                      </li>
                    ))}
                  </ul>
                )}

                {net.tier2.length > 0 && (
                  <details class="network-tier2">
                    <summary class="network-tier2-label">
                      {t('paths.shorter_segments', locale, { count: String(net.tier2.length) })}
                      <span class="network-tier2-names">
                        {net.tier2.slice(0, 5).map((m, j) => (
                          <span>{m.name}{j < Math.min(4, net.tier2.length - 1) ? ', ' : ''}</span>
                        ))}
                        {net.tier2.length > 5 && <span class="network-tier2-ellipsis">&hellip;</span>}
                      </span>
                    </summary>
                    <ul class="network-members-list">
                      {net.tier2.map(m => (
                        <li data-slug={m.slug}>
                          {m.url ? (
                            <a href={m.url} class="network-member-link">
                              <span class="network-member-name">{m.name}</span>
                              {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                            </a>
                          ) : (
                            <span class="network-member-no-page">
                              <span class="network-member-name">{m.name}</span>
                              {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                            </span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </div>
            ))}

            {/* Standalone paths (not in any network) */}
            {cat.standalonePaths.length > 0 && (
              <div class="category-standalone-group">
                <h3 class="category-standalone-heading">{t('paths.standalone_heading', locale)}</h3>
                <ul class="paths-list">
                  {cat.standalonePaths.map(sp => (
                    <li data-slug={sp.slug}>
                      <a href={sp.url} class="path-link">
                        <span class="path-link-name">{sp.name}</span>
                        <span class="path-link-meta">
                          {sp.length_km && <span class="path-meta">{sp.length_km} km</span>}
                          {sp.surface && <span class="path-meta">{sp.surface}</span>}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))}

        <div class="network-panel" data-panel="all">
          <ul class="paths-list">
            {uncategorized.map(sp => (
              <li data-slug={sp.slug}>
                <a href={sp.url} class="path-link">
                  <span class="path-link-name">{sp.name}</span>
                  <span class="path-link-meta">
                    {sp.length_km && <span class="path-meta">{sp.length_km} km</span>}
                    {sp.surface && <span class="path-meta">{sp.surface}</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    <p class="paths-osm-attribution">
      {t('paths.index_osm_attribution', locale)} <a href="https://www.openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>. {t('paths.index_osm_edit', locale)}
    </p>
  </div>
</Base>

<script>
  import { createPathsBrowseMap } from '../../lib/maps/paths-browse-map';
  import { closePopup } from '../../lib/maps/map-init';

  const container = document.getElementById('paths-network-map');
  if (container) {
    const center: [number, number] = JSON.parse(container.dataset.center || '[0,0]');
    const mapCenter: [number, number] = [center[1], center[0]]; // [lng, lat] for MapLibre
    const slugInfo = JSON.parse(container.dataset.slugInfo || '{}');
    const networkGeoIds: Record<string, string[]> = JSON.parse(container.dataset.networkGeoIds || '{}');
    const categoryGeoIds: Record<string, string[]> = JSON.parse(container.dataset.categoryGeoIds || '{}');
    const slugToNetworkMap: Record<string, string> = JSON.parse(container.dataset.slugToNetwork || '{}');
    const networkBounds: Record<string, [number, number, number, number]> = JSON.parse(container.dataset.networkBounds || '{}');
    const categoryBounds: Record<string, [number, number, number, number]> = JSON.parse(container.dataset.categoryBounds || '{}');

    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    let flyBackFn: (() => void) | undefined;


    const { map, highlightGeoIds, unlockHighlight, isHighlightLocked } = createPathsBrowseMap({
      container,
      touchLockEl: document.getElementById('paths-map-touch-lock'),
      center,
      zoom: 11,
      compactHeight: 400,
      expandedHeight: 700,
      slugInfo,
      listSelector: '.paths-list li[data-slug], .network-members-list li[data-slug], .network-panel-header[data-slug]',
      slugToNetwork: slugToNetworkMap,
      networkGeoIds,
      labels: {
        viewDetails: container.dataset.labelViewDetails,
        clearSelection: container.dataset.labelClearSelection,
      },
      onHighlightClear: isMobile ? () => flyBackFn?.() : undefined,
      onReady: () => {
        // Activate first tab's highlight once layers are ready
        const activeTab = document.querySelector<HTMLButtonElement>('#network-tabs .network-tab.active');
        const activeSlug = activeTab?.dataset.network;
        if (activeSlug && activeSlug !== 'all') {
          const geoIds = categoryGeoIds[activeSlug] ?? networkGeoIds[activeSlug];
          highlightGeoIds(geoIds ?? null, false);
          fitToBounds(activeSlug);
        }
      },
    });

    /** Fit map to precomputed bounds for a network or category slug. */
    function fitToBounds(slug: string) {
      const bounds = categoryBounds[slug] ?? networkBounds[slug];
      if (!bounds) { map.flyTo({ center: mapCenter, zoom: 11, duration: 500 }); return; }
      const [minLng, minLat, maxLng, maxLat] = bounds;
      const opts: { padding: number; animate: boolean; duration: number; maxZoom?: number } = { padding: 60, animate: true, duration: 500 };
      if (slug === 'trails') opts.maxZoom = 10;
      map.fitBounds([[minLng, minLat], [maxLng, maxLat]], opts);
    }

    // --- Tab interaction (index-specific) ---
    const tabBar = document.getElementById('network-tabs');
    if (tabBar) {
      const tabs = tabBar.querySelectorAll<HTMLButtonElement>('.network-tab');
      const panels = document.querySelectorAll<HTMLElement>('.network-panel');

      function activateTab(networkSlug: string) {
        unlockHighlight();
        tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.network === networkSlug));
        panels.forEach(panel => panel.classList.toggle('active', panel.dataset.panel === networkSlug));
        closePopup(map);
        if (networkSlug === 'all') {
          highlightGeoIds(null);
          map.flyTo({ center: mapCenter, zoom: 11, duration: 500 });
        } else {
          const geoIds = categoryGeoIds[networkSlug] ?? networkGeoIds[networkSlug];
          highlightGeoIds(geoIds ?? null, false);
          fitToBounds(networkSlug);
        }
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const slug = tab.dataset.network;
          if (slug) activateTab(slug);
        });
        if (!isMobile) {
          tab.addEventListener('mouseenter', () => {
            if (isHighlightLocked()) return;
            const slug = tab.dataset.network;
            if (slug && slug !== 'all') {
              const geoIds = categoryGeoIds[slug] ?? networkGeoIds[slug];
              highlightGeoIds(geoIds ?? null, false);
              fitToBounds(slug);
            }
          });
          tab.addEventListener('mouseleave', () => {
            if (isHighlightLocked()) return;
            const activeTab = tabBar.querySelector<HTMLButtonElement>('.network-tab.active');
            const activeSlug = activeTab?.dataset.network;
            if (activeSlug && activeSlug !== 'all') {
              const geoIds = categoryGeoIds[activeSlug] ?? networkGeoIds[activeSlug];
              highlightGeoIds(geoIds ?? null);
            } else {
              highlightGeoIds(null);
            }
          });
        }
      });
    }

    // --- Fly back to category extent when leaving a group (not between items) ---
    function flyBackToCategory() {
      if (isHighlightLocked()) return;
      const activeTab = document.querySelector<HTMLButtonElement>('#network-tabs .network-tab.active');
      const activeSlug = activeTab?.dataset.network;
      if (activeSlug && activeSlug !== 'all') {
        fitToBounds(activeSlug);
      } else {
        map.flyTo({ center: mapCenter, zoom: 11, duration: 500 });
      }
    }
    flyBackFn = flyBackToCategory;

    if (!isMobile) {
      document.querySelectorAll<HTMLElement>('.category-network-group, .network-panel[data-panel="all"] .paths-list').forEach(group => {
        group.addEventListener('mouseleave', flyBackToCategory);
      });
    }
  }
</script>
