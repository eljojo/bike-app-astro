---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;
const { pages, geoFiles } = await loadBikePathData();

// Build operator → colour mapping for the map
const operatorSet = new Set<string>();
for (const p of pages) {
  if (p.operator) operatorSet.add(p.operator);
}
const operatorList = [...operatorSet].sort();
const operatorColorMap: Record<string, number> = {};
operatorList.forEach((op, i) => { operatorColorMap[op] = i; });

// Build slug → operator index for the map script
const slugOperatorMap: Record<string, number> = {};
for (const p of pages) {
  if (p.operator && operatorColorMap[p.operator] !== undefined) {
    slugOperatorMap[p.slug] = operatorColorMap[p.operator];
  }
}

// Build relation ID → slug mapping so the map script can tag features correctly
const relationToSlug: Record<string, string> = {};
for (const p of pages) {
  for (const relId of p.osmRelationIds) {
    relationToSlug[String(relId)] = p.slug;
  }
}


// Featured: paths with markdown descriptions
const featured = pages.filter(p => p.featured);

// Group by operator dynamically
type OperatorGroup = { label: string; paths: typeof pages };
const operatorMap = new Map<string, typeof pages>();

for (const p of pages) {
  const key = p.operator || '';
  const list = operatorMap.get(key);
  if (list) {
    list.push(p);
  } else {
    operatorMap.set(key, [p]);
  }
}

const groups: OperatorGroup[] = [];
// Sort groups: largest first, "Other" (empty operator) last
const sortedEntries = [...operatorMap.entries()].sort((a, b) => {
  if (a[0] === '') return 1;
  if (b[0] === '') return -1;
  return b[1].length - a[1].length;
});

for (const [operator, pathsList] of sortedEntries) {
  groups.push({
    label: operator || t('paths.other_group', locale),
    paths: pathsList,
  });
}

const mapCenter: [number, number] = [config.center.lat, config.center.lng];
const seoDescription = t('paths.seo_description', locale, { count: String(pages.length), city: config.name });
---

<Base title={`${t('paths.title', locale)} | ${config.display_name}`} description={seoDescription}>
  <div class="paths-index">
    {geoFiles.length > 0 && (
      <div
        class="paths-map-hero"
        id="paths-network-map"
        data-geo-files={JSON.stringify(geoFiles)}
        data-center={JSON.stringify(mapCenter)}
        data-slug-operators={JSON.stringify(slugOperatorMap)}
        data-relation-slugs={JSON.stringify(relationToSlug)}
        style="height: 400px; background: var(--color-surface-alt, #f0f0f0);"
      ></div>
    )}

    {featured.length > 0 && (
      <section class="paths-featured">
        <h2>{t('paths.featured', locale)}</h2>
        <div class="featured-cards">
          {featured.map(p => {
            const photoKey = p.photo_key;
            return (
              <a href={paths.bikePath(p.slug, locale)} class="path-card">
                {photoKey && (
                  <img
                    src={imageUrl(photoKey, { width: 400, height: 200, fit: 'cover' })}
                    srcset={`${imageUrl(photoKey, { width: 800, height: 400, fit: 'cover' })} 2x`}
                    alt={p.name}
                    width="400"
                    height="200"
                    loading="lazy"
                    class="path-card-photo"
                  />
                )}
                <h3>{p.name}</h3>
                {p.vibe && <p class="path-vibe">{p.vibe}</p>}
                <span class="path-card-meta">
                  {p.surface && <span class="path-surface">{p.surface}</span>}
                  {p.routeCount > 0 && <span class="path-routes-count">{t('paths.routes_count', locale, { count: String(p.routeCount) })}</span>}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {groups.map(group => (
      <section class="paths-group">
        <h2>{group.label}</h2>
        <ul class="paths-list">
          {group.paths.map(p => (
              <li data-slug={p.slug} id={`path-${p.slug}`}>
                <a href={paths.bikePath(p.slug, locale)}>
                  {p.name}
                </a>
                {p.surface && <span class="path-meta">{p.surface}</span>}
                {p.routeCount > 0 && <span class="path-meta">{t('paths.routes_count', locale, { count: String(p.routeCount) })}</span>}
              </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Base>

<script>
  import { initMap, TOUR_PALETTE, ROUTE_LINE_WIDTH } from '../../lib/maps/map-init';
  import { loadStylePreference, getStyleUrl } from '../../lib/maps/map-style-switch';

  const PATH_WIDTH_HOVER = ROUTE_LINE_WIDTH + 3;
  const DEFAULT_COLOR = '#888888';

  const container = document.getElementById('paths-network-map');
  if (container) {
    const geoFiles: string[] = JSON.parse(container.dataset.geoFiles || '[]');
    const center: [number, number] = JSON.parse(container.dataset.center || '[0,0]');
    const slugOperators: Record<string, number> = JSON.parse(container.dataset.slugOperators || '{}');
    const relationSlugs: Record<string, string> = JSON.parse(container.dataset.relationSlugs || '{}');

    if (geoFiles.length > 0) {
      const styleKey = loadStylePreference();
      const map = initMap({ el: container, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

      // Enable pan/zoom for interaction
      map.scrollZoom.disable();
      map.dragPan.enable();
      map.doubleClickZoom.disable();
      map.touchZoomRotate.disable();

      map.on('load', async () => {
        const allFeatures: GeoJSON.Feature[] = [];

        for (const file of geoFiles) {
          try {
            const res = await fetch(`/paths/geo/${file}`);
            if (!res.ok) continue;
            const geojson = await res.json();
            const relationId = file.replace(/\.geojson$/, '');
            const slug = relationSlugs[relationId] || relationId;
            const opIdx = slugOperators[slug];
            const color = opIdx !== undefined
              ? TOUR_PALETTE[opIdx % TOUR_PALETTE.length]
              : DEFAULT_COLOR;

            for (const feature of geojson.features) {
              feature.properties = feature.properties || {};
              feature.properties.slug = slug;
              feature.properties.relationId = relationId;
              feature.properties.color = color;

              allFeatures.push(feature);
            }
          } catch {
            // Missing file — fine
          }
        }

        if (allFeatures.length > 0) {
          map.addSource('paths-network', {
            type: 'geojson',
            data: { type: 'FeatureCollection', features: allFeatures },
          });

          map.addLayer({
            id: 'paths-network-line',
            type: 'line',
            source: 'paths-network',
            layout: { 'line-cap': 'round', 'line-join': 'round' },
            paint: {
              'line-color': ['get', 'color'],
              'line-width': ROUTE_LINE_WIDTH,
              'line-opacity': 0.8,
            },
          });

          // Don't fitBounds — use city center + zoom 11 (matching the big map)
          // so distant paths (Trans Canada to Montreal) don't zoom the map out

          // --- Map ↔ list interaction ---

          // Map click → scroll to list entry
          map.on('click', 'paths-network-line', (e) => {
            if (!e.features?.length) return;
            const slug = e.features[0].properties?.slug;
            if (!slug) return;
            const listItem = document.getElementById(`path-${slug}`);
            if (listItem) {
              listItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
              listItem.classList.add('path-highlight');
              setTimeout(() => listItem.classList.remove('path-highlight'), 1500);
            }
          });

          map.on('mouseenter', 'paths-network-line', () => {
            map.getCanvas().style.cursor = 'pointer';
          });
          map.on('mouseleave', 'paths-network-line', () => {
            map.getCanvas().style.cursor = '';
          });

          // List hover → highlight path on map
          let hoveredSlug: string | null = null;

          function highlightPath(slug: string | null) {
            if (hoveredSlug === slug) return;
            hoveredSlug = slug;
            if (slug) {
              map.setPaintProperty('paths-network-line', 'line-width', [
                'case',
                ['==', ['get', 'slug'], slug],
                PATH_WIDTH_HOVER,
                PATH_WIDTH,
              ]);
              map.setPaintProperty('paths-network-line', 'line-opacity', [
                'case',
                ['==', ['get', 'slug'], slug],
                1,
                0.4,
              ]);
            } else {
              map.setPaintProperty('paths-network-line', 'line-width', ROUTE_LINE_WIDTH);
              map.setPaintProperty('paths-network-line', 'line-opacity', 0.8);
            }
          }

          document.querySelectorAll<HTMLElement>('.paths-list li[data-slug]').forEach(li => {
            li.addEventListener('mouseenter', () => {
              highlightPath(li.dataset.slug || null);
            });
            li.addEventListener('mouseleave', () => {
              highlightPath(null);
            });
          });
        }
      });
    }
  }
</script>
