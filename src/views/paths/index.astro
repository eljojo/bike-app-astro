---
export const prerender = true;
import fs from 'node:fs';
import nodePath from 'node:path';
import Base from '@/layouts/Base.astro';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { paths } from '@/lib/paths';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;
const { pages } = await loadBikePathData();

// Featured: paths with markdown descriptions
const featured = pages.filter(p => p.hasMarkdown && p.body);

// Group by operator dynamically
type OperatorGroup = { label: string; paths: typeof pages };
const operatorMap = new Map<string, typeof pages>();

for (const p of pages) {
  const key = p.operator || '';
  const list = operatorMap.get(key);
  if (list) {
    list.push(p);
  } else {
    operatorMap.set(key, [p]);
  }
}

const groups: OperatorGroup[] = [];
// Sort groups: largest first, "Other" (empty operator) last
const sortedEntries = [...operatorMap.entries()].sort((a, b) => {
  if (a[0] === '') return 1;
  if (b[0] === '') return -1;
  return b[1].length - a[1].length;
});

for (const [operator, pathsList] of sortedEntries) {
  groups.push({
    label: operator || t('paths.other_group', locale),
    paths: pathsList,
  });
}

// Discover available GeoJSON files for the network map
const geoDir = nodePath.resolve('public/paths/geo');
const geoFiles = fs.existsSync(geoDir)
  ? fs.readdirSync(geoDir).filter(f => f.endsWith('.geojson'))
  : [];

const mapCenter: [number, number] = [config.center.lat, config.center.lng];
---

<Base title={`${t('paths.title', locale)} | ${config.display_name}`}>
  <div class="paths-index">
    {geoFiles.length > 0 && (
      <div
        class="paths-map-hero"
        id="paths-network-map"
        data-geo-files={JSON.stringify(geoFiles)}
        data-center={JSON.stringify(mapCenter)}
        style="height: 400px; background: var(--color-surface-alt, #f0f0f0);"
      ></div>
    )}

    {featured.length > 0 && (
      <section class="paths-featured">
        <h2>{t('paths.featured', locale)}</h2>
        <div class="featured-cards">
          {featured.map(p => (
            <a href={paths.bikePath(p.slug, locale)} class="path-card">
              <h3>{p.name}</h3>
              {p.vibe && <p class="path-vibe">{p.vibe}</p>}
              {p.surface && <span class="path-surface">{p.surface}</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {groups.map(group => (
      <section class="paths-group">
        <h2>{group.label}</h2>
        <ul class="paths-list">
          {group.paths.map(p => (
            <li>
              <a href={paths.bikePath(p.slug, locale)}>
                {p.name}
              </a>
              {p.surface && <span class="path-meta">{p.surface}</span>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Base>

<script>
  import { initMap } from '../../lib/maps/map-init';
  import { loadStylePreference, getStyleUrl } from '../../lib/maps/map-style-switch';
  import maplibregl from 'maplibre-gl';

  const PATH_COLOR = '#E6194B';
  const PATH_WIDTH = 3;

  const container = document.getElementById('paths-network-map');
  if (container) {
    const geoFiles: string[] = JSON.parse(container.dataset.geoFiles || '[]');
    const center: [number, number] = JSON.parse(container.dataset.center || '[0,0]');

    if (geoFiles.length > 0) {
      const styleKey = loadStylePreference();
      const map = initMap({ el: container, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

      // Non-interactive overview
      map.scrollZoom.disable();
      map.dragPan.disable();
      map.doubleClickZoom.disable();
      map.touchZoomRotate.disable();

      map.on('load', async () => {
        const allFeatures: GeoJSON.Feature[] = [];
        const bounds = new maplibregl.LngLatBounds();

        for (const file of geoFiles) {
          try {
            const res = await fetch(`/paths/geo/${file}`);
            if (!res.ok) continue;
            const geojson = await res.json();
            for (const feature of geojson.features) {
              allFeatures.push(feature);
              if (feature.geometry.type === 'LineString') {
                for (const coord of feature.geometry.coordinates) {
                  bounds.extend(coord as [number, number]);
                }
              }
            }
          } catch {
            // Missing file — fine
          }
        }

        if (allFeatures.length > 0) {
          map.addSource('paths-network', {
            type: 'geojson',
            data: { type: 'FeatureCollection', features: allFeatures },
          });

          map.addLayer({
            id: 'paths-network-line',
            type: 'line',
            source: 'paths-network',
            layout: { 'line-cap': 'round', 'line-join': 'round' },
            paint: {
              'line-color': PATH_COLOR,
              'line-width': PATH_WIDTH,
              'line-opacity': 0.8,
            },
          });

          if (!bounds.isEmpty()) {
            map.fitBounds(bounds, { padding: 40, animate: false });
          }
        }
      });
    }
  }
</script>
