---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { t, localePath } from '@/i18n';
import { localizeSurface } from '@/lib/bike-paths/bike-path-facts';

const config = getCityConfig();
const locale = Astro.currentLocale;
const { pages: allPages } = await loadBikePathData();
// Directory listing: only listed paths (destination + infrastructure types), excluding very short ones
const pages = allPages.filter(p => p.listed && (!p.length_km || p.length_km >= 1));

// Locale-aware accessors
function pathName(p: typeof pages[0]): string {
  return (locale && p.translations[locale]?.name) || p.name;
}
function pathVibe(p: typeof pages[0]): string | undefined {
  return (locale && p.translations[locale]?.vibe) || p.vibe;
}

// All paths are interactive (clickable → navigate to detail page).
// Listed paths render bold; unlisted paths render subtle but still clickable.
const interactiveRelIds = new Set<string>();
const listedRelIds = new Set<string>();
const relationToSlug: Record<string, string> = {};
// Pre-compute slug → URL so client-side click handlers use correct (potentially nested) URLs.
// Only include paths that have a page (standalone) — prevents dead links on the map.
const slugToUrl: Record<string, string> = {};
// Popup info for each path — keyed by slug, serialized to JSON for client
// Localize path_type for popup display
function localizePathType(pt?: string): string | undefined {
  if (!pt) return undefined;
  const key = `paths.fact.${pt.replace(/-/g, '_')}`;
  const val = t(key, locale);
  return val !== key ? val : undefined;
}
const slugInfo: Record<string, { name: string; url: string; length_km?: number; surface?: string; path_type?: string; vibe?: string; network?: string; networkUrl?: string }> = {};
// slug → network slug for fly-to framing
const slugToNetwork: Record<string, string> = {};
for (const p of allPages) {
  // Skip connectors — not listed, not standalone, don't appear on the map
  if (!p.listed && !p.standalone) continue;
  // Skip network pages' aggregated geometry — member pages already registered
  // their own geoIds. Network overwrites would route member clicks to the network page.
  if (p.memberRefs && p.memberRefs.length > 0) {
    if (p.standalone) {
      const url = paths.bikePath(p.slug, p.memberOf, locale);
      slugToUrl[p.slug] = url;
      slugInfo[p.slug] = { name: pathName(p), url, length_km: p.length_km, surface: localizeSurface(p.surface, t, locale) || p.surface, path_type: localizePathType(p.path_type), vibe: pathVibe(p), network: undefined };
    }
    continue;
  }
  if (p.standalone) {
    const url = paths.bikePath(p.slug, p.memberOf, locale);
    slugToUrl[p.slug] = url;
    // Find network name if member
    const netPage = p.memberOf ? allPages.find(n => n.slug === p.memberOf) : undefined;
    const netName = netPage ? pathName(netPage) : undefined;
    const netUrl = p.memberOf ? paths.bikePath(p.memberOf, undefined, locale) : undefined;
    slugInfo[p.slug] = { name: pathName(p), url, length_km: p.length_km, surface: localizeSurface(p.surface, t, locale) || p.surface, path_type: localizePathType(p.path_type), vibe: pathVibe(p), network: netName, networkUrl: netUrl };
    if (p.memberOf) slugToNetwork[p.slug] = p.memberOf;
  }
  for (const relId of p.osmRelationIds) {
    relationToSlug[String(relId)] = p.slug;
    interactiveRelIds.add(String(relId));
    if (p.listed) listedRelIds.add(String(relId));
  }
  // Also map name-based and segment-based geo files
  for (const gf of p.geoFiles) {
    const geoId = gf.replace(/\.geojson$/, '');
    relationToSlug[geoId] = p.slug;
    interactiveRelIds.add(geoId);
    if (p.listed) listedRelIds.add(geoId);
  }
}

// Separate network pages, member paths, and standalone paths
const networkPages = pages.filter(p => p.memberRefs && p.memberRefs.length > 0);
const memberSlugs = new Set(networkPages.flatMap(n => (n.memberRefs ?? []).map(m => m.slug)));

// Independent paths: standalone destination paths not in any network
const allIndependent = pages.filter(p =>
  p.standalone && !p.memberRefs && !memberSlugs.has(p.slug)
).sort((a, b) => (b.length_km ?? 0) - (a.length_km ?? 0));

// Standalone long-distance trails (not members of any network)
const longDistancePaths = allIndependent.filter(p => p.entryType === 'long-distance');
const longDistanceSlugs = new Set(longDistancePaths.map(p => p.slug));
const independentPaths = allIndependent.filter(p => !longDistanceSlugs.has(p.slug));

// --- Classify networks into riding categories ---
const TIER1_MIN_KM = 5;

interface NetworkInfo {
  slug: string;
  name: string;
  length_km?: number;
  operator?: string;
  tier1: typeof networkPages[0]['memberRefs'] extends (infer T)[] | undefined ? NonNullable<T>[] : never[];
  tier2: typeof networkPages[0]['memberRefs'] extends (infer T)[] | undefined ? NonNullable<T>[] : never[];
}

// Long-distance members extracted from all networks — shown in the Long-distance tab, not in their network
const longDistanceMemberRefs: Array<{ slug: string; name: string; length_km?: number; standalone: boolean; memberOf?: string }> = [];

function buildNetworkInfo(net: typeof networkPages[0]): NetworkInfo {
  const refs = (net.memberRefs ?? []).filter(m => m.length_km == null || m.length_km >= 0.5);
  // Separate long-distance members — they go to the Long-distance category tab
  const localRefs = refs.filter(m => {
    if (m.entryType === 'long-distance') {
      longDistanceMemberRefs.push({ slug: m.slug, name: m.name, length_km: m.length_km, standalone: m.standalone, memberOf: m.memberOf });
      return false;
    }
    return true;
  });
  const tier1 = localRefs.filter(m => m.hasMarkdown || (m.length_km != null && m.length_km >= TIER1_MIN_KM));
  const tier2 = localRefs.filter(m => !m.hasMarkdown && (m.length_km == null || m.length_km < TIER1_MIN_KM));
  tier1.sort((a, b) => (b.length_km ?? 0) - (a.length_km ?? 0));
  return { slug: net.slug, name: pathName(net), length_km: net.length_km, operator: net.operator, tier1, tier2 };
}

// Classify each network by its members' dominant path_type
function classifyNetwork(net: typeof networkPages[0]): 'mtb' | 'long-distance' | 'bikeways' | 'pathways' {
  const members = net.memberRefs ?? [];
  if (members.length === 0) return 'pathways';

  // MTB: >=50% of members are mtb-trail
  const mtbCount = members.filter(m => {
    const page = pageBySlug.get(m.slug);
    return page?.path_type === 'mtb-trail';
  }).length;
  if (mtbCount / members.length >= 0.5) return 'mtb';

  // Long-distance: ncn or rcn network tag
  if (net.network === 'ncn' || net.network === 'rcn') return 'long-distance';

  // Bikeways: lcn network tag and mostly mup/separated-lane/bike-lane
  if (net.network === 'lcn') return 'bikeways';

  return 'pathways';
}

const pageBySlug = new Map(allPages.map(p => [p.slug, p]));

const categoryMap: Record<string, NetworkInfo[]> = {
  pathways: [],
  mtb: [],
  'long-distance': [],
  bikeways: [],
};

for (const net of networkPages) {
  const cat = classifyNetwork(net);
  categoryMap[cat].push(buildNetworkInfo(net));
}

// Sort networks within each category by total length (largest first)
for (const nets of Object.values(categoryMap)) {
  nets.sort((a, b) => (b.length_km ?? 0) - (a.length_km ?? 0));
}

// Build category tabs — only include categories that have content
interface Category {
  key: string;
  label: string;
  networks: NetworkInfo[];
  standalonePaths?: typeof longDistancePaths;
}

const categories: Category[] = [];
if (categoryMap.pathways.length > 0) {
  categories.push({ key: 'pathways', label: t('paths.cat_pathways', locale), networks: categoryMap.pathways });
}
if (categoryMap.mtb.length > 0) {
  categories.push({ key: 'mtb', label: t('paths.cat_mtb', locale), networks: categoryMap.mtb });
}
// Combine standalone long-distance paths + long-distance members extracted from networks
const allLongDistanceStandalone = [...longDistancePaths];
const ldSlugs = new Set(allLongDistanceStandalone.map(p => p.slug));
// Add member refs as lightweight entries (they have enough data to render links)
for (const m of longDistanceMemberRefs) {
  if (ldSlugs.has(m.slug)) continue;
  ldSlugs.add(m.slug);
  const page = pageBySlug.get(m.slug);
  if (page) allLongDistanceStandalone.push(page);
}
allLongDistanceStandalone.sort((a, b) => (b.length_km ?? 0) - (a.length_km ?? 0));

if (categoryMap['long-distance'].length > 0 || allLongDistanceStandalone.length > 0) {
  categories.push({
    key: 'long-distance',
    label: t('paths.cat_long_distance', locale),
    networks: categoryMap['long-distance'],
    standalonePaths: allLongDistanceStandalone,
  });
}
if (categoryMap.bikeways.length > 0) {
  categories.push({ key: 'bikeways', label: t('paths.cat_bikeways', locale), networks: categoryMap.bikeways });
}

// Compat: networkData is still used for map highlighting
const networkData = networkPages.map(buildNetworkInfo);

// Build network → geoId mapping for map highlighting
const networkGeoIds: Record<string, string[]> = {};
for (const net of networkPages) {
  const geoIds: string[] = [];
  for (const gf of net.geoFiles) geoIds.push(gf.replace(/\.geojson$/, ''));
  for (const m of net.memberRefs ?? []) {
    const memberPage = pageBySlug.get(m.slug);
    if (memberPage) {
      for (const gf of memberPage.geoFiles) geoIds.push(gf.replace(/\.geojson$/, ''));
    }
  }
  networkGeoIds[net.slug] = geoIds;
}

// Build category → geoIds mapping (union of all networks in each category)
const categoryGeoIds: Record<string, string[]> = {};
for (const cat of categories) {
  const allIds: string[] = [];
  for (const net of cat.networks) {
    const ids = networkGeoIds[net.slug] ?? [];
    allIds.push(...ids);
  }
  categoryGeoIds[cat.key] = allIds;
}

const mapCenter: [number, number] = [config.center.lat, config.center.lng];
const seoDescription = t('paths.seo_description', locale, { count: String(pages.length), city: config.name });
const ogImage = config.page_posters?.map ? imageUrl(config.page_posters.map, { width: 1200, height: 630, fit: 'cover' }) : undefined;
---

<Base title={`${t('paths.page_title', locale, { city: config.name })} | ${config.display_name}`} description={seoDescription} ogImage={ogImage}>
  <SubTabToggle isIndex items={[
    { label: t('nav.routes', locale), href: localePath('/routes', locale), active: false },
    { label: t('nav.bike_paths', locale), href: paths.bikePaths(locale), active: true },
  ]} />
  <div class="paths-index">
    <h1>{t('paths.heading', locale, { city: config.name })}</h1>

    {allPages.length > 0 && categories.length > 0 && (
      <div class="paths-browse">
        {/* Sticky header: map + tabs stick as you scroll through panels */}
        <div class="paths-browse-header">
          <div class="paths-map-hero-wrapper">
            <div
              class="paths-map-hero"
              id="paths-network-map"
              data-center={JSON.stringify(mapCenter)}
              data-relation-slugs={JSON.stringify(relationToSlug)}
              data-slug-urls={JSON.stringify(slugToUrl)}
              data-interactive-ids={JSON.stringify([...interactiveRelIds])}
              data-listed-ids={JSON.stringify([...listedRelIds])}
              data-network-geo-ids={JSON.stringify(networkGeoIds)}
              data-category-geo-ids={JSON.stringify(categoryGeoIds)}
          data-slug-info={JSON.stringify(slugInfo)}
          data-slug-to-network={JSON.stringify(slugToNetwork)}
              style="height: 400px; background: var(--color-surface-alt, #f0f0f0); transition: height 0.35s ease-out;"
            ></div>
            <div class="map-touch-lock" id="paths-map-touch-lock">
              <span class="map-touch-label">{t('paths.tap_to_explore', locale)}</span>
            </div>
          </div>
          <div class="network-tabs" id="network-tabs">
            {categories.map((cat, i) => (
              <button
                class:list={['network-tab', { active: i === 0 }]}
                data-network={cat.key}
              >{cat.label}</button>
            ))}
            <button class="network-tab network-tab--all" data-network="all">{t('paths.all_paths_tab', locale)}</button>
          </div>
        </div>

        {categories.map((cat, i) => (
          <div class:list={['network-panel', { active: i === 0 }]} data-panel={cat.key}>
            {cat.networks.map(net => (
              <div class="category-network-group">
                <div class="network-panel-header" data-slug={net.slug}>
                  <div class="network-panel-info">
                    <span class="network-panel-name">{net.name}</span>
                    {net.length_km && <span class="path-meta">{net.length_km} km</span>}
                    {net.operator && <span class="path-meta path-meta--operator">{net.operator}</span>}
                  </div>
                  <a href={paths.bikePath(net.slug, undefined, locale)} class="network-panel-link">
                    {t('paths.view_network', locale)} &rarr;
                  </a>
                </div>

                {net.tier1.length > 0 && (
                  <ul class="paths-list">
                    {net.tier1.map(m => (
                      <li data-slug={m.slug}>
                        {m.standalone ? (
                          <a href={paths.bikePath(m.slug, m.memberOf ?? net.slug, locale)} class="path-link">
                            <span class="path-link-name">{m.name}</span>
                            {m.length_km && <span class="path-meta">{m.length_km} km</span>}
                          </a>
                        ) : (
                          <span class="path-link">
                            <span class="path-link-name">{m.name}</span>
                            {m.length_km && <span class="path-meta">{m.length_km} km</span>}
                          </span>
                        )}
                      </li>
                    ))}
                  </ul>
                )}

                {net.tier2.length > 0 && (
                  <div class="network-tier2">
                    <span class="network-tier2-label">{t('paths.shorter_segments', locale, { count: String(net.tier2.length) })}</span>
                    <span class="network-tier2-names">
                      {net.tier2.slice(0, 5).map((m, j) => (
                        <span>{m.name}{j < Math.min(4, net.tier2.length - 1) ? ', ' : ''}</span>
                      ))}
                      {net.tier2.length > 5 && <span class="network-tier2-ellipsis">&hellip;</span>}
                    </span>
                  </div>
                )}
              </div>
            ))}

            {/* Standalone long-distance paths (not in any network) */}
            {cat.standalonePaths && cat.standalonePaths.length > 0 && (
              <ul class="paths-list">
                {cat.standalonePaths.map(p => (
                  <li data-slug={p.slug}>
                    <a href={paths.bikePath(p.slug, p.memberOf, locale)} class="path-link">
                      <span class="path-link-name">{pathName(p)}</span>
                      <span class="path-link-meta">
                        {p.length_km && <span class="path-meta">{p.length_km} km</span>}
                        {localizeSurface(p.surface, t, locale) && <span class="path-meta">{localizeSurface(p.surface, t, locale)}</span>}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}

        <div class="network-panel" data-panel="all">
          <ul class="paths-list">
            {independentPaths.map(p => (
              <li data-slug={p.slug}>
                <a href={paths.bikePath(p.slug, p.memberOf, locale)} class="path-link">
                  <span class="path-link-name">{pathName(p)}</span>
                  <span class="path-link-meta">
                    {p.length_km && <span class="path-meta">{p.length_km} km</span>}
                    {localizeSurface(p.surface, t, locale) && <span class="path-meta">{localizeSurface(p.surface, t, locale)}</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    {independentPaths.length > 0 && (
      <section class="paths-independent">
        <h2>{t('paths.independent_paths', locale)}</h2>
        <ul class="paths-list">
          {independentPaths.map(p => (
            <li data-slug={p.slug}>
              <a href={paths.bikePath(p.slug, p.memberOf, locale)} class="path-link">
                <span class="path-link-name">{pathName(p)}</span>
                <span class="path-link-meta">
                  {p.length_km && <span class="path-meta">{p.length_km} km</span>}
                  {localizeSurface(p.surface, t, locale) && <span class="path-meta">{localizeSurface(p.surface, t, locale)}</span>}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="paths-osm-attribution">
      {t('paths.index_osm_attribution', locale)} <a href="https://www.openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a>. {t('paths.index_osm_edit', locale)}
    </p>
  </div>
</Base>

<script>
  import { initMap, showPopup, ROUTE_COLOR, ROUTE_LINE_WIDTH } from '../../lib/maps/map-init';
  import { loadStylePreference, getStyleUrl } from '../../lib/maps/map-style-switch';
  import { setupMapTouchLock } from '../../lib/maps/map-touch-lock';
  import { setupPathHighlight } from '../../lib/maps/path-highlight';
  import { html, raw } from '../../lib/maps/map-helpers';
  import { createTileLoader, type TileLoader } from '../../lib/maps/tile-loader';
  import { createMapExpandButton } from '../../lib/maps/map-expand-button';
  import maplibregl from 'maplibre-gl';

  const PATH_WIDTH = ROUTE_LINE_WIDTH;
  const PATH_WIDTH_UNLISTED = Math.max(2, ROUTE_LINE_WIDTH - 2);
  const PATH_WIDTH_HOVER = ROUTE_LINE_WIDTH + 2;

  const container = document.getElementById('paths-network-map');
  if (container) {
    const center: [number, number] = JSON.parse(container.dataset.center || '[0,0]');
    const relationSlugs: Record<string, string> = JSON.parse(container.dataset.relationSlugs || '{}');
    const slugUrls: Record<string, string> = JSON.parse(container.dataset.slugUrls || '{}');
    const slugInfo: Record<string, { name: string; url: string; length_km?: number; surface?: string; path_type?: string; vibe?: string; network?: string; networkUrl?: string }> = JSON.parse(container.dataset.slugInfo || '{}');
    const interactiveIds = new Set<string>(JSON.parse(container.dataset.interactiveIds || '[]'));
    const listedIds = new Set<string>(JSON.parse(container.dataset.listedIds || '[]'));
    const networkGeoIds: Record<string, string[]> = JSON.parse(container.dataset.networkGeoIds || '{}');
    const categoryGeoIds: Record<string, string[]> = JSON.parse(container.dataset.categoryGeoIds || '{}');
    const slugToNetworkMap: Record<string, string> = JSON.parse(container.dataset.slugToNetwork || '{}');

    const styleKey = loadStylePreference();
    const map = initMap({ el: container, center, zoom: 11, styleUrl: getStyleUrl(styleKey) });

    setupMapTouchLock(map, document.getElementById('paths-map-touch-lock'));
    createMapExpandButton(map, container, { compactHeight: 400, expandedHeight: 700 });

    function enrichFeatures(features: GeoJSON.Feature[]) {
      for (const f of features) {
        const geoId = f.properties?._geoId;
        if (!geoId) continue;
        const slug = relationSlugs[geoId] || geoId;
        const interactive = interactiveIds.has(geoId);
        const listed = listedIds.has(geoId);
        f.properties!.slug = slug;
        f.properties!.relationId = geoId;
        f.properties!.interactive = interactive ? 'true' : '';
        f.properties!.listed = listed ? 'true' : '';
      }
    }

    // --- Network highlight ---
    let activeNetwork: string | null = null;

    function fitToGeoIds(geoIds: string[]) {
      if (!map.getSource('paths-network')) return;
      const features = map.querySourceFeatures('paths-network', {
        filter: ['in', ['get', 'relationId'], ['literal', geoIds]],
      });
      if (features.length === 0) return;
      let minLng = Infinity, maxLng = -Infinity, minLat = Infinity, maxLat = -Infinity;
      for (const f of features) {
        const coords = f.geometry.type === 'LineString' ? (f.geometry as GeoJSON.LineString).coordinates
          : f.geometry.type === 'MultiLineString' ? (f.geometry as GeoJSON.MultiLineString).coordinates.flat()
          : [];
        for (const [lng, lat] of coords as [number, number][]) {
          if (lng < minLng) minLng = lng;
          if (lng > maxLng) maxLng = lng;
          if (lat < minLat) minLat = lat;
          if (lat > maxLat) maxLat = lat;
        }
      }
      if (minLng === Infinity) return;
      map.fitBounds([[minLng, minLat], [maxLng, maxLat]], { padding: 60, animate: true, duration: 500 });
    }

    function highlightNetwork(slug: string | null, fly = false) {
      if (activeNetwork === slug) return;
      activeNetwork = slug;

      if (!map.getLayer('paths-network-highlight')) return;

      // Check category IDs first, then individual network IDs
      const geoIds = slug ? (categoryGeoIds[slug] ?? networkGeoIds[slug]) : undefined;
      if (geoIds && geoIds.length > 0) {
        map.setFilter('paths-network-highlight', ['in', ['get', 'relationId'], ['literal', geoIds]]);
        map.setPaintProperty('paths-network-line', 'line-opacity', 0.3);
        map.setPaintProperty('paths-network-bg', 'line-opacity', 0.15);
        if (fly) fitToGeoIds(geoIds);
      } else {
        map.setFilter('paths-network-highlight', ['==', ['get', 'relationId'], '']);
        map.setPaintProperty('paths-network-line', 'line-opacity', 0.8);
        map.setPaintProperty('paths-network-bg', 'line-opacity', 0.5);
      }
    }

    // --- Tab interaction ---
    const tabBar = document.getElementById('network-tabs');
    if (tabBar) {
      const tabs = tabBar.querySelectorAll<HTMLButtonElement>('.network-tab');
      const panels = document.querySelectorAll<HTMLElement>('.network-panel');

      function activateTab(networkSlug: string) {
        tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.network === networkSlug));
        panels.forEach(panel => panel.classList.toggle('active', panel.dataset.panel === networkSlug));
        if (networkSlug === 'all') {
          highlightNetwork(null, true);
        } else {
          highlightNetwork(networkSlug, true);
        }
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const slug = tab.dataset.network;
          if (slug) activateTab(slug);
        });
        tab.addEventListener('mouseenter', () => {
          const slug = tab.dataset.network;
          if (slug && slug !== 'all') highlightNetwork(slug);
        });
        tab.addEventListener('mouseleave', () => {
          // Restore to active tab's highlight
          const activeTab = tabBar.querySelector<HTMLButtonElement>('.network-tab.active');
          const activeSlug = activeTab?.dataset.network;
          if (activeSlug && activeSlug !== 'all') {
            highlightNetwork(activeSlug);
          } else {
            highlightNetwork(null);
          }
        });
      });
    }

    let layersSetUp = false;
    let prevFeatureCount = 0;

    function setupPathsLayers(features: GeoJSON.Feature[]) {
      map.addSource('paths-network', {
        type: 'geojson',
        data: { type: 'FeatureCollection', features },
      });

      // Unlisted paths: thinner, lower opacity, but still clickable
      map.addLayer({
        id: 'paths-network-bg',
        type: 'line',
        source: 'paths-network',
        filter: ['all', ['==', ['get', 'interactive'], 'true'], ['!=', ['get', 'listed'], 'true']],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': ROUTE_COLOR,
          'line-width': PATH_WIDTH_UNLISTED,
          'line-opacity': 0.5,
        },
      });

      // Listed paths: full width, bold
      map.addLayer({
        id: 'paths-network-line',
        type: 'line',
        source: 'paths-network',
        filter: ['==', ['get', 'listed'], 'true'],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': ROUTE_COLOR,
          'line-width': PATH_WIDTH,
          'line-opacity': 0.8,
        },
      });

      // Highlight layer for network hover/selection
      map.addLayer({
        id: 'paths-network-highlight',
        type: 'line',
        source: 'paths-network',
        filter: ['==', ['get', 'relationId'], ''],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': ROUTE_COLOR,
          'line-width': PATH_WIDTH + 2,
          'line-opacity': 1,
        },
      });

      // --- Map interaction ---

      // Click on any path → show info popup
      function handlePathClick(e: maplibregl.MapMouseEvent & { features?: maplibregl.MapGeoJSONFeature[] }) {
        if (!e.features?.length) return;
        const slug = e.features[0].properties?.slug;
        if (!slug) return;
        const info = slugInfo[slug];
        if (!info) return;

        const meta: string[] = [];
        if (info.length_km) meta.push(`${info.length_km} km`);
        if (info.surface) meta.push(info.surface);
        if (info.path_type) meta.push(info.path_type);

        const content = html`<div class="path-popup">
          <strong class="path-popup-name">${info.name}</strong>
          ${info.network ? raw(info.networkUrl ? html`<div class="path-popup-network"><a href="${info.networkUrl}" class="path-popup-network-link">${info.network}</a></div>` : html`<div class="path-popup-network">${info.network}</div>`) : ''}
          ${meta.length > 0 ? raw(html`<div class="path-popup-meta">${meta.join(' · ')}</div>`) : ''}
          ${info.vibe ? raw(html`<div class="path-popup-vibe">${info.vibe}</div>`) : ''}
          <a href="${info.url}" class="path-popup-link">View details &rarr;</a>
        </div>`;

        const popup = new maplibregl.Popup({ closeButton: true, maxWidth: '280px' })
          .setLngLat(e.lngLat)
          .setHTML(content);
        showPopup(map, popup);
      }
      map.on('click', 'paths-network-line', handlePathClick);
      map.on('click', 'paths-network-bg', handlePathClick);

      for (const layerId of ['paths-network-line', 'paths-network-bg', 'paths-network-highlight']) {
        map.on('mouseenter', layerId, () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', layerId, () => { map.getCanvas().style.cursor = ''; });
      }

      // List hover → highlight path on map + fly to if off-screen
      setupPathHighlight(map, {
        listSelector: '.paths-list li[data-slug], .network-panel-header[data-slug]',
        layerIds: ['paths-network-line'],
        lineWidth: PATH_WIDTH,
        lineWidthHover: PATH_WIDTH_HOVER,
        lineOpacity: 0.8,
        sourceId: 'paths-network',
        slugToNetwork: slugToNetworkMap,
        networkGeoIds,
        onHighlight: (slug) => {
          // Hide other layers when hovering so only the hovered path is visible
          for (const id of ['paths-network-highlight', 'paths-network-bg']) {
            if (map.getLayer(id)) {
              map.setLayoutProperty(id, 'visibility', slug ? 'none' : 'visible');
            }
          }
          // On mouseleave, fly back to active tab's extent (or city center)
          if (!slug) {
            const activeTab = document.querySelector<HTMLButtonElement>('#network-tabs .network-tab.active');
            const activeSlug = activeTab?.dataset.network;
            const geoIds = activeSlug && activeSlug !== 'all'
              ? (categoryGeoIds[activeSlug] ?? networkGeoIds[activeSlug])
              : undefined;
            if (geoIds && geoIds.length > 0) {
              fitToGeoIds(geoIds);
            } else {
              map.flyTo({ center, zoom: 11, duration: 500 });
            }
          }
        },
      });

      layersSetUp = true;

      // Activate the first network tab's highlight once layers are ready
      const activeTab = document.querySelector<HTMLButtonElement>('#network-tabs .network-tab.active');
      const activeSlug = activeTab?.dataset.network;
      if (activeSlug && activeSlug !== 'all') {
        highlightNetwork(activeSlug);
      }
    }

    function getMapBounds(): [number, number, number, number] {
      const b = map.getBounds();
      return [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()];
    }

    map.on('load', async () => {
      let tileLoader: TileLoader;
      try {
        const res = await fetch('/bike-paths/geo/tiles/manifest.json');
        if (!res.ok) return;
        const manifest = await res.json();
        tileLoader = createTileLoader(manifest, '/bike-paths/geo/tiles/');
      } catch {
        return;
      }

      // Load initial tiles immediately — this page is about paths
      const features = await tileLoader.loadTilesForBounds(getMapBounds());
      enrichFeatures(features);
      prevFeatureCount = features.length;

      if (features.length > 0) {
        setupPathsLayers(features);
      }

      // On pan/zoom, load new tiles and update source if new features arrived
      map.on('moveend', async () => {
        const updated = await tileLoader.loadTilesForBounds(getMapBounds());
        if (updated.length === prevFeatureCount) return;

        enrichFeatures(updated);
        prevFeatureCount = updated.length;

        if (!layersSetUp) {
          if (updated.length > 0) setupPathsLayers(updated);
          return;
        }

        const source = map.getSource('paths-network') as maplibregl.GeoJSONSource;
        if (source) {
          source.setData({ type: 'FeatureCollection', features: updated });
        }
      });
    });
  }

</script>
