---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import { getCityConfig } from '@/lib/config/city-config';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import BikePathMap from '@/components/BikePathMap.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import RoutesOnPath from '@/components/RoutesOnPath.astro';
import EditEntryPoint from '@/components/EditEntryPoint.astro';
import { t, localePath } from '@/i18n';
import { paths, assets } from '@/lib/paths';
import { breadcrumbJsonLd } from '@/lib/json-ld';
import { imageUrl } from '@/lib/media/image-service';
import { hasCachedMap } from '@/lib/maps/map-thumbnails';
import { computeCenter } from '@/lib/bike-paths/bike-path-facts';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  const networkPages = pages.filter(p => p.memberRefs && p.memberRefs.length > 0);
  return networkPages.map(page => ({
    params: { network: page.slug },
    props: { page },
  }));
}

interface Props { page: BikePathPage }
const { page } = Astro.props;
const { overlappingRoutes, nearbyPhotos, nearbyPlaces } = page;
const config = getCityConfig();
const locale = Astro.currentLocale;

// Locale-aware content
const localeName = (locale && page.translations[locale]?.name) || page.name;
const localeVibe = (locale && page.translations[locale]?.vibe) || page.vibe;
const localeBody = (locale && page.translations[locale]?.body) || page.body;
const bodyHtml = localeBody ? renderMarkdownHtml(localeBody) : '';

const memberRefs = page.memberRefs ?? [];
const standaloneMemberCount = memberRefs.filter(m => m.standalone).length;
const wikidataMeta = page.ymlEntries[0]?.wikidata_meta;

const fallbackCenter: [number, number] = [config.center.lat, config.center.lng];

// SEO
const wikidataDesc = wikidataMeta
  ? (wikidataMeta as Record<string, unknown>)[`description_${locale}`] as string | undefined
    ?? wikidataMeta.description_en
  : undefined;
const seoDescription = localeVibe
  || wikidataDesc
  || `${localeName} — ${standaloneMemberCount} ${t('paths.pathways', locale)}`;

const hasMapThumb = hasCachedMap(`path-${page.slug}`);
const mapThumbUrl = hasMapThumb ? assets.mapSocial(`path-${page.slug}`) : undefined;
const ogImage = mapThumbUrl || (page.thumbnail_key ? imageUrl(page.thumbnail_key, { width: 1200, height: 630, fit: 'cover' }) : undefined);

const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('nav.bike_paths', locale), url: `${config.url}${paths.bikePaths(locale)}` },
  { name: localeName, url: `${config.url}${paths.bikePath(page.slug, undefined, locale)}` },
]);
---

<Base title={`${localeName} | ${config.display_name}`} description={seoDescription} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <div class="bike-path-detail network-detail">
    <h1>{localeName}</h1>
    {localeVibe && <p class="bike-path-vibe">{localeVibe}</p>}

    <div class="network-map-full">
      <BikePathMap
        geoFiles={page.geoFiles}
        center={computeCenter(page.points)}
        fallbackCenter={fallbackCenter}
        hintText={t('paths.tap_to_explore', locale)}
        closeLabel={t('paths.close_map', locale)}
        photos={nearbyPhotos.filter(p => p.lat && p.lng)}
        places={nearbyPlaces.map(p => ({ name: p.name, lat: p.lat, lng: p.lng, category: p.category }))}
        cdnUrl={config.cdn_url}
      />
    </div>

    <div class="bike-path-layout">
      <div class="bike-path-main">
        {bodyHtml ? (
          <div class="bike-path-description" set:html={bodyHtml} />
        ) : (
          <p class="bike-path-stub-cta">
            {t('paths.stub_cta', locale)} <a href={`/admin/bike-paths/${page.slug}`}>{t('paths.stub_cta_link', locale)}</a>
          </p>
        )}

        <EditEntryPoint text={t('paths.edit_description', locale)} href={`/admin/bike-paths/${page.slug}`} />

        {memberRefs.length > 0 && (
          <section class="network-members">
            <h2>{t('paths.member_paths', locale)}</h2>
            <ul class="network-members-list">
              {memberRefs.map(m => (
                <li>
                  {m.standalone ? (
                    <a href={paths.bikePath(m.slug, m.memberOf ?? page.slug, locale)} class="network-member-link">
                      <span class="network-member-name">{m.name}</span>
                      {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                    </a>
                  ) : (
                    <span class="network-member-no-page">
                      <span class="network-member-name">{m.name}</span>
                      {m.length_km && <span class="network-member-meta">{m.length_km} km</span>}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}

        <RoutesOnPath routes={overlappingRoutes} locale={locale} />

        {nearbyPhotos.length > 0 && (
          <section class="bike-path-photos">
            <h2>{t('paths.photos', locale)}</h2>
            <div class="bike-path-photo-grid">
              {nearbyPhotos.slice(0, 8).map(photo => (
                <a href={`${paths.route(photo.routeSlug, locale)}?photo=${encodeURIComponent(photo.key)}#photos`} class="bike-path-photo">
                  <img
                    src={imageUrl(photo.key, { width: 300, height: 200, fit: 'cover' })}
                    srcset={`${imageUrl(photo.key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                    alt={photo.caption || localeName}
                    width="300"
                    height="200"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="bike-path-sidebar">
        <table class="bike-path-facts-table">
          {page.length_km && (
            <tr><td>{t('paths.label.length', locale)}</td><td>{page.length_km} km</td></tr>
          )}
          <tr><td>{t('paths.pathways', locale)}</td><td>{standaloneMemberCount}</td></tr>
          {page.operator && (
            <tr><td>{t('paths.label.operator', locale)}</td><td>{page.operator}</td></tr>
          )}
          {wikidataMeta?.inception && (
            <tr><td>{t('paths.fact.established', locale)}</td><td>{wikidataMeta.inception}</td></tr>
          )}
          {wikidataMeta?.website && (
            <tr><td>{t('paths.fact.website', locale)}</td><td><a href={wikidataMeta.website} target="_blank" rel="noopener">{new URL(wikidataMeta.website).hostname}</a></td></tr>
          )}
        </table>

        {nearbyPlaces.length > 0 && (
          <NearbyPlaces nearby={nearbyPlaces} limit={8} />
        )}
      </aside>
    </div>

    <a href={paths.bikePaths(locale)} class="go-back-button">&#x21A9; {t('paths.go_back', locale)}</a>
  </div>
</Base>
