---
export const prerender = true;
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import BikePathDetail from './BikePathDetail.astro';
import { buildNetworkMeta, type NetworkMeta } from '@/lib/bike-paths/infrastructure-grouping';
import type { PathMeta } from '@/lib/bike-paths/bike-path-facts';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  const networkPages = pages.filter(p => p.memberRefs && p.memberRefs.length > 0);
  const networkMeta = buildNetworkMeta(pages);
  // Build member metadata for fact aggregation
  const pageBySlug = new Map(pages.map(p => [p.slug, p]));
  return networkPages.map(page => {
    const memberMeta: PathMeta[] = [];
    for (const m of page.memberRefs ?? []) {
      const memberPage = pageBySlug.get(m.slug);
      if (memberPage) {
        memberMeta.push({
          surface: memberPage.surface, smoothness: memberPage.smoothness, width: memberPage.width,
          highway: memberPage.highway, segregated: memberPage.segregated, lit: memberPage.lit,
          elevation_gain_m: memberPage.elevation_gain_m, operator: memberPage.operator,
          network: memberPage.network, mtb: memberPage.mtb, path_type: memberPage.path_type,
          seasonal: memberPage.seasonal, ref: memberPage.ref, inception: memberPage.inception,
          bicycle: memberPage.bicycle, cycleway: memberPage.cycleway, parallel_to: memberPage.parallel_to,
        });
      }
    }
    // Compute member geo IDs for the browse-style map
    // allMemberGeoIds: ALL member geoFiles (for fit-to-network-extent on hover reset)
    // interactiveGeoIds: only standalone members (for bold styling + popups)
    // Use a Set because page.geoFiles may already include aggregated member geo files
    const allGeoIdSet = new Set<string>();
    const interactiveGeoIds: string[] = [];
    for (const gf of page.geoFiles) {
      allGeoIdSet.add(gf.replace(/\.geojson$/, ''));
    }
    for (const m of page.memberRefs ?? []) {
      const memberPage = pageBySlug.get(m.slug);
      if (memberPage) {
        for (const gf of memberPage.geoFiles) {
          allGeoIdSet.add(gf.replace(/\.geojson$/, ''));
          if (memberPage.standalone) {
            interactiveGeoIds.push(gf.replace(/\.geojson$/, ''));
          }
        }
      }
    }
    const allMemberGeoIds = [...allGeoIdSet];

    return {
      params: { network: page.slug },
      props: { page, networkMeta, memberMeta, allMemberGeoIds, interactiveGeoIds },
    };
  });
}

interface Props { page: BikePathPage; networkMeta: Record<string, NetworkMeta>; memberMeta: PathMeta[]; allMemberGeoIds: string[]; interactiveGeoIds: string[] }
const { page, networkMeta, memberMeta, allMemberGeoIds, interactiveGeoIds } = Astro.props;
---

<BikePathDetail page={page} networkMeta={networkMeta} memberMeta={memberMeta}
  allMemberGeoIds={allMemberGeoIds} interactiveGeoIds={interactiveGeoIds} />
