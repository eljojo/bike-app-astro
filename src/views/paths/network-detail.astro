---
export const prerender = true;
import { loadBikePathData, type BikePathPage } from '@/lib/bike-paths/bike-path-data.server';
import BikePathDetail from './BikePathDetail.astro';
import type { NetworkMeta } from '@/lib/bike-paths/infrastructure-grouping';

export async function getStaticPaths() {
  const { pages } = await loadBikePathData();
  const networkPages = pages.filter(p => p.memberRefs && p.memberRefs.length > 0);
  // Build network slug → meta lookup for "Connects to" display
  const networkMeta: Record<string, NetworkMeta> = {};
  for (const p of pages) {
    if (p.memberRefs && p.memberRefs.length > 0) {
      networkMeta[p.slug] = { name: p.name, length_km: p.length_km, operator: p.operator };
    }
  }
  // Build member metadata for fact aggregation
  const pageBySlug = new Map(pages.map(p => [p.slug, p]));
  return networkPages.map(page => {
    const memberMeta: Array<{ surface?: string; smoothness?: string; width?: string; highway?: string; segregated?: string; lit?: string; elevation_gain_m?: number; operator?: string; network?: string; mtb?: boolean; path_type?: string; seasonal?: string; ref?: string; inception?: string; bicycle?: string; cycleway?: string; parallel_to?: string }> = [];
    for (const m of page.memberRefs ?? []) {
      const memberPage = pageBySlug.get(m.slug);
      if (memberPage) {
        memberMeta.push({
          surface: memberPage.surface, smoothness: memberPage.smoothness, width: memberPage.width,
          highway: memberPage.highway, segregated: memberPage.segregated, lit: memberPage.lit,
          elevation_gain_m: memberPage.elevation_gain_m, operator: memberPage.operator,
          network: memberPage.network, mtb: memberPage.mtb, path_type: memberPage.path_type,
          seasonal: memberPage.seasonal, ref: memberPage.ref, inception: memberPage.inception,
          bicycle: memberPage.bicycle, cycleway: memberPage.cycleway, parallel_to: memberPage.parallel_to,
        });
      }
    }
    return {
      params: { network: page.slug },
      props: { page, networkMeta, memberMeta },
    };
  });
}

interface Props { page: BikePathPage; networkMeta: Record<string, NetworkMeta>; memberMeta: Array<{ surface?: string; smoothness?: string; width?: string; highway?: string; segregated?: string; lit?: string; elevation_gain_m?: number; operator?: string; network?: string; mtb?: boolean; path_type?: string; seasonal?: string; ref?: string; inception?: string; bicycle?: string; cycleway?: string; parallel_to?: string }> }
const { page, networkMeta, memberMeta } = Astro.props;
---

<BikePathDetail page={page} networkMeta={networkMeta} memberMeta={memberMeta} />
