---
export const prerender = false;

import AuthCardLayout from '../../components/AuthCardLayout.astro';
import { db } from '../../lib/get-db';
import { setSessionCookies } from '../../lib/auth/auth';
import { consumeMagicLinkToken } from './verify.server';

const token = Astro.url.searchParams.get('token');
let error = '';

if (token) {
  const result = await consumeMagicLinkToken(db(), token);

  if (result.ok) {
    setSessionCookies(Astro.cookies, result.token);
    return Astro.redirect('/admin');
  }

  error = result.error;
} else {
  error = 'No verification token provided.';
}
---

<AuthCardLayout title="Sign in">
  <div class="auth-error">{error}</div>
  <p><a href="/login">Back to sign in</a></p>
</AuthCardLayout>
