---
export const prerender = false;

import AuthCardLayout from '../../components/AuthCardLayout.astro';
import RegisterForm from '../../components/admin/RegisterForm.tsx';
import { isFirstUser } from '../../lib/auth/auth';
import { db } from '../../lib/get-db';

const first = await isFirstUser(db());
if (!first) return new Response(null, { status: 404 });
---

<AuthCardLayout title="Setup" subtitle="Create the first admin account.">
  <RegisterForm client:load isSetup returnTo="/admin" />
</AuthCardLayout>
