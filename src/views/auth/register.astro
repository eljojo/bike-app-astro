---
export const prerender = false;

import AuthCardLayout from '../../components/AuthCardLayout.astro';
import RegisterForm from '../../components/admin/RegisterForm.tsx';
import { getInstanceFeatures } from '../../lib/instance-features';

if (!getInstanceFeatures().allowsRegistration) {
  return new Response(null, { status: 404 });
}

const returnTo = Astro.url.searchParams.get('returnTo') || '/admin';
const isUpgrade = Astro.url.searchParams.get('join') === '1' || Astro.url.searchParams.get('upgrade') === '1';
---

<AuthCardLayout title={isUpgrade ? 'Create your account' : 'Create account'}>
  <p class="auth-message">
    {isUpgrade
      ? 'Register to get credit for your contributions.'
      : 'Create an account to make edits to routes and events.'}
  </p>
  <RegisterForm client:load returnTo={returnTo} isUpgrade={isUpgrade} />
  {!isUpgrade && <p class="auth-link">Already have an account? <a href="/login">Sign in</a></p>}
</AuthCardLayout>
