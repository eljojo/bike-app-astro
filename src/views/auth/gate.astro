---
export const prerender = false;

import AuthCardLayout from '../../components/AuthCardLayout.astro';
import AuthGate from '../../components/admin/AuthGate.tsx';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { t, localePath } from '@/i18n';

const returnTo = Astro.url.searchParams.get('returnTo') || '/admin';
const features = getInstanceFeatures();
const locale = Astro.currentLocale;

// Derive contextual title from returnTo path
function getGateTitle(): string {
  if (returnTo.includes('/routes/new')) return t('auth.gate_title_new_route', locale);
  if (returnTo.includes('/routes/')) return t('auth.gate_title_route', locale);
  if (returnTo.includes('/events/')) return t('auth.gate_title_event', locale);
  if (returnTo.includes('/places/')) return t('auth.gate_title_place', locale);
  return t('auth.gate_title_wiki', locale);
}

const title = !features.allowsGuestAccess ? t('auth.gate_title_blog', locale) : getGateTitle();
---

<AuthCardLayout title={title}>
  <AuthGate client:load returnTo={returnTo} blogMode={!features.allowsGuestAccess} locale={locale} aboutUrl={localePath('/about', locale)} />
</AuthCardLayout>
