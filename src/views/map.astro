---
export const prerender = true;
// src/views/map.astro
import Base from '@/layouts/Base.astro';
import BigMap from '@/components/BigMap.astro';
import { getCollection } from 'astro:content';
import { categoryEmoji } from '@/lib/geo/place-categories';
import { getCityConfig } from '@/lib/config/city-config';
import { t } from '@/i18n';
import { paths, routeSlug } from '@/lib/paths';
import photoLocations from 'virtual:bike-app/photo-locations';
import { haversineM, PHOTO_NEAR_PLACE_M } from '@/lib/geo/proximity';

const config = getCityConfig();
const locale = Astro.currentLocale;

const routes = await getCollection('routes');
const places = await getCollection('places');

const published = routes.filter(r => r.data.status === 'published');

const routeData = published
  .map(r => {
    const firstVariant = r.data.variants[0];
    const track = firstVariant ? r.data.gpxTracks[firstVariant.gpx] : null;
    const trans = r.data.translations?.[locale!];
    return {
      url: paths.route(routeSlug(r, locale), locale),
      name: trans?.name || r.data.name,
      polyline: track?.polyline || '',
      distance_km: r.data.distance_km,
    };
  })
  .filter(r => r.polyline);

// Build slug → {name, url} lookup for route links in photo popups
const routeInfo = new Map(published.map(r => {
  const trans = r.data.translations?.[locale!];
  return [r.id, {
    name: trans?.name || r.data.name,
    url: paths.route(routeSlug(r, locale), locale),
  }];
}));

const placeData = places
  .filter(p => p.data.status === 'published')
  .map(p => ({
    name: p.data.name,
    category: p.data.category,
    emoji: categoryEmoji[p.data.category] || '📍',
    lat: p.data.lat,
    lng: p.data.lng,
    google_maps_url: p.data.google_maps_url || `https://www.google.com/maps/?q=${p.data.lat},${p.data.lng}`,
    link: p.data.website,
    address: p.data.address,
    phone: p.data.phone,
    photo_key: p.data.photo_key,
  }));
// Select photos for the big map:
// 1. First geolocated photo per route (cover/top photo)
// 2. Any photo within PHOTO_NEAR_PLACE_M of a place marker
const selectedKeys = new Set<string>();

// 1. Top N geolocated photos per route (in media order)
const TOP_PER_ROUTE = 10;
const routePhotoCounts = new Map<string, number>();
for (const p of photoLocations) {
  if (p.routeSlug === '__parked') continue;
  const count = routePhotoCounts.get(p.routeSlug) || 0;
  if (count >= TOP_PER_ROUTE) continue;
  routePhotoCounts.set(p.routeSlug, count + 1);
  selectedKeys.add(p.key);
}

// 2. Photos near any place
for (const p of photoLocations) {
  if (selectedKeys.has(p.key)) continue;
  for (const place of placeData) {
    if (haversineM(p.lat, p.lng, place.lat, place.lng) <= PHOTO_NEAR_PLACE_M) {
      selectedKeys.add(p.key);
      break;
    }
  }
}

const photoData = photoLocations
  .filter(p => selectedKeys.has(p.key))
  .map((p, i) => {
    const info = routeInfo.get(p.routeSlug);
    return {
      key: p.key, lat: p.lat, lng: p.lng,
      caption: p.caption, width: p.width, height: p.height,
      routeName: info?.name, routeUrl: info?.url,
      index: i,
    };
  });
---

<Base title={`${t('nav.map', locale)} | ${config.display_name}`}>
  <BigMap routes={routeData} places={placeData} photos={photoData} center={[config.center.lat, config.center.lng]} />
</Base>
