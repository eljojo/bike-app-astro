---
export const prerender = true;
// src/views/map.astro
import Base from '@/layouts/Base.astro';
import BigMap from '@/components/BigMap.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { webPageJsonLd } from '@/lib/json-ld';
import { t } from '@/i18n';
import { paths, routeSlug } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getInstanceFeatures } from '@/lib/config/instance-features';

const config = getCityConfig();
const features = getInstanceFeatures();
const locale = Astro.currentLocale;

const routes = await getCollection('routes');

const { pages: bikePathPages, allYmlEntries } = features.hasPaths
  ? await loadBikePathData()
  : { pages: [], allYmlEntries: [] };

// Build relation ID → path info for map popups and interactivity
// Pages are interactive (clickable with popups). Hard-excluded entries render
// but are non-interactive (thinner, no popup, no cursor change).
import { isHardExcluded } from '../lib/bike-paths/bike-path-scoring.server';

// Map geo file ID → metadata. IDs are relation IDs (e.g., "12345") or
// prefixed slugs (e.g., "name-foo", "seg-bar") matching the .geojson filenames.
const pathMapData: Array<{ relId: string; slug: string; name: string; hasPage: boolean; interactive: boolean; surface?: string; memberOf?: string }> = [];
const mappedGeoIds = new Set<string>();

// Pages: interactive, with slug links — all geo file types
for (const p of bikePathPages) {
  for (const file of p.geoFiles) {
    const geoId = file.replace(/\.geojson$/, '');
    mappedGeoIds.add(geoId);
    pathMapData.push({
      relId: geoId,
      slug: p.slug,
      name: p.name,
      hasPage: true,
      interactive: true,
      surface: p.surface,
      memberOf: p.memberOf,
    });
  }
}

// YML entries whose geo IDs weren't already covered by page geoFiles.
// All non-hard-excluded entries now have pages, but some geo IDs may not
// be mapped via the page's geoFiles list (e.g. unclaimed relations).
for (const e of allYmlEntries) {
  const relIds = (e.osm_relations ?? []).map(String).filter(id => !mappedGeoIds.has(id));
  if (relIds.length === 0) continue;
  const excluded = isHardExcluded(e);
  // Find the page for this entry (all non-excluded entries have pages now)
  const page = !excluded ? bikePathPages.find(p => p.slug === e.slug) : undefined;
  for (const relId of relIds) {
    mappedGeoIds.add(relId);
    pathMapData.push({
      relId,
      slug: page?.slug ?? '',
      name: e.name,
      hasPage: !!page,
      interactive: !excluded,
      surface: e.surface,
      memberOf: page?.memberOf ?? e.member_of,
    });
  }
}

const published = routes.filter(r => r.data.status === 'published');

const routeData = published
  .map(r => {
    const firstVariant = r.data.variants[0];
    const track = firstVariant ? r.data.gpxTracks[firstVariant.gpx] : null;
    const trans = r.data.translations?.[locale!];
    const mediaCover = r.data.media?.find(m => m.cover)?.key || r.data.media?.[0]?.key;
    return {
      url: paths.route(routeSlug(r, locale), locale),
      name: trans?.name || r.data.name,
      polyline: track?.polyline || '',
      distance_km: r.data.distance_km,
      photo_key: mediaCover,
    };
  })
  .filter(r => r.polyline);

const mapTitle = `${t('nav.map', locale)} | ${config.display_name}`;
const mapDescription = t('map.description', locale, { count: String(routeData.length), city: config.name });
const ogImage = config.page_posters?.map ? imageUrl(config.page_posters.map, { width: 1200, height: 630, fit: 'cover' }) : undefined;
const jsonLd = webPageJsonLd({
  name: mapTitle,
  description: mapDescription,
  url: `${config.url}/map`,
  aboutName: config.name,
});
---

<Base title={mapTitle} description={mapDescription} jsonLd={jsonLd} ogImage={ogImage} fullbleed>
  <BigMap routes={routeData} center={[config.center.lat, config.center.lng]} pathMapData={features.hasPaths ? pathMapData : []} routesLabel={features.hasPaths ? t('nav.routes', locale) : undefined} pathsLabel={features.hasPaths ? t('nav.bike_paths', locale) : undefined} />
</Base>
