---
export const prerender = true;
// src/views/map.astro
import Base from '@/layouts/Base.astro';
import BigMap from '@/components/BigMap.astro';
import { getCollection } from 'astro:content';
import { categoryEmoji } from '@/lib/geo/place-categories';
import { getCityConfig } from '@/lib/config/city-config';
import { webPageJsonLd } from '@/lib/json-ld';
import { t } from '@/i18n';
import { paths, routeSlug } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import photoLocations from 'virtual:bike-app/media-locations';
import { haversineM, PHOTO_NEAR_PLACE_M } from '@/lib/geo/proximity';
import { loadBikePathData } from '@/lib/bike-paths/bike-path-data.server';
import { getInstanceFeatures } from '@/lib/config/instance-features';

const config = getCityConfig();
const features = getInstanceFeatures();
const locale = Astro.currentLocale;

const routes = await getCollection('routes');
const places = await getCollection('places');
const organizers = await getCollection('organizers');
const organizerMap = new Map(organizers.map(o => [o.id, o]));

const { pages: bikePathPages, allYmlEntries } = features.hasPaths
  ? await loadBikePathData()
  : { pages: [], allYmlEntries: [] };

// Build relation ID → path info for map popups and interactivity
// Pages are interactive (clickable with popups). Hard-excluded entries render
// but are non-interactive (thinner, no popup, no cursor change).
import { isHardExcluded } from '../lib/bike-paths/bike-path-scoring.server';

// Map geo file ID → metadata. IDs are relation IDs (e.g., "12345") or
// prefixed slugs (e.g., "name-foo", "seg-bar") matching the .geojson filenames.
const pathMapData: Array<{ relId: string; slug: string; name: string; hasPage: boolean; interactive: boolean; surface?: string; memberOf?: string }> = [];
const mappedGeoIds = new Set<string>();

// Pages: interactive, with slug links — all geo file types
for (const p of bikePathPages) {
  for (const file of p.geoFiles) {
    const geoId = file.replace(/\.geojson$/, '');
    mappedGeoIds.add(geoId);
    pathMapData.push({
      relId: geoId,
      slug: p.slug,
      name: p.name,
      hasPage: true,
      interactive: true,
      surface: p.surface,
      memberOf: p.memberOf,
    });
  }
}

// YML entries whose geo IDs weren't already covered by page geoFiles.
// All non-hard-excluded entries now have pages, but some geo IDs may not
// be mapped via the page's geoFiles list (e.g. unclaimed relations).
for (const e of allYmlEntries) {
  const relIds = (e.osm_relations ?? []).map(String).filter(id => !mappedGeoIds.has(id));
  if (relIds.length === 0) continue;
  const excluded = isHardExcluded(e);
  // Find the page for this entry (all non-excluded entries have pages now)
  const page = !excluded ? bikePathPages.find(p => p.slug === e.slug) : undefined;
  for (const relId of relIds) {
    mappedGeoIds.add(relId);
    pathMapData.push({
      relId,
      slug: page?.slug ?? '',
      name: e.name,
      hasPage: !!page,
      interactive: !excluded,
      surface: e.surface,
      memberOf: page?.memberOf ?? e.member_of,
    });
  }
}

const published = routes.filter(r => r.data.status === 'published');

const routeData = published
  .map(r => {
    const firstVariant = r.data.variants[0];
    const track = firstVariant ? r.data.gpxTracks[firstVariant.gpx] : null;
    const trans = r.data.translations?.[locale!];
    const mediaCover = r.data.media?.find(m => m.cover)?.key || r.data.media?.[0]?.key;
    return {
      url: paths.route(routeSlug(r, locale), locale),
      name: trans?.name || r.data.name,
      polyline: track?.polyline || '',
      distance_km: r.data.distance_km,
      photo_key: mediaCover,
    };
  })
  .filter(r => r.polyline);

// Build slug → {name, url} lookup for route links in photo popups
const routeInfo = new Map(published.map(r => {
  const trans = r.data.translations?.[locale!];
  return [r.id, {
    name: trans?.name || r.data.name,
    url: paths.route(routeSlug(r, locale), locale),
  }];
}));

const placeData = places
  .filter(p => p.data.status === 'published')
  .map(p => {
    const mediaCover = p.data.media?.find(m => m.cover)?.key || p.data.media?.[0]?.key;
    const org = p.data.organizer ? organizerMap.get(p.data.organizer) : undefined;
    return {
      name: p.data.name,
      category: p.data.category,
      emoji: categoryEmoji[p.data.category] || '📍',
      lat: p.data.lat,
      lng: p.data.lng,
      google_maps_url: p.data.google_maps_url || `https://www.google.com/maps/?q=${p.data.lat},${p.data.lng}`,
      link: p.data.website,
      address: p.data.address,
      phone: p.data.phone,
      photo_key: mediaCover || p.data.photo_key,
      organizer_name: org?.data.name,
      organizer_url: org ? paths.community(org.id, locale) : undefined,
    };
  });
// Auto-assign nearby route photos to places without a photo
for (const place of placeData) {
  if (place.photo_key) continue;
  let bestKey: string | undefined;
  let bestDist = PHOTO_NEAR_PLACE_M;
  for (const p of photoLocations) {
    const dist = haversineM(p.lat, p.lng, place.lat, place.lng);
    if (dist < bestDist) { bestDist = dist; bestKey = p.key; }
  }
  if (bestKey) place.photo_key = bestKey;
}
// Select photos for the big map:
// 1. First geolocated photo per route (cover/top photo)
// 2. Any photo within PHOTO_NEAR_PLACE_M of a place marker
const selectedKeys = new Set<string>();

// 1. Top N geolocated photos per route (in media order)
const TOP_PER_ROUTE = 10;
const routePhotoCounts = new Map<string, number>();
for (const p of photoLocations) {
  if (p.routeSlug === '__parked') continue;
  const count = routePhotoCounts.get(p.routeSlug) || 0;
  if (count >= TOP_PER_ROUTE) continue;
  routePhotoCounts.set(p.routeSlug, count + 1);
  selectedKeys.add(p.key);
}

// 2. Photos near any place
for (const p of photoLocations) {
  if (selectedKeys.has(p.key)) continue;
  for (const place of placeData) {
    if (haversineM(p.lat, p.lng, place.lat, place.lng) <= PHOTO_NEAR_PLACE_M) {
      selectedKeys.add(p.key);
      break;
    }
  }
}

const photoData = photoLocations
  .filter(p => selectedKeys.has(p.key))
  .map((p, i) => {
    const info = routeInfo.get(p.routeSlug);
    return {
      key: p.key, lat: p.lat, lng: p.lng,
      caption: p.caption, width: p.width, height: p.height,
      routeName: info?.name, routeUrl: info?.url,
      index: i,
    };
  });
const mapTitle = `${t('nav.map', locale)} | ${config.display_name}`;
const mapDescription = t('map.description', locale, { count: String(routeData.length), city: config.name });
const ogImage = config.page_posters?.map ? imageUrl(config.page_posters.map, { width: 1200, height: 630, fit: 'cover' }) : undefined;
const jsonLd = webPageJsonLd({
  name: mapTitle,
  description: mapDescription,
  url: `${config.url}/map`,
  aboutName: config.name,
});
---

<Base title={mapTitle} description={mapDescription} jsonLd={jsonLd} ogImage={ogImage} fullbleed>
  <BigMap routes={routeData} places={placeData} photos={photoData} center={[config.center.lat, config.center.lng]} pathMapData={features.hasPaths ? pathMapData : []} routesLabel={features.hasPaths ? t('nav.routes', locale) : undefined} pathsLabel={features.hasPaths ? t('nav.bike_paths', locale) : undefined} />
</Base>
