---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import RouteMap from '@/components/RouteMap.astro';
import tours from 'virtual:bike-app/tours';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/city-config';
import { TOUR_PALETTE } from '@/lib/map-init';
import { paths } from '@/lib/paths';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;

export async function getStaticPaths() {
  const toursData = (await import('virtual:bike-app/tours')).default;
  const routes = await getCollection('routes');

  return toursData.map(tour => {
    const tourRides = tour.rides
      .map(slug => routes.find(r => r.id === slug))
      .filter((r): r is NonNullable<typeof r> => r != null)
      .sort((a, b) => (a.data.ride_date || '').localeCompare(b.data.ride_date || ''));
    return {
      params: { slug: tour.slug },
      props: { tour, tourRides },
    };
  });
}

const { tour, tourRides } = Astro.props;

const polylines = tourRides
  .map((ride, i) => {
    const variant = ride.data.variants[0];
    if (!variant) return null;
    const track = ride.data.gpxTracks[variant.gpx];
    if (!track?.polyline) return null;
    return {
      name: ride.data.name,
      encoded: track.polyline,
      color: TOUR_PALETTE[i % TOUR_PALETTE.length],
    };
  })
  .filter((p): p is NonNullable<typeof p> => p != null);

const photos = tourRides.flatMap(ride =>
  ride.data.media
    .filter(m => m.type === 'photo' && m.lat != null && m.lng != null)
    .map((m, i) => ({ key: m.key, lat: m.lat!, lng: m.lng!, caption: m.caption, width: m.width, height: m.height, index: i }))
);

const seoTitle = `${tour.name} — Map | ${config.display_name}`;
---

<Base title={seoTitle}>
  <div class="route-map-page">
    <h1>{tour.name}</h1>
    <RouteMap polylines={polylines} photos={photos} />
    <p style="margin-top: 1em;">
      <a href={paths.tour(tour.slug)} class="go-back-button">&#x21A9; {t('map.back_to', locale, { name: tour.name })}</a>
    </p>
  </div>
</Base>
