---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import CelebrationIsland from '../../components/admin/CelebrationIsland.tsx';
import { getCityConfig } from '../../lib/config/city-config';
import { loadDetailFromJson } from '../../lib/content/load-admin-content.server';
import { eventDetailFromCache } from '../../lib/models/event-model';
import { organizerDetailFromCache } from '../../lib/models/organizer-model';
import { placeDetailFromCache } from '../../lib/models/place-model';
import { routeDetailFromCache } from '../../lib/models/route-model';

const { contentType, id } = Astro.params;
const contentId = id || '';
const isFirst = Astro.url.searchParams.get('first') === 'true';
const skipped = Astro.url.searchParams.get('skipped')?.split(',').filter(Boolean) || [];

// Slug-derived fallback: strip year prefix (e.g. "2026/bike-workshop" → "Bike Workshop")
const slugPart = contentId.includes('/') ? contentId.split('/').pop()! : contentId;
let contentName = slugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const contentTypeMap: Record<string, { collection: string; fromCache: (blob: string) => { name?: string } }> = {
  event: { collection: 'events', fromCache: eventDetailFromCache },
  route: { collection: 'routes', fromCache: routeDetailFromCache },
  place: { collection: 'places', fromCache: placeDetailFromCache },
  community: { collection: 'organizers', fromCache: organizerDetailFromCache },
};
try {
  const typeConfig = contentType ? contentTypeMap[contentType] : undefined;
  if (typeConfig) {
    const result = await loadDetailFromJson({
      contentType: typeConfig.collection,
      id: contentId,
      jsonUrl: new URL(`/admin/data/${typeConfig.collection}/${contentId}.json`, Astro.url),
      fromCache: typeConfig.fromCache,
    });
    if (!result.notFound && result.data?.name) contentName = result.data.name;
  }
} catch {
  // Fallback to slug-derived name
}

const cityConfig = getCityConfig();
const domain = cityConfig.domain;
const cityName = cityConfig.name;
let publicPath: string;
if (contentType === 'event') {
  publicPath = `/events/${contentId}`;
} else if (contentType === 'place') {
  publicPath = `/places`;
} else if (contentType === 'community') {
  publicPath = `/communities/${contentId}`;
} else {
  publicPath = `/${contentType}s/${contentId}`;
}
const publicUrl = `https://${domain}${publicPath}`;

const user = Astro.locals.user;
const isGuest = user?.role === 'guest';
const tabMap: Record<string, string> = {
  event: 'events',
  route: 'routes',
  place: 'places',
  community: 'organizers',
};
const currentTab = contentType ? (tabMap[contentType] ?? 'routes') : 'routes';
---

<AdminEditorLayout title="Contribution saved" user={user} currentTab={currentTab} hideTitle>
  <CelebrationIsland client:load
    contentType={contentType || 'route'} contentId={contentId} contentName={contentName}
    cityName={cityName} publicUrl={publicUrl} isFirst={isFirst} isGuest={isGuest} skipped={skipped} />
</AdminEditorLayout>
