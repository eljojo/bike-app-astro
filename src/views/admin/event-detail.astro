---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import EventEditor from '../../components/admin/EventEditor.tsx';
import adminEventDetails from 'virtual:bike-app/admin-event-detail';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import { env } from '../../lib/env';
import { db } from '../../lib/get-db';
import { contentEdits } from '../../db/schema';
import { eq, and } from 'drizzle-orm';
import { createGitService } from '../../lib/git-factory';
import { findDraft, deleteDraft } from '../../lib/draft-service';
import { GIT_OWNER, GIT_DATA_REPO } from '../../lib/config';
import matter from 'gray-matter';
import '../../styles/admin.scss';

const id = Astro.params.id;
if (!id) return new Response(null, { status: 404 });

const database = db();
const user = Astro.locals.user;
const city = 'ottawa';
const [year, slug] = id.split('/');
const eventPath = `${city}/events/${year}/${slug}.md`;

let eventData: any = null;
let isDraft = false;
let draftPrNumber: number | null = null;

// Check if user has an existing draft for this event
if (user) {
  const draft = await findDraft(database, user.id, 'events', id);

  if (draft) {
    const git = createGitService({
      token: env.GITHUB_TOKEN, owner: GIT_OWNER, repo: GIT_DATA_REPO,
      branch: draft.branchName,
    });
    const branchSha = await git.getRef(draft.branchName);

    if (branchSha) {
      const file = await git.readFile(eventPath);
      if (file) {
        const { data: fm, content: body } = matter(file.content);
        eventData = {
          id, slug, year,
          ...fm, body: body.trim(),
        };
        isDraft = true;
        draftPrNumber = draft.prNumber;
      }
    } else {
      await deleteDraft(database, draft.id);
    }
  }
}

// Fall back to D1 cache → virtual module
if (!eventData) {
  const cached = await database.select().from(contentEdits).where(and(eq(contentEdits.contentType, 'events'), eq(contentEdits.contentSlug, id))).get();
  eventData = cached ? JSON.parse(cached.data) : adminEventDetails[id];
}

if (!eventData) return new Response(null, { status: 404 });

const organizers = adminOrganizers;
const cdnUrl = env.R2_PUBLIC_URL || 'https://cdn.ottawabybike.ca';
---

<Base title={`Edit: ${eventData.name}`} admin>
  <div class="admin-page">
    <div class="editor-header">
      <a href="/admin/events" class="back-link">&larr; Back to events</a>
    </div>
    <h1 class="editor-title">Edit: {eventData.name}</h1>
    <EventEditor client:load initialData={eventData} organizers={organizers} cdnUrl={cdnUrl} isDraft={isDraft} draftPrNumber={draftPrNumber} />
  </div>
</Base>

<style lang="scss">
  @use '../../styles/editor';
</style>
