---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventEditor from '../../components/admin/EventEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import { env } from '../../lib/env/env.service';
import { can } from '../../lib/auth/authorize';
import { CITY } from '../../lib/config/config';
import { loadDetailFromJson, loadAdminEventList, fetchJson } from '../../lib/content/load-admin-content.server';
import { eventDetailFromCache } from '../../lib/models/event-model';
import { getCityConfig } from '../../lib/config/city-config';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { loadTagTranslations } from '../../lib/i18n/tag-translations.server';
import { defaultLocale } from '../../lib/i18n/locale-utils';
import { t } from '@/i18n';
import type { AdminEvent } from '../../types/admin';

const result = await loadDetailFromJson({
  contentType: 'events',
  id: Astro.params.id,
  jsonUrl: new URL(`/admin/data/events/${Astro.params.id}.json`, Astro.url),
  fromCache: eventDetailFromCache,
});

if (result.notFound) return new Response(null, { status: 404 });
const eventData = result.data;

const { organizers, events: buildTimeEvents } = await fetchJson<{ organizers: _AdminOrganizer[]; events: AdminEvent[] }>(new URL('/admin/data/events.json', Astro.url));
const { events: allEvents } = await loadAdminEventList(buildTimeEvents);
const adminRoutes = await fetchJson<_AdminRoute[]>(new URL('/admin/data/routes.json', Astro.url));
const adminPlaces = await fetchJson<_AdminPlace[]>(new URL('/admin/data/places.json', Astro.url));
const features = getInstanceFeatures();
const routeOptions = features.hasEnrichedEvents ? adminRoutes.map((r: { slug: string; name: string }) => ({ slug: r.slug, name: r.name })) : [];
const placeOptions = features.hasEnrichedEvents ? adminPlaces.map((p: { id: string; name: string }) => ({ id: p.id, name: p.name })) : [];
const eventOptions = allEvents
  .map((e: AdminEvent) => ({ id: e.id, name: e.name, year: e.year }))
  .sort((a: { year: string; name: string }, b: { year: string; name: string }) => b.year.localeCompare(a.year) || a.name.localeCompare(b.name));
const cityConfig = getCityConfig();
const cdnUrl = env.R2_PUBLIC_URL || cityConfig.cdn_url;
const countryCode = cityConfig.locale.includes('-') ? cityConfig.locale.split('-').pop()!.toLowerCase() : undefined;
const tagTranslations = loadTagTranslations();
const knownTags = await fetchJson<string[]>(new URL('/admin/data/known-tags.json', Astro.url));
const user = Astro.locals.user;
const today = new Date().toISOString().slice(0, 10);
const isPast = eventData.start_date < today;
const readOnly = isPast && !can(user, 'edit-past-event');
const focusParam = Astro.url.searchParams.get('focus');
const focusMode = focusParam === 'description' ? 'description' as const : null;
const locale = Astro.currentLocale;
const focusLabels = focusMode ? {
  description: t('editor.focus_description', locale, { name: eventData.name }),
  showAll: t('editor.show_all_fields', locale),
} : undefined;
---

<AdminEditorLayout title={`Edit: ${eventData.name}`} viewLink={`/events/${eventData.id}`} hideTitle user={user} currentTab="events">
  {readOnly && <p class="admin-notice">This event is in the past. Only admins can edit past events.</p>}
  <EventEditor client:load initialData={eventData} organizers={organizers} cdnUrl={cdnUrl} readOnly={readOnly} userRole={user?.role} showLicenseNotice={features.showsLicenseNotice} isClub={features.hasEnrichedEvents} routeOptions={routeOptions} placeOptions={placeOptions} eventOptions={eventOptions} tagTranslations={tagTranslations} knownTags={knownTags} defaultLocale={defaultLocale()} guestLabel={t('editor.guest_label', Astro.currentLocale)} cityCenter={[cityConfig.center.lat, cityConfig.center.lng]} cityBounds={cityConfig.bounds} cityName={cityConfig.name} countryCode={countryCode} focusMode={focusMode} focusLabels={focusLabels} />
  <EditHistory client:load contentPath={`${CITY}/events/${Astro.params.id}.md`} gitRepo={`${env.GIT_OWNER}/${env.GIT_DATA_REPO}`} userRole={user?.role} />
</AdminEditorLayout>
