---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventEditor from '../../components/admin/EventEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import adminEventDetails from 'virtual:bike-app/admin-event-detail';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import adminRoutes from 'virtual:bike-app/admin-routes';
import adminPlaces from 'virtual:bike-app/admin-places';
import { env } from '../../lib/env';
import { can } from '../../lib/authorize';
import { CDN_FALLBACK_URL, CITY } from '../../lib/config';
import { loadDetailPageData } from '../../lib/load-admin-content';
import { eventDetailFromCache } from '../../lib/models/event-model';
import { isBlogInstance, isClubInstance } from '../../lib/city-config';

const result = await loadDetailPageData({
  contentType: 'events',
  id: Astro.params.id,
  virtualModuleData: adminEventDetails,
  fromCache: eventDetailFromCache,
});

if (result.notFound) return new Response(null, { status: 404 });
const eventData = result.data;

const organizers = adminOrganizers;
const isClub = isClubInstance();
const routeOptions = isClub ? adminRoutes.map((r: { slug: string; name: string }) => ({ slug: r.slug, name: r.name })) : [];
const placeOptions = isClub ? adminPlaces.map((p: { id: string; name: string }) => ({ id: p.id, name: p.name })) : [];
const cdnUrl = env.R2_PUBLIC_URL || CDN_FALLBACK_URL;
const user = Astro.locals.user;
const today = new Date().toISOString().slice(0, 10);
const isPast = eventData.start_date < today;
const readOnly = isPast && !can(user, 'edit-past-event');
---

<AdminEditorLayout title={`Edit: ${eventData.name}`} backLink="/admin/events" backLabel="Back to events" hideTitle user={user} currentTab="events">
  {readOnly && <p class="admin-notice">This event is in the past. Only admins can edit past events.</p>}
  <EventEditor client:load initialData={eventData} organizers={organizers} cdnUrl={cdnUrl} readOnly={readOnly} userRole={user?.role} showLicenseNotice={!isBlogInstance()} isClub={isClub} routeOptions={routeOptions} placeOptions={placeOptions} />
  <EditHistory client:load contentPath={`${CITY}/events/${Astro.params.id}.md`} gitRepo={`${env.GIT_OWNER}/${env.GIT_DATA_REPO}`} userRole={user?.role} />
</AdminEditorLayout>
