---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventEditor from '../../components/admin/EventEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import adminEventDetails from 'virtual:bike-app/admin-event-detail';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import { env } from '../../lib/env';
import { can } from '../../lib/authorize';
import { CDN_FALLBACK_URL, CITY, GIT_REPO } from '../../lib/config';
import { loadAdminContent } from '../../lib/load-admin-content';
import { eventDetailFromCache } from '../../lib/models/event-model';

const id = Astro.params.id;
if (!id) return new Response(null, { status: 404 });

const [year, slug] = id.split('/');

const { data: eventData } = await loadAdminContent({
  contentType: 'events',
  contentSlug: id,
  virtualModuleData: adminEventDetails,
  fromCache: eventDetailFromCache,
});

if (!eventData) return new Response(null, { status: 404 });

const organizers = adminOrganizers;
const cdnUrl = env.R2_PUBLIC_URL || CDN_FALLBACK_URL;
const user = Astro.locals.user;
const today = new Date().toISOString().slice(0, 10);
const isPast = eventData.start_date < today;
const readOnly = isPast && !can(user, 'edit-past-event');
---

<AdminEditorLayout title={`Edit: ${eventData.name}`} backLink="/admin/events" backLabel="Back to events" hideTitle user={user} currentTab="events">
  {readOnly && <p class="admin-notice">This event is in the past. Only admins can edit past events.</p>}
  <EventEditor client:load initialData={eventData} organizers={organizers} cdnUrl={cdnUrl} readOnly={readOnly} userRole={user?.role} />
  <EditHistory client:load contentPath={`${CITY}/events/${id}.md`} gitRepo={GIT_REPO} userRole={user?.role} />
</AdminEditorLayout>
