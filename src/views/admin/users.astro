---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import UserList from '../../components/admin/UserList.tsx';
import { can } from '../../lib/auth/authorize';
import '../../styles/admin.scss';
const user = Astro.locals.user;

if (!can(Astro.locals.user, 'manage-users')) {
  return Astro.redirect('/admin');
}
---

<Base title="Users" admin>
  <div class="admin-page admin-page--narrow">
    <AdminHeader user={user} currentTab="users" subtitle="People who can edit the site." />
    <UserList client:load />
  </div>
</Base>

