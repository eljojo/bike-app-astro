---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import PlaceEditor from '../../components/admin/PlaceEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import adminPlaceDetails from 'virtual:bike-app/admin-place-detail';
import { env } from '../../lib/env/env.service';
import { CITY } from '../../lib/config/config';
import { supportedLocales, defaultLocale } from '../../lib/i18n/locale-utils';
import { loadDetailPageData } from '../../lib/load-admin-content';
import { placeDetailFromCache } from '../../lib/models/place-model';
import { getCityConfig } from '../../lib/config/city-config';

const result = await loadDetailPageData({
  contentType: 'places',
  id: Astro.params.id,
  virtualModuleData: adminPlaceDetails,
  fromCache: placeDetailFromCache,
});

if (result.notFound) return new Response(null, { status: 404 });
const placeData = result.data;

const cdnUrl = env.R2_PUBLIC_URL || getCityConfig().cdn_url;
const secondaryLocales = supportedLocales().filter(l => l !== defaultLocale());
const user = Astro.locals.user;
const cityConfig = getCityConfig();
const mapCenter: [number, number] = [cityConfig.center.lat, cityConfig.center.lng];
---

<AdminEditorLayout title={`Edit: ${placeData.name}`} backLink="/admin/places" backLabel="Back to places" hideTitle user={user} currentTab="places">
  <PlaceEditor client:load initialData={placeData} cdnUrl={cdnUrl} userRole={user?.role} secondaryLocales={secondaryLocales} mapCenter={mapCenter} />
  <EditHistory client:load contentPath={`${CITY}/places/${placeData.id}.md`} gitRepo={`${env.GIT_OWNER}/${env.GIT_DATA_REPO}`} userRole={user?.role} />
</AdminEditorLayout>
