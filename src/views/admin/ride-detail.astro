---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import RideEditor from '../../components/admin/RideEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import { env } from '../../lib/env/env.service';
import { CITY, VIDEO_PREFIX } from '../../lib/config/config';
import { getCityConfig, isBlogInstance } from '../../lib/config/city-config';
import { loadDetailFromJson } from '../../lib/content/load-admin-content.server';
import { rideDetailFromCache } from '../../lib/models/ride-model';
import { paths } from '@/lib/paths';
import { t } from '@/i18n';
import tours from 'virtual:bike-app/tours';
import { db } from '@/lib/get-db';
import { stravaTokens } from '@/db/schema';
import { eq } from 'drizzle-orm';

const { slug } = Astro.params;

// Allow ride slugs: YYYY-MM-DD-name format
if (slug && !/^[a-z0-9][a-z0-9-]*[a-z0-9]$/.test(slug)) {
  return new Response(null, { status: 404 });
}

const isNew = !slug;

let rideData;
if (isNew) {
  // Pre-fill from query params (e.g. Strava import redirect)
  const qName = Astro.url.searchParams.get('name') || '';
  const qDate = Astro.url.searchParams.get('date') || '';
  const qStravaId = Astro.url.searchParams.get('strava_id') || '';

  rideData = {
    slug: '',
    name: qName,
    tagline: '',
    tags: [],
    status: 'published',
    body: '',
    media: [],
    variants: [],
    contentHash: '',
    ride_date: qDate,
    strava_id: qStravaId,
    isNew: true,
  };
} else {
  const result = await loadDetailFromJson({
    contentType: 'rides',
    id: slug,
    jsonUrl: new URL(`/admin/data/routes/${slug}.json`, Astro.url),
    fromCache: rideDetailFromCache,
  });

  if (result.notFound) return new Response(null, { status: 404 });
  rideData = result.data;
}

const cdnUrl = env.R2_PUBLIC_URL || getCityConfig().cdn_url;
const videosCdnUrl = getCityConfig().videos_cdn_url;
const videoPrefix = isBlogInstance() ? VIDEO_PREFIX : CITY;
const title = isNew ? 'New Ride' : `Edit: ${rideData.name}`;
const locale = Astro.currentLocale;
const rideLabels = {
  date: t('ride.date', locale),
  distance: t('ride.distance', locale),
  elevation: t('ride.elevation', locale),
  moving_time: t('ride.moving_time', locale),
  speed: t('ride.speed', locale),
  country: t('ride.country', locale),
};

// Build content path for edit history from gpxRelativePath
const contentPath = slug && rideData.gpxRelativePath
  ? `${CITY}/rides/${rideData.gpxRelativePath.replace(/\.gpx$/i, '')}`
  : '';

// Check if current user has Strava connected
let stravaConnected = false;
try {
  const rows = await db().select({ userId: stravaTokens.userId }).from(stravaTokens).where(eq(stravaTokens.userId, Astro.locals.user.id));
  stravaConnected = rows.length > 0;
} catch {
  // Table may not exist yet — ignore
}
---

<AdminEditorLayout
  title={title}
  viewLink={slug ? paths.ride(slug, rideData.tour_slug) : undefined}
  hideTitle
  wide
  user={Astro.locals.user}
  currentTab="routes"
>
  <RideEditor client:load initialData={rideData} cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} userRole={Astro.locals.user?.role} rideLabels={rideLabels} tours={tours} stravaConnected={stravaConnected} />
  {slug && (
    <EditHistory client:load contentPath={contentPath} gitRepo={`${env.GIT_OWNER}/${env.GIT_DATA_REPO}`} userRole={Astro.locals.user?.role} />
  )}
</AdminEditorLayout>
