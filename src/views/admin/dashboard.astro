---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import '../../styles/admin.scss';

const user = Astro.locals.user;
---

<Base title="Admin" admin>
  <div class="admin-dashboard">
    <AdminHeader user={user} currentTab="home" />
    <h1 class="dashboard-headline">Collaborator area</h1>
    <p class="dashboard-summary">Dashboard coming soon.</p>
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;

  .admin-dashboard {
    max-width: 1200px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .dashboard-headline {
    font-family: $font-heading;
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }

  .dashboard-summary {
    font-size: 0.9375rem;
    margin: 0 0 1.5rem;
  }
</style>
