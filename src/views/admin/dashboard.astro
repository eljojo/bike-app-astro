---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import '../../styles/admin.scss';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { getCityConfig } from '../../lib/config/city-config';
import { buildImageUrl, buildImageSrcSet2x } from '../../lib/media/image-service';
import { env } from '../../lib/env/env.service';
import { createGitService } from '../../lib/git/git-factory';
import { CITY } from '../../lib/config/config';
import { toRecentCommits, groupConsecutiveByAuthor, type RecentCommit } from '../../lib/history-data.server';
import { formatAdminDateTime } from '../../lib/date-utils';
import { fetchJson } from '../../lib/content/load-admin-content.server';

const user = Astro.locals.user;
const cspNonce = Astro.locals.cspNonce;
const features = getInstanceFeatures();
const cityConfig = getCityConfig();
const cdnUrl = env.R2_PUBLIC_URL || cityConfig.cdn_url;

// Content counts and card data from virtual modules (build-time snapshots)
// Each module imported once and reused for both counts and card items.
let routeCount = 0;
let placeCount = 0;
let eventCount = 0;
let communityCount = 0;
let routesWithoutPhotos = 0;
let draftRouteCount = 0;
let totalPhotos = 0;
let routeItems: _AdminRoute[] = [];
let placeItems: _AdminPlace[] = [];
let eventItems: _AdminEvent[] = [];
let communityItems: _AdminOrganizer[] = [];

if (features.hasRoutes || features.hasRides) {
  const adminRoutes = await fetchJson<_AdminRoute[]>(new URL('/admin/data/routes.json', Astro.url));
  routeCount = adminRoutes.length;
  routeItems = adminRoutes.slice(0, 6);
  totalPhotos = adminRoutes.reduce((sum: number, r: _AdminRoute) => sum + (r.mediaCount ?? 0), 0);

  if (features.hasRoutes) {
    routesWithoutPhotos = adminRoutes.filter((r: _AdminRoute) => !r.mediaCount || r.mediaCount === 0).length;
    draftRouteCount = adminRoutes.filter((r: _AdminRoute) => r.status === 'draft').length;
  }
}

if (features.hasPlaces) {
  const adminPlaces = await fetchJson<_AdminPlace[]>(new URL('/admin/data/places.json', Astro.url));
  placeCount = adminPlaces.length;
  placeItems = adminPlaces.slice(0, 4);
}

if (features.hasEvents) {
  const adminEvents = await fetchJson<{ events: _AdminEvent[] }>(new URL('/admin/data/events.json', Astro.url)).then(d => d.events);
  const now = new Date().toISOString().slice(0, 10);
  eventCount = adminEvents.filter((e: _AdminEvent) => e.start_date >= now).length;
  eventItems = adminEvents
    .filter((e: _AdminEvent) => e.start_date >= now)
    .sort((a: _AdminEvent, b: _AdminEvent) => a.start_date.localeCompare(b.start_date))
    .slice(0, 4);

  const adminOrganizers = await fetchJson<_AdminOrganizer[]>(new URL('/admin/data/organizers.json', Astro.url));
  communityCount = adminOrganizers.length;
  communityItems = adminOrganizers.slice(0, 4);
}

// Contextual nudge — first applicable wins
let nudge = '';
if (features.hasRoutes) {
  if (routesWithoutPhotos > 0) {
    nudge = `${routesWithoutPhotos} route${routesWithoutPhotos === 1 ? '' : 's'} don't have photos yet — they'd look great with some.`;
  } else if (draftRouteCount > 0) {
    nudge = `${draftRouteCount} route${draftRouteCount === 1 ? ' is' : 's are'} still in draft.`;
  }
}

const contentLabel = features.hasRides ? 'rides' : 'routes';

// Recent changes — last 5 commits from history API
const git = createGitService({
  token: env.GITHUB_TOKEN,
  owner: env.GIT_OWNER,
  repo: env.GIT_DATA_REPO,
  branch: env.GIT_BRANCH || 'main',
});

let recentCommits: RecentCommit[] = [];
try {
  const commits = await git.listCommits({ perPage: 5, page: 1 });
  recentCommits = toRecentCommits(commits, CITY);
} catch {
  // GitHub API unavailable (local dev without token) — show empty
}
const commitGroups = groupConsecutiveByAuthor(recentCommits);
---

<Base title="Admin" admin>
  <div class="admin-dashboard">
    <AdminHeader user={user} currentTab="home" />

    <!-- Deploy Progress Bar (populated by JS) -->
    <div class="deploy-bar" id="deploy-bar" style="display: none;" role="status" aria-live="polite" data-anonymous={!user.id ? 'true' : undefined}>
      <div class="deploy-bar-content">
        <span class="deploy-bar-text" id="deploy-bar-text"></span>
        <div class="deploy-bar-track" id="deploy-bar-track" style="display: none;">
          <div class="deploy-bar-fill" id="deploy-bar-fill"></div>
        </div>
        <button type="button" class="deploy-bar-dismiss" id="deploy-bar-dismiss" aria-label="Dismiss" style="display: none;">&times;</button>
      </div>
    </div>

    <!-- Welcome Area -->
    <section class="dashboard-welcome">
      <h1 class="dashboard-headline">{features.hasRides ? 'Your rides' : 'Collaborator area'}</h1>

      <div class="dashboard-first-visit" id="dashboard-first-visit">
        <p>{features.hasRides
          ? 'Upload GPX files from your rides, add photos, and write about where you went. Each ride gets its own page with a map and everything you want to remember.'
          : 'You can add routes you\'ve ridden, mark places worth stopping at, and keep the event calendar current. No special permissions needed — browse around, and edit anything that could use your knowledge.'
        }</p>
        <button type="button" class="dashboard-first-visit-dismiss" id="dashboard-first-visit-dismiss" aria-label="Dismiss">&times;</button>
      </div>

      <p class="dashboard-summary">
        {features.hasRides
          ? `Your personal ride journal. ${routeCount} ride${routeCount === 1 ? '' : 's'} so far. Every edit goes live within a few minutes.`
          : `This is where ${cityConfig.display_name}'s cycling community builds and maintains the site together. ${routeCount} ${contentLabel}, ${placeCount} places, and ${eventCount} upcoming event${eventCount === 1 ? '' : 's'} so far. Every edit goes live within a few minutes.`
        }
      </p>
      {nudge && <p class="dashboard-nudge">{nudge}</p>}

      <div class="dashboard-quickstart">
        {features.hasRoutes && <a href="/admin/routes/new" class="quickstart-pill">Upload a route</a>}
        {features.hasRides && <a href="/admin/rides/new" class="quickstart-pill">Upload a ride</a>}
        {features.hasPlaces && <a href="/admin/places/new" class="quickstart-pill">Add a recommended stop</a>}
        {features.hasEvents && <a href="/admin/events/new" class="quickstart-pill">Add an upcoming event</a>}
      </div>
    </section>

    <!-- Content Cards -->
    <div class="dashboard-cards">
      {(features.hasRoutes || features.hasRides) && (
        <section class="dashboard-card dashboard-card--routes">
          <div class="card-header">
            <span class="card-label">{features.hasRides ? 'RIDES' : 'ROUTES'}</span>
            <span class="card-count">{routeCount}</span>
            <a href={features.hasRides ? '/admin/rides' : '/admin/routes'} class="card-viewall">View all →</a>
          </div>
          <div class="card-items card-items--routes">
            {routeItems.map((route) => (
              <a href={`/admin/${features.hasRides ? 'rides' : 'routes'}/${route.slug}`} class="card-item">
                {route.coverKey && (
                  <img
                    src={buildImageUrl(cdnUrl, route.coverKey, { width: 80, height: 80, fit: 'cover' })}
                    srcset={buildImageSrcSet2x(cdnUrl, route.coverKey, { width: 80, height: 80, fit: 'cover' })}
                    alt="" loading="lazy" class="card-item-thumb"
                  />
                )}
                <div class="card-item-info">
                  <span class="card-item-name">{route.name}</span>
                  <span class="card-item-meta">
                    {route.distance_km != null && `${route.distance_km} km`}
                    {route.mediaCount != null && route.mediaCount > 0 && ` ${route.mediaCount} photos`}
                    {route.status === 'draft' && <span class="badge-draft">draft</span>}
                  </span>
                </div>
              </a>
            ))}
          </div>
          <div class="card-footer">
            <a href={features.hasRides ? '/admin/rides/new' : '/admin/routes/new'}>+ Add new {features.hasRides ? 'ride' : 'route'}</a>
            <a href={features.hasRides ? '/admin/rides' : '/admin/routes'}>View all {routeCount} →</a>
          </div>
        </section>
      )}

      {features.hasPlaces && placeItems.length > 0 && (
        <section class="dashboard-card dashboard-card--places">
          <div class="card-header">
            <span class="card-label">PLACES</span>
            <span class="card-count">{placeCount}</span>
            <a href="/admin/places" class="card-viewall">View all →</a>
          </div>
          <div class="card-items">
            {placeItems.map((place) => (
              <a href={`/admin/places/${place.id}`} class="card-item">
                <span class="card-item-name">{place.name}</span>
                <span class="card-item-meta">{place.category}</span>
              </a>
            ))}
          </div>
          <div class="card-footer">
            <a href="/admin/places/new">+ Add new place</a>
            <a href="/admin/places">View all {placeCount} →</a>
          </div>
        </section>
      )}

      {features.hasEvents && (
        <section class="dashboard-card dashboard-card--events">
          <div class="card-header">
            <span class="card-label">EVENTS</span>
            <span class="card-count">{eventCount}</span>
            <a href="/admin/events" class="card-viewall">View all →</a>
          </div>
          <div class="card-items">
            {eventItems.map((event) => (
              <a href={`/admin/events/${event.id}`} class="card-item">
                {event.poster_key && (
                  <img
                    src={buildImageUrl(cdnUrl, event.poster_key, { width: 48, height: 64, fit: 'cover' })}
                    srcset={buildImageSrcSet2x(cdnUrl, event.poster_key, { width: 48, height: 64, fit: 'cover' })}
                    alt="" loading="lazy" class="card-item-thumb card-item-thumb--portrait"
                  />
                )}
                <div class="card-item-info">
                  <span class="card-item-name">{event.name}</span>
                  <span class="card-item-meta">{event.start_date}</span>
                </div>
              </a>
            ))}
          </div>
          <div class="card-footer">
            <a href="/admin/events/new">+ Add new event</a>
            <a href="/admin/events">View all →</a>
          </div>
        </section>
      )}

      {features.hasEvents && communityItems.length > 0 && (
        <section class="dashboard-card dashboard-card--communities">
          <div class="card-header">
            <span class="card-label">COMMUNITIES</span>
            <span class="card-count">{communityCount}</span>
            <a href="/admin/communities" class="card-viewall">View all →</a>
          </div>
          <div class="card-items card-items--communities">
            {communityItems.map((org) => (
              <a href={`/admin/communities/${org.slug}`} class="card-item">
                {org.photo_key ? (
                  <img
                    src={buildImageUrl(cdnUrl, org.photo_key, { width: 80, height: 80, fit: 'cover' })}
                    srcset={buildImageSrcSet2x(cdnUrl, org.photo_key, { width: 80, height: 80, fit: 'cover' })}
                    alt="" loading="lazy" class="card-item-thumb card-item-thumb--round"
                  />
                ) : (
                  <div class="card-item-initials">{org.name.split(/\s+/).slice(0, 3).map(w => w[0]).join('').toUpperCase()}</div>
                )}
                <div class="card-item-info">
                  <span class="card-item-name">{org.name}</span>
                  {org.tagline && <span class="card-item-meta">{org.tagline}</span>}
                </div>
              </a>
            ))}
          </div>
          <div class="card-footer">
            <a href="/admin/communities/new">+ Add new community</a>
            <a href="/admin/communities">View all {communityCount} →</a>
          </div>
        </section>
      )}
    </div>

    <!-- Bottom Row -->
    <div class="dashboard-bottom">
      <section class="dashboard-card dashboard-card--changes">
        <div class="card-header">
          <span class="card-label">RECENT CHANGES</span>
          <a href="/admin/history" class="card-viewall">View full history &rarr;</a>
        </div>
        <div class="card-items">
          {commitGroups.map((group) => (
            <div class="change-group">
              <div class="change-group-author"><strong>{group.username}</strong></div>
              {group.commits.map((c) => (
                <div class="change-item">
                  <div class="change-info">
                    <span class="change-headline">
                      {c.editorUrl
                        ? <a href={c.editorUrl}>{c.headline}</a>
                        : c.headline
                      }
                      {c.detail && ` \u2014 ${c.detail}`}
                    </span>
                    {c.contentType && <span class={`change-badge change-badge--${c.contentType}`}>{c.contentType.replace(/s$/, '')}</span>}
                  </div>
                  <time class="change-time">{formatAdminDateTime(c.date)}</time>
                </div>
              ))}
            </div>
          ))}
          {recentCommits.length === 0 && <p class="card-empty">No recent changes.</p>}
        </div>
      </section>

      <section class="dashboard-card dashboard-card--glance">
        <div class="card-header">
          <span class="card-label">AT A GLANCE</span>
        </div>
        <div class="glance-stats">
          {features.hasRides && (
            <>
              <div class="glance-row">
                <span>Rides</span>
                <strong>{routeCount}</strong>
              </div>
              <div class="glance-row">
                <span>Total photos</span>
                <strong>{totalPhotos}</strong>
              </div>
            </>
          )}
          {features.hasRoutes && (
            <>
              <div class="glance-row">
                <span>Published routes</span>
                <strong>{routeCount - draftRouteCount}</strong>
              </div>
              {draftRouteCount > 0 && (
                <div class="glance-row">
                  <span>Draft routes</span>
                  <strong>{draftRouteCount}</strong>
                </div>
              )}
              <div class="glance-row">
                <span>Total photos</span>
                <strong>{totalPhotos}</strong>
              </div>
              {routesWithoutPhotos > 0 && (
                <div class="glance-row glance-row--highlight">
                  <span>Routes without photos</span>
                  <strong>{routesWithoutPhotos}</strong>
                </div>
              )}
            </>
          )}
          {features.hasEvents && (
            <div class="glance-row">
              <span>Upcoming events</span>
              <strong>{eventCount}</strong>
            </div>
          )}
          {features.hasEvents && communityCount > 0 && (
            <div class="glance-row">
              <span>Communities</span>
              <strong>{communityCount}</strong>
            </div>
          )}
          {features.hasPlaces && (
            <div class="glance-row">
              <span>Places</span>
              <strong>{placeCount}</strong>
            </div>
          )}
        </div>
      </section>
    </div>
  </div>
</Base>

<script is:inline nonce={cspNonce}>
  const firstVisit = document.getElementById('dashboard-first-visit');
  const dismiss = document.getElementById('dashboard-first-visit-dismiss');
  if (localStorage.getItem('dashboard-welcomed')) {
    firstVisit?.remove();
  }
  dismiss?.addEventListener('click', () => {
    localStorage.setItem('dashboard-welcomed', '1');
    firstVisit?.remove();
  });
</script>

<script is:inline nonce={cspNonce}>
  const bar = document.getElementById('deploy-bar');
  const text = document.getElementById('deploy-bar-text');
  const track = document.getElementById('deploy-bar-track');
  const fill = document.getElementById('deploy-bar-fill');
  const dismissBtn = document.getElementById('deploy-bar-dismiss');

  if (bar && text && track && fill && dismissBtn) {
    if (bar.dataset.anonymous === 'true') return;
    let dismissed = false;
    let prevStatus = '';
    let interval = 30000;

    dismissBtn.addEventListener('click', () => {
      dismissed = true;
      sessionStorage.setItem('deploy-bar-dismissed', '1');
      bar.style.display = 'none';
    });

    async function checkDeploy() {
      if (dismissed) return;
      try {
        const res = await fetch('/api/admin/deploy-status');
        if (!res.ok) return;
        const data = await res.json();

        // If we were deploying/queued and now idle, show "live" instead of hiding
        if (data.status === 'idle' && (prevStatus === 'deploying' || prevStatus === 'queued')) {
          data.status = 'live';
        }

        prevStatus = data.status;

        if (data.status === 'idle') {
          bar.style.display = 'none';
          interval = 30000;
          return;
        }

        if (data.status === 'live' && sessionStorage.getItem('deploy-bar-dismissed')) {
          bar.style.display = 'none';
          interval = 30000;
          return;
        }

        bar.style.display = 'block';

        if (data.status === 'deploying') {
          text.textContent = 'Your changes are on their way \u2014 about ' + data.estimatedMinutes + ' minute' + (data.estimatedMinutes === 1 ? '' : 's');
          track.style.display = 'block';
          fill.style.width = data.progress + '%';
          dismissBtn.style.display = 'none';
          interval = 10000;
        } else if (data.status === 'queued') {
          text.textContent = 'Changes are queued \u2014 they\'ll go out with the next update.';
          track.style.display = 'none';
          dismissBtn.style.display = 'none';
          interval = 10000;
        } else if (data.status === 'live') {
          text.textContent = 'Changes are live.';
          track.style.display = 'none';
          dismissBtn.style.display = 'block';
          sessionStorage.removeItem('deploy-bar-dismissed');
          interval = 30000;
        }
      } catch { /* network error — skip silently */ }
    }

    function poll() {
      checkDeploy().then(function() {
        setTimeout(poll, interval);
      });
    }
    poll();
  }
</script>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-dashboard {
    max-width: 1200px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .dashboard-welcome {
    margin-bottom: 2rem;
  }

  .dashboard-headline {
    font-family: $font-heading;
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }

  .dashboard-summary {
    font-size: 0.9375rem;
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .dashboard-nudge {
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    color: $color-warning;

    @include dark-mode {
      color: $color-warning-dark;
    }
  }

  .dashboard-first-visit {
    position: relative;
    background: $color-info-bg;
    border: 1px solid $color-info-border;
    border-radius: $border-radius;
    padding: 0.75rem 2rem 0.75rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: $color-info;

    @include dark-mode {
      background: $color-info-bg-dark;
      border-color: $color-info-border-dark;
      color: $color-info-dark;
    }

    p { margin: 0; }
  }

  .dashboard-first-visit-dismiss {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: 1.125rem;
    line-height: 1;
    color: inherit;
    opacity: 0.5;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.125rem 0.25rem;

    &:hover { opacity: 1; }
  }

  .dashboard-quickstart {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .quickstart-pill {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border: 1px solid $color-border;
    border-radius: 999px;
    font-size: 0.8125rem;
    text-decoration: none;
    color: $color-text;

    @include dark-mode {
      border-color: $color-border-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;
      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .dashboard-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;

    @media (max-width: $breakpoint-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .dashboard-card {
    background: $color-card-bg;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: $color-card-bg-dark;
      border-color: $color-border-dark;
    }
  }

  .dashboard-card--routes,
  .dashboard-card--communities {
    grid-column: 1 / -1;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid $color-border;

    @include dark-mode {
      border-color: $color-border-subtle-dark;
    }
  }

  .card-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    @include muted-text;
  }

  .card-count {
    font-size: 1.25rem;
    font-weight: 700;
    font-family: $font-heading;
  }

  .card-viewall {
    margin-left: auto;
    font-size: 0.8125rem;
    text-decoration: none;
    @include muted-text;

    &:hover { text-decoration: underline; }
  }

  .card-items {
    padding: 0.5rem;
  }

  .card-items--routes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;

    @media (max-width: $breakpoint-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .card-items--communities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;

    @media (max-width: $breakpoint-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .card-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: $border-radius;
    text-decoration: none;
    color: $color-text;

    @include dark-mode {
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;
      @include dark-mode { background: $color-card-hover-dark; }
    }
  }

  .card-item-thumb {
    width: 40px;
    height: 40px;
    border-radius: $border-radius;
    object-fit: cover;
    flex-shrink: 0;
  }

  .card-item-thumb--portrait {
    width: 32px;
    height: 44px;
  }

  .card-item-thumb--round {
    border-radius: 50%;
  }

  .card-item-initials {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: $color-tag-bg;
    color: $color-tag-text;
    font-size: 0.75rem;
    font-weight: 600;

    @include dark-mode {
      background: $color-border-dark;
      color: $color-text-dark;
    }
  }

  .card-item-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-item-name {
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-item-meta {
    font-size: 0.75rem;
    @include muted-text;
  }

  .badge-draft {
    background: $color-accent;
    color: #000;
    padding: 0.0625rem 0.25rem;
    border-radius: $border-radius;
    font-size: 0.6875rem;
    margin-left: 0.25rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    border-top: 1px solid $color-border;
    font-size: 0.8125rem;

    @include dark-mode {
      border-color: $color-border-subtle-dark;
    }

    a {
      text-decoration: none;
      @include muted-text;
      &:hover { text-decoration: underline; }
    }
  }

  .dashboard-bottom {
    display: grid;
