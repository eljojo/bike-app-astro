---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import StagingSyncButton from '../../components/admin/StagingSyncButton.tsx';
import adminRoutes from 'virtual:bike-app/admin-routes';
import { env } from '../../lib/env/env.service';
import { loadAdminRouteList } from '../../lib/content/load-admin-content.server';
import { getCityConfig } from '../../lib/config/city-config';
import { buildImageUrl } from '@/lib/media/image-service';
import '../../styles/admin.scss';
const user = Astro.locals.user;
const cspNonce = Astro.locals.cspNonce;
const isStaging = env.ENVIRONMENT === 'staging';
const cdnUrl = env.R2_PUBLIC_URL || getCityConfig().cdn_url;
const sortBy = Astro.url.searchParams.get('sort') === 'score' ? 'score' : 'alpha';

const { routes: mergedRoutes, pendingSlugs } = await loadAdminRouteList(adminRoutes);

let routes = mergedRoutes.sort((a, b) => {
  if (sortBy === 'score') {
    // Routes with scores first (ascending = easiest first), then routes without scores alphabetically
    if (a.difficultyScore != null && b.difficultyScore != null) return a.difficultyScore - b.difficultyScore;
    if (a.difficultyScore != null) return -1;
    if (b.difficultyScore != null) return 1;
    return a.name.localeCompare(b.name);
  }
  return a.name.localeCompare(b.name);
});
---

<Base title="Admin" admin>
  {user.analyticsOptOut && <script is:inline nonce={cspNonce}>localStorage.plausible_ignore=true</script>}
  <div class="admin-page">
    <AdminHeader
      user={user}
      currentTab="routes"
      subtitle="Cycling routes people can follow. Each one has a map, photos, and directions."
    />

    <div class="admin-actions">
      <a href="/admin/routes/new" class="btn-new-route">+ New route</a>
    </div>

    <div class="sort-controls">
      <span class="sort-label">Sort:</span>
      <a href="/admin/routes" class:list={['sort-option', { active: sortBy === 'alpha' }]}>A–Z</a>
      <a href="/admin/routes?sort=score" class:list={['sort-option', { active: sortBy === 'score' }]}>Difficulty</a>
      <label class="photo-toggle">
        <input type="checkbox" id="photo-toggle" checked /> Photos
      </label>
    </div>

    <div class="route-list" id="route-list">
      {routes.map((route) => (
        <a href={`/admin/routes/${route.slug}`} class="route-list-item">
          {route.coverKey && (
            <img
              src={buildImageUrl(cdnUrl, route.coverKey, { width: 80, height: 80, fit: 'cover' })}
              alt=""
              loading="lazy"
              class="route-cover-thumb"
            />
          )}
          <div class="route-card-info">
            <span class="route-name">{route.name}</span>
            <span class="route-meta">
              {route.difficultyScore != null && <span class="route-score">{route.difficultyScore}</span>}
              {route.mediaCount} media
              {route.status === 'draft' && <span class="route-draft">draft</span>}
              {pendingSlugs.has(route.slug) && <span class="route-pending">pending</span>}
            </span>
          </div>
        </a>
      ))}
      {routes.length === 0 && (
        <p class="auth-message">No routes found.</p>
      )}
    </div>

    {isStaging && user.role === 'admin' && (
      <div class="admin-section">
        <h2>Sync from production</h2>
        <StagingSyncButton client:load />
      </div>
    )}
  </div>
</Base>

<script>
  const toggle = document.getElementById('photo-toggle') as HTMLInputElement | null;
  const list = document.getElementById('route-list');
  if (toggle && list) {
    const key = 'admin-routes-photos';
    const saved = localStorage.getItem(key);
    if (saved === 'off') {
      toggle.checked = false;
      list.classList.add('compact');
    }
    toggle.addEventListener('change', () => {
      list.classList.toggle('compact', !toggle.checked);
      localStorage.setItem(key, toggle.checked ? 'on' : 'off');
    });
  }
</script>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .admin-actions {
    margin-bottom: 0.75rem;
  }

  .btn-new-route {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: $color-accent;
    color: #000;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;

    &:hover {
      opacity: 0.9;
    }
  }

  .sort-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
  }

  .sort-label {
    @include muted-text;
  }

  .sort-option {
    text-decoration: none;
    padding: 0.125rem 0.5rem;
    border-radius: $border-radius;
    @include muted-text;

    &.active {
      background: $color-tag-bg;
      color: $color-tag-text;
    }

    &:hover:not(.active) {
      text-decoration: underline;
    }
  }

  .route-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: $color-border-subtle-dark;
    }
  }

  .route-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .route-cover-thumb {
    width: 40px;
    height: 40px;
    border-radius: $border-radius;
    object-fit: cover;
    flex-shrink: 0;

    .compact & { display: none; }
  }

  .route-card-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .route-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .route-meta {
    font-size: 0.8125rem;
    flex-shrink: 0;
    @include muted-text;
  }

  .photo-toggle {
    margin-left: auto;
    font-size: 0.8125rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    @include muted-text;

    input { cursor: pointer; }
  }

  .route-score {
    font-family: $font-mono;
    font-size: 0.75rem;
    margin-right: 0.25rem;
    @include muted-text;
  }

  .route-draft {
    background: $color-accent;
    color: #000;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
    margin-left: 0.5rem;
  }

  .route-pending {
    background: $color-tag-bg;
    color: $color-tag-text;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
    margin-left: 0.5rem;
  }

  .admin-section {
    margin-top: 2rem;

    h2 {
      font-family: $font-heading;
      font-size: 1.25rem;
      margin: 0 0 0.75rem;
    }
  }

</style>
