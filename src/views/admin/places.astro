---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import AdminListSidebar from '../../components/admin/AdminListSidebar.tsx';
import { categoryEmoji } from '../../lib/geo/place-categories';
import { getCityConfig } from '../../lib/config/city-config';
import { fetchJson } from '../../lib/content/load-admin-content.server';
import { t } from '../../i18n';
import '../../styles/admin.scss';

const locale = Astro.currentLocale;
const adminPlaces = await fetchJson<_AdminPlace[]>(new URL('/admin/data/places.json', Astro.url));

const user = Astro.locals.user;
const config = getCityConfig();
const mapPlaces = adminPlaces.filter(p => p.lat && p.lng).map(p => ({
  id: p.id,
  name: p.name,
  emoji: categoryEmoji[p.category] || '\u{1F4CD}',
  lat: p.lat,
  lng: p.lng,
}));

// Group by category
function groupByCategory(places: typeof adminPlaces) {
  const groups: Record<string, { label: string; emoji: string; places: typeof adminPlaces }> = {};
  for (const p of places) {
    if (!groups[p.category]) {
      groups[p.category] = {
        label: p.category.replace(/-/g, ' '),
        emoji: categoryEmoji[p.category] || '📌',
        places: [],
      };
    }
    groups[p.category].places.push(p);
  }
  return Object.entries(groups)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([key, group]) => ({ key, ...group }));
}

const grouped = groupByCategory(adminPlaces);

const incomplete = adminPlaces
  .filter(p => {
    if (!p.photo_key) return true;
    const hasContact = p.social_links?.some(l => ['website', 'telephone'].includes(l.platform));
    return !hasContact;
  })
  .map(p => ({
    slug: p.id,
    name: p.name,
    hint: !p.photo_key ? t('admin.sidebar.no_photo', locale) : t('admin.sidebar.no_website', locale),
    editUrl: `/admin/places/${p.id}`,
  }))
  .slice(0, 5);

const nameMap: Record<string, string> = {};
for (const p of adminPlaces) nameMap[p.id] = p.name;

const sidebarLabels = {
  mostViewed: t('admin.sidebar.most_visited', locale),
  mostStarred: t('admin.sidebar.most_starred', locale),
  trending: t('admin.sidebar.trending', locale),
  overlooked: t('admin.sidebar.overlooked', locale),
};
---

<Base title="Places - Admin" admin>
  <div class="admin-page">
    <AdminHeader user={user} currentTab="places" subtitle="Recommended stops along routes — cafes, viewpoints, swimming spots, parks." ctaHref="/admin/places/new" ctaLabel="+ New place" />

    <div class="admin-list-layout">
      <div class="admin-list-main">
        <div class="place-actions-bar">
          <span class="place-count">{adminPlaces.length} places</span>
        </div>

        {mapPlaces.length > 0 && (
          <div
            id="places-map"
            class="places-admin-map"
            data-places={JSON.stringify(mapPlaces)}
            data-center={JSON.stringify([config.center.lat, config.center.lng])}
          />
        )}

        {grouped.map(({ key, label, emoji, places }) => (
          <div class="place-category-group" id={`cat-${key}`}>
            <h2 class="category-header">{emoji} {label} <span class="category-count">({places.length})</span></h2>
            <div class="place-list">
              {places.map(p => (
                <a href={`/admin/places/${p.id}`} class="place-list-item">
                  <span class="place-card-emoji">{categoryEmoji[p.category] || '📌'}</span>
                  <div class="place-card-info">
                    <span class="place-card-name">{p.name}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}

        {adminPlaces.length === 0 && <p class="auth-message">No places found. Create one to get started.</p>}
      </div>
      <div class="places-sidebar">
        <nav class="places-category-nav">
          <h4 class="admin-sidebar-heading">Categories</h4>
          <div class="admin-sidebar-list">
            {grouped.map(({ key, emoji, label, places }) => (
              <div class="admin-sidebar-item">
                <a href={`#cat-${key}`}>{emoji} {label}</a>
                <span class="admin-sidebar-value">{places.length}</span>
              </div>
            ))}
          </div>
        </nav>
        <AdminListSidebar
          client:idle
          contentType="places"
          incomplete={incomplete}
          nameMap={nameMap}
          editPrefix="/admin/places"
          labels={sidebarLabels}
        />
      </div>
    </div>
  </div>
</Base>

<script>
  import { initMap, addMarkers } from '../../lib/maps/map-init';
  import { getStyleUrl, loadStylePreference } from '../../lib/maps/map-style-switch';
  import maplibregl from 'maplibre-gl';
  import { html } from '../../lib/maps/map-helpers';

  const el = document.getElementById('places-map');
  if (el) {
    const places = JSON.parse(el.dataset.places || '[]');
    const center = JSON.parse(el.dataset.center || '[45.42, -75.69]');

    const map = initMap({ el, center, zoom: 11, styleUrl: getStyleUrl(loadStylePreference()) });

    map.on('load', () => {
      addMarkers(map, places.map((p: any) => ({
        lat: p.lat, lng: p.lng, emoji: p.emoji,
        popup: html`<a href="/admin/places/${p.id}"><strong>${p.name}</strong></a>`,
      })));

      if (places.length > 0) {
        const bounds = new maplibregl.LngLatBounds();
        for (const p of places) bounds.extend([p.lng, p.lat]);
        map.fitBounds(bounds.toArray() as [[number, number], [number, number]], { padding: 30 });
      }
    });
  }
</script>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-list-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;

    @media (max-width: $breakpoint-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .admin-list-main {
    min-width: 0;
  }

  .places-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .places-category-nav {
    font-size: 0.8rem;
  }

  .places-admin-map {
    height: 350px;
    border-radius: $border-radius;
    margin-bottom: 1.5rem;
  }

  .place-actions-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .place-count {
    font-size: 0.875rem;
    @include muted-text;
  }

  .place-category-group {
    margin-bottom: 1.5rem;
  }

  .category-header {
    font-family: $font-heading;
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    text-transform: capitalize;
  }

  .category-count {
    font-weight: 400;
    font-size: 0.875rem;
    @include muted-text;
  }

  .place-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: $color-border-subtle-dark;
    }
  }

  .place-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .place-card-emoji {
    font-size: 1.25rem;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }

  .place-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .place-card-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
