---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import adminRidesData from 'virtual:bike-app/admin-routes';
import type { AdminRide } from '../../loaders/admin-rides';
import { loadAdminRideList } from '../../lib/load-admin-content';
import '../../styles/admin.scss';

const user = Astro.locals.user;
const cspNonce = Astro.locals.cspNonce;

// Virtual module is typed as AdminRoute[] but contains AdminRide[] for blog instances
const { rides, pendingSlugs } = await loadAdminRideList(adminRidesData as unknown as AdminRide[]);
const sortedRides = [...rides].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
---

<Base title="Rides" admin>
  {user.analyticsOptOut && <script is:inline nonce={cspNonce}>localStorage.plausible_ignore=true</script>}
  <div class="admin-page">
    <AdminHeader
      user={user}
      currentTab="routes"
    />

    <div class="admin-actions">
      <a href="/admin/rides/new" class="btn-new-route">+ New ride</a>
    </div>

    <div class="route-list">
      {sortedRides.map((ride) => (
        <a href={`/admin/rides/${ride.slug}`} class="route-list-item">
          <span class="route-name">{ride.name}</span>
          <span class="route-meta">
            {ride.date && <span>{ride.date}</span>}
            {ride.distance_km > 0 && <span>{ride.distance_km.toFixed(0)} km</span>}
            {ride.country && <span>{ride.country}</span>}
            {pendingSlugs.has(ride.slug) && <span class="route-pending">pending</span>}
          </span>
        </a>
      ))}
      {sortedRides.length === 0 && (
        <p class="auth-message">No rides yet. Upload a GPX to get started.</p>
      )}
    </div>
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .admin-actions {
    margin-bottom: 0.75rem;
  }

  .btn-new-route {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: $color-accent;
    color: #000;
    border-radius: $border-radius;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;

    &:hover {
      opacity: 0.9;
    }
  }

  .route-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: #333;
    }
  }

  .route-list-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .route-name {
    font-weight: 600;
  }

  .route-meta {
    font-size: 0.8125rem;
    @include muted-text;
    display: flex;
    gap: 0.5rem;
  }

  .route-pending {
    background: $color-tag-bg;
    color: $color-tag-text;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
  }
</style>
