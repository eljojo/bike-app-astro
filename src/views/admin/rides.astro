---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import StravaImport from '../../components/admin/StravaImport.tsx';
import type { AdminRide } from '../../loaders/admin-rides';
import { loadAdminRideList, fetchJson } from '../../lib/content/load-admin-content.server';
import { formatDistance } from '../../lib/format';
import { db } from '../../lib/get-db';
import { stravaTokens } from '../../db/schema';
import { eq } from 'drizzle-orm';
import '../../styles/admin.scss';

const user = Astro.locals.user;
const cspNonce = Astro.locals.cspNonce;

const adminRidesData = await fetchJson<AdminRide[]>(new URL('/admin/data/routes.json', Astro.url));

const { rides, pendingSlugs } = await loadAdminRideList(adminRidesData as unknown as AdminRide[]);

let stravaConnected = false;
if (user.id) {
  try {
    const rows = await db().select({ userId: stravaTokens.userId }).from(stravaTokens).where(eq(stravaTokens.userId, user.id));
    stravaConnected = rows.length > 0;
  } catch {
    // Table may not exist yet
  }
}
const sortedRides = [...rides].sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// Extract unique years for year filter
const years = [...new Set(sortedRides.map(r => r.date?.slice(0, 4)).filter(Boolean))].sort((a, b) => b!.localeCompare(a!));
---

<Base title="Rides" admin>
  {user.analyticsOptOut && <script is:inline nonce={cspNonce}>localStorage.plausible_ignore=true</script>}
  <div class="admin-page">
    <AdminHeader
      user={user}
      currentTab="rides"
      subtitle="Your rides, newest first. Each one gets its own page with a map and photos."
      ctaHref="/admin/rides/new"
      ctaLabel="+ New ride"
    />

    {user.role === 'admin' && stravaConnected && (
      <div class="admin-actions">
        <StravaImport client:load />
      </div>
    )}

    <div class="admin-filters" id="ride-filters">
      <button type="button" class="admin-filter-pill active" data-filter="all">All</button>
      <button type="button" class="admin-filter-pill" data-filter="long">Long (50km+)</button>
      <button type="button" class="admin-filter-pill" data-filter="century">Century (100km+)</button>
      <button type="button" class="admin-filter-pill" data-filter="tours">Tours</button>
      {years.length > 1 && (
        <select class="admin-filter-year" id="year-filter">
          <option value="">All years</option>
          {years.map(year => (
            <option value={year}>{year}</option>
          ))}
        </select>
      )}
    </div>

    <div class="route-list" id="ride-list">
      {sortedRides.map((ride) => (
        <a
          href={`/admin/rides/${ride.slug}`}
          class="route-list-item"
          data-distance={ride.distance_km}
          data-tour={ride.tour_slug || ''}
          data-country={ride.country || ''}
          data-date={ride.date || ''}
        >
          <span class="route-name">{ride.name}</span>
          <span class="route-meta">
            {ride.date && <span>{ride.date}</span>}
            {ride.distance_km > 0 && <span>{formatDistance(ride.distance_km)}</span>}
            {ride.country && <span>{ride.country}</span>}
            {pendingSlugs.has(ride.slug) && <span class="route-pending">pending</span>}
          </span>
        </a>
      ))}
      {sortedRides.length === 0 && (
        <p class="auth-message">No rides yet. Upload a GPX to get started.</p>
      )}
    </div>
  </div>
</Base>

<script>
  // Astro compiles <script> to <script type="module"> which is deferred,
  // so the DOM is ready when this runs — no event wrapper needed.
  const filtersEl = document.getElementById('ride-filters');
  const listEl = document.getElementById('ride-list');
  const yearSelect = document.getElementById('year-filter') as HTMLSelectElement | null;
  if (filtersEl && listEl) {
    const pills = filtersEl.querySelectorAll<HTMLButtonElement>('.admin-filter-pill');
    const items = listEl.querySelectorAll<HTMLElement>('.route-list-item');

    let activeFilter = 'all';
    let activeYear = '';

    function applyFilters() {
      let visible = 0;
      items.forEach(item => {
        const distance = parseFloat(item.dataset.distance || '0');
        const tour = item.dataset.tour || '';
        const date = item.dataset.date || '';
        const year = date.slice(0, 4);

        let show = true;

        // Type filter
        if (activeFilter === 'long') show = distance >= 50;
        else if (activeFilter === 'century') show = distance >= 100;
        else if (activeFilter === 'tours') show = !!tour;

        // Year filter
        if (show && activeYear) show = year === activeYear;

        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        activeFilter = pill.dataset.filter || 'all';
        applyFilters();
      });
    });

    if (yearSelect) {
      yearSelect.addEventListener('change', () => {
        activeYear = yearSelect.value;
        applyFilters();
      });
    }

    // Check URL for initial filter
    const params = new URLSearchParams(window.location.search);
    const urlFilter = params.get('filter');
    if (urlFilter) {
      const matchPill = filtersEl.querySelector<HTMLButtonElement>(`[data-filter="${urlFilter}"]`);
      if (matchPill) {
        pills.forEach(p => p.classList.remove('active'));
        matchPill.classList.add('active');
        activeFilter = urlFilter;
        applyFilters();
      }
    }
  }
</script>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .admin-actions {
    margin-bottom: 0.75rem;
  }

  .admin-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }

  .admin-filter-pill {
    padding: 0.25rem 0.75rem;
    border: 1px solid $color-border;
    border-radius: 1rem;
    background: transparent;
    color: $color-text;
    cursor: pointer;
    font-size: 0.8125rem;

    @include dark-mode {
      color: $color-text-dark;
      border-color: $color-border-dark;
    }

    &.active {
      background: $color-accent;
      color: $color-text;
      border-color: $color-accent;
    }
  }

  .admin-filter-year {
    padding: 0.25rem 0.5rem;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: transparent;
    color: $color-text;
    font-size: 0.8125rem;
    margin-left: 0.25rem;

    @include dark-mode {
      color: $color-text-dark;
      border-color: $color-border-dark;
      background: $color-card-bg-dark;
    }
  }

  .route-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: $color-border-subtle-dark;
    }
}

  .route-list-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .route-name {
    font-weight: 600;
  }

  .route-meta {
    font-size: 0.8125rem;
    @include muted-text;
    display: flex;
    gap: 0.5rem;
  }

  .route-pending {
    background: $color-tag-bg;
    color: $color-tag-text;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
  }
</style>
