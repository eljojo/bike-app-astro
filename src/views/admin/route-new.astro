---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import RouteCreator from '../../components/admin/RouteCreator.tsx';
import RouteWizard from '../../components/admin/RouteWizard.tsx';
import { env } from '../../lib/env/env.service';
import { CITY, VIDEO_PREFIX } from '../../lib/config/config';
import { getCityConfig, isBlogInstance } from '../../lib/config/city-config';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { loadTagTranslations } from '../../lib/i18n/tag-translations.server';
import { defaultLocale } from '../../lib/i18n/locale-utils';
import { fetchJson } from '../../lib/content/load-admin-content.server';
import { t } from '@/i18n';

const cityConfig = getCityConfig();
const cdnUrl = env.R2_PUBLIC_URL || cityConfig.cdn_url;
const videosCdnUrl = cityConfig.videos_cdn_url;
const videoPrefix = isBlogInstance() ? VIDEO_PREFIX : CITY;
const mediaLocations = await fetchJson<_MediaLocation[]>(new URL('/admin/data/media-locations.json', Astro.url));
const fullEditor = Astro.url.searchParams.get('full') === '1';
const tagTranslations = loadTagTranslations();
const knownTags = await fetchJson<string[]>(new URL('/admin/data/known-tags.json', Astro.url));
---

<AdminEditorLayout title="New Route" user={Astro.locals.user} currentTab="routes" hideTitle={!fullEditor}>
  {fullEditor ? (
    <RouteCreator client:load cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} mediaLocations={mediaLocations} />
  ) : (
    <RouteWizard client:load cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} mediaLocations={mediaLocations} knownTags={knownTags} tagTranslations={tagTranslations} defaultLocale={defaultLocale()} userRole={Astro.locals.user?.role} showLicenseNotice={getInstanceFeatures().showsLicenseNotice} guestLabel={t('editor.guest_label', Astro.currentLocale)} cityName={cityConfig.name} />
  )}
</AdminEditorLayout>
