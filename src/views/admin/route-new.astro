---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import RouteCreator from '../../components/admin/RouteCreator.tsx';
import { env } from '../../lib/env/env.service';
import { getCityConfig } from '../../lib/config/city-config';

const cdnUrl = env.R2_PUBLIC_URL || getCityConfig().cdn_url;
---

<AdminEditorLayout title="New Route" backLink="/admin" backLabel="Back to routes" user={Astro.locals.user} currentTab="routes">
  <RouteCreator client:load cdnUrl={cdnUrl} />
</AdminEditorLayout>
