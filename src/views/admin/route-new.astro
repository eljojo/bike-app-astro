---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import RouteCreator from '../../components/admin/RouteCreator.tsx';
import '../../styles/admin.scss';
---

<Base title="New Route" admin>
  <div class="admin-page">
    <div class="editor-header">
      <a href="/admin" class="back-link">&larr; Back to routes</a>
    </div>
    <h1 class="editor-title">New Route</h1>
    <RouteCreator client:load />
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;
  @use '../../styles/editor';

  .route-creator {
    max-width: 500px;
  }

  .drop-zone--large {
    padding: 3rem 1.5rem;
    font-size: 1rem;
  }

  .route-creator-setup {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;

    small {
      font-size: 0.75rem;
      @include muted-text;
    }
  }
</style>
