---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import RouteCreator from '../../components/admin/RouteCreator.tsx';
import '../../styles/admin.scss';
---

<Base title="New Route" admin>
  <div class="admin-page">
    <div class="editor-header">
      <a href="/admin" class="back-link">&larr; Back to routes</a>
    </div>
    <h1>New Route</h1>
    <RouteCreator client:load />
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;

  .editor-header {
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }

  .back-link {
    color: $color-text-muted;
    text-decoration: none;

    @media (prefers-color-scheme: dark) {
      color: #aaa;
    }

    &:hover {
      text-decoration: underline;
    }
  }

  h1 {
    font-family: $font-heading;
    font-size: 1.25rem;
    margin: 0 0 1.5rem;
  }

  .route-creator {
    max-width: 500px;
  }

  .drop-zone {
    border: 2px dashed $color-border;
    border-radius: $border-radius;
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
    color: $color-text-muted;
    font-size: 0.875rem;

    @media (prefers-color-scheme: dark) {
      border-color: #444;
      color: #aaa;
    }
  }

  .drop-zone--large {
    padding: 3rem 1.5rem;
    font-size: 1rem;
  }

  .drop-zone--active {
    border-color: $color-accent;
    background: rgba(255, 165, 0, 0.05);
  }

  .route-creator-setup {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;

    small {
      font-size: 0.75rem;
      color: $color-text-muted;

      @media (prefers-color-scheme: dark) {
        color: #aaa;
      }
    }
  }
</style>
