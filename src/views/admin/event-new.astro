---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventCreator from '../../components/admin/EventCreator.tsx';
import EventWizard from '../../components/admin/EventWizard.tsx';
import { eventDetailFromCache } from '../../lib/models/event-model';
import { loadDetailFromJson, loadAdminEventList, fetchJson } from '../../lib/content/load-admin-content.server';
import { env } from '../../lib/env/env.service';
import { getCityConfig } from '../../lib/config/city-config';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { loadTagTranslations } from '../../lib/i18n/tag-translations.server';
import { defaultLocale } from '../../lib/i18n/locale-utils';
import { t } from '@/i18n';
import type { AdminEvent } from '../../types/admin';

const { organizers: adminOrganizers, events: buildTimeEvents } = await fetchJson<{ organizers: _AdminOrganizer[]; events: AdminEvent[] }>(new URL('/admin/data/events.json', Astro.url));
const { events: allEvents } = await loadAdminEventList(buildTimeEvents);
const organizers = adminOrganizers;
const cityConfig = getCityConfig();
const cdnUrl = env.R2_PUBLIC_URL || cityConfig.cdn_url;
const countryCode = cityConfig.locale.includes('-') ? cityConfig.locale.split('-').pop()!.toLowerCase() : undefined;
const tagTranslations = loadTagTranslations();
const knownTags = await fetchJson<string[]>(new URL('/admin/data/known-tags.json', Astro.url));
const eventOptions = allEvents
  .map((e: AdminEvent) => ({ id: e.id, name: e.name, year: e.year }))
  .sort((a: { year: string; name: string }, b: { year: string; name: string }) => b.year.localeCompare(a.year) || a.name.localeCompare(b.name));

const fullEditor = Astro.url.searchParams.get('full') === '1';

// Load source event data for copy/duplicate (full editor only)
const copyFromId = fullEditor ? Astro.url.searchParams.get('copy') : null;
let copyData: Record<string, unknown> | undefined;

if (copyFromId) {
  const result = await loadDetailFromJson({
    contentType: 'events',
    id: copyFromId,
    jsonUrl: new URL(`/admin/data/events/${copyFromId}.json`, Astro.url),
    fromCache: eventDetailFromCache,
  });
  if (!result.notFound) {
    const src = result.data;
    copyData = {
      name: src.name,
      start_time: src.start_time,
      end_time: src.end_time,
      location: src.location,
      distances: src.distances,
      registration_url: src.registration_url,
      organizer: src.organizer,
      poster_key: src.poster_key,
      poster_content_type: src.poster_content_type,
      body: src.body,
      edition: src.edition,
      event_url: src.event_url,
      map_url: src.map_url,
      previous_event: copyFromId,
    };
  }
}

// Branch: ?from_feed=<slug>&uid=<ics_uid> — prefill from an organizer's ICS feed
const fromFeed = Astro.url.searchParams.get('from_feed');
const icsUid = Astro.url.searchParams.get('uid');
let icsCopyData: Record<string, unknown> | undefined;
let icsMissing = false;

if (fromFeed && icsUid && !copyFromId) {
  const { db } = await import('../../lib/get-db');
  const { readCachedFeed, writeCachedFeed } = await import('../../lib/calendar-suggestions/cache.server');
  const { fetchIcsFeed } = await import('../../lib/external/ics-feed.server');
  const { buildCopyDataFromVevent } = await import('../../lib/calendar-suggestions/prefill');

  const org = adminOrganizers.find(o => o.slug === fromFeed);
  if (!org?.ics_url) {
    icsMissing = true;
  } else {
    try {
      let feed = await readCachedFeed(db(), fromFeed, org.ics_url);
      if (!feed) {
        feed = await fetchIcsFeed(org.ics_url);
        await writeCachedFeed(db(), fromFeed, org.ics_url, feed);
      }
      const vevent = feed.events.find(e => e.uid === icsUid);
      if (!vevent) {
        icsMissing = true;
      } else {
        icsCopyData = buildCopyDataFromVevent(vevent, fromFeed);
      }
    } catch (err) {
      console.error('ICS prefill failed:', err);
      icsMissing = true;
    }
  }
  if (icsMissing) {
    console.warn(`ICS prefill missing: feed=${fromFeed} uid=${icsUid}`);
  }
}

// Route ICS prefills through the full editor.
// Spec says wizard for one-offs and full editor for series, but EventWizard doesn't
// currently accept a copyData prop (its flow starts with a poster upload + extraction).
// Threading copyData through EventWizard is a separate follow-up; for now both one-off
// and series ICS imports land in EventCreator where the prefill works.
const hasSeries = !!icsCopyData && 'series' in icsCopyData;
const useFullEditor = fullEditor || hasSeries || !!icsCopyData;
const effectiveCopyData = icsCopyData ?? copyData;
---

<AdminEditorLayout title="New Event" user={Astro.locals.user} currentTab="events" hideTitle={!useFullEditor}>
  {icsMissing && (
    <p class="ics-missing-notice">
      This suggestion is no longer in the source calendar. You can still create the event manually.
    </p>
  )}
  {useFullEditor ? (
    <EventCreator client:load cdnUrl={cdnUrl} organizers={organizers} copyData={effectiveCopyData} eventOptions={eventOptions} tagTranslations={tagTranslations} knownTags={knownTags} defaultLocale={defaultLocale()} cityCenter={[cityConfig.center.lat, cityConfig.center.lng]} cityBounds={cityConfig.bounds} cityName={cityConfig.name} countryCode={countryCode} />
  ) : (
    <EventWizard client:load cdnUrl={cdnUrl} organizers={organizers} eventOptions={eventOptions} tagTranslations={tagTranslations} knownTags={knownTags} defaultLocale={defaultLocale()} userRole={Astro.locals.user?.role} showLicenseNotice={getInstanceFeatures().showsLicenseNotice} guestLabel={t('editor.guest_label', Astro.currentLocale)} siteName={cityConfig.display_name} cityCenter={[cityConfig.center.lat, cityConfig.center.lng]} cityBounds={cityConfig.bounds} cityName={cityConfig.name} countryCode={countryCode} />
  )}
</AdminEditorLayout>

<style>
  .ics-missing-notice {
    background: rgba(255, 200, 120, 0.12);
    border: 1px solid rgba(255, 200, 120, 0.4);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin: 0 0 1rem;
    font-size: 0.95em;
    color: inherit;
    opacity: 0.85;
  }
</style>
