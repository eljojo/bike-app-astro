---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventEditor from '../../components/admin/EventEditor.tsx';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import { env } from '../../lib/env';
import { CDN_FALLBACK_URL } from '../../lib/config';

const organizers = adminOrganizers;
const cdnUrl = env.R2_PUBLIC_URL || CDN_FALLBACK_URL;

const today = new Date().toISOString().split('T')[0];
const year = today.substring(0, 4);

const initialData = {
  id: '',
  slug: '',
  year,
  name: '',
  start_date: today,
  body: '',
  isNew: true,
};
---

<AdminEditorLayout title="New Event" backLink="/admin/events" backLabel="Back to events">
  <EventEditor client:load initialData={initialData} organizers={organizers} cdnUrl={cdnUrl} />
</AdminEditorLayout>
