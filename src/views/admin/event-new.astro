---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import EventCreator from '../../components/admin/EventCreator.tsx';
import adminOrganizers from 'virtual:bike-app/admin-organizers';
import { env } from '../../lib/env';
import { CDN_FALLBACK_URL } from '../../lib/config';

const organizers = adminOrganizers;
const cdnUrl = env.R2_PUBLIC_URL || CDN_FALLBACK_URL;
---

<AdminEditorLayout title="New Event" backLink="/admin/events" backLabel="Back to events" user={Astro.locals.user} currentTab="events">
  <EventCreator client:load cdnUrl={cdnUrl} organizers={organizers} />
</AdminEditorLayout>
