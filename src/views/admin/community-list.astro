---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AdminHeader from '../../components/AdminHeader.astro';
import { fetchJson, loadAdminOrganizerList } from '../../lib/content/load-admin-content.server';
import { buildImageUrl } from '../../lib/media/image-service';
import { getCityConfig } from '../../lib/config/city-config';
import { organizerInitials } from '../../lib/models/organizer-model';
import '../../styles/admin.scss';

const buildTimeOrganizers = await fetchJson<_AdminOrganizer[]>(new URL('/admin/data/organizers.json', Astro.url));
const { items: organizers, pendingIds } = await loadAdminOrganizerList(buildTimeOrganizers);

const user = Astro.locals.user;
const config = getCityConfig();
const cdnUrl = (await import('../../lib/env/env.service')).env.R2_PUBLIC_URL || config.cdn_url;
---

<Base title="Communities - Admin" admin>
  <div class="admin-page">
    <AdminHeader user={user} currentTab="organizers" subtitle="Groups, clubs, and organizations that host rides and events." ctaHref="/admin/communities/new" ctaLabel="+ New community" />

    <div class="community-actions-bar">
      <span class="community-count">{organizers.length} communities</span>
    </div>

    <div class="community-list">
      {organizers.map(org => (
        <a href={`/admin/communities/${org.slug}`} class="community-list-item">
          {org.photo_key ? (
            <img
              src={buildImageUrl(cdnUrl, org.photo_key, { width: 80, height: 80, fit: 'cover' })}
              alt=""
              class="community-avatar"
            />
          ) : (
            <div class="community-avatar community-avatar--initials">
              {organizerInitials(org.name)}
            </div>
          )}
          <div class="community-card-info">
            <span class="community-card-name">
              {org.name}
              {pendingIds.has(org.slug) && <span class="community-badge community-badge--pending">Pending</span>}
              {org.featured && <span class="community-badge community-badge--featured">Featured</span>}
            </span>
            {org.instagram && <span class="community-card-handle">@{org.instagram}</span>}
            {org.tagline && <span class="community-card-tagline">{org.tagline}</span>}
          </div>
        </a>
      ))}
    </div>

    {organizers.length === 0 && <p class="auth-message">No communities found. Create one to get started.</p>}
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .admin-page {
    max-width: 700px;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .community-actions-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .community-count {
    font-size: 0.875rem;
    @include muted-text;
  }

  .community-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: $color-border;
    border-radius: $border-radius;
    overflow: hidden;

    @include dark-mode {
      background: $color-border-subtle-dark;
    }
  }

  .community-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: $color-card-bg;
    color: $color-text;
    text-decoration: none;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
    }

    &:hover {
      background: $color-card-hover;

      @include dark-mode {
        background: $color-card-hover-dark;
      }
    }
  }

  .community-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  .community-avatar--initials {
    display: flex;
    align-items: center;
    justify-content: center;
    background: $color-tag-bg;
    color: $color-tag-text;
    font-size: 0.75rem;
    font-weight: 600;

    @include dark-mode {
      background: $color-border-dark;
      color: $color-text-dark;
    }
  }

  .community-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .community-card-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .community-badge {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .community-badge--pending {
    background: $color-warning-bg;
    color: $color-warning;

    @include dark-mode {
      background: $color-warning-bg-dark;
      color: $color-warning-dark;
    }
  }

  .community-badge--featured {
    background: $color-success-bg;
    color: $color-success;

    @include dark-mode {
      background: $color-success-bg-dark;
      color: $color-success-dark;
    }
  }

  .community-card-handle {
    font-size: 0.8125rem;
    @include muted-text;
  }

  .community-card-tagline {
    font-size: 0.8125rem;
    @include muted-text;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
