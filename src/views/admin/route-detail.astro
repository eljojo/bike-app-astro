---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import RouteEditor from '../../components/admin/RouteEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import { env } from '../../lib/env/env.service';
import { CITY, VIDEO_PREFIX } from '../../lib/config/config';
import { loadDetailFromJson, loadParkedMediaWithOverlay } from '../../lib/content/load-admin-content.server';
import { routeDetailFromCache } from '../../lib/models/route-model';
import { loadTagTranslations } from '../../lib/i18n/tag-translations.server';
import { defaultLocale } from '../../lib/i18n/locale-utils';
import { getCityConfig, isBlogInstance } from '../../lib/config/city-config';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { t } from '@/i18n';

const { slug } = Astro.params;

if (slug && !/^[a-z0-9][a-z0-9-]*[a-z0-9]$/.test(slug)) {
  return new Response(null, { status: 404 });
}

const result = await loadDetailFromJson({
  contentType: 'routes',
  id: slug,
  jsonUrl: new URL(`/admin/data/routes/${slug}.json`, Astro.url),
  fromCache: routeDetailFromCache,
});

if (result.notFound) return new Response(null, { status: 404 });
const routeData = result.data;

const parkedPhotosData = await fetch(new URL('/admin/data/parked-media.json', Astro.url)).then(r => r.json());
const parkedPhotos = await loadParkedMediaWithOverlay(parkedPhotosData);
const cdnUrl = env.R2_PUBLIC_URL || getCityConfig().cdn_url;
const videosCdnUrl = getCityConfig().videos_cdn_url;
const videoPrefix = isBlogInstance() ? VIDEO_PREFIX : CITY;
const tagTranslations = loadTagTranslations();
const knownTags = await fetch(new URL('/admin/data/known-tags.json', Astro.url)).then(r => r.json()) as string[];
const allNearbyMedia = await fetch(new URL('/admin/data/nearby-media.json', Astro.url)).then(r => r.json()) as Record<string, Array<{ key: string; lat: number; lng: number; routeSlug: string; caption?: string; width?: number; height?: number; type?: string }>>;
const focusParam = Astro.url.searchParams.get('focus');
const focusMode = (focusParam === 'description' || focusParam === 'media') ? focusParam : null;
const locale = Astro.currentLocale;
const focusLabels = focusMode ? {
  description: t('editor.focus_description', locale, { name: routeData.name }),
  media: t('editor.focus_media', locale, { name: routeData.name }),
  showAll: t('editor.show_all_fields', locale),
} : undefined;
---

<AdminEditorLayout
  title={`Edit: ${routeData.name}`}
  viewLink={`/routes/${slug}`}
  hideTitle
  wide
  user={Astro.locals.user}
  currentTab="routes"
>
  <RouteEditor client:load initialData={routeData} cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} tagTranslations={tagTranslations} knownTags={knownTags} defaultLocale={defaultLocale()} userRole={Astro.locals.user?.role} parkedPhotos={parkedPhotos} showLicenseNotice={getInstanceFeatures().showsLicenseNotice} focusMode={focusMode} focusLabels={focusLabels} nearbyMedia={allNearbyMedia[slug!] || []} />
  <EditHistory client:load contentPath={`${CITY}/routes/${slug}`} gitRepo={`${env.GIT_OWNER}/${env.GIT_DATA_REPO}`} userRole={Astro.locals.user?.role} />
</AdminEditorLayout>
