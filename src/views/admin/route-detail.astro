---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import RouteEditor from '../../components/admin/RouteEditor.tsx';
import EditHistory from '../../components/admin/EditHistory.tsx';
import adminRouteDetails from 'virtual:bike-app/admin-route-detail';
import { env } from '../../lib/env';
import { CDN_FALLBACK_URL } from '../../lib/config';
import { loadAdminContent } from '../../lib/load-admin-content';
import { routeDetailFromCache } from '../../lib/models/route-model';

const { slug } = Astro.params;

if (!slug || !/^[a-z0-9][a-z0-9-]*[a-z0-9]$/.test(slug)) {
  return new Response(null, { status: 404 });
}

const { data: routeData } = await loadAdminContent({
  contentType: 'routes',
  contentSlug: slug,
  virtualModuleData: adminRouteDetails,
  fromCache: routeDetailFromCache,
});

if (!routeData) {
  return new Response(null, { status: 404 });
}

const cdnUrl = env.R2_PUBLIC_URL || CDN_FALLBACK_URL;
---

<AdminEditorLayout
  title={`Edit: ${routeData.name}`}
  backLink="/admin"
  backLabel="Back to routes"
  viewLink={`/routes/${slug}`}
>
  <RouteEditor client:load initialData={routeData} cdnUrl={cdnUrl} />
  <EditHistory client:load contentPath={`ottawa/routes/${slug}`} gitRepo="eljojo/bike-routes" />
</AdminEditorLayout>
