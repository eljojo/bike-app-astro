---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import RouteEditor from '../../components/admin/RouteEditor.tsx';
import adminRouteDetails from 'virtual:bike-app/admin-route-detail';
import { env } from '../../lib/env';
import { db } from '../../lib/get-db';
import { contentEdits } from '../../db/schema';
import { eq, and } from 'drizzle-orm';
import { createGitService } from '../../lib/git-factory';
import { findDraft, deleteDraft } from '../../lib/draft-service';
import { GIT_OWNER, GIT_DATA_REPO } from '../../lib/config';
import matter from 'gray-matter';
import yaml from 'js-yaml';
import '../../styles/admin.scss';

const { slug } = Astro.params;

if (!slug || !/^[a-z0-9][a-z0-9-]*[a-z0-9]$/.test(slug)) {
  return new Response(null, { status: 404 });
}

const database = db();
const user = Astro.locals.user;
const city = 'ottawa';
const basePath = `${city}/routes/${slug}`;

let routeData: any = null;
let isDraft = false;
let draftPrNumber: number | null = null;

// Check if user has an existing draft for this route
if (user) {
  const draft = await findDraft(database, user.id, 'routes', slug);

  if (draft) {
    const git = createGitService({
      token: env.GITHUB_TOKEN, owner: GIT_OWNER, repo: GIT_DATA_REPO,
      branch: draft.branchName,
    });
    const branchSha = await git.getRef(draft.branchName);

    if (branchSha) {
      const file = await git.readFile(`${basePath}/index.md`);
      if (file) {
        const { data: fm, content: body } = matter(file.content);
        const mediaFile = await git.readFile(`${basePath}/media.yml`);
        let media: any[] = [];
        if (mediaFile) {
          media = ((yaml.load(mediaFile.content) as any[]) || []).map((m: any) => {
            const item: Record<string, unknown> = { key: m.key };
            if (m.caption) item.caption = m.caption;
            if (m.cover) item.cover = m.cover;
            return item;
          });
        }
        routeData = {
          slug,
          name: fm.name,
          tagline: fm.tagline || '',
          tags: fm.tags || [],
          distance: fm.distance_km,
          status: fm.status,
          body: body.trim(),
          media,
          variants: (fm.variants as any[]) || [],
        };
        isDraft = true;
        draftPrNumber = draft.prNumber;
      }
    } else {
      // Branch gone (merged or deleted) — clean up draft row
      await deleteDraft(database, draft.id);
    }
  }
}

// Fall back to D1 cache → virtual module
if (!routeData) {
  const cached = await database.select().from(contentEdits).where(and(eq(contentEdits.contentType, 'routes'), eq(contentEdits.contentSlug, slug))).get();
  routeData = cached ? JSON.parse(cached.data) : adminRouteDetails[slug];
}

if (!routeData) {
  return new Response(null, { status: 404 });
}

const cdnUrl = env.R2_PUBLIC_URL || 'https://cdn.ottawabybike.ca';
---

<Base title={`Edit: ${routeData.name}`} admin>
  <div class="admin-page">
    <div class="editor-header">
      <a href="/admin" class="back-link">&larr; Back to routes</a>
      <a href={`/routes/${slug}`} class="view-link" target="_blank" rel="noopener">View live &nearr;</a>
    </div>
    <h1 class="editor-title">Edit: {routeData.name}</h1>
    <RouteEditor client:load initialData={routeData} cdnUrl={cdnUrl} isDraft={isDraft} draftPrNumber={draftPrNumber} />
  </div>
</Base>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;
  @use '../../styles/editor';

  textarea {
    @include form-control;
    font-family: $font-mono;
    font-size: 0.875rem;
    width: 100%;
    resize: vertical;

    &:focus {
      outline: 2px solid $color-accent;
      outline-offset: -1px;
    }
  }

  select {
    @include form-control;
    font-family: $font-body;
  }

  .tag-editor {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
    padding: 0.375rem;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: $color-bg;

    @include dark-mode {
      background: $color-bg-dark;
      border-color: #444;
    }
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.5rem;
    background: $color-tag-bg;
    color: $color-tag-text;
    border-radius: $border-radius;
    font-size: 0.8125rem;

    button {
      background: none;
      border: none;
      color: $color-tag-text;
      cursor: pointer;
      padding: 0;
      font-size: 1rem;
      line-height: 1;
    }
  }

  .tag-input {
    border: none;
    outline: none;
    font-size: 0.875rem;
    padding: 0.125rem;
    flex: 1;
    min-width: 80px;
    background: transparent;
    color: $color-text;

    @include dark-mode {
      color: $color-text-dark;
    }
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .photo-card {
    position: relative;
    border-radius: $border-radius;
    overflow: hidden;
    background: $color-card-bg;
    cursor: grab;

    @include dark-mode {
      background: $color-card-bg-dark;
    }

    img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }
  }

  .photo-card--dragging {
    opacity: 0.5;
  }

  .photo-actions {
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    display: flex;
    gap: 0.25rem;
  }

  .btn-star,
  .btn-remove {
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    border-radius: $border-radius;
    width: 24px;
    height: 24px;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-star--active {
    background: rgba(255, 165, 0, 0.8);
  }

  .photo-caption {
    width: 100%;
    border: none;
    border-top: 1px solid $color-border;
    padding: 0.25rem 0.375rem;
    font-size: 0.75rem;
    background: $color-card-bg;
    color: $color-text;

    @include dark-mode {
      background: $color-card-bg-dark;
      color: $color-text-dark;
      border-color: #333;
    }
  }

  .variant-manager {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .variant-card {
    border: 1px solid $color-border;
    border-radius: $border-radius;
    background: $color-card-bg;
    padding: 0.75rem;

    @include dark-mode {
      background: $color-card-bg-dark;
      border-color: #333;
    }
  }

  .variant-card--dragging {
    opacity: 0.5;
  }

  .variant-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .variant-grip {
    cursor: grab;
    @include muted-text;
    user-select: none;
  }

  .variant-name {
    flex: 1;
  }

  .variant-distance {
    font-size: 0.8125rem;
    @include muted-text;
  }

  .variant-new {
    background: $color-accent;
    color: #000;
    padding: 0.125rem 0.375rem;
    border-radius: $border-radius;
    font-size: 0.75rem;
  }

  .variant-actions {
    display: flex;
    gap: 0.25rem;
  }

  .btn-edit-variant {
    background: none;
    border: 1px solid $color-border;
    border-radius: $border-radius;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    cursor: pointer;
    color: $color-text;

    @include dark-mode {
      color: $color-text-dark;
      border-color: #444;
    }
  }

  .variant-edit-form {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid $color-border;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    @include dark-mode {
      border-color: #333;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;

      label {
        font-size: 0.75rem;
        @include muted-text;
      }

      code {
        font-family: $font-mono;
        font-size: 0.8125rem;
      }
    }
  }

  .variant-add {
    margin-top: 0.25rem;
  }
</style>
