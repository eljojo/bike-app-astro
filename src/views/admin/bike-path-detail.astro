---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import BikePathEditor from '../../components/admin/BikePathEditor.tsx';
import { loadDetailFromJson } from '../../lib/content/load-admin-content.server';
import { bikePathDetailFromCache } from '../../lib/models/bike-path-model';

const result = await loadDetailFromJson({
  contentType: 'bike-paths',
  id: Astro.params.id,
  jsonUrl: new URL(`/admin/data/bike-paths/${Astro.params.id}.json`, Astro.url),
  fromCache: bikePathDetailFromCache,
});

if (result.notFound) return new Response(null, { status: 404 });
const bikePathData = result.data;
const user = Astro.locals.user;
---

<AdminEditorLayout title={`Edit: ${bikePathData.name || bikePathData.id}`} hideTitle user={user} currentTab="bike-paths">
  <BikePathEditor client:load initialData={bikePathData} userRole={user?.role} />
</AdminEditorLayout>
