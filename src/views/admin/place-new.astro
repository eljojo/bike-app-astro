---
export const prerender = false;

import AdminEditorLayout from '../../components/AdminEditorLayout.astro';
import PlaceEditor from '../../components/admin/PlaceEditor.tsx';
import PlaceWizard from '../../components/admin/PlaceWizard.tsx';
import { env } from '../../lib/env/env.service';
import { CITY, VIDEO_PREFIX } from '../../lib/config/config';
import { supportedLocales, defaultLocale } from '../../lib/i18n/locale-utils';
import { getCityConfig, isBlogInstance } from '../../lib/config/city-config';
import { getInstanceFeatures } from '../../lib/config/instance-features';
import { fetchJson } from '../../lib/content/load-admin-content.server';
import { categoryEmoji } from '../../lib/geo/place-categories';
import { t } from '@/i18n';
import type { AdminOrganizer } from '../../types/admin';

const cityConfig = getCityConfig();
const cdnUrl = env.R2_PUBLIC_URL || cityConfig.cdn_url;
const videosCdnUrl = cityConfig.videos_cdn_url;
const videoPrefix = isBlogInstance() ? VIDEO_PREFIX : CITY;
const secondaryLocales = supportedLocales().filter(l => l !== defaultLocale());
const mapCenter: [number, number] = [cityConfig.center.lat, cityConfig.center.lng];

const nearSlug = Astro.url.searchParams.get('near') || undefined;
const detailsToggleLabel = t('place_editor.details_toggle', Astro.currentLocale);
const mediaLocations = await fetchJson<_MediaLocation[]>(new URL('/admin/data/media-locations.json', Astro.url));
const allOrganizers = await fetchJson<AdminOrganizer[]>(new URL('/admin/data/organizers.json', Astro.url));
const organizerOptions = allOrganizers.filter((o: AdminOrganizer) => o.tags.includes('bike-shop')).map((o: AdminOrganizer) => ({ slug: o.slug, name: o.name }));

const fullEditor = Astro.url.searchParams.get('full') === '1';
const features = getInstanceFeatures();
const categories = Object.entries(categoryEmoji);

const initialData = {
  id: '',
  name: '',
  category: 'other',
  lat: 0,
  lng: 0,
  isNew: true,
};
---

<AdminEditorLayout title="New Place" user={Astro.locals.user} currentTab="places" hideTitle={!fullEditor}>
  {fullEditor ? (
    <PlaceEditor client:load initialData={initialData} cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} userRole={Astro.locals.user?.role} secondaryLocales={secondaryLocales} mapCenter={mapCenter} nearRouteSlug={nearSlug} detailsToggleLabel={detailsToggleLabel} mediaLocations={mediaLocations} guestLabel={t('editor.guest_label', Astro.currentLocale)} organizers={organizerOptions} />
  ) : (
    <PlaceWizard client:load cdnUrl={cdnUrl} videosCdnUrl={videosCdnUrl} videoPrefix={videoPrefix} userRole={Astro.locals.user?.role} showLicenseNotice={features.showsLicenseNotice} guestLabel={t('editor.guest_label', Astro.currentLocale)} mapCenter={mapCenter} cityName={cityConfig.name} mediaLocations={mediaLocations} organizers={organizerOptions} categories={categories} />
  )}
</AdminEditorLayout>
