---
export const prerender = true;
// src/views/calendar.astro
import Base from '@/layouts/Base.astro';
import EventCardDayGroup, { type DayGroupEntry } from '@/components/EventCardDayGroup.astro';
import EventCardFeatured from '@/components/EventCardFeatured.astro';
import SeasonalBanner from '@/components/SeasonalBanner.astro';
import OrganizerSpotlight from '@/components/OrganizerSpotlight.astro';
import TagFilter from '@/components/TagFilter.astro';
import { getCollection } from 'astro:content';
import { parseLocalDate } from '@/lib/date-utils';
import { getCityConfig } from '@/lib/config/city-config';
import { t, formatLocale, eventNoun, calendarUpcomingLabel, localePath } from '@/i18n';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { paths } from '@/lib/paths';
import { classifyEvent, canonicalTags } from '@/lib/event-tags';
import { tTag } from '@/lib/i18n/tag-translations.server';
import { expandSeriesOccurrences, isSeriesEvent } from '@/lib/series-utils';
import { imageUrl } from '@/lib/media/image-service';
import { expandEvents, deduplicateSeries, splitUpcomingPast, groupByMonth, effectiveDate, type CalendarEntry } from '@/lib/calendar-helpers';
import Icon from '@/components/Icon.astro';

const config = getCityConfig();
const locale = Astro.currentLocale;
const fmtLocale = formatLocale(locale);

const icalUrl = `${config.url.replace(/\/$/, '')}/calendar.ics`;
const webcalUrl = icalUrl.replace(/^https?:\/\//, 'webcal://');
const icalUrlHttp = icalUrl.replace(/^https:\/\//, 'http://');
const googleCalendarUrl = `http://www.google.com/calendar/render?cid=${encodeURIComponent(icalUrlHttp)}`;

const events = await getCollection('events');
const allOrganizers = await getCollection('organizers');
const now = new Date();
const currentYear = now.getFullYear();

const expanded = expandEvents(events as CalendarEntry['event'][]);
const { upcoming, past } = splitUpcomingPast(expanded, now);

// Pre-resolve organizer names: slug → display name
const organizerNameMap = new Map<string, string>();
for (const org of allOrganizers) {
  organizerNameMap.set(org.id, org.data.name);
}
function resolveOrganizerName(entry: CalendarEntry): string {
  const org = entry.event.data.organizer;
  if (typeof org === 'string') return organizerNameMap.get(org) || org;
  if (org && typeof org === 'object' && 'name' in org) return (org as { name: string }).name;
  return '';
}

// Cache series badges per event ID (all occurrences share the same badge)
const seriesBadgeCache = new Map<string, string | undefined>();
function getSeriesBadge(entry: CalendarEntry): string | undefined {
  const id = entry.event.id;
  if (seriesBadgeCache.has(id)) return seriesBadgeCache.get(id);
  const badge = computeSeriesBadge(entry);
  seriesBadgeCache.set(id, badge);
  return badge;
}
function computeSeriesBadge(entry: CalendarEntry): string | undefined {
  if (!isSeriesEvent(entry.event.data)) return undefined;
  const series = entry.event.data.series;
  if (!series) return undefined;
  if (series.recurrence && series.recurrence_day) {
    const occurrences = expandSeriesOccurrences(entry.event.data);
    const localizedDay = parseLocalDate(
      occurrences[0]?.date || '2026-01-01'
    ).toLocaleString(fmtLocale, { weekday: 'long' });
    const summaryTime = entry.event.data.meet_time || entry.event.data.start_time;
    const timeStr = summaryTime
      ? new Date(2000, 0, 1, ...summaryTime.split(':').map(Number)).toLocaleTimeString(fmtLocale, { hour: 'numeric', minute: '2-digit' })
      : '';
    const key = series.recurrence === 'biweekly' ? 'events.series_every_two_weeks' : 'events.series_every_week';
    return t(key, locale, { day: localizedDay, time: timeStr });
  }
  if (series.schedule?.length) {
    return t('events.series_dates_count', locale, { count: series.schedule.filter((s: { cancelled?: boolean }) => !s.cancelled).length });
  }
  return undefined;
}

// Deduplicated upcoming entries for section views
const upcomingDeduped = deduplicateSeries(upcoming);

// Classify upcoming events (deduplicated for sections)
const seasonal: CalendarEntry[] = [];
const community: CalendarEntry[] = [];
const learnConnect: CalendarEntry[] = [];
const general: CalendarEntry[] = [];

for (const e of upcomingDeduped) {
  const section = classifyEvent(e.event.data.tags ?? []);
  switch (section) {
    case 'seasonal': seasonal.push(e); break;
    case 'community': community.push(e); break;
    case 'learn-connect': learnConnect.push(e); break;
    default: general.push(e); break;
  }
}

// Determine which sections have enough events to show independently
const showCommunity = community.length >= 2;
const showLearnConnect = learnConnect.length >= 2;

// Build "Coming up" pool: general events + lone events from sparse sections
const comingUpPool = [...general];
if (!showCommunity) comingUpPool.push(...community);
if (!showLearnConnect) comingUpPool.push(...learnConnect);
comingUpPool.sort((a, b) => parseLocalDate(effectiveDate(a)).getTime() - parseLocalDate(effectiveDate(b)).getTime());
const comingUp = comingUpPool.slice(0, 3);

// Compute adaptive heading: if all comingUp events share the same noun, use type-specific heading
const comingUpHeading = (() => {
  if (comingUp.length === 0) return t('calendar.coming_up', locale);
  const nouns = comingUp
    .filter(e => e.event.data.tags?.length)
    .map(e => eventNoun(e.event.data.tags!, locale));
  if (nouns.length === comingUp.length && new Set(nouns).size === 1) {
    const representative = comingUp.find(e => e.event.data.tags?.length);
    return calendarUpcomingLabel(representative!.event.data.tags!, locale);
  }
  return t('calendar.coming_up', locale);
})();

// For folded events, determine if they need a tag pill
function getTagLabel(entry: CalendarEntry): string | undefined {
  const section = classifyEvent(entry.event.data.tags ?? []);
  if (section === 'community' && !showCommunity) {
    const tag = entry.event.data.tags?.find((t: string) => ['social', 'group-ride', 'critical-mass'].includes(t));
    return tag ? tTag(tag, locale) : undefined;
  }
  if (section === 'learn-connect' && !showLearnConnect) {
    const tag = entry.event.data.tags?.find((t: string) => ['workshop', 'swap-meet', 'festival', 'advocacy', 'bikepacking'].includes(t));
    return tag ? tTag(tag, locale) : undefined;
  }
  return undefined;
}

// Non-seasonal upcoming for full calendar section (expanded — shows all occurrences)
const nonSeasonalUpcoming = upcoming.filter(e => classifyEvent(e.event.data.tags ?? []) !== 'seasonal');

const upcomingByMonth = groupByMonth(nonSeasonalUpcoming, fmtLocale);

// Group consecutive entries inside a month by the day-cell they'd render in,
// so multiple events on the same day collapse into a single stacked card with
// one shared date column. Multi-day events (start_date != end_date) get their
// own group so the "FRI 22–24" range stays intact and doesn't merge with
// single-day FRI 22 events.
function dayKey(entry: CalendarEntry): string {
  const start = entry.occurrenceDate || (entry.event.data.start_date as string);
  // A series occurrence is always single-day for that date. A one-off is
  // single-day if end_date is missing or equals start_date — normalize both
  // to "" so a one-off on a date merges with a series occurrence on the same
  // date.
  let end = '';
  if (!entry.occurrenceDate) {
    const endDate = entry.event.data.end_date as string | undefined;
    if (endDate && endDate !== start) end = endDate;
  }
  return `${start}|${end}`;
}

function toDayGroupEntry(e: CalendarEntry): DayGroupEntry {
  return {
    event: e.event,
    occurrenceDate: e.occurrenceDate,
    occurrenceLocation: e.occurrenceLocation,
    seriesBadge: getSeriesBadge(e),
    organizerName: resolveOrganizerName(e),
    muted: isEntryMuted(e),
  };
}

function groupByDay(entries: CalendarEntry[]): DayGroupEntry[][] {
  const groups: Record<string, DayGroupEntry[]> = {};
  const order: string[] = [];
  for (const e of entries) {
    const k = dayKey(e);
    if (!groups[k]) { groups[k] = []; order.push(k); }
    groups[k].push(toDayGroupEntry(e));
  }
  return order.map(k => groups[k]);
}

// Month display names: drop year when same as page heading year
const monthDisplayNames = new Map<string, string>();
for (const [key, evts] of Object.entries(upcomingByMonth)) {
  const firstDate = parseLocalDate(effectiveDate(evts[0]));
  const display = firstDate.toLocaleString(fmtLocale, {
    month: 'long',
    ...(firstDate.getFullYear() !== currentYear ? { year: 'numeric' } : {}),
  });
  monthDisplayNames.set(key, display);
}

// Organizer spotlight: organizers with >=2 total events and instagram
const totalOrganizerCounts = new Map<string, number>();
const organizerYears = new Map<string, Set<number>>();

for (const e of events) {
  const orgId = typeof e.data.organizer === 'string' ? e.data.organizer : undefined;
  if (!orgId) continue;
  totalOrganizerCounts.set(orgId, (totalOrganizerCounts.get(orgId) || 0) + 1);
  const year = parseLocalDate(e.data.start_date).getFullYear();
  if (!organizerYears.has(orgId)) organizerYears.set(orgId, new Set());
  organizerYears.get(orgId)!.add(year);
}

const spotlightCandidates = allOrganizers
  .filter(o => o.data.instagram && (totalOrganizerCounts.get(o.id) || 0) >= 2);

// Rank by year span (desc) then event count (desc), shuffle within tiers
function seededRandom(seed: string) {
  let h = 0;
  for (let i = 0; i < seed.length; i++) {
    h = Math.imul(31, h) + seed.charCodeAt(i) | 0;
  }
  return () => {
    h = Math.imul(h ^ (h >>> 16), 0x45d9f3b);
    h = Math.imul(h ^ (h >>> 13), 0x45d9f3b);
    h = (h ^ (h >>> 16)) >>> 0;
    return h / 0x100000000;
  };
}

const dailySeed = new Date().toISOString().slice(0, 10);
const rng = seededRandom(dailySeed);

const rankedOrganizers = spotlightCandidates
  .map(o => {
    const years = organizerYears.get(o.id)?.size ?? 0;
    const count = totalOrganizerCounts.get(o.id) || 0;
    // Years active worth 3 points each, total events worth 1 point each
    const score = years * 3 + count;
    return { organizer: o, score, tiebreaker: rng() };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return a.tiebreaker - b.tiebreaker;
  });

const spotlightOrganizers = rankedOrganizers.slice(0, 8).map(r => r.organizer);

// Track which series occurrences should be muted in the full calendar.
// Rule: if a series has >3 upcoming instances, the first is normal, the rest are muted.
const seriesUpcomingCounts = new Map<string, number>();
for (const entry of nonSeasonalUpcoming) {
  if (!isSeriesEvent(entry.event.data)) continue;
  seriesUpcomingCounts.set(entry.event.id, (seriesUpcomingCounts.get(entry.event.id) || 0) + 1);
}
const seriesSeenSoFar = new Map<string, number>();
const mutedOccurrences = new Set<string>();
for (const entry of nonSeasonalUpcoming) {
  if (!entry.occurrenceDate || !isSeriesEvent(entry.event.data)) continue;
  const id = entry.event.id;
  if ((seriesUpcomingCounts.get(id) || 0) <= 3) continue;
  const seen = (seriesSeenSoFar.get(id) || 0) + 1;
  seriesSeenSoFar.set(id, seen);
  if (seen > 1) mutedOccurrences.add(`${id}:${entry.occurrenceDate}`);
}
function isEntryMuted(entry: CalendarEntry): boolean {
  return !!entry.occurrenceDate && mutedOccurrences.has(`${entry.event.id}:${entry.occurrenceDate}`);
}

const hasUpcoming = upcoming.length > 0 || seasonal.length > 0;

// Tag filter for the full calendar section. Tag pool = tags appearing on
// non-seasonal upcoming events; seasonal banners drive the hero section so
// their tags stay out of the filter bar. Pure popularity, same shape as
// the routes filter — top N by frequency, with an avoid list for tags
// that don't help a reader narrow what's on (operational labels).
//
// Tags are routed through `canonicalTags` first so synonyms (e.g. `social`
// → `social-ride`) collapse for filtering: one pill, frequency = sum of
// all forms, click matches events tagged with any of them.
const EVENT_FILTER_TAGS_TO_AVOID = ['seasonal', 'always-on'];
const eventTagCounts = new Map<string, number>();
for (const entry of nonSeasonalUpcoming) {
  for (const tag of canonicalTags(entry.event.data.tags ?? [])) {
    eventTagCounts.set(tag, (eventTagCounts.get(tag) ?? 0) + 1);
  }
}
const eventFilterTags = [...eventTagCounts.entries()]
  .sort((a, b) => a[1] - b[1])
  .map(([tag]) => tag)
  .filter(tag => !EVENT_FILTER_TAGS_TO_AVOID.includes(tag))
  .slice(-14)
  .sort();

// items map for TagFilter: event-slug → tags. Series events show up as
// many .event-day-group-row elements (one per occurrence) but they share
// the event id, so a single entry per event id is enough — the consumer's
// listener hides every matching row by data-event-slug. Stored tags are
// the canonical forms so the filter's AND-match resolves synonyms.
const eventTagsBySlug: Record<string, string[]> = {};
for (const entry of nonSeasonalUpcoming) {
  if (eventTagsBySlug[entry.event.id]) continue;
  eventTagsBySlug[entry.event.id] = canonicalTags(entry.event.data.tags ?? []);
}

// Spotlight match by tag, not by event-overlap: an org's "filter identity"
// is the union of its own `tags` field and the canonicalised tags carried
// by any event it hosts. A women-only club with no women-only event in
// the upcoming window still matches the women-only filter because its
// own org-level tag asserts the identity.
const orgTagsForSpotlightBySlug: Record<string, string[]> = {};
const orgEventTagsAcc = new Map<string, Set<string>>();
for (const entry of nonSeasonalUpcoming) {
  const org = entry.event.data.organizer;
  const orgSlug = typeof org === 'string' ? org : undefined;
  if (!orgSlug) continue;
  const set = orgEventTagsAcc.get(orgSlug) ?? new Set<string>();
  for (const t of entry.event.data.tags ?? []) set.add(t);
  orgEventTagsAcc.set(orgSlug, set);
}
for (const org of allOrganizers) {
  const own = org.data.tags ?? [];
  const fromEvents = [...(orgEventTagsAcc.get(org.id) ?? [])];
  orgTagsForSpotlightBySlug[org.id] = canonicalTags([...own, ...fromEvents]);
}

// Tag-filter fallbacks: orgs that don't qualify for the default spotlight
// (no Instagram, fewer than 2 events) but whose own tags overlap with the
// filter pool. These render hidden and only surface when the matching
// tag is engaged — so a women-only club without upcoming women-only events
// still appears under the women-only filter. Declared here, after
// `eventFilterTags` and `orgTagsForSpotlightBySlug`, so the closure can
// resolve them at evaluation time.
const spotlightSlugs = new Set(spotlightOrganizers.map(o => o.id));
const filterTagSet = new Set(eventFilterTags);
const spotlightFallbacks = allOrganizers.filter(o => {
  if (spotlightSlugs.has(o.id)) return false;
  if (o.data.hidden) return false;
  const tags = orgTagsForSpotlightBySlug[o.id] ?? [];
  return tags.some(t => filterTagSet.has(t));
});

const ogImage = config.page_posters?.calendar ? imageUrl(config.page_posters.calendar, { width: 1200, height: 630, fit: 'cover' }) : undefined;
const calendarDescription = t('calendar.description', locale, { city: config.name });
---

<Base title={`${t('calendar.title', locale, { year: currentYear })} | ${config.display_name}`} description={calendarDescription} ogImage={ogImage}>
  <SubTabToggle isIndex items={[
    { label: t('nav.calendar', locale), href: localePath('/calendar', locale), active: true },
    { label: t('nav.people', locale), href: paths.communities(locale), active: false },
    { label: t('nav.bike_shops', locale), href: paths.bikeShops(locale), active: false },
  ]} />
  <div class="calendar-header">
    <h1>{t('calendar.title', locale, { year: currentYear })}</h1>
  </div>

  {seasonal.map(e => (
    <SeasonalBanner
      name={e.event.data.name}
      startDate={effectiveDate(e)}
      endDate={e.event.data.end_date}
      bannerText={e.event.data.banner_text}
      eventId={e.event.id}
      locale={locale}
    />
  ))}

  <section class="calendar-bookmarks" style="display: none;">
    <h2>{t('calendar.your_events', locale)}</h2>
    <div class="calendar-bookmarks-cards featured-cards">
    </div>
  </section>

  {eventFilterTags.length > 0 && (
    <TagFilter id="calendar-filter" tags={eventFilterTags} items={eventTagsBySlug} urlParam="tags" />
  )}

  {/*
    Spotlight org-tags map for the calendar listener. Stashed in a data
    attribute on a hidden element so a hoisted <script> can read it; an
    `is:inline define:vars` script tag would need a CSP hash that
    production doesn't grant.
  */}
  <div hidden id="calendar-spotlight-data" data-org-tags={JSON.stringify(orgTagsForSpotlightBySlug)}></div>

  {!hasUpcoming && (
    <p><strong>{t('calendar.wrap', locale)}</strong></p>
  )}

  {showCommunity && (
    <section class="calendar-section">
      <h2>{t('calendar.find_your_people', locale)}</h2>
      <div class="featured-cards">
        {community.slice(0, 3).map(e => (
          <EventCardFeatured event={e.event} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} organizerName={resolveOrganizerName(e)} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {showLearnConnect && (
    <section class="calendar-section">
      <h2>{t('calendar.learn_and_connect', locale)}</h2>
      <div class="featured-cards">
        {learnConnect.slice(0, 3).map(e => (
          <EventCardFeatured event={e.event} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} organizerName={resolveOrganizerName(e)} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {comingUp.length > 0 && (
    <section class="calendar-section">
      <h2>{comingUpHeading}</h2>
      <div class="featured-cards">
        {comingUp.map(e => (
          <EventCardFeatured event={e.event} tagLabel={getTagLabel(e)} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} organizerName={resolveOrganizerName(e)} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {(spotlightOrganizers.length > 0 || spotlightFallbacks.length > 0) && (
    <OrganizerSpotlight
      organizers={spotlightOrganizers}
      fallbackOrganizers={spotlightFallbacks}
      locale={locale}
    />
  )}

  {Object.keys(upcomingByMonth).length > 0 && (
    <section>
      <h2>{t('calendar.full_calendar', locale)}</h2>
      <div class="calendar-subscribe-actions">
        <a href={googleCalendarUrl} class="action-button" target="_blank" rel="noopener noreferrer"><Icon name="calendar-blank" size={18} /> {t('calendar.google', locale)}</a>
        <a href={webcalUrl} class="action-button"><Icon name="calendar-blank" size={18} /> {t('calendar.subscribe', locale)}</a>
        <a href="/admin/events/new" class="action-button"><Icon name="plus" size={18} /> {t('calendar.add_event', locale)}</a>
      </div>
      <div class="calendar-months-grid">
        {Object.entries(upcomingByMonth).map(([month, evts]) => (
          <div class="calendar-month-card">
            <h3 class="month-header">{monthDisplayNames.get(month)}</h3>
            <div class="events-list">
              {groupByDay(evts).map(group => (
                <EventCardDayGroup entries={group} locale={locale} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {past.length > 0 && (
    <div>
      <h2>{t('calendar.past', locale)}</h2>
      <button class="action-button" id="show-past-events"
        data-show={t('calendar.show_past', locale)}
        data-hide={t('calendar.hide_past', locale)}>
        {t('calendar.show_past', locale)}
      </button>
      <div class="past-events" style="display: none;">
        <div class="events-list">
          {groupByDay(past).map(group => (
            <EventCardDayGroup entries={group} locale={locale} />
          ))}
        </div>
      </div>
    </div>
  )}

  <script>
    // Show bookmarked events at top of calendar
    (async () => {
      try {
        const res = await fetch('/api/reactions/event/_starred');
        if (!res.ok) return;
        const data = await res.json();
        const starred: string[] = data.starredSlugs || [];
        if (starred.length === 0) return;

        const section = document.querySelector('.calendar-bookmarks');
        const container = section?.querySelector('.calendar-bookmarks-cards');
        if (!section || !container) return;

        const starredSet = new Set(starred);
        const today = new Date().toISOString().slice(0, 10);

        // Find slugs already in featured sections (dedup)
        const featuredSlugs = new Set<string>();
        document.querySelectorAll('.calendar-section .event-card-featured[data-event-slug]').forEach(el => {
          const slug = (el as HTMLElement).dataset.eventSlug;
          if (slug) featuredSlugs.add(slug);
        });

        // Find matching event rows in the full calendar grid. Each row sits
        // inside an .event-day-group; clone the surrounding day-group and trim
        // it down to just the bookmarked row so the cloned card keeps its
        // date column.
        const rows = document.querySelectorAll<HTMLElement>('.calendar-months-grid .event-day-group-row[data-event-slug]');
        let shown = 0;

        for (const row of rows) {
          const slug = row.dataset.eventSlug || '';
          const startDate = row.dataset.startDate || '';
          if (!starredSet.has(slug)) continue;
          if (startDate < today) continue;
          if (featuredSlugs.has(slug)) continue;

          const dayGroup = row.closest('.event-day-group');
          if (!dayGroup) continue;
          const clone = dayGroup.cloneNode(true) as HTMLElement;
          clone.classList.add('event-day-group--bookmarked');
          // Remove sibling rows so only the bookmarked one renders
          clone.querySelectorAll('.event-day-group-row').forEach(r => {
            if ((r as HTMLElement).dataset.eventSlug !== slug) r.remove();
          });
          container.appendChild(clone);
          shown++;
        }

        if (shown > 0) {
          (section as HTMLElement).style.display = '';
        }
      } catch {
        // Silently fail — bookmarking is progressive enhancement
      }
    })();
  </script>

  <script>
    // Calendar's TagFilter wiring. Filter applies across every section that
    // surfaces events: the featured strips (Find your people, Learn and
    // connect, Coming up), the organizer spotlight (orgs with no matching
    // events drop out), and the full month grid. Each section also collapses
    // entirely when nothing inside it survives, so a narrow filter doesn't
    // leave empty headings.
    const calendarFilterRoot = document.getElementById('calendar-filter');
    const orgTagsHost = document.getElementById('calendar-spotlight-data');
    let orgTagsForSpotlightBySlug: Record<string, string[]> = {};
    try {
      orgTagsForSpotlightBySlug = JSON.parse(orgTagsHost?.dataset.orgTags || '{}');
    } catch {
      orgTagsForSpotlightBySlug = {};
    }
    calendarFilterRoot?.addEventListener('tagfilter:change', (e: Event) => {
      const detail = (e as CustomEvent<{
        enabledSlugs: string[];
        activeTags: string[];
        action: 'init' | 'add' | 'remove' | 'clear';
        lastChangedTag?: string;
      }>).detail;
      const enabled = new Set(detail.enabledSlugs);
      const isFiltered = detail.activeTags.length > 0;

      // 1) Featured cards across all .calendar-section blocks.
      document.querySelectorAll<HTMLElement>('.event-card-featured[data-event-slug]').forEach(card => {
        const slug = card.dataset.eventSlug ?? '';
        card.style.display = enabled.has(slug) ? '' : 'none';
      });

      // 2) Empty .calendar-section <section> elements (Find your people,
      //    Learn and connect, Coming up).
      document.querySelectorAll<HTMLElement>('.calendar-section').forEach(section => {
        const cards = section.querySelectorAll<HTMLElement>('.event-card-featured');
        if (cards.length === 0) return;
        const anyVisible = Array.from(cards).some(c => c.style.display !== 'none');
        section.style.display = anyVisible ? '' : 'none';
      });

      // 3) Organizer spotlight. The listener fully owns spotlight display:
      //    - Unfiltered: hide every fallback, Fisher-Yates shuffle the main
      //      orgs, show the first `data-show`.
      //    - Filtered: an org matches if its tags include EVERY active tag
      //      (AND, like the rest of the filter). Mains and fallbacks both
      //      compete; shuffle matches, keep the first `data-show`.
      //    Fallbacks are orgs that don't meet the default Instagram + 2-events
      //    gate but appear under matching tag filters (e.g. a women-only club
      //    with no upcoming women-only events).
      const spotlight = document.querySelector<HTMLElement>('.organizer-spotlight');
      if (spotlight) {
        const strip = spotlight.querySelector<HTMLElement>('.organizer-spotlight-strip');
        const cap = parseInt(strip?.dataset.show || '3', 10);
        const orgCards = Array.from(spotlight.querySelectorAll<HTMLElement>('[data-organizer-slug]'));
        const mains = orgCards.filter(c => !c.dataset.tagFallback);
        const candidates = isFiltered
          ? orgCards.filter(card => {
              const slug = card.dataset.organizerSlug ?? '';
              const orgTags = orgTagsForSpotlightBySlug[slug] ?? [];
              return detail.activeTags.every(t => orgTags.includes(t));
            })
          : mains;
        // Fisher-Yates shuffle the candidate set, take the first `cap`.
        const shuffled = candidates.slice();
        for (let i = shuffled.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        const keep = new Set(shuffled.slice(0, cap));
        for (const card of orgCards) {
          card.style.display = keep.has(card) ? '' : 'none';
        }
        spotlight.style.display = keep.size > 0 ? '' : 'none';
      }

      // 4) Subscribe / Add Event buttons sit above the months grid; when a
      //    filter is active the user is in "narrow what's on" mode, not in
      //    "subscribe to the whole calendar" mode, so tuck the strip away.
      const subscribeActions = document.querySelector<HTMLElement>('.calendar-subscribe-actions');
      if (subscribeActions) {
        subscribeActions.style.display = isFiltered ? 'none' : '';
      }

      // 5) Full calendar grid: rows + parent collapse.
      document.querySelectorAll<HTMLElement>('.calendar-months-grid .event-day-group-row').forEach(row => {
        const slug = row.dataset.eventSlug ?? '';
        row.style.display = enabled.has(slug) ? '' : 'none';
      });
      document.querySelectorAll<HTMLElement>('.calendar-months-grid .event-day-group').forEach(group => {
        const anyVisible = Array.from(group.querySelectorAll<HTMLElement>('.event-day-group-row'))
          .some(r => r.style.display !== 'none');
        group.style.display = anyVisible ? '' : 'none';
      });
      document.querySelectorAll<HTMLElement>('.calendar-month-card').forEach(card => {
        const anyVisible = Array.from(card.querySelectorAll<HTMLElement>('.event-day-group'))
          .some(g => g.style.display !== 'none');
        card.style.display = anyVisible ? '' : 'none';
      });

      if (detail.action === 'add' && detail.lastChangedTag) {
        window.BikeApp?.tE?.('Calendar: Tag Filter', { props: { tagName: detail.lastChangedTag } });
      } else if (detail.action === 'init') {
        // Visiting /calendar?tags=foo,bar fires one event per pre-enabled tag —
        // the URL is effectively a series of "tag enabled" actions.
        for (const tag of detail.activeTags) {
          window.BikeApp?.tE?.('Calendar: Tag Filter', { props: { tagName: tag } });
        }
      }
    });
  </script>

  <script>
    document.getElementById('show-past-events')?.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement);
      const pastEl = document.querySelector('.past-events') as HTMLElement;
      if (pastEl) {
        pastEl.style.display = pastEl.style.display === 'none' ? '' : 'none';
        target.textContent = pastEl.style.display === 'none' ? target.dataset.show! : target.dataset.hide!;
        if (pastEl.style.display !== 'none') {
          window.BikeApp?.tE?.('show past events in calendar page');
        }
      }
    });
  </script>
</Base>

<style>
  .calendar-subscribe-actions {
    margin-bottom: 1.5rem;
  }

  /* When a seasonal banner sits above the tag filter, add a touch of
     breathing room so the pills don't crowd the banner. The hidden
     .calendar-bookmarks placeholder lives between them in the DOM, so we
     use the general-sibling combinator rather than the adjacent one. */
  :global(.seasonal-banner ~ #calendar-filter) {
    margin-top: 1rem;
  }
</style>
