---
export const prerender = true;
// src/views/calendar.astro
import Base from '@/layouts/Base.astro';
import EventCardCompact from '@/components/EventCardCompact.astro';
import EventCardFeatured from '@/components/EventCardFeatured.astro';
import SeasonalBanner from '@/components/SeasonalBanner.astro';
import OrganizerSpotlight from '@/components/OrganizerSpotlight.astro';
import { getCollection } from 'astro:content';
import { parseLocalDate, formatMonthName } from '@/lib/date-utils';
import { getCityConfig } from '@/lib/config/city-config';
import { t, formatLocale } from '@/i18n';
import { paths } from '@/lib/paths';
import { classifyEvent } from '@/lib/event-tags';
import { tTag } from '@/lib/i18n/tag-translations.server';
import { expandSeriesOccurrences, isSeriesEvent } from '@/lib/series-utils';

const config = getCityConfig();
const locale = Astro.currentLocale;
const fmtLocale = formatLocale(locale);

const icalUrl = `${config.url.replace(/\/$/, '')}/calendar.ics`;
const webcalUrl = icalUrl.replace(/^https?:\/\//, 'webcal://');
const icalUrlHttp = icalUrl.replace(/^https:\/\//, 'http://');
const googleCalendarUrl = `http://www.google.com/calendar/render?cid=${encodeURIComponent(icalUrlHttp)}`;

const events = await getCollection('events');
const allOrganizers = await getCollection('organizers');
const now = new Date();
const currentYear = now.getFullYear();

// CalendarEntry wraps events with optional occurrence overrides for series
interface CalendarEntry {
  event: typeof events[0];
  occurrenceDate?: string;
  occurrenceLocation?: string;
}

function effectiveDate(entry: CalendarEntry): string {
  return entry.occurrenceDate || entry.event.data.start_date;
}
function effectiveEndDate(entry: CalendarEntry): string {
  return entry.occurrenceDate || entry.event.data.end_date || entry.event.data.start_date;
}

// Expand series events into one CalendarEntry per occurrence
const expanded: CalendarEntry[] = [];
for (const event of events) {
  if (isSeriesEvent(event.data)) {
    const occurrences = expandSeriesOccurrences(event.data);
    for (const occ of occurrences) {
      if (!occ.cancelled) {
        expanded.push({
          event,
          occurrenceDate: occ.date,
          occurrenceLocation: occ.location,
        });
      }
    }
  } else {
    expanded.push({ event });
  }
}

const upcoming = expanded
  .filter(e => parseLocalDate(effectiveEndDate(e)) >= now)
  .sort((a, b) => parseLocalDate(effectiveDate(a)).getTime() - parseLocalDate(effectiveDate(b)).getTime());

const past = expanded
  .filter(e => parseLocalDate(effectiveEndDate(e)) < now)
  .sort((a, b) => parseLocalDate(effectiveDate(b)).getTime() - parseLocalDate(effectiveDate(a)).getTime());

// Deduplicate series for section views: show each series once with its next occurrence date
function deduplicateSeries(entries: CalendarEntry[]): CalendarEntry[] {
  const seen = new Set<string>();
  const result: CalendarEntry[] = [];
  for (const entry of entries) {
    const id = entry.event.id;
    if (isSeriesEvent(entry.event.data)) {
      if (seen.has(id)) continue;
      seen.add(id);
    }
    result.push(entry);
  }
  return result;
}

// Build a series badge label for display on cards
function getSeriesBadge(entry: CalendarEntry): string | undefined {
  if (!isSeriesEvent(entry.event.data)) return undefined;
  const series = entry.event.data.series;
  if (!series) return undefined;
  if (series.recurrence && series.recurrence_day) {
    const occurrences = expandSeriesOccurrences(entry.event.data);
    const localizedDay = parseLocalDate(
      occurrences[0]?.date || '2026-01-01'
    ).toLocaleString(fmtLocale, { weekday: 'long' });
    const timeStr = entry.event.data.start_time
      ? new Date(2000, 0, 1, ...entry.event.data.start_time.split(':').map(Number)).toLocaleTimeString(fmtLocale, { hour: 'numeric', minute: '2-digit' })
      : '';
    const key = series.recurrence === 'biweekly' ? 'events.series_every_two_weeks' : 'events.series_every_week';
    return t(key, locale, { day: localizedDay, time: timeStr });
  }
  if (series.schedule?.length) {
    return t('events.series_dates_count', locale, { count: series.schedule.filter((s: { cancelled?: boolean }) => !s.cancelled).length });
  }
  return undefined;
}

// Deduplicated upcoming entries for section views
const upcomingDeduped = deduplicateSeries(upcoming);

// Classify upcoming events (deduplicated for sections)
const seasonal: CalendarEntry[] = [];
const community: CalendarEntry[] = [];
const learnConnect: CalendarEntry[] = [];
const general: CalendarEntry[] = [];

for (const e of upcomingDeduped) {
  const section = classifyEvent(e.event.data.tags ?? []);
  switch (section) {
    case 'seasonal': seasonal.push(e); break;
    case 'community': community.push(e); break;
    case 'learn-connect': learnConnect.push(e); break;
    default: general.push(e); break;
  }
}

// Determine which sections have enough events to show independently
const showCommunity = community.length >= 2;
const showLearnConnect = learnConnect.length >= 2;

// Build "Coming up" pool: general events + lone events from sparse sections
const comingUpPool = [...general];
if (!showCommunity) comingUpPool.push(...community);
if (!showLearnConnect) comingUpPool.push(...learnConnect);
comingUpPool.sort((a, b) => parseLocalDate(effectiveDate(a)).getTime() - parseLocalDate(effectiveDate(b)).getTime());
const comingUp = comingUpPool.slice(0, 3);

// For folded events, determine if they need a tag pill
function getTagLabel(entry: CalendarEntry): string | undefined {
  const section = classifyEvent(entry.event.data.tags ?? []);
  if (section === 'community' && !showCommunity) {
    const tag = entry.event.data.tags?.find((t: string) => ['social', 'group-ride', 'critical-mass'].includes(t));
    return tag ? tTag(tag, locale) : undefined;
  }
  if (section === 'learn-connect' && !showLearnConnect) {
    const tag = entry.event.data.tags?.find((t: string) => ['workshop', 'swap-meet', 'festival', 'advocacy', 'bikepacking'].includes(t));
    return tag ? tTag(tag, locale) : undefined;
  }
  return undefined;
}

// Non-seasonal upcoming for full calendar section (expanded — shows all occurrences)
const nonSeasonalUpcoming = upcoming.filter(e => classifyEvent(e.event.data.tags ?? []) !== 'seasonal');

function groupByMonth(entries: CalendarEntry[]) {
  const groups: Record<string, CalendarEntry[]> = {};
  for (const entry of entries) {
    const month = formatMonthName(effectiveDate(entry), fmtLocale);
    if (!groups[month]) groups[month] = [];
    groups[month].push(entry);
  }
  return groups;
}

const upcomingByMonth = groupByMonth(nonSeasonalUpcoming);

// Organizer spotlight: organizers with >=2 total events and instagram
const totalOrganizerCounts = new Map<string, number>();
const organizerYears = new Map<string, Set<number>>();

for (const e of events) {
  const orgId = typeof e.data.organizer === 'string' ? e.data.organizer : undefined;
  if (!orgId) continue;
  totalOrganizerCounts.set(orgId, (totalOrganizerCounts.get(orgId) || 0) + 1);
  const year = parseLocalDate(e.data.start_date).getFullYear();
  if (!organizerYears.has(orgId)) organizerYears.set(orgId, new Set());
  organizerYears.get(orgId)!.add(year);
}

const spotlightCandidates = allOrganizers
  .filter(o => o.data.instagram && (totalOrganizerCounts.get(o.id) || 0) >= 2);

// Rank by year span (desc) then event count (desc), shuffle within tiers
function seededRandom(seed: string) {
  let h = 0;
  for (let i = 0; i < seed.length; i++) {
    h = Math.imul(31, h) + seed.charCodeAt(i) | 0;
  }
  return () => {
    h = Math.imul(h ^ (h >>> 16), 0x45d9f3b);
    h = Math.imul(h ^ (h >>> 13), 0x45d9f3b);
    h = (h ^ (h >>> 16)) >>> 0;
    return h / 0x100000000;
  };
}

const dailySeed = new Date().toISOString().slice(0, 10);
const rng = seededRandom(dailySeed);

const rankedOrganizers = spotlightCandidates
  .map(o => {
    const years = organizerYears.get(o.id)?.size ?? 0;
    const count = totalOrganizerCounts.get(o.id) || 0;
    // Years active worth 3 points each, total events worth 1 point each
    const score = years * 3 + count;
    return { organizer: o, score, tiebreaker: rng() };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return a.tiebreaker - b.tiebreaker;
  });

const spotlightOrganizers = rankedOrganizers.slice(0, 8).map(r => ({
  name: r.organizer.data.name,
  instagram: r.organizer.data.instagram,
  photo_key: r.organizer.data.photo_key,
}));

const hasUpcoming = upcoming.length > 0 || seasonal.length > 0;

---

<Base title={`${t('calendar.title', locale, { year: currentYear })} | ${config.display_name}`}>
  <h1 style="font-size: 1.7em;">{t('calendar.title', locale, { year: currentYear })}</h1>
  <a href="/admin/events/new" class="action-button">Add your event</a>

  {seasonal.map(e => (
    <SeasonalBanner
      name={e.event.data.name}
      startDate={effectiveDate(e)}
      endDate={e.event.data.end_date}
      bannerText={e.event.data.banner_text}
      eventId={e.event.id}
      locale={locale}
    />
  ))}

  {!hasUpcoming && (
    <p><strong>{t('calendar.wrap', locale)}</strong></p>
  )}

  {comingUp.length > 0 && (
    <section class="calendar-section">
      <h2>{t('calendar.coming_up', locale)}</h2>
      <div class="featured-cards">
        {comingUp.map(e => (
          <EventCardFeatured event={e.event} tagLabel={getTagLabel(e)} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {showCommunity && (
    <section class="calendar-section">
      <h2>{t('calendar.find_your_people', locale)}</h2>
      <div class="featured-cards">
        {community.slice(0, 3).map(e => (
          <EventCardFeatured event={e.event} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {showLearnConnect && (
    <section class="calendar-section">
      <h2>{t('calendar.learn_and_connect', locale)}</h2>
      <div class="featured-cards">
        {learnConnect.slice(0, 3).map(e => (
          <EventCardFeatured event={e.event} seriesBadge={getSeriesBadge(e)} occurrenceDate={e.occurrenceDate} locale={locale} />
        ))}
      </div>
    </section>
  )}

  {spotlightOrganizers.length > 0 && (
    <OrganizerSpotlight organizers={spotlightOrganizers} locale={locale} />
  )}

  <a href={webcalUrl} class="action-button">&#x1F4C5; {t('calendar.subscribe', locale)}</a>
  <a href={googleCalendarUrl} class="action-button" target="_blank" rel="noopener noreferrer">{t('calendar.google', locale)}</a>

  {Object.keys(upcomingByMonth).length > 0 && (
    <section>
      <h2>{t('calendar.full_calendar', locale)}</h2>
      <div class="calendar-months-grid">
        {Object.entries(upcomingByMonth).map(([month, evts]) => (
          <div class="calendar-month-card">
            <h3 class="month-header">{month}</h3>
            <div class="events-list">
              {evts.map(e => (
                <EventCardCompact event={e.event} occurrenceDate={e.occurrenceDate} occurrenceLocation={e.occurrenceLocation} seriesBadge={getSeriesBadge(e)} locale={locale} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {past.length > 0 && (
    <div>
      <h2>{t('calendar.past', locale)}</h2>
      <button class="action-button" id="show-past-events"
        data-show={t('calendar.show_past', locale)}
        data-hide={t('calendar.hide_past', locale)}>
        {t('calendar.show_past', locale)}
      </button>
      <div class="past-events" style="display: none;">
        <div class="events-list">
          {past.map(e => (
            <EventCardCompact event={e.event} occurrenceDate={e.occurrenceDate} occurrenceLocation={e.occurrenceLocation} locale={locale} />
          ))}
        </div>
      </div>
    </div>
  )}

  <script>
    document.getElementById('show-past-events')?.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement);
      const pastEl = document.querySelector('.past-events') as HTMLElement;
      if (pastEl) {
        pastEl.style.display = pastEl.style.display === 'none' ? '' : 'none';
        target.textContent = pastEl.style.display === 'none' ? target.dataset.show! : target.dataset.hide!;
        if (pastEl.style.display !== 'none') {
          window.BikeApp?.tE?.('show past events in calendar page');
        }
      }
    });
  </script>
</Base>
