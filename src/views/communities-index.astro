---
export const prerender = true;
import './CommunitiesIndex.scss';
import Base from '@/layouts/Base.astro';
import SubTabToggle from '@/components/SubTabToggle.astro';
import CommunityCard from '@/components/CommunityCard.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { t, localePath } from '@/i18n';
import { paths } from '@/lib/paths';
import { hasDetailPage, isBikeShop } from '@/lib/models/organizer-model';

const config = getCityConfig();
const locale = Astro.currentLocale;

const organizers = await getCollection('organizers');
const events = await getCollection('events');

// Count events per organizer
const eventCounts = new Map<string, number>();
for (const event of events) {
  const orgId = typeof event.data.organizer === 'string' ? event.data.organizer : undefined;
  if (orgId) {
    eventCounts.set(orgId, (eventCounts.get(orgId) || 0) + 1);
  }
}

// Only show organizers that qualify for a detail page
// Sort: featured first, then by event count descending
const sorted = organizers
  .filter(org => hasDetailPage(org))
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return (eventCounts.get(b.id) || 0) - (eventCounts.get(a.id) || 0);
  });

const communities = sorted.filter(org => !isBikeShop(org));

import { breadcrumbJsonLd } from '@/lib/json-ld';
const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('communities.title', locale), url: `${config.url}${paths.communities(locale)}` },
]);
---

<Base title={`${t('communities.title', locale)} | ${config.display_name}`} breadcrumbs={breadcrumbs}>
  <SubTabToggle isIndex items={[
    { label: t('nav.calendar', locale), href: localePath('/calendar', locale), active: false },
    { label: t('nav.people', locale), href: paths.communities(locale), active: true },
    { label: t('nav.bike_shops', locale), href: paths.bikeShops(locale), active: false },
  ]} />
  <h1>{t('communities.title', locale)}</h1>
  <p class="communities-intro">{t('communities.intro', locale)}</p>

  <div class="communities-grid">
    {communities.map(org => (
      <CommunityCard org={org} locale={locale} eventCount={eventCounts.get(org.id) || 0} />
    ))}
  </div>
</Base>
