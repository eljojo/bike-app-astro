---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/city-config';
import { isPublished } from '@/lib/content-filters';
import { t } from '@/i18n';
import { paths } from '@/lib/paths';
import { hasCachedMap } from '@/lib/map-thumbnails';
import RideCard from '@/components/RideCard.astro';
import RideFilterSidebar from '@/components/RideFilterSidebar.astro';

const config = getCityConfig();
const locale = Astro.currentLocale;
const allRoutes = await getCollection('routes');

const published = allRoutes
  .filter(isPublished)
  .sort((a, b) => (a.data.ride_date || '').localeCompare(b.data.ride_date || '')); // oldest first

// --- Badge computation (mirrors homepage) ---
const badgeMap = new Map<string, string[]>();

// Top 3 longest
const byDistance = [...published].sort((a, b) => b.data.distance_km - a.data.distance_km);
for (const ride of byDistance.slice(0, 3)) {
  const b = badgeMap.get(ride.id) || [];
  b.push(t('ride.badge.longest', locale));
  badgeMap.set(ride.id, b);
}

// Top 3 biggest climbs
const withElevation = published.filter(r => r.data.total_elevation_gain && r.data.total_elevation_gain > 0);
const byElevation = [...withElevation].sort((a, b) => (b.data.total_elevation_gain || 0) - (a.data.total_elevation_gain || 0));
for (const ride of byElevation.slice(0, 3)) {
  const b = badgeMap.get(ride.id) || [];
  b.push(t('ride.badge.biggest_climb', locale));
  badgeMap.set(ride.id, b);
}

// Tour
const { default: toursData } = await import('virtual:bike-app/tours');
const tourNameMap = new Map(toursData.map((tour: { slug: string; name: string }) => [tour.slug, tour.name]));
for (const ride of published) {
  if (ride.data.tour_slug) {
    const tourName = tourNameMap.get(ride.data.tour_slug) || ride.data.tour_slug;
    const b = badgeMap.get(ride.id) || [];
    b.push(t('ride.badge.part_of_tour', locale, { tour: tourName }));
    badgeMap.set(ride.id, b);
  }
}

// Abroad
const countryCounts = new Map<string, number>();
for (const ride of published) {
  if (ride.data.country) {
    countryCounts.set(ride.data.country, (countryCounts.get(ride.data.country) || 0) + 1);
  }
}
const homeCountry = [...countryCounts.entries()].sort((a, b) => b[1] - a[1])[0]?.[0];
if (homeCountry) {
  for (const ride of published) {
    if (ride.data.country && ride.data.country !== homeCountry) {
      const b = badgeMap.get(ride.id) || [];
      b.push(t('ride.badge.abroad', locale));
      badgeMap.set(ride.id, b);
    }
  }
}

const featuredIds = new Set(
  [...badgeMap.entries()].filter(([, b]) => b.length >= 1).map(([id]) => id)
);

// --- Monthly grouping ---
const byMonth = new Map<string, typeof published>();
for (const ride of published) {
  const key = ride.data.ride_date ? ride.data.ride_date.slice(0, 7) : 'unknown'; // YYYY-MM
  if (!byMonth.has(key)) byMonth.set(key, []);
  byMonth.get(key)!.push(ride);
}
const months = [...byMonth.keys()].sort(); // oldest first

function monthLabel(key: string): string {
  if (key === 'unknown') return 'Unknown';
  const [year, month] = key.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1, 1);
  return date.toLocaleDateString('en', { month: 'long', year: 'numeric' });
}

// Build filter input data for sidebar
const filterData = published.map(r => ({
  distance_km: r.data.distance_km,
  moving_time_s: r.data.moving_time_s,
  average_speed_kmh: r.data.average_speed_kmh,
  tour_slug: r.data.tour_slug,
  country: r.data.country,
  ride_date: r.data.ride_date,
}));
---

<Base title={`${t('nav.rides', locale)} | ${config.display_name}`} description={t('rides.description', locale)}>
  <h1>{t('nav.rides', locale)}</h1>
  <div class="rides-page">
    <RideFilterSidebar rides={filterData} />
    <div id="rides-grid">
      {months.map(monthKey => (
        <section class="rides-month-section" data-month={monthKey}>
          <h2 class="rides-month-label">{monthLabel(monthKey)}</h2>
          <ul class="rides-list rides-list--grid rides-month-grid">
            {byMonth.get(monthKey)!.map(ride => (
              <RideCard
                ride={ride}
                featured={featuredIds.has(ride.id)}
                badges={badgeMap.get(ride.id) || []}
              />
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    if (!params.has('filter') && !params.has('year') && !params.has('country')) {
      window.scrollTo(0, document.body.scrollHeight);
    }

    // Make header sticky on rides page only — month labels and sidebar offset below it
    const header = document.querySelector('.site-header');
    const nav = header?.nextElementSibling as HTMLElement | null;
    if (header && nav) {
      document.body.style.overflowX = 'clip'; // prevent horizontal scrollbar from full-width shadow
      const wrapper = document.createElement('div');
      wrapper.className = 'sticky-header';
      header.parentNode!.insertBefore(wrapper, header);
      wrapper.appendChild(header);
      wrapper.appendChild(nav);
      const update = () => document.documentElement.style.setProperty('--sticky-header-h', wrapper.offsetHeight + 'px');
      update();
      window.addEventListener('resize', update);
    }
  </script>
</Base>
