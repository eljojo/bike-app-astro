---
import Base from '@/layouts/Base.astro';
import MapPage from '@/components/MapPage.astro';
import { elevationConclusion } from '@/lib/geo/elevation';
import { getCityConfig } from '@/lib/config/city-config';
import { getCollection } from 'astro:content';
import { getAllElevations } from '@/lib/geo/elevation';
import { paths } from '@/lib/paths';
import { variantKeyFromGpx } from '@/lib/maps/map-thumbnails';
import { loadBuildPlan, filterByBuildPlan } from '@/lib/content/build-plan';

const config = getCityConfig();

export const prerender = true;
export async function getStaticPaths() {
  const routes = await getCollection('routes');
  const allElevations = getAllElevations(routes);
  const standalone = routes.filter(r => !r.data.tour_slug);
  const filtered = filterByBuildPlan(standalone, loadBuildPlan(), 'ride');
  return filtered.map(route => ({
    params: { slug: route.id },
    props: { route, allElevations },
  }));
}

const { route, allElevations } = Astro.props;
const { name, variants, gpxTracks } = route.data;

const variant = variants[0];
const track = variant ? gpxTracks[variant.gpx] : null;
const elevation = route.data.total_elevation_gain ?? track?.elevation_gain_m;
const conclusion = elevation ? elevationConclusion(elevation, allElevations) : null;
const variantKey = variant ? variantKeyFromGpx(variant.gpx) : '';

const photos = route.data.media
  .filter((m) => m.type === 'photo' && m.lat != null && m.lng != null)
  .map((m, i) => ({ key: m.key, lat: m.lat!, lng: m.lng!, caption: m.caption, width: m.width, height: m.height, index: i }));
---

<Base title={`Map: ${name} | ${config.display_name}`}>
  {variant && track ? (
    <MapPage
      routeSlug={route.id}
      routeLocaleSlug={route.id}
      routeName={name}
      variant={variant}
      polyline={track.polyline}
      elevationGain={elevation}
      elevationConclusion={conclusion}
      places={[]}
      photos={photos}
      trackPoints={track.points}
      trackDistanceM={track.distance_m}
      gpxPath={paths.rideGpx(route.id, variantKey)}
      backPath={paths.ride(route.id, route.data.tour_slug)}
    />
  ) : (
    <p>No map available for this ride.</p>
  )}
</Base>
