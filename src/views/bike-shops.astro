---
export const prerender = true;
import './CommunitiesIndex.scss';
import Base from '@/layouts/Base.astro';
import SubTabToggle from '@/components/SubTabToggle.astro';
import PinMap from '@/components/PinMap.astro';
import CommunityCard from '@/components/CommunityCard.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { t, localePath } from '@/i18n';
import { paths } from '@/lib/paths';
import { organizerLink, hasDetailPage, isBikeShop } from '@/lib/models/organizer-model';
import { tTag } from '@/lib/i18n/tag-translations.server';

const config = getCityConfig();
const locale = Astro.currentLocale;

const allOrganizers = await getCollection('organizers');
const bikeShops = allOrganizers
  .filter(o => isBikeShop(o) && !o.data.hidden && hasDetailPage(o))
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.name.localeCompare(b.data.name);
  });

// Build slug→link lookup so map popups can link to detail pages. Keying
// by organizer slug (not display name) handles the common case where a
// place has a more specific name than its parent organizer — e.g. the
// place "Full Cycle (St. Laurent)" links to the "Full Cycle" organizer
// via `organizer: full-cycle` in the place's frontmatter. A name-based
// match would miss because the strings differ. Falls back to a name
// match for any place that doesn't carry an explicit organizer slug.
const shopLinkBySlug = new Map<string, string>();
const shopLinkByName = new Map<string, string>();
for (const org of bikeShops) {
  const link = organizerLink(org, locale);
  shopLinkBySlug.set(org.id, link);
  shopLinkByName.set(org.data.name, link);
}

// Load places with bike-shop category for map pins
const allPlaces = await getCollection('places');
const shopPlaces = allPlaces.filter(p =>
  p.data.category === 'bike-shop' && p.data.lat && p.data.lng
);

const pins = shopPlaces.map(p => {
  const link = (p.data.organizer && shopLinkBySlug.get(p.data.organizer))
    ?? shopLinkByName.get(p.data.name);
  return {
    lat: p.data.lat,
    lng: p.data.lng,
    label: '🔧',
    popup: link
      ? `<a href="${link}" style="font-weight:600;color:inherit">${p.data.name}</a>`
      : p.data.name,
  };
});

const seoDescription = t('bike_shops.seo_description', locale, { city: config.name });

import { breadcrumbJsonLd } from '@/lib/json-ld';
const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('bike_shops.heading', locale), url: `${config.url}${paths.bikeShops(locale)}` },
]);
---

<Base title={`${t('bike_shops.page_title', locale)} | ${config.display_name}`} description={seoDescription} breadcrumbs={breadcrumbs}>
  <SubTabToggle isIndex items={[
    { label: t('nav.calendar', locale), href: localePath('/calendar', locale), active: false },
    { label: t('nav.people', locale), href: paths.communities(locale), active: false },
    { label: t('nav.bike_shops', locale), href: paths.bikeShops(locale), active: true },
  ]} />
  <h1>{t('bike_shops.heading', locale)}</h1>

  {pins.length > 0 && (
    <PinMap pins={pins} class="bike-shops-map" />
  )}

  <div class="communities-grid">
    {bikeShops.map(org => {
      const specialties = org.data.tags.filter(tag => tag !== 'bike-shop');
      return (
        <CommunityCard
          org={org}
          locale={locale}
          showFeatured={false}
          showHandle={false}
          showEventCount={false}
        >
          {specialties.length > 0 && (
            <span class="community-card-specialties">
              {specialties.map(tag => (
                <span class="specialty-pill">{tTag(tag, locale)}</span>
              ))}
            </span>
          )}
        </CommunityCard>
      );
    })}
  </div>
</Base>
