---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import OttawaHeroMap from '@/components/about/OttawaHeroMap.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { getInstanceFeatures } from '@/lib/config/instance-features';
import { defaultLocale } from '@/lib/i18n/locale-utils';
import { t, localePath } from '@/i18n';
import contributors from 'virtual:bike-app/contributors';
import { categoryEmoji } from '@/lib/geo/place-categories';

const config = getCityConfig();
const features = getInstanceFeatures();
const locale = Astro.currentLocale || defaultLocale();

const pages = await getCollection('pages');
const aboutPage = pages.find(p => p.id === 'about');
if (!aboutPage) throw new Error('About page not found in content');

const translation = aboutPage.data.translations?.[locale];
const title = translation?.title || aboutPage.data.title;
const rawHtml = translation?.renderedBody || aboutPage.data.renderedBody;

// Variable replacement on the full rendered HTML
const contentHtml = rawHtml
  .replace(/\{author_email\}/g, config.author.email)
  .replace(/\{author_photo_url\}/g, config.author.photo_url)
  .replace(/\{author_name\}/g, config.author.name)
  .replace(/\{display_name\}/g, config.display_name);

// Parse H2-delimited sections into accordion items
// Each <h2> starts a section; a <blockquote> right after becomes the description
interface AccordionSection {
  title: string;
  desc: string;
  body: string;
}

const sections: AccordionSection[] = [];
const parts = contentHtml.split(/<h2[^>]*>([\s\S]*?)<\/h2>/);
// parts[0] = content before first h2 (ignored)
// parts[1] = h2 inner html, parts[2] = body, parts[3] = h2, parts[4] = body, ...
for (let i = 1; i < parts.length; i += 2) {
  const sectionTitle = parts[i].trim();
  let body = (parts[i + 1] || '').trim();
  let desc = '';

  const bqMatch = body.match(/^<blockquote>\s*<p>([\s\S]*?)<\/p>\s*<\/blockquote>/);
  if (bqMatch) {
    desc = bqMatch[1].trim();
    body = body.slice(bqMatch[0].length).trim();
  }

  sections.push({ title: sectionTitle, desc, body });
}

// Places for emoji pins (random selection per category at build time)
const allPlaces = await getCollection('places');
const pinCategories = ['cafe', 'poutine', 'beach', 'park', 'ice-cream', 'lookout', 'beer', 'bike-shop', 'camping-spot'];
const selectedPlaces = pinCategories
  .map(cat => {
    const matches = allPlaces.filter(p => p.data.category === cat);
    return matches.length > 0 ? matches[Math.floor(Math.random() * matches.length)] : undefined;
  })
  .filter(Boolean);
---

<Base title={`${title} | ${config.display_name}`} description={t('about.hero_subtitle', locale)}>
  <!-- Hero Map -->
  <div class="about-hero">
    <OttawaHeroMap />

    <!-- Emoji pins from real places -->
    {selectedPlaces.map((place, i) => {
      const emoji = categoryEmoji[place.data.category] || '📌';
      const positions = [
        { left: '38%', top: '28%' }, { left: '55%', top: '32%' },
        { left: '63%', top: '22%' }, { left: '14%', top: '14%' },
        { left: '46%', top: '45%' }, { left: '20%', top: '24%' },
        { left: '82%', top: '35%' }, { left: '33%', top: '38%' },
        { left: '88%', top: '25%' }, { left: '8%', top: '30%' },
      ];
      const pos = positions[i] || positions[0];
      const delay = 2.2 + i * 0.4;
      return (
        <div class="about-pin" style={`left:${pos.left};top:${pos.top};animation-delay:${delay}s`}>
          <span class="about-pin__emoji">{emoji}</span>
          {i < 7 && (
            <span class="about-pin__label" style={`animation-delay:${delay + 0.4}s`}>
              {place.data.name}
            </span>
          )}
        </div>
      );
    })}

    <!-- Route tags -->
    {(['family friendly', 'gravel', 'scenic', 'bike path'] as const).map((tag, i) => {
      const positions = [
        { left: '42%', top: '16%', delay: 3.0 },
        { left: '18%', top: '8%', delay: 4.0 },
        { left: '68%', top: '38%', delay: 4.5 },
        { left: '52%', top: '52%', delay: 5.0 },
      ];
      const pos = positions[i];
      return (
        <div class="about-route-tag" style={`left:${pos.left};top:${pos.top};animation-delay:${pos.delay}s`}>
          {tag}
        </div>
      );
    })}

    <!-- Text overlay -->
    <div class="about-hero-text">
      <h1 class="about-hero-tagline">{config.display_name}</h1>
      <p class="about-hero-subtitle">{t('about.hero_subtitle', locale)}</p>
      <div class="about-trust-row">
        <span class="about-trust-badge">{t('about.trust_ridden', locale)}</span>
        <span class="about-trust-badge">{t('about.trust_community', locale)}</span>
        <span class="about-trust-badge">{t('about.trust_free', locale)}</span>
      </div>
      <div class="about-hero-ctas">
        <a class="about-cta-primary" href={localePath('/', locale)}>{t('about.cta_browse', locale)}</a>
        {features.showsContributeLink && (
          <a class="about-cta-secondary" href="/admin">{t('about.cta_contribute', locale)}</a>
        )}
      </div>
    </div>
  </div>

  <!-- Accordions -->
  <div class="about-accordions">
    <div class="about-section-label">{t('about.section_learn_more', locale)}</div>
    <div class="about-accordion">
      {sections.map(section => (
        <details>
          <summary>
            <div>
              <div class="about-accordion__title" set:html={section.title} />
              {section.desc && <div class="about-accordion__desc" set:html={section.desc} />}
            </div>
          </summary>
          <div class="about-accordion__body" set:html={section.body} />
        </details>
      ))}
    </div>

    <!-- Contributors -->
    {contributors.length > 0 && (
      <div class="about-contributors">
        <h3>{t('about.contributors_heading', locale)}</h3>
        <div class="contributor-list">
          {contributors.map(c => (
            <div class="contributor">
              <img
                src={`https://www.gravatar.com/avatar/${c.gravatarHash}?d=mp&s=64`}
                alt={c.username}
                width="32"
                height="32"
                loading="lazy"
              />
              <span>{c.username}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Contact -->
    <p class="about-contact" set:html={t('about.contact_line', locale, { email: `<a href="mailto:${config.author.email}">${config.author.email}</a>` })} />
  </div>

  <br />
  <small style="display:block;text-align:center;padding:0 20px;">the <img src="/bicycle.png" alt="bicycle" width="32" height="32" class="about-inline-icon" /> icon is from <a href="https://www.flaticon.com/free-icon/bicycle_2972185#" target="_blank" rel="noopener">flaticon</a> - <a href="/sitemap">sitemap</a></small>
</Base>
