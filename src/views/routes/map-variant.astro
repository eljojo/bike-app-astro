---
import { variantKey as variantKeyFromGpx, variantSlug } from '@/lib/gpx/filenames';
import { paths, routeSlug } from '@/lib/paths';
import { loadRouteData } from '@/lib/route-data';
import { loadBuildPlan, filterByBuildPlan } from '@/lib/content/build-plan.server';

export const prerender = true;
export async function getStaticPaths() {
  const { routes } = await loadRouteData();
  const filtered = filterByBuildPlan(routes, loadBuildPlan(), 'route');
  const results: { params: { slug: string; variant: string }; props: Record<string, unknown> }[] = [];

  for (const route of filtered) {
    for (const v of route.data.variants) {
      const variantKey = variantKeyFromGpx(v.gpx);
      if (!route.data.gpxTracks[v.gpx]) continue;

      results.push({
        params: { slug: route.id, variant: variantKey },
        props: { route },
      });
    }
  }
  return results;
}

const { route } = Astro.props;
const locale = Astro.currentLocale;
const slug = routeSlug(route, locale);
const variant = Astro.params.variant;
const defaultVariant = variantKeyFromGpx(route.data.variants[0]?.gpx || '');
// Use clean slug in URL param ("cyclotour" not "variants-cyclotour")
const variantParam = variant ? variant.replace(/^variants-/, '') : '';
const defaultSlug = variantSlug(route.data.variants[0]?.gpx || '');
const dest = variantParam && variantParam !== defaultSlug
  ? `${paths.route(slug, locale)}?variant=${variantParam}`
  : paths.route(slug, locale);
return Astro.redirect(dest, 301);
---
