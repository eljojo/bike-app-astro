---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { imageUrl } from '@/lib/media/image-service';
import { videoPlaybackSources, videoPosterUrl, videoDisplaySize, videoFallbackUrl } from '@/lib/media/video-service';
import { hasCachedMap, cachedMapLocale } from '@/lib/maps/map-thumbnails';
import { variantKey as variantKeyFromGpx } from '@/lib/gpx/filenames';
import { routeJsonLd, breadcrumbJsonLd } from '@/lib/json-ld';
import { formatDistance } from '@/lib/geo/distance';
import PhotoGallery from '@/components/PhotoGallery.astro';
import NearbyPlaces from '@/components/NearbyPlaces.astro';
import { elevationConclusion } from '@/lib/geo/elevation';
import { routeShape, placeCounts } from '@/lib/route-insights';
import { difficultyLabel } from '@/lib/difficulty';
import { t, tCategory, localePath, formatLocale } from '@/i18n';
import { findNearbyPlaces } from '@/lib/geo/proximity';
import { loadRouteData } from '@/lib/route-data';
import { findSimilarRoutes } from '@/lib/route-similarity';
import { getCityConfig } from '@/lib/config/city-config';
import { getInstanceFeatures } from '@/lib/config/instance-features';
import { paths, assets, routeSlug } from '@/lib/paths';
import { supportedLocales } from '@/lib/i18n/locale-utils';
import { tTag } from '@/lib/i18n/tag-translations';
import ReactionsWidget from '@/components/ReactionsWidget';
import { loadBuildPlan, filterByBuildPlan } from '@/lib/content/build-plan.server';

const config = getCityConfig();
const locale = Astro.currentLocale;

export const prerender = true;
export async function getStaticPaths() {
  const { routes, allElevations, placeData, routeDifficultyScores, allScores, similarityMatrix, routeNames } = await loadRouteData();
  const filtered = filterByBuildPlan(routes, loadBuildPlan(), 'route');

  return filtered.map(route => ({
    params: { slug: route.id },
    props: { route, allElevations, routeDifficultyScores, allScores, placeData, similarityMatrix, routeNames },
  }));
}

const { route, allElevations, routeDifficultyScores, allScores, placeData, similarityMatrix, routeNames } = Astro.props;
const { name, tagline, distance_km, tags, media, variants, gpxTracks } = route.data;

// Get translated route content
const trans = route.data.translations?.[locale!];
const localeName = trans?.name || name;
const localeTagline = trans?.tagline || tagline;
const localeBody = trans?.renderedBody || route.data.renderedBody;
const slug = routeSlug(route, locale);
const alternateUrls: Record<string, string> = {};
for (const loc of supportedLocales()) {
  alternateUrls[loc] = paths.route(routeSlug(route, loc), loc);
}

const cover = media.find(m => m.cover);
const coverUrl = cover ? imageUrl(cover.key, { width: 1200, height: 628, fit: 'cover' }) : undefined;
const ogImageAlt = cover?.caption || t('route.photo_from', locale, { name: localeName });
const photos = media.filter(m => m.type === 'photo').sort((a, b) => (b.score || 0) - (a.score || 0));
const videos = media.filter(m => m.type === 'video');
const hasMap = hasCachedMap(route.id, undefined, locale);
const mapLang = cachedMapLocale(route.id, undefined, locale);

const primaryGpx = variants[0]?.gpx;
const primaryTrack = primaryGpx ? gpxTracks[primaryGpx] : null;
const manyVariants = variants.length > 1;

const variantDistances = variants.map(v => v.distance_km).filter((d): d is number => d != null);
const distanceTag = variantDistances.length > 0 ? formatDistance(variantDistances) : formatDistance([distance_km]);

const conclusion = primaryTrack?.elevation_gain_m
  ? elevationConclusion(primaryTrack.elevation_gain_m, allElevations)
  : null;

const variantScores = routeDifficultyScores.get(route.id) || [];
const primaryScore = variantScores[0] ?? null;
const minScore = variantScores.length > 0 ? Math.min(...variantScores) : null;
const maxScore = variantScores.length > 0 ? Math.max(...variantScores) : null;
const hasRange = minScore !== null && maxScore !== null && Math.abs(maxScore - minScore) > 3;
const shape = primaryTrack ? routeShape(primaryTrack.points, primaryTrack.distance_m) : null;
const nearbyPlaces = primaryTrack ? findNearbyPlaces(primaryTrack.points, placeData) : [];
const nearbyCategories = placeCounts(nearbyPlaces);

// Build place description using new i18n functions
function buildPlaceDesc(categories: { category: string; count: number }[]): string | null {
  if (categories.length === 0) return null;
  const parts = categories.map(p => `${p.count} ${tCategory(p.category, p.count, locale)}`);
  return t('places.summary_prefix', locale) + ' ' + parts.join(', ');
}
const placeDesc = buildPlaceDesc(nearbyCategories);

const similarRoutes = findSimilarRoutes(route.id, similarityMatrix, 3);

const displayTags = tags;

const difficultyText = primaryScore !== null
  ? (hasRange
      ? t('difficulty.range', locale, {
          low: t('difficulty.' + difficultyLabel(minScore!, allScores), locale),
          high: t('difficulty.' + difficultyLabel(maxScore!, allScores), locale),
        })
      : t('difficulty.' + difficultyLabel(primaryScore, allScores), locale))
  : null;

const SEO_FRIENDLY_TAGS = ['gravel', 'scenic', 'easy', 'chill'];
const seoTitle = (() => {
  if (localeTagline) return `${localeName} - ${localeTagline} | ${config.display_name}`;
  const matchingTag = tags.find((t: string) => SEO_FRIENDLY_TAGS.includes(t));
  if (matchingTag) return `${localeName} - ${matchingTag.charAt(0).toUpperCase() + matchingTag.slice(1)} ${t('route.bike_route', locale)} | ${config.display_name}`;
  return `${localeName} - ${t('route.bike_route', locale)} | ${config.display_name}`;
})();

const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: localeName, url: `${config.url}${paths.route(slug, locale)}` },
]);
---

<Base title={seoTitle} description={localeTagline || `${localeName} — ${distanceTag} ${t('route.bike_route', locale)}`} ogImage={coverUrl} ogImageAlt={ogImageAlt} jsonLd={routeJsonLd({...route.data, id: route.id}, coverUrl)} breadcrumbs={breadcrumbs} alternateUrls={alternateUrls}>
  <div class="route-detail">
    {cover && (
      <div class="route-detail--hero">
        <img
          src={imageUrl(cover.key, { width: 1170 })}
          srcset={`${imageUrl(cover.key, { width: 2340 })} 2x`}
          alt={cover.caption || localeName}
          class="gallery-cover-photo"
        />
      </div>
    )}

    <div class="route-detail--content">
      <div class="route-detail--body">
        {/* Zone 1: Header */}
        <h1>
          {localeName}
          <a href={`/admin/routes/${route.id}`} class="admin-edit-link" aria-label="Edit this route">Edit</a>
        </h1>
        {localeTagline && <h2>{localeTagline}</h2>}

        {displayTags.length > 0 && (
          <ul class="route--tags">
            {displayTags.map(tag => <li class="tag-pill">{tTag(tag, locale)}</li>)}
          </ul>
        )}

        {/* Zone 2: Stats Strip */}
        <div class="route-stats">
          <div class="route-stats--item">
            <span class="route-stats--label">{t('route.distance', locale)}</span>
            <span class="route-stats--value">{distanceTag}</span>
          </div>
          {shape && (
            <div class="route-stats--item">
              <span class="route-stats--label">{t('route.shape', locale)}</span>
              <span class="route-stats--value">{t('shape.' + shape, locale)}</span>
            </div>
          )}
          {primaryTrack?.elevation_gain_m != null && !manyVariants && (
            <div class="route-stats--item">
              <span class="route-stats--label">
                <a href={`${paths.routeMap(slug, locale)}#elevation-profile`}>{t('route.elevation_gain', locale)}</a>
              </span>
              <span class="route-stats--value">{primaryTrack.elevation_gain_m} {t('route.meters', locale)}</span>
              {conclusion && <span class="route-stats--detail">{t('elevation.' + conclusion, locale)}</span>}
            </div>
          )}
          {difficultyText && (
            <div class="route-stats--item">
              <span class="route-stats--label">{t('route.difficulty', locale)}</span>
              <span class="route-stats--value">{difficultyText}</span>
            </div>
          )}
        </div>

        {/* Zone 3: Description */}
        <div class="route-description" set:html={localeBody} />

        <a href={`/admin/routes/${route.id}`} class="suggest-edit-link">&#x270F;&#xFE0F; {t('route.suggest_edit', locale)}</a>

        {/* Zone 4: Actions */}
        <div class="route-actions">
          {variants.length > 1 ? (
            <div>
              <h3>{t('route.versions', locale, { count: variants.length })}</h3>
              {variants.map((v, i) => (
                <p>
                  <a href={paths.routeVariantMap(slug, variantKeyFromGpx(v.gpx), locale)} class={`action-button --wider ${i === 0 ? '--primary' : ''}`}>
                    &#x1F5FA;&#xFE0F; {v.name} ({v.distance_km} km)
                  </a>
                  {v.strava_url && (
                    <Fragment>
                      {' '}
                      <a href={v.strava_url} target="_blank" rel="noopener" class="action-button --light --logo">
                        <img src="/strava.svg" width="80" alt={t('strava.open', locale)} />
                      </a>
                    </Fragment>
                  )}
                  {v.rwgps_url && (
                    <Fragment>
                      {' '}
                      <a href={v.rwgps_url} target="_blank" rel="noopener" class="action-button --light --logo">
                        <img src="/rwgps.svg" width="78" alt={t('rwgps.open', locale)} />
                      </a>
                    </Fragment>
                  )}
                </p>
              ))}
            </div>
          ) : (
            <p>
              <a href={paths.routeMap(slug, locale)} class="action-button --primary --wider">
                &#x1F5FA;&#xFE0F; {t('route.view_map', locale, { name: localeName })}
              </a>
              {variants[0]?.strava_url && (
                <Fragment>
                  {' '}
                  <a href={variants[0].strava_url} target="_blank" rel="noopener" class="action-button --light --logo">
                    <img src="/strava.svg" width="80" alt={t('strava.open', locale)} />
                  </a>
                </Fragment>
              )}
              {variants[0]?.rwgps_url && (
                <Fragment>
                  {' '}
                  <a href={variants[0].rwgps_url} target="_blank" rel="noopener" class="action-button --light --logo">
                    <img src="/rwgps.svg" width="78" alt={t('rwgps.open', locale)} />
                  </a>
                </Fragment>
              )}
            </p>
          )}

          {getInstanceFeatures().allowsReactions && (
            <ReactionsWidget client:idle contentType="route" contentSlug={route.id} labels={[
              { type: 'ridden', icon: '\u{1F6B4}', label: t('reaction.ridden', locale) },
              { type: 'thumbs-up', icon: '\u{1F44D}', label: t('reaction.thumbs-up', locale) },
              { type: 'star', icon: '\u2B50', label: t('reaction.star', locale), title: t('reaction.star_title', locale) },
            ]} />
          )}
        </div>
      </div>

      {hasMap && (
        <div class="route-detail--static-map">
          <a href={paths.routeMap(slug, locale)} title={t('route.view_map', locale, { name: localeName })}>
            <img
              src={assets.mapThumbnail(route.id, 750, mapLang)}
              srcset={assets.mapThumbnailSrcsetLarge(route.id, mapLang)}
              alt={t('route.map_of', locale, { name: localeName })}
            />
          </a>
          {nearbyPlaces.length > 0 && (
            <NearbyPlaces nearby={nearbyPlaces} limit={8} />
          )}
          {placeDesc && <p class="route-place-summary">&#x1F5FA;&#xFE0F; {t('route.this_route', locale)} {placeDesc}</p>}
        </div>
      )}
    </div>

    {photos.length > 0 && (
      <PhotoGallery photos={photos} routeName={localeName} />
    )}

    {videos.length > 0 && (
      <section class="route-videos">
        <h3>{t('videos.title', locale)}</h3>
        {videos.map(video => {
          const sources = videoPlaybackSources(video.key);
          const size = videoDisplaySize(video.width || 640, video.height || 360);
          return (
            <div class="route-video">
              <video
                controls
                preload="metadata"
                width={size.width}
                height={size.height}
                poster={videoPosterUrl(video.key)}
                disablepictureinpicture
              >
                {sources.map(s => <source src={s.src} type={s.type} />)}
                <p><a href={videoFallbackUrl(video.key)}>{video.title || t('videos.download', locale)}</a></p>
              </video>
              {video.title && <p><a href={paths.video(video.handle)}>{video.title}</a></p>}
            </div>
          );
        })}
      </section>
    )}

    {similarRoutes.length > 0 && (
      <div class="route-similar">
        <h3>{t('route.similar', locale)}</h3>
        <ul>
          {similarRoutes.map(s => (
            <li>
              <a href={paths.route(s.id, locale)}>{routeNames[s.id]}</a>
              <span class="route-similar--score"> ({t('route.similar_pct', locale, { score: s.score })})</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <p class="route-similar">
      <a href={localePath('/', locale)} class="go-back-button">&#x21A9; {t('route.go_back', locale)}</a>
    </p>
  </div>
  {videos.length > 0 && <script>import '@/lib/media/hls-player';</script>}
</Base>
