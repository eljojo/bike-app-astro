---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import RouteCard from '@/components/RouteCard.astro';
import TagFilter from '@/components/TagFilter.astro';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { t, localePath } from '@/i18n';
import { getCityConfig } from '@/lib/config/city-config';
import { routeSlug, paths } from '@/lib/paths';
import { loadHomepageData } from '@/lib/route-data';
import { getInstanceFeatures } from '@/lib/config/instance-features';

const features = getInstanceFeatures();

const locale = Astro.currentLocale;
const config = getCityConfig();
const { published, filterTags, routeTagsMap } = await loadHomepageData();

// TagFilter takes a flat object — convert the per-route Map to plain JSON
// so it can be embedded as the component's `items` prop.
const routeTagsBySlug: Record<string, string[]> = {};
for (const route of published) {
  routeTagsBySlug[route.id] = routeTagsMap.get(route.id)!;
}

const suggestKey = published.length < 5
  ? 'home.suggest_route_few'
  : published.length >= 50
  ? 'home.suggest_route_many'
  : 'home.suggest_route';
---

<Base title={`${t('nav.routes', locale)} | ${config.display_name}`}>
  {features.hasPaths && (
    <SubTabToggle isIndex items={[
      { label: t('nav.routes', locale), href: localePath('/routes', locale), active: true },
      { label: t('nav.bike_paths', locale), href: paths.bikePaths(locale), active: false },
    ]} />
  )}

  <TagFilter id="routes-filter" tags={filterTags} items={routeTagsBySlug} urlParam="tags" />
  <ul class="routes-grid">
    {published.map((route, i) => {
      const cover = route.data.media.find(m => m.cover);
      const trans = route.data.translations?.[locale!];
      return (
        <RouteCard
          slug={route.id}
          localeSlug={routeSlug(route, locale)}
          name={trans?.name || route.data.name}
          tagline={trans?.tagline || route.data.tagline}
          distance_km={route.data.distance_km}
          tags={routeTagsMap.get(route.id)!}
          body={trans?.body || route.body}
          coverKey={cover?.key}
          lazy={i >= 5}
          variants={route.data.variants}
          gpxHash={route.data.gpxHash}
        />
      );
    })}
  </ul>
  <div class="suggest-route-cta">
    <a href="/admin/routes/new" class="suggest-route-link">
      {t(suggestKey, locale)}
    </a>
  </div>
</Base>

<script>
  // TagFilter owns pill state, URL sync, and the AND-match that decides
  // which slugs are enabled. We own the DOM-wiring — hide the cards whose
  // slug isn't in the enabled set.
  const filterRoot = document.getElementById('routes-filter');
  filterRoot?.addEventListener('tagfilter:change', (e: Event) => {
    const detail = (e as CustomEvent<{ enabledSlugs: string[]; activeTags: string[] }>).detail;
    const enabled = new Set(detail.enabledSlugs);
    document.querySelectorAll<HTMLElement>('.route-card').forEach(card => {
      card.style.display = enabled.has(card.dataset.slug ?? '') ? '' : 'none';
    });
    if (detail.activeTags.length > 0) {
      // Last-clicked tag isn't carried in the event detail; report the most
      // recent active tag for analytics. Empty string when nothing's active.
      window.BikeApp?.tE?.('Routes: Tag Filter', { props: { tagName: detail.activeTags[detail.activeTags.length - 1] } });
    }
  });
</script>

<script>
  // Reorder starred routes to top of the grid
  (async () => {
    try {
      const res = await fetch('/api/reactions/route/_starred');
      if (!res.ok) return;
      const data = await res.json();
      const starred: string[] = data.starredSlugs || [];
      if (starred.length === 0) return;

      const grid = document.querySelector('.routes-grid');
      if (!grid) return;

      const starredSet = new Set(starred);
      const cards = [...grid.querySelectorAll<HTMLElement>('.route-card')];
      const starredCards = cards.filter(c => starredSet.has(c.dataset.slug || ''));

      // Move starred cards to the top, preserving their relative order
      for (const card of starredCards.reverse()) {
        grid.prepend(card);
      }
    } catch {
      // Silently fail — starred reordering is progressive enhancement
    }
  })();
</script>
