---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import RouteCard from '@/components/RouteCard.astro';
import TagFilter from '@/components/TagFilter.astro';
import { getCityConfig } from '@/lib/config/city-config';
import { getInstanceFeatures } from '@/lib/config/instance-features';
import { t, localePath } from '@/i18n';
import { routeSlug, paths } from '@/lib/paths';
import type { CollectionEntry } from 'astro:content';
import RideCard from '@/components/RideCard.astro';
import EventCard from '@/components/EventCard.astro';

const config = getCityConfig();
const locale = Astro.currentLocale;
const features = getInstanceFeatures();

// For wiki instances, load the traditional homepage data
// For blog instances, load rides and stats
let wikiData: Awaited<ReturnType<typeof import('@/lib/route-data').loadHomepageData>> | null = null;
let blogRides: CollectionEntry<'routes'>[] = [];
let blogHighlights: CollectionEntry<'routes'>[] = [];
let blogBadgeMap = new Map<string, string[]>();
let blogFeaturedIds = new Set<string>();

// Club instance data
let clubUpcoming: CollectionEntry<'events'>[] = [];
let clubRecent: CollectionEntry<'events'>[] = [];
if (features.hasEnrichedEvents) {
  const { getCollection } = await import('astro:content');
  const { parseLocalDate } = await import('@/lib/date-utils');
  const events = await getCollection('events');
  const now = new Date();
  clubUpcoming = events
    .filter(e => parseLocalDate(e.data.end_date || e.data.start_date) >= now)
    .sort((a, b) => parseLocalDate(a.data.start_date).getTime() - parseLocalDate(b.data.start_date).getTime());
  clubRecent = events
    .filter(e => parseLocalDate(e.data.end_date || e.data.start_date) < now)
    .sort((a, b) => parseLocalDate(b.data.start_date).getTime() - parseLocalDate(a.data.start_date).getTime())
    .slice(0, 5);
} else if (features.hasRides) {
  const { getCollection } = await import('astro:content');
  const { isPublished } = await import('@/lib/content-filters');
  const allRoutes = await getCollection('routes');
  const published = allRoutes
    .filter(isPublished)
    .sort((a, b) => (b.data.ride_date || '').localeCompare(a.data.ride_date || ''));
  blogHighlights = published.filter(r => r.data.highlight);
  blogRides = published.slice(0, 10);

  // Compute noteworthy badges
  const badgeMap = new Map<string, string[]>();

  // Top 3 longest rides
  const byDistance = [...published].sort((a, b) => b.data.distance_km - a.data.distance_km);
  for (const ride of byDistance.slice(0, 3)) {
    const badges = badgeMap.get(ride.id) || [];
    badges.push(t('ride.badge.longest', locale));
    badgeMap.set(ride.id, badges);
  }

  // Top 3 biggest climbs
  const withElevation = published.filter(r => r.data.total_elevation_gain && r.data.total_elevation_gain > 0);
  const byElevation = [...withElevation].sort((a, b) => (b.data.total_elevation_gain || 0) - (a.data.total_elevation_gain || 0));
  for (const ride of byElevation.slice(0, 3)) {
    const badges = badgeMap.get(ride.id) || [];
    badges.push(t('ride.badge.biggest_climb', locale));
    badgeMap.set(ride.id, badges);
  }

  // Part of tour
  const { default: toursData } = await import('virtual:bike-app/tours');
  const tourNameMap = new Map(toursData.map((tour: { slug: string; name: string }) => [tour.slug, tour.name]));
  for (const ride of published) {
    if (ride.data.tour_slug) {
      const tourName = tourNameMap.get(ride.data.tour_slug) || ride.data.tour_slug;
      const badges = badgeMap.get(ride.id) || [];
      badges.push(t('ride.badge.part_of_tour', locale, { tour: tourName }));
      badgeMap.set(ride.id, badges);
    }
  }

  // Abroad (country differs from most common country)
  const countryCounts = new Map<string, number>();
  for (const ride of published) {
    if (ride.data.country) {
      countryCounts.set(ride.data.country, (countryCounts.get(ride.data.country) || 0) + 1);
    }
  }
  const homeCountry = [...countryCounts.entries()].sort((a, b) => b[1] - a[1])[0]?.[0];
  if (homeCountry) {
    for (const ride of published) {
      if (ride.data.country && ride.data.country !== homeCountry) {
        const badges = badgeMap.get(ride.id) || [];
        badges.push(t('ride.badge.abroad', locale));
        badgeMap.set(ride.id, badges);
      }
    }
  }

  blogBadgeMap = badgeMap;

  // Rides with 1+ badge get featured (larger card)
  for (const [id, badges] of badgeMap) {
    if (badges.length >= 1) blogFeaturedIds.add(id);
  }
} else if (!features.hasEnrichedEvents) {
  const { loadHomepageData } = await import('@/lib/route-data');
  wikiData = await loadHomepageData();
}

---

<Base title={config.display_name} description={config.tagline}>
  {features.hasEnrichedEvents ? (
    <div class="club-home">
      <div class="welcome-message">
        <h3>{config.tagline}</h3>
      </div>

      {clubUpcoming.length > 0 && (
        <section class="club-home--section">
          <h2>{t('events.title', locale)}</h2>
          <div class="events-grid">
            {clubUpcoming.map(e => (
              <EventCard
                name={e.data.name}
                start_date={e.data.start_date}
                end_date={e.data.end_date}
                distances={e.data.distances}
                organizer={e.data.organizer}
                poster_key={e.data.poster_key}
                href={paths.event(e.id, locale)}
              />
            ))}
          </div>
          <p class="club-home--more">
            <a href={localePath('/events', locale)}>{t('events.title', locale)}</a>
          </p>
        </section>
      )}

      {clubRecent.length > 0 && (
        <section class="club-home--section">
          <h2>{t('calendar.past', locale)}</h2>
          <div class="events-grid">
            {clubRecent.map(e => (
              <EventCard
                name={e.data.name}
                start_date={e.data.start_date}
                end_date={e.data.end_date}
                distances={e.data.distances}
                organizer={e.data.organizer}
                poster_key={e.data.poster_key}
                href={paths.event(e.id, locale)}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  ) : features.hasRides ? (
    <div class="blog-home">
      <div class="welcome-message">
        <h3>{config.tagline}</h3>
      </div>

      {blogHighlights.length > 0 && (
        <section class="blog-home--section">
          <h2>{t('home.highlights', locale)}</h2>
          <ul class="rides-list rides-list--grid">
            {blogHighlights.map(ride => (
              <RideCard
                ride={ride}
                featured={blogFeaturedIds.has(ride.id)}
                badges={blogBadgeMap.get(ride.id) || []}
              />
            ))}
          </ul>
        </section>
      )}

      <section class="blog-home--section">
        <h2>{t('home.latest_rides', locale)}</h2>
        <ul class="rides-list rides-list--grid">
          {blogRides.map(ride => (
            <RideCard
              ride={ride}
              badges={blogBadgeMap.get(ride.id) || []}
            />
          ))}
        </ul>
        <p class="blog-home--more">
          <a href="/rides">{t('home.all_rides', locale)}</a>
        </p>
      </section>
    </div>
  ) : (
    <>
      <div class="welcome-message">
        <h3>{t('home.welcome', locale)}</h3>
      </div>
      <TagFilter tags={wikiData!.filterTags} />
      <ul class="routes-grid">
        {wikiData!.published.map((route, i) => {
          const cover = route.data.media.find(m => m.cover);
          const trans = route.data.translations?.[locale!];
          return (
            <RouteCard
              slug={route.id}
              localeSlug={routeSlug(route, locale)}
              name={trans?.name || route.data.name}
              tagline={trans?.tagline || route.data.tagline}
              distance_km={route.data.distance_km}
              tags={wikiData!.routeTagsMap.get(route.id)!}
              body={trans?.body || route.body}
              coverKey={cover?.key}
              lazy={i >= 5}
              variants={route.data.variants}
            />
          );
        })}
      </ul>
      <div class="suggest-route-cta">
        <a href="/admin/routes/new" class="suggest-route-link">
          Know a route that's missing? Suggest a new route
        </a>
      </div>
      <script>
        // Reorder starred routes to top of the grid
        (async () => {
          try {
            const res = await fetch('/api/reactions/route/_starred');
            if (!res.ok) return;
            const data = await res.json();
            const starred: string[] = data.starredSlugs || [];
            if (starred.length === 0) return;

            const grid = document.querySelector('.routes-grid');
            if (!grid) return;

            const starredSet = new Set(starred);
            const cards = [...grid.querySelectorAll<HTMLElement>('.route-card')];
            const starredCards = cards.filter(c => starredSet.has(c.dataset.slug || ''));

            // Move starred cards to the top, preserving their relative order
            for (const card of starredCards.reverse()) {
              grid.prepend(card);
            }
          } catch {
            // Silently fail — starred reordering is progressive enhancement
          }
        })();
      </script>
    </>
  )}
</Base>
