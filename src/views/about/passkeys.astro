---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { getCityConfig } from '@/lib/config/city-config';
import { defaultLocale } from '@/lib/i18n/locale-utils';
import { t, localePath } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale || defaultLocale();
const title = t('passkeys.title', locale);
---

<Base title={`${title} | ${config.display_name}`} description={t('passkeys.intro', locale)}>
  <article class="passkeys-page">
    <h1>{title}</h1>

    <p>{t('passkeys.intro', locale)}</p>

    <h2>{t('passkeys.what_heading', locale)}</h2>
    <p>{t('passkeys.what_body', locale)}</p>

    <h2>{t('passkeys.why_heading', locale)}</h2>
    <p>{t('passkeys.why_body', locale)}</p>

    <h2>{t('passkeys.how_heading', locale)}</h2>
    <p set:html={t('passkeys.how_body', locale, { settings_url: localePath('/admin/settings', locale) })} />

    <h2>{t('passkeys.lost_device_heading', locale)}</h2>
    <p>{t('passkeys.lost_device_body', locale)}</p>

    <h2>{t('passkeys.learn_more_heading', locale)}</h2>
    <p set:html={t('passkeys.learn_more_body', locale)} />

    <p><a href={localePath('/about', locale)}>&larr; {t('passkeys.back_to_about', locale)}</a></p>
  </article>
</Base>

<style>
  .passkeys-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .passkeys-page h1 {
    margin-bottom: 0.5rem;
  }

  .passkeys-page h2 {
    margin-top: 2rem;
  }

  .passkeys-page p {
    line-height: 1.6;
  }
</style>
