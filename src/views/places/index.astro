---
export const prerender = true;
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { getInstanceFeatures } from '@/lib/config/instance-features';
import { categoryEmoji } from '@/lib/geo/place-categories';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;

const places = await getCollection('places');
const sorted = places
  .filter(p => p.data.status === 'published')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title={`${t('places.title', locale)} | ${config.display_name}`}>
  <h1>{t('places.title', locale)}</h1>
  <ul class="guides-list">
    {sorted.map(place => (
      <li class="guides-list--guide">
        <span class="guide--name">
          {categoryEmoji[place.data.category] || '\u{1F4CD}'} {place.data.name}
        </span>
        {place.data.address && <span class="guide--tagline">{place.data.address}</span>}
      </li>
    ))}
  </ul>
  {getInstanceFeatures().showsContributeLink && (
    <div class="suggest-route-cta">
      <a href="/admin/places/new" class="suggest-route-link">
        {t('places.add_missing', locale)}
      </a>
    </div>
  )}
</Base>
