---
import Base from '@/layouts/Base.astro';
import EventRouteMap from '@/components/EventRouteMap.astro';
import WaypointTimeline from '@/components/WaypointTimeline.astro';
import ResultsTable from '@/components/ResultsTable.astro';
import ResponsiveImage from '@/components/ResponsiveImage.astro';
import { getCollection } from 'astro:content';
import { eventJsonLd, breadcrumbJsonLd } from '@/lib/json-ld';
import { makePreview } from '@/lib/markdown/markdown-preview';
import { getCityConfig } from '@/lib/config/city-config';
import { imageUrl } from '@/lib/media/image-service';
import { eventCoverKey } from '@/lib/models/event-model';
import { formatDateRange, formatDate, parseLocalDate, endOfDay } from '@/lib/date-utils';
import { t, localePath, eventNoun, eventNextLabel, eventSignUpLabel, eventEditionsLabel, eventGoBackLabel } from '@/i18n';
import { expandSeriesOccurrences, getNextOccurrence, isSeriesActive, isSeriesEvent, type SeriesOccurrence } from '@/lib/series-utils';
import { paths } from '@/lib/paths';
import SubTabToggle from '@/components/SubTabToggle.astro';
import { getInstanceFeatures } from '@/lib/config/instance-features';
import ReactionsWidget from '@/components/ReactionsWidget.tsx';
import { tTag } from '@/lib/i18n/tag-translations.server';
import EditEntryPoint from '@/components/EditEntryPoint.astro';
import MediaGallery from '@/components/MediaGallery.astro';
import VideoPlayer from '@/components/VideoPlayer';
import { videoPlaybackSources, videoPosterUrl, videoFallbackUrl, videoDisplaySize } from '@/lib/media/video-service';
import { extractYouTubeUrls } from '@/lib/youtube-extract';
import YouTubeEmbed from '@/components/YouTubeEmbed.astro';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import { slugify } from '@/lib/slug';
import { findSimilarEvents, type EventSimilarityInput } from '@/lib/event-similarity';
import { organizerLink, normalizeSocialLinks, parseInstagramUsername, organizerInitials, type OrganizerEntry } from '@/lib/models/organizer-model';

const config = getCityConfig();
const locale = Astro.currentLocale;

export const prerender = true;
export async function getStaticPaths() {
  const events = await getCollection('events');
  const organizers = await getCollection('organizers');
  const allRoutes = await getCollection('routes');
  const allPlaces = await getCollection('places');

  // Build edition chains: walk previous_event links forward and backward
  type EventEntry = typeof events[number];
  const byId = new Map<string, EventEntry>();
  const nextOf = new Map<string, string>(); // reverse index: previous -> next
  for (const ev of events) {
    byId.set(ev.id, ev);
    const prev = ev.data.previous_event;
    if (prev) nextOf.set(prev, ev.id);
  }

  function resolveEditions(eventId: string): Array<{
    id: string;
    year: string;
    name: string;
    poster_key?: string;
    start_date: string;
    distances?: string;
  }> {
    const visited = new Set<string>();
    const chain: Array<{ id: string; year: string }> = [];

    // Walk backward via previous_event
    let cur = byId.get(eventId)?.data.previous_event;
    while (cur && !visited.has(cur)) {
      visited.add(cur);
      const ev = byId.get(cur);
      if (!ev) break;
      chain.unshift({ id: cur, year: cur.split('/')[0] });
      cur = ev.data.previous_event;
    }

    // Walk forward via reverse index
    visited.add(eventId);
    cur = nextOf.get(eventId);
    while (cur && !visited.has(cur)) {
      visited.add(cur);
      const ev = byId.get(cur);
      if (!ev) break;
      chain.push({ id: cur, year: cur.split('/')[0] });
      cur = nextOf.get(cur);
    }

    if (chain.length > 0) {
      chain.push({ id: eventId, year: eventId.split('/')[0] });
      chain.sort((a, b) => a.year.localeCompare(b.year));
    } else {
      // Fallback: match by organizer + slug
      const self = byId.get(eventId);
      if (self) {
        const selfOrg = typeof self.data.organizer === 'string' ? self.data.organizer : undefined;
        const selfSlug = eventId.split('/').slice(1).join('/');
        if (selfOrg) {
          for (const ev of events) {
            if (ev.id === eventId) continue;
            const org = typeof ev.data.organizer === 'string' ? ev.data.organizer : undefined;
            const slug = ev.id.split('/').slice(1).join('/');
            if (org === selfOrg && slugify(slug) === slugify(selfSlug)) {
              chain.push({ id: ev.id, year: ev.id.split('/')[0] });
            }
          }
          if (chain.length > 0) {
            chain.push({ id: eventId, year: eventId.split('/')[0] });
            chain.sort((a, b) => a.year.localeCompare(b.year));
          }
        }
      }
    }

    // Enrich with event data for thumbnail cards
    return chain.map(ed => {
      const ev = byId.get(ed.id);
      return {
        id: ed.id,
        year: ed.year,
        name: ev?.data.name || '',
        poster_key: ev ? eventCoverKey(ev.data) : undefined,
        start_date: ev?.data.start_date || '',
        distances: ev?.data.distances,
      };
    });
  }

  // Build similarity inputs for all events
  const allEventInputs: EventSimilarityInput[] = events.map(ev => ({
    id: ev.id,
    organizer: typeof ev.data.organizer === 'string' ? ev.data.organizer : '',
    tags: ev.data.tags ?? [],
    distances: ev.data.distances ?? '',
    linkedRoutes: ev.data.routes ?? [],
    startDate: ev.data.start_date,
  }));

  // Build lightweight card data for rendering similar event cards
  const eventCardData: Record<string, { name: string; start_date: string; poster_key?: string; distances?: string; organizer?: string; edition?: string }> = {};
  for (const ev of events) {
    const orgName = typeof ev.data.organizer === 'string'
      ? organizers.find(o => o.id === ev.data.organizer)?.data.name || ev.data.organizer
      : ev.data.organizer?.name || '';
    eventCardData[ev.id] = {
      name: ev.data.name,
      start_date: ev.data.start_date,
      poster_key: eventCoverKey(ev.data),
      distances: ev.data.distances,
      organizer: orgName,
      edition: ev.data.edition,
    };
  }

  return events.map(event => {
    const editions = resolveEditions(event.id);
    const editionIds = new Set(editions.map(ed => ed.id));
    const similarEvents = findSimilarEvents(event.id, allEventInputs, editionIds);
    return {
      params: { slug: event.id },
      props: { event, organizers, allRoutes, allPlaces, editions, similarEvents, eventCardData },
    };
  });
}

const { event, organizers, allRoutes, allPlaces, editions, similarEvents, eventCardData } = Astro.props;
const data = event.data;

// Resolve organizer name, URL, and entry
let organizerName = '';
let organizerUrl: string | undefined;
let organizerEntry: OrganizerEntry | undefined;
if (typeof data.organizer === 'string') {
  const org = organizers.find((o: { id: string }) => o.id === data.organizer);
  organizerName = org?.data.name || data.organizer;
  organizerEntry = org;
  organizerUrl = org ? organizerLink(org, locale) : undefined;
} else if (data.organizer?.name) {
  organizerName = data.organizer.name;
  organizerUrl = data.organizer.website;
}

const dateDisplay = formatDateRange(data.start_date, data.end_date, locale);
const coverKey = eventCoverKey(data);
const coverUrl = coverKey ? imageUrl(coverKey, { width: 800 }) : undefined;

function mapServiceName(url: string): string | undefined {
  try {
    const host = new URL(url).hostname;
    if (host.includes('ridewithgps.com')) return 'RideWithGPS';
    if (host.includes('strava.com')) return 'Strava';
    if (host.includes('google.com') || host.includes('maps.google')) return 'Google Maps';
    if (host.includes('komoot.com')) return 'Komoot';
  } catch {}
  return undefined;
}

// Resolve organizer website and Instagram
let organizerWebsite: string | undefined;
let organizerInstagram: string | undefined;
if (typeof data.organizer === 'string') {
  const org = organizers.find((o: { id: string }) => o.id === data.organizer);
  organizerWebsite = org?.data.website;
  organizerInstagram = org?.data.instagram;
} else if (data.organizer) {
  organizerWebsite = data.organizer.website;
  organizerInstagram = data.organizer.instagram;
}
const regUrl = data.registration?.url || data.registration_url;

// Organizer photo — from entry or inline
const organizerPhotoKey = organizerEntry?.data.photo_key
  ?? (typeof data.organizer !== 'string' ? data.organizer?.photo_key : undefined);

// Organizer social links — resolve from entry or inline fields
const organizerSocialLinks = organizerEntry
  ? normalizeSocialLinks(
      organizerEntry.data.social_links ?? [],
      { instagram: organizerEntry.data.instagram, website: organizerEntry.data.website },
    ).filter(link => !['twitter', 'x'].includes(link.platform.toLowerCase()))
  : normalizeSocialLinks(
      [],
      { instagram: organizerInstagram, website: organizerWebsite },
    ).filter(link => !['twitter', 'x'].includes(link.platform.toLowerCase()));

// Exclude links already surfaced elsewhere on the page
const shownUrls = new Set<string>();
if (organizerUrl) shownUrls.add(organizerUrl);
if (data.event_url) shownUrls.add(data.event_url);
if (regUrl) shownUrls.add(regUrl);
const extraSocialLinks = organizerSocialLinks.filter(link => !shownUrls.has(link.url));

function socialLinkLabel(link: { platform: string; url: string }): string {
  if (link.platform === 'instagram') {
    const username = parseInstagramUsername(link.url);
    return username ? t('social.on_instagram', locale, { username }) : 'Instagram';
  }
  const labels: Record<string, string> = {
    facebook: 'Facebook',
    strava: 'Strava',
    youtube: 'YouTube',
    meetup: 'Meetup',
    tiktok: 'TikTok',
    bluesky: 'Bluesky',
    threads: 'Threads',
    website: t('social.website', locale),
    discord: 'Discord',
    google_form: t('social.sign_up_form', locale),
    linktree: 'Linktree',
    rwgps: 'Ride with GPS',
    komoot: 'Komoot',
    newsletter: t('social.newsletter', locale),
    mastodon: 'Mastodon',
    booking: t('social.booking', locale),
    telephone: link.url,
    email: link.url,
  };
  return labels[link.platform] || link.platform;
}

// Format a 24h time string (e.g. "18:00") to locale-friendly display (e.g. "6:00 pm")
function formatTime(time: string, loc?: string): string {
  const [h, m] = time.split(':').map(Number);
  const d = new Date(2000, 0, 1, h, m);
  return d.toLocaleTimeString(loc || 'en-CA', { hour: 'numeric', minute: '2-digit' });
}

// Build date display with optional time — meet time shown when available
const hasMeetTime = !!data.meet_time && !!data.start_time;
const timeDisplay = hasMeetTime
  ? t('events.meet_time', locale, { meet: formatTime(data.meet_time!, locale), roll: formatTime(data.start_time!, locale) })
  : data.start_time
    ? formatTime(data.start_time, locale)
    : undefined;
const dateWithTime = timeDisplay ? `${dateDisplay} \u2014 ${timeDisplay}` : dateDisplay;

// Series data — must be declared before isPastEvent which depends on them
const isSeries = isSeriesEvent(data);
const seriesOccurrences = isSeries ? expandSeriesOccurrences(data) : [];
const now = new Date();
const nextOccurrence = isSeries ? getNextOccurrence(seriesOccurrences, now) : undefined;
const seriesActive = isSeries && isSeriesActive(seriesOccurrences, now);
const seriesEnded = isSeries && !seriesActive;

// Past event detection — for series, use whether the series is still active
const eventEndDate = data.end_date || data.start_date;
const isPastEvent = isSeries ? seriesEnded : endOfDay(eventEndDate) < new Date();

// Find next edition (forward in chain) for past event messaging
const currentIndex = editions.findIndex((ed: { id: string }) => ed.id === event.id);
const nextEdition = currentIndex >= 0 && currentIndex < editions.length - 1
  ? editions[currentIndex + 1]
  : undefined;

// Build organizer follow link for past events
let followUrl: string | undefined;
let followName: string | undefined;
if (organizerEntry) {
  followUrl = organizerLink(organizerEntry, locale);
  followName = organizerName;
} else if (organizerInstagram) {
  const handle = organizerInstagram.replace(/^@/, '').replace(/^https?:\/\/(www\.)?instagram\.com\//, '').replace(/\/$/, '');
  followUrl = `https://instagram.com/${handle}`;
  followName = `@${handle}`;
} else if (organizerWebsite) {
  followUrl = organizerWebsite;
  followName = organizerName;
}

// Split occurrences into upcoming and past
const upcomingOccurrences = seriesOccurrences.filter(o => endOfDay(o.date) >= now);
const pastOccurrences = seriesOccurrences.filter(o => endOfDay(o.date) < now);

// Series recurrence pattern description
function seriesPatternLabel(): string | undefined {
  const series = data.series;
  if (!series) return undefined;
  if (series.recurrence && series.recurrence_day) {
    const localizedDay = parseLocalDate(
      // Find first occurrence to get a real date for this day name
      seriesOccurrences[0]?.date || '2026-01-01'
    ).toLocaleString(locale || 'en-CA', { weekday: 'long' });
    const summaryTime = data.meet_time || data.start_time;
    const timeStr = summaryTime ? formatTime(summaryTime, locale) : '';
    const key = series.recurrence === 'biweekly' ? 'events.series_every_two_weeks' : 'events.series_every_week';
    return t(key, locale, { day: localizedDay, time: timeStr });
  }
  return undefined;
}

function seriesSeasonLabel(): string | undefined {
  const series = data.series;
  if (!series?.season_start || !series?.season_end) return undefined;
  const startStr = formatDate(parseLocalDate(series.season_start), { locale: locale || 'en-CA', includeYear: false });
  const endStr = formatDate(parseLocalDate(series.season_end), { locale: locale || 'en-CA' });
  return t('events.series_season', locale, { start: startStr, end: endStr });
}

// Format occurrence date for display
function formatOccurrenceDate(dateStr: string): string {
  const d = parseLocalDate(dateStr);
  return d.toLocaleDateString(locale || 'en-CA', { weekday: 'short', month: 'short', day: 'numeric' });
}

function formatOccurrenceDateLong(dateStr: string): string {
  const d = parseLocalDate(dateStr);
  return d.toLocaleDateString(locale || 'en-CA', { weekday: 'long', month: 'long', day: 'numeric' });
}

// Registration details
const reg = data.registration;
const departureGroups = reg?.departure_groups ?? [];

// Registration link text
const isInstagramReg = regUrl && (regUrl.includes('instagram.com') || regUrl.includes('instagr.am'));

// Tags
const tags = data.tags ?? [];

const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('nav.events', locale), url: `${config.url}${localePath('/events', locale)}` },
  { name: data.name, url: `${config.url}${paths.event(event.id, locale)}` },
]);

// Build a plain-text description for JSON-LD from the markdown body
const bodyPreview = makePreview(event.body).join(' ').slice(0, 200) || undefined;

const jsonLd = eventJsonLd({
  name: data.name,
  start_date: data.start_date,
  start_time: data.start_time,
  end_date: data.end_date,
  end_time: data.end_time,
  location: data.location,
  registration_url: regUrl,
  organizer_name: organizerName,
  organizer_url: organizerUrl,
  poster_key: coverKey,
  description: bodyPreview,
  tags,
  isPast: isPastEvent,
  price: reg?.price,
});

// Social preview description: date, location, distance, noun — no name repetition
const seoDescParts = [dateDisplay, data.location, data.distances].filter(Boolean);
const seoNoun = eventNoun(tags, locale);
const seoDescription = seoDescParts.length > 0
  ? `${seoDescParts.join(' \u2014 ')}. ${seoNoun.charAt(0).toUpperCase() + seoNoun.slice(1)}.`
  : data.name;

// Resolve event routes to route collection items
const routeSlugs = data.routes ?? [];
const eventRoutes = routeSlugs
  .map((slug: string) => allRoutes.find((r: { id: string }) => r.id === slug))
  .filter(Boolean);

const hasWaypoints = data.waypoints && data.waypoints.length > 0;
const hasResults = data.results && data.results.length > 0;

const mediaItems = (data.media ?? []).map((m) => ({
  type: m.type || 'photo',
  key: m.key,
  caption: m.caption,
  width: m.width,
  height: m.height,
}));
const posterAlreadyInMedia = data.poster_key && mediaItems.some(m => m.key === data.poster_key);
const posterMedia: Array<{ type: string; key: string; score?: number }> =
  data.poster_key && !posterAlreadyInMedia ? [{ type: 'photo', key: data.poster_key, score: 999 }] : [];
const galleryMedia = [
  ...posterMedia,
  ...mediaItems,
];

const { videoIds: youtubeIds, cleanedMarkdown: cleanBody } = extractYouTubeUrls(event.body || '');

// Determine hero video: first self-hosted video, or first YouTube
const selfHostedVideos = (data.media ?? []).filter(m => m.type === 'video');
const heroSelfHosted = selfHostedVideos[0];
const heroYouTubeId = !heroSelfHosted ? youtubeIds[0] : undefined;
const hasHeroVideo = !!heroSelfHosted || !!heroYouTubeId;

// Exclude hero video and poster from gallery (both are shown separately)
const excludeKeys = new Set<string>();
if (heroSelfHosted) excludeKeys.add(heroSelfHosted.key);
if (coverKey) excludeKeys.add(coverKey);
const galleryMediaFiltered = galleryMedia.filter(m => !excludeKeys.has(m.key));

// TODO: Render additional YouTube videos (youtubeIds.slice(1)) in gallery

// Other editions (excluding current) for past rides section
const otherEditions = editions.filter((ed: { id: string }) => ed.id !== event.id);

// Format edition date as "Mon YYYY"
function editionDateLabel(startDate: string, loc?: string): string {
  if (!startDate) return '';
  const d = parseLocalDate(startDate);
  return d.toLocaleString(loc || 'en-CA', { month: 'short', year: 'numeric' });
}
---

<Base title={`${data.name}${organizerName ? ` - ${organizerName}` : ''} | ${config.display_name}`} description={seoDescription} ogImage={coverUrl} ogImageAlt={data.name} ogType="event" jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <SubTabToggle items={[
    { label: t('nav.calendar', locale), href: localePath('/calendar', locale), active: true },
    { label: t('nav.people', locale), href: paths.communities(locale), active: false },
    { label: t('nav.bike_shops', locale), href: paths.bikeShops(locale), active: false },
  ]} />
  <article class="event-detail">
    <div class={`event-detail-hero ${coverKey ? '' : 'event-detail-hero--no-poster'}`}>
      {coverKey && (
        <div class="event-detail-hero-poster">
          <ResponsiveImage
            blobKey={coverKey}
            alt={data.name}
            widths={[400, 800]}
            fit="contain"
            loading="eager"
            data-pswp-width={data.poster_width || 800}
            data-pswp-height={data.poster_height || 1200}
          />
          {galleryMedia.length > 1 && (
            <span class="event-poster-photo-count">
              {t('events.photos_count', locale, { count: galleryMedia.length })}
            </span>
          )}
        </div>
      )}

      <div class="event-detail-hero-info">
        <h1>{data.name}</h1>
        {data.edition && <p class="event-detail-edition">{data.edition}</p>}

        {tags.length > 0 && (
          <ul class="event-detail-tags">
            {tags.map((tag: string) => <li class="tag-pill">{tTag(tag, locale)}</li>)}
          </ul>
        )}

        {nextOccurrence && (() => {
          const summaryTime = nextOccurrence.meet_time || nextOccurrence.start_time;
          return (
            <div class="event-series-next-ride">
              <strong>{eventNextLabel(tags, locale)}:</strong>{' '}
              {formatOccurrenceDateLong(nextOccurrence.date)}
              {summaryTime && ` \u00b7 ${formatTime(summaryTime, locale)}`}
              {nextOccurrence.location && (
                <Fragment>
                  {' \u00b7 '}
                  {/^https?:\/\//i.test(nextOccurrence.location)
                    ? <a href={nextOccurrence.location} target="_blank" rel="noopener noreferrer" title={nextOccurrence.location}>\ud83c\udf10</a>
                    : nextOccurrence.location}
                </Fragment>
              )}
            </div>
          );
        })()}

        <div class="event-detail-facts">
          <dl class="event-detail-facts-grid">
            <dt>{t('events.date', locale)}</dt>
            <dd>{dateWithTime}</dd>

            {data.distances && (
              <Fragment>
                <dt>{t('events.distance', locale)}</dt>
                <dd>{data.distances}</dd>
              </Fragment>
            )}

            {data.time_limit_hours && (
              <Fragment>
                <dt>{t('events.time_limit', locale)}</dt>
                <dd>{data.time_limit_hours} {t('events.hours', locale)}</dd>
              </Fragment>
            )}

            {data.location && (
              <Fragment>
                <dt>{t('events.location', locale)}</dt>
                <dd>{/^https?:\/\//i.test(data.location)
                  ? <a href={data.location} target="_blank" rel="noopener noreferrer" title={data.location}>🌐</a>
                  : data.location}</dd>
              </Fragment>
            )}

            {reg?.price && (
              <Fragment>
                <dt>{t('events.price', locale)}</dt>
                <dd>{reg.price}</dd>
              </Fragment>
            )}

            {reg?.slots && (
              <Fragment>
                <dt>{t('events.slots', locale)}</dt>
                <dd>{reg.slots}</dd>
              </Fragment>
            )}

            {reg?.deadline && (
              <Fragment>
                <dt>{t('events.deadline', locale)}</dt>
                <dd>{reg.deadline}</dd>
              </Fragment>
            )}

            {departureGroups.length > 0 && (
              <Fragment>
                <dt>{t('events.departure_groups', locale)}</dt>
                <dd>
                  <ul class="event-detail-departure-groups">
                    {departureGroups.map((g: string) => <li>{g}</li>)}
                  </ul>
                </dd>
              </Fragment>
            )}
          </dl>

          {!isPastEvent && regUrl ? (
            <a class="event-detail-facts-cta" href={regUrl} target="_blank" rel="noopener noreferrer">
              {isInstagramReg && followName ? followName : eventSignUpLabel(tags, locale)} &#x2192;
            </a>
          ) : !isPastEvent && data.event_url && (
            <a class="event-detail-facts-cta" href={data.event_url} target="_blank" rel="noopener noreferrer">
              {t('events.event_website', locale)} &#x2192;
            </a>
          )}

          {data.event_url && regUrl && (
            <div class="event-detail-facts-links">
              <a href={data.event_url} target="_blank" rel="noopener noreferrer">
                {t('events.event_website', locale)}
              </a>
            </div>
          )}
        </div>

        {organizerName && (
          <div class="event-organizer">
            <div class="event-organizer-avatar">
              {organizerUrl && organizerUrl !== '#' ? (
                <a href={organizerUrl} {...(!organizerUrl.startsWith('http') ? {} : { target: '_blank', rel: 'noopener noreferrer' })}>
                  {organizerPhotoKey ? (
                    <ResponsiveImage
                      blobKey={organizerPhotoKey}
                      alt={organizerName}
                      widths={[80, 160]}
                      width={48}
                      height={48}
                      class="event-organizer-photo"
                    />
                  ) : (
                    <div class="event-organizer-initials">{organizerInitials(organizerName)}</div>
                  )}
                </a>
              ) : organizerPhotoKey ? (
                <ResponsiveImage
                  blobKey={organizerPhotoKey}
                  alt={organizerName}
                  widths={[80, 160]}
                  width={48}
                  height={48}
                  class="event-organizer-photo"
                />
              ) : (
                <div class="event-organizer-initials">{organizerInitials(organizerName)}</div>
              )}
            </div>
            <div class="event-organizer-info">
              {organizerUrl && organizerUrl !== '#' ? (
                <a class="event-organizer-name" href={organizerUrl} {...(!organizerUrl.startsWith('http') ? {} : { target: '_blank', rel: 'noopener noreferrer' })}>
                  {organizerName}
                </a>
              ) : (
                <span class="event-organizer-name">{organizerName}</span>
              )}
              {extraSocialLinks.length > 0 && (
                <div class="event-organizer-links">
                  {extraSocialLinks.map(link => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {socialLinkLabel(link)}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        {getInstanceFeatures().allowsReactions && !isPastEvent && (
          <div class="event-reactions-zone">
            <ReactionsWidget client:idle contentType="event" contentSlug={event.id}
              bookmarkHint={t('reaction.bookmark_hint_event', locale)}
              trustReceiptMessage={t('reaction.trust_receipt', locale)}
              labels={[
                { type: 'thumbs-up', icon: 'calendar-check', label: t('reaction.want_to_go', locale), title: t('reaction.want_to_go_title', locale) },
                { type: 'star', icon: 'bookmark-simple', label: t('reaction.bookmark', locale), title: t('reaction.bookmark_title', locale) },
              ]} />
          </div>
        )}
        {getInstanceFeatures().allowsReactions && isPastEvent && (
          <div class="event-reactions-zone">
            <ReactionsWidget client:idle contentType="event" contentSlug={event.id}
              trustReceiptMessage={t('reaction.trust_receipt', locale)}
              labels={[
                { type: 'attended', icon: 'calendar-check', label: t('reaction.attended', locale), title: t('reaction.attended_title', locale) },
              ]} />
          </div>
        )}

        {isPastEvent && (
          <div class="event-detail-past-state">
            <p>{t('events.past_event', locale, { noun: eventNoun(tags, locale) })}</p>
            {nextEdition ? (
              <a href={paths.event(nextEdition.id, locale)}>
                {t('events.next_edition', locale, { name: nextEdition.name })} &#x2192;
              </a>
            ) : followUrl && followName ? (
              <a href={followUrl} target="_blank" rel="noopener noreferrer">
                {t('events.follow_next', locale, { name: followName })} &#x2192;
              </a>
            ) : null}
          </div>
        )}

        {event.body?.trim() ? (
          <div class="event-detail-body">
            <div class="event-description" set:html={await renderMarkdownHtml(cleanBody)} />
          </div>
        ) : getInstanceFeatures().showsContributeLink && (
          <p class="contribution-invite">
            Know about this event? <a href={`/admin/events/${event.id}?focus=description`}>Add details so people can plan.</a>
          </p>
        )}

        {heroSelfHosted && (
          <div class="event-detail-hero-video">
            <VideoPlayer
              client:idle
              sources={videoPlaybackSources(heroSelfHosted.key)}
              poster={videoPosterUrl(heroSelfHosted.key)}
              fallbackUrl={videoFallbackUrl(heroSelfHosted.key)}
              width={videoDisplaySize(heroSelfHosted.width || 640, heroSelfHosted.height || 360).width}
              height={videoDisplaySize(heroSelfHosted.width || 640, heroSelfHosted.height || 360).height}
              title={data.name}
            />
          </div>
        )}
        {heroYouTubeId && (
          <div class="event-detail-hero-video">
            <YouTubeEmbed videoId={heroYouTubeId} title={data.name} />
          </div>
        )}
      </div>
    </div>

    <div class="event-detail-content">
      <EditEntryPoint text={t('events.edit_description', locale)} href={`/admin/events/${event.id}?focus=description`} />

      {isSeries && seriesOccurrences.length > 0 && (
        <section class="event-series-schedule">
          <h2>{t('events.series_schedule', locale)}</h2>

          {seriesPatternLabel() && (
            <p class="event-series-pattern">
              {seriesPatternLabel()}
              {seriesSeasonLabel() && <span class="event-series-season"> &mdash; {seriesSeasonLabel()}</span>}
            </p>
          )}

          {!seriesPatternLabel() && seriesOccurrences.length > 0 && (
            <p class="event-series-pattern">
              {t('events.series_dates_count', locale, { count: seriesOccurrences.filter(o => !o.cancelled).length })}
            </p>
          )}

          {seriesEnded && (
            <p class="event-series-ended">{t('events.series_ended', locale)}</p>
          )}

          {upcomingOccurrences.length > 0 && (
            <ul class="event-series-dates">
              {upcomingOccurrences.map((occ: SeriesOccurrence) => {
                const occTime = occ.meet_time || occ.start_time;
                return (
                <li class={`event-series-date-item ${occ.cancelled ? 'event-series-date-item--cancelled' : ''}`}>
                  <span class="event-series-date-day">{formatOccurrenceDate(occ.date)}</span>
                  {occTime && <span class="event-series-date-time">{formatTime(occTime, locale)}</span>}
                  {occ.location && <span class="event-series-date-location">{/^https?:\/\//i.test(occ.location)
                    ? <a href={occ.location} target="_blank" rel="noopener noreferrer" title={occ.location}>🌐</a>
                    : occ.location}</span>}
                  {occ.cancelled && <span class="event-series-date-badge">{t('events.series_cancelled', locale)}</span>}
                  {occ.rescheduled_from && (
                    <span class="event-series-date-note">
                      {t('events.series_rescheduled_from', locale, { date: formatOccurrenceDate(occ.rescheduled_from) })}
                    </span>
                  )}
                  {occ.note && !occ.cancelled && <span class="event-series-date-note">{occ.note}</span>}
                </li>
                );
              })}
            </ul>
          )}

          {pastOccurrences.length > 0 && (
            <details class="event-series-past-dates">
              <summary>{t('events.series_past_dates', locale)} <span class="event-detail-count">({pastOccurrences.length})</span></summary>
              <ul class="event-series-dates event-series-dates--past">
                {pastOccurrences.toReversed().map((occ: SeriesOccurrence) => (
                  <li class={`event-series-date-item event-series-date-item--past ${occ.cancelled ? 'event-series-date-item--cancelled' : ''}`}>
                    <span class="event-series-date-day">{formatOccurrenceDate(occ.date)}</span>
                    {occ.location && <span class="event-series-date-location">{/^https?:\/\//i.test(occ.location)
                      ? <a href={occ.location} target="_blank" rel="noopener noreferrer" title={occ.location}>🌐</a>
                      : occ.location}</span>}
                    {occ.cancelled && <span class="event-series-date-badge">{t('events.series_cancelled', locale)}</span>}
                    {occ.note && !occ.cancelled && <span class="event-series-date-note">{occ.note}</span>}
                  </li>
                ))}
              </ul>
            </details>
          )}
        </section>
      )}

      {galleryMediaFiltered.length > 0 && (
        <section class="event-detail-section">
          <MediaGallery media={galleryMediaFiltered} name={data.name} />
        </section>
      )}

      {eventRoutes.length > 0 && (
        <section class="event-detail-section">
          <EventRouteMap routes={eventRoutes} locale={locale} waypoints={data.waypoints} places={allPlaces} />
        </section>
      )}

      {data.map_url && !eventRoutes.length && (
        <section class="event-detail-section">
          <a href={data.map_url} class="event-map-link" target="_blank" rel="noopener noreferrer">
            {mapServiceName(data.map_url)
              ? t('events.view_route_map_on', locale, { service: mapServiceName(data.map_url)! })
              : t('events.view_route_map', locale)} &#x2192;
          </a>
        </section>
      )}
      {data.map_url && eventRoutes.length > 0 && (
        <p class="event-map-external">
          <a href={data.map_url} target="_blank" rel="noopener noreferrer">
            {mapServiceName(data.map_url)
              ? t('events.also_on', locale, { service: mapServiceName(data.map_url)! })
              : t('events.view_route_map', locale)} &#x2192;
          </a>
        </p>
      )}

      {hasWaypoints && (
        <details class="event-detail-collapsible">
          <summary>{t('events.waypoints', locale)} <span class="event-detail-count">{t('events.checkpoints_count', locale, { count: data.waypoints!.length })}</span></summary>
          <WaypointTimeline waypoints={data.waypoints!} locale={locale} />
        </details>
      )}

      {hasResults && (
        <details class="event-detail-collapsible">
          <summary>{t('events.results', locale)} <span class="event-detail-count">{t('events.finishers_count', locale, { count: data.results!.filter((r: { status?: string }) => !r.status).length })}</span></summary>
          <ResultsTable results={data.results!} locale={locale} privacy={config.results_privacy} />
        </details>
      )}

      {otherEditions.length > 0 && (
        <section class="event-editions">
          <h2>{eventEditionsLabel(tags, locale)}</h2>
          <div class="edition-cards">
            {otherEditions.map((ed: { id: string; year: string; name: string; poster_key?: string; start_date: string; distances?: string }) => (
              <a href={paths.event(ed.id, locale)} class={`edition-card ${ed.id === event.id ? 'edition-card--current' : ''}`}>
                {ed.poster_key ? (
                  <img
                    src={imageUrl(ed.poster_key, { width: 200, height: 200, fit: 'cover' })}
                    alt={ed.name}
                    class="edition-card-poster"
                    loading="lazy"
                  />
                ) : (
                  <div class="edition-card-placeholder">🚲</div>
                )}
                <div class="edition-card-info">
                  <span class="edition-card-date">{editionDateLabel(ed.start_date, locale)}</span>
                  {ed.distances && <span class="edition-card-distance">{ed.distances}</span>}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
      {similarEvents.length > 0 && (
        <section class="event-similar">
          <h2>{similarEvents.length === 1 ? t('events.similar_one', locale) : t('events.similar', locale)}</h2>
          <div class="event-similar-cards">
            {similarEvents.map((s: { id: string; score: number }) => {
              const card = eventCardData[s.id];
              if (!card) return null;
              const currentYear = new Date().getFullYear();
              const eventYear = parseInt(card.start_date.slice(0, 4), 10);
              const isPast = eventYear < currentYear;
              const secondaryMeta = isPast
                ? (card.edition || String(eventYear))
                : card.distances;
              return (
                <a href={paths.event(s.id, locale)} class={`event-similar-card${isPast ? ' is-past' : ''}`}>
                  {card.poster_key ? (
                    <img
                      src={imageUrl(card.poster_key, { width: 300, height: 200, fit: 'cover' })}
                      srcset={`${imageUrl(card.poster_key, { width: 600, height: 400, fit: 'cover' })} 2x`}
                      alt={card.name}
                      width="300"
                      height="200"
                      loading="lazy"
                    />
                  ) : (
                    <div class="event-similar-card-placeholder">🚲</div>
                  )}
                  <span class="event-similar-card-name">{card.name}</span>
                  <span class="event-similar-card-meta">
                    {[card.organizer, secondaryMeta].filter(Boolean).join(' \u00b7 ')}
                  </span>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </article>

  <p style="margin-top: 2em;">
    <a href={localePath(getInstanceFeatures().hasEnrichedEvents ? '/events' : '/calendar', locale)} class="go-back-button">&#x21A9; {eventGoBackLabel(tags, locale)}</a>
  </p>

  <script>
    /** Convert FAQ section: h3 headings after an h2 "FAQ" become collapsible details/summary. */
    document.addEventListener('DOMContentLoaded', () => {
      const body = document.querySelector('.event-detail-body');
      if (!body) return;

      const headings = Array.from(body.querySelectorAll('h2'));
      const faqH2 = headings.find(h => /^faq$/i.test(h.textContent?.trim() || ''));
      if (!faqH2) return;

      // Collect all siblings after the FAQ h2 until the next h2
      const faqItems: Array<{ heading: HTMLElement; content: Node[] }> = [];
      let current: { heading: HTMLElement; content: Node[] } | null = null;
      let sibling = faqH2.nextElementSibling as HTMLElement | null;

      while (sibling && sibling.tagName !== 'H2') {
        if (sibling.tagName === 'H3') {
          if (current) faqItems.push(current);
          current = { heading: sibling, content: [] };
        } else if (current) {
          current.content.push(sibling);
        }
        sibling = sibling.nextElementSibling as HTMLElement | null;
      }
      if (current) faqItems.push(current);
      if (faqItems.length === 0) return;

      // Replace FAQ heading + items with details/summary
      const faqSection = document.createElement('div');
      faqSection.className = 'faq-section';

      for (const item of faqItems) {
        const details = document.createElement('details');
        const summary = document.createElement('summary');
        summary.textContent = item.heading.textContent;
        details.appendChild(summary);
        for (const node of item.content) {
          details.appendChild(node);
        }
        faqSection.appendChild(details);
      }

      // Remove original elements and insert faq section after the h2
      for (const item of faqItems) {
        item.heading.remove();
      }
      faqH2.after(faqSection);
    });


    /** Poster lightbox: standalone PhotoSwipe instance for the event poster. */
    const poster = document.querySelector('.event-detail-hero-poster img') as HTMLImageElement | null;
    if (poster) {
      poster.style.cursor = 'pointer';
      poster.addEventListener('click', async () => {
        const { default: PhotoSwipeLightbox } = await import('photoswipe/lightbox');
        await import('photoswipe/style.css');
        const { default: PhotoSwipe } = await import('photoswipe');

        const w = Number(poster.dataset.pswpWidth) || 800;
        const h = Number(poster.dataset.pswpHeight) || 1200;
        const src = poster.src.replace(/width=\d+/, 'width=1600');

        const lightbox = new PhotoSwipeLightbox({
          dataSource: [{ src, width: w, height: h, msrc: poster.src }],
          pswpModule: () => Promise.resolve(PhotoSwipe),
          showHideAnimationType: 'fade',
        });
        lightbox.init();
        lightbox.loadAndOpen(0);
      });
    }
  </script>
</Base>
