---
export const prerender = true;
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '../lib/config/city-config';
import { paths, routeSlug } from '../lib/paths';
import { localePath, t } from '../i18n/index';
import { supportedLocales, defaultLocale } from '../lib/i18n/locale-utils';

const config = getCityConfig();
const locales = supportedLocales();
const defLocale = defaultLocale();

import { loadBikePathData } from '../lib/bike-paths/bike-path-data.server';
import { getInstanceFeatures } from '../lib/config/instance-features';

const features = getInstanceFeatures();
import { isBikeShop, isCommunity, hasDetailPage } from '../lib/models/organizer-model';

const routes = await getCollection('routes');
const guides = await getCollection('guides');
const events = await getCollection('events').catch(() => []);
const organizers = await getCollection('organizers').catch(() => []);
const bikePaths = features.hasPaths
  ? (await loadBikePathData()).pages
  : [];

const publishedRoutes = routes
  .filter(r => r.data.status === 'published')
  .sort((a, b) => a.data.distance_km - b.data.distance_km);

const allVideos = publishedRoutes
  .flatMap(r => r.data.media.filter(m => m.type === 'video').map(v => ({ ...v, routeName: r.data.name })));

const publishedGuides = guides
  .filter(g => g.data.status === 'published');

const communities = organizers.filter(o => isCommunity(o) && hasDetailPage(o) && !o.data.hidden);
const bikeShops = organizers.filter(o => isBikeShop(o) && hasDetailPage(o) && !o.data.hidden);

// Bike paths: separate networks and standalone paths
const networkPages = bikePaths.filter(p => p.memberRefs && p.memberRefs.length > 0);
const memberSlugs = new Set(networkPages.flatMap(n => (n.memberRefs ?? []).map(m => m.slug)));
const standaloneBikePaths = bikePaths.filter(p => p.standalone && !p.memberRefs && !memberSlugs.has(p.slug));

const nonDefaultLocales = locales.filter(l => l !== defLocale);
---

<Base title={`${t('sitemap.title', defLocale)} | ${config.display_name}`} description={`Sitemap for ${config.display_name}`}>
  <h1>{t('sitemap.title', defLocale)}</h1>
  <ul>
    <li><a href={localePath('/', defLocale)}>{config.display_name}</a>
      <ul>
        <li><a href="/about">{t('nav.about', defLocale)} {config.display_name}</a></li>
        <li><a href="/map">{t('sitemap.map_description', defLocale)}</a></li>
      </ul>
    </li>

    <li><strong>{t('nav.ride', defLocale)}</strong>
      <ul>
        <li><a href={localePath('/routes', defLocale)}>{t('nav.routes', defLocale)}</a>
          <ul>
            {publishedRoutes.map(route => (
              <li><a href={paths.route(route.id, defLocale)}>{route.data.name}</a></li>
            ))}
          </ul>
        </li>
        {bikePaths.length > 0 && (
          <li><a href={paths.bikePaths(defLocale)}>{t('nav.bike_paths', defLocale)}</a>
            <ul>
              {networkPages.map(net => (
                <li>
                  <a href={paths.bikePath(net.slug, undefined, defLocale)}>{net.name}</a>
                  {net.memberRefs && net.memberRefs.length > 0 && (
                    <ul>
                      {net.memberRefs.filter(m => m.standalone).map(m => (
                        <li><a href={paths.bikePath(m.slug, m.memberOf ?? net.slug, defLocale)}>{m.name}</a></li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
              {standaloneBikePaths.map(bp => (
                <li><a href={paths.bikePath(bp.slug, bp.memberOf, defLocale)}>{bp.name}</a></li>
              ))}
            </ul>
          </li>
        )}
      </ul>
    </li>

    <li><strong>{t('nav.community', defLocale)}</strong>
      <ul>
        <li><a href={localePath('/calendar', defLocale)}>{t('sitemap.cycling_calendar', defLocale)}</a>
          {events.length > 0 && (
            <ul>
              {events.map(e => (
                <li><a href={paths.event(e.id, defLocale)}>{e.data.name}</a></li>
              ))}
            </ul>
          )}
        </li>
        <li><a href={paths.communities(defLocale)}>{t('nav.people', defLocale)}</a>
          {communities.length > 0 && (
            <ul>
              {communities.map(c => (
                <li><a href={paths.community(c.id, defLocale)}>{c.data.name}</a></li>
              ))}
            </ul>
          )}
        </li>
        <li><a href={paths.bikeShops(defLocale)}>{t('bike_shops.heading', defLocale)}</a>
          {bikeShops.length > 0 && (
            <ul>
              {bikeShops.map(s => (
                <li><a href={paths.community(s.id, defLocale)}>{s.data.name}</a></li>
              ))}
            </ul>
          )}
        </li>
      </ul>
    </li>

    <li><a href="/guides">{t('guides.title', defLocale)}</a>
      <ul>
        {publishedGuides.map(guide => (
          <li><a href={paths.guide(guide.id, defLocale)}>{guide.data.name}</a></li>
        ))}
      </ul>
    </li>

    {allVideos.length > 0 && (
      <li><a href="/videos">{t('videos.title', defLocale)}</a>
        <ul>
          {allVideos.map(v => (
            <li><a href={paths.video(v.handle)}>{v.title || v.handle}</a></li>
          ))}
        </ul>
      </li>
    )}
  </ul>

  {nonDefaultLocales.map(locale => (
    <h2>/{locale}/</h2>
    <ul>
      <li><a href={localePath('/', locale)}>{config.display_name} ({locale})</a>
        <ul>
          <li><a href={localePath('/about', locale)}>{t('nav.about', locale)}</a></li>
          <li><a href={localePath('/map', locale)}>{t('nav.map', locale)}</a></li>
        </ul>
      </li>

      <li><strong>{t('nav.ride', locale)}</strong>
        <ul>
          <li><a href={localePath('/routes', locale)}>{t('nav.routes', locale)}</a>
            <ul>
              {publishedRoutes.map(route => (
                <li><a href={paths.route(routeSlug(route, locale), locale)}>{route.data.name}</a></li>
              ))}
            </ul>
          </li>
          {bikePaths.length > 0 && (
            <li><a href={paths.bikePaths(locale)}>{t('nav.bike_paths', locale)}</a>
              <ul>
                {networkPages.map(net => (
                  <li>
                    <a href={paths.bikePath(net.slug, undefined, locale)}>{net.name}</a>
                    {net.memberRefs && net.memberRefs.length > 0 && (
                      <ul>
                        {net.memberRefs.filter(m => m.standalone).map(m => (
                          <li><a href={paths.bikePath(m.slug, m.memberOf ?? net.slug, locale)}>{m.name}</a></li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
                {standaloneBikePaths.map(bp => (
                  <li><a href={paths.bikePath(bp.slug, bp.memberOf, locale)}>{bp.name}</a></li>
                ))}
              </ul>
            </li>
          )}
        </ul>
      </li>

      <li><strong>{t('nav.community', locale)}</strong>
        <ul>
          <li><a href={localePath('/calendar', locale)}>{t('nav.calendar', locale)}</a>
            {events.length > 0 && (
              <ul>
                {events.map(e => (
                  <li><a href={paths.event(e.id, locale)}>{e.data.name}</a></li>
                ))}
              </ul>
            )}
          </li>
          <li><a href={paths.communities(locale)}>{t('nav.people', locale)}</a></li>
          <li><a href={paths.bikeShops(locale)}>{t('bike_shops.heading', locale)}</a></li>
        </ul>
      </li>

      <li><a href={localePath('/guides', locale)}>{t('guides.title', locale)}</a>
        <ul>
          {publishedGuides.map(guide => (
            <li><a href={paths.guide(guide.id, locale)}>{guide.data.name}</a></li>
          ))}
        </ul>
      </li>

      {allVideos.length > 0 && (
        <li><a href={localePath('/videos', locale)}>{t('videos.title', locale)}</a>
          <ul>
            {allVideos.map(v => (
              <li><a href={paths.video(v.handle, locale)}>{v.title || v.handle}</a></li>
            ))}
          </ul>
        </li>
      )}
    </ul>
  ))}

  <p><a href="/sitemap.xml">sitemap.xml</a></p>
</Base>
