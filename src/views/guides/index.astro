---
// src/views/guides/index.astro
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/city-config';
import { paths } from '@/lib/paths';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;

const guides = await getCollection('guides');
const published = guides
  .filter(g => g.data.status === 'published')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title={`${t('guides.title', locale)} | ${config.display_name}`}>
  <h1>📖 {t('guides.title', locale)}</h1>
  <ul class="guides-list">
    {published.map(guide => (
      <li class="guides-list--guide">
        <a href={paths.guide(guide.id, locale)} class="guide--name">{guide.data.name}</a>
        {guide.data.tagline && <span class="guide--tagline">{guide.data.tagline}</span>}
      </li>
    ))}
  </ul>
</Base>
