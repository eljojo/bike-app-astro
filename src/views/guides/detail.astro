---
// src/views/guides/detail.astro
import Base from '@/layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { guideJsonLd, breadcrumbJsonLd } from '@/lib/json-ld';
import { getCityConfig } from '@/lib/city-config';
import { t, localePath } from '@/i18n';
import { paths } from '@/lib/paths';

const config = getCityConfig();
const locale = Astro.currentLocale;

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: t('nav.guides', locale), url: `${config.url}${localePath('/guides', locale)}` },
  { name: guide.data.name, url: `${config.url}${paths.guide(guide.id, locale)}` },
]);
---

<Base title={`${guide.data.name} | ${config.display_name}`} description={guide.data.tagline} jsonLd={guideJsonLd({...guide.data, id: guide.id})} breadcrumbs={breadcrumbs}>
  <div class="guide-detail">
    <h1>{guide.data.name}</h1>
    {guide.data.tagline && <p class="guide-tagline">{guide.data.tagline}</p>}
    <div class="guide-body">
      <Content />
    </div>
  </div>
  <p style="margin-top: 2em;">
    <a href={localePath('/guides', locale)} class="go-back-button">&#x21A9; {t('guides.go_back', locale)}</a>
  </p>
</Base>
