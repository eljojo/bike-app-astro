---
export const prerender = true;
import './CommunityDetail.scss';
import Base from '@/layouts/Base.astro';
import ResponsiveImage from '@/components/ResponsiveImage.astro';
import MediaGallery from '@/components/MediaGallery.astro';
import { getCollection } from 'astro:content';
import { getCityConfig } from '@/lib/config/city-config';
import { t, localePath } from '@/i18n';
import { paths } from '@/lib/paths';
import { imageUrl } from '@/lib/media/image-service';
import { hasDetailPage, organizerInitials, normalizeSocialLinks, parseInstagramUsername, isBikeShop } from '@/lib/models/organizer-model';
import { categoryEmoji } from '@/lib/geo/place-categories';
import { tTag } from '@/lib/i18n/tag-translations.server';
import { parseLocalDate, endOfDay, formatDateRange } from '@/lib/date-utils';
import { eventCoverKey } from '@/lib/models/event-model';
import EditEntryPoint from '@/components/EditEntryPoint.astro';
import { extractYouTubeUrls } from '@/lib/youtube-extract';
import YouTubeEmbed from '@/components/YouTubeEmbed.astro';
import { renderMarkdownHtml } from '@/lib/markdown/markdown-render';
import PinMap from '@/components/PinMap.astro';
import Icon from '@/components/Icon.astro';
import { escapeHtml } from '@/lib/maps/map-helpers';

const config = getCityConfig();
const locale = Astro.currentLocale;

export async function getStaticPaths() {
  const organizers = await getCollection('organizers');
  return organizers
    .filter(org => hasDetailPage(org))
    .map(org => ({
      params: { slug: org.id },
      props: { organizer: org },
    }));
}

const { organizer } = Astro.props;
const data = organizer.data;
const { videoIds: youtubeIds, cleanedMarkdown: cleanBody } = extractYouTubeUrls(organizer.body || '');

// Load places linked to this organizer
const allPlaces = await getCollection('places');
const locations = allPlaces
  .filter(p => p.data.organizer === organizer.id && p.data.status === 'published')
  .map(p => ({
    name: p.data.name,
    address: p.data.address,
    phone: p.data.phone,
    website: p.data.website,
    google_maps_url: p.data.google_maps_url,
    lat: p.data.lat,
    lng: p.data.lng,
    category: p.data.category,
    emoji: categoryEmoji[p.data.category] || '📍',
    social_links: p.data.social_links || [],
  }));

const isShop = isBikeShop(organizer);

// Load events by this organizer
const allEvents = await getCollection('events');
const now = new Date();
const orgEvents = allEvents
  .filter(e => {
    const orgId = typeof e.data.organizer === 'string' ? e.data.organizer : undefined;
    return orgId === organizer.id;
  })
  .sort((a, b) => {
    const da = parseLocalDate(a.data.start_date);
    const db = parseLocalDate(b.data.start_date);
    return db.getTime() - da.getTime();
  });

const upcomingEvents = orgEvents.filter(e => endOfDay(e.data.end_date || e.data.start_date) >= now);
const pastEvents = orgEvents.filter(e => endOfDay(e.data.end_date || e.data.start_date) < now);

// Unify legacy instagram/website fields with social_links, then filter out Twitter/X
const socialLinks = normalizeSocialLinks(
  data.social_links ?? [],
  { instagram: data.instagram, website: data.website },
).filter(link => !['twitter', 'x'].includes(link.platform.toLowerCase()));

function socialLinkHref(link: { platform: string; url: string }): string {
  if (link.platform === 'telephone') return `tel:${link.url.replace(/[^+\d]/g, '')}`;
  if (link.platform === 'email') return `mailto:${link.url}`;
  return link.url;
}

function socialLinkLabel(link: { platform: string; url: string }): string {
  if (link.platform === 'instagram') {
    const username = parseInstagramUsername(link.url);
    return username ? t('social.on_instagram', locale, { username }) : 'Instagram';
  }
  if (link.platform === 'telephone') return link.url;
  if (link.platform === 'email') return link.url;
  // Brand names stay untranslated; generic labels use t()
  const labels: Record<string, string> = {
    facebook: 'Facebook',
    strava: 'Strava',
    youtube: 'YouTube',
    meetup: 'Meetup',
    tiktok: 'TikTok',
    bluesky: 'Bluesky',
    threads: 'Threads',
    website: t('social.website', locale),
    discord: 'Discord',
    google_form: t('social.sign_up_form', locale),
    linktree: 'Linktree',
    rwgps: 'Ride with GPS',
    komoot: 'Komoot',
    newsletter: t('social.newsletter', locale),
    mastodon: 'Mastodon',
    booking: t('social.booking', locale),
  };
  return labels[link.platform] || link.platform;
}

// Media gallery
const mediaItems = (data.media ?? []).map(m => ({
  type: m.type || 'photo',
  key: m.key,
  caption: m.caption,
  width: m.width,
  height: m.height,
}));

const contactPlatforms = new Set(['telephone', 'email', 'booking']);
const contactLinks = socialLinks.filter(l => contactPlatforms.has(l.platform));
const socialOnlyLinks = socialLinks.filter(l => !contactPlatforms.has(l.platform));

const PAST_EVENTS_INITIAL = 4;
---

<Base title={`${data.name} | ${config.display_name}`} description={data.tagline}>
  <article class="community-detail">
    <header class="community-detail-header">
      <div class="community-detail-avatar">
        {data.photo_key ? (
          <ResponsiveImage
            blobKey={data.photo_key}
            alt={data.name}
            widths={[128, 256]}
            width={80}
            height={80}
            class="community-detail-photo"
          />
        ) : (
          <div class="community-detail-initials">{organizerInitials(data.name)}</div>
        )}
      </div>
      <div class="community-detail-header-info">
        <h1>{data.name}</h1>
        {data.tagline && <p class="community-detail-tagline">{data.tagline}</p>}
        {socialOnlyLinks.length > 0 && (
          <div class="community-detail-links">
            {socialOnlyLinks.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="community-social-pill">
                {socialLinkLabel(link)}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    {contactLinks.length > 0 && (
      <div class="community-contact-card">
        {contactLinks.map(link => (
          <a
            href={socialLinkHref(link)}
            {...(link.platform === 'booking' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class:list={['community-contact-item', { 'community-contact-booking': link.platform === 'booking' }]}
          >
            {link.platform === 'telephone' && <Icon name="phone" size={16} />}
            {link.platform === 'email' && <Icon name="envelope-simple" size={16} />}
            {link.platform === 'booking' && <Icon name="calendar-check" size={16} />}
            {socialLinkLabel(link)}
          </a>
        ))}
      </div>
    )}

    {data.tags && data.tags.length > 0 && (
      <ul class="community-detail-tags">
        {data.tags.map(tag => <li class="tag-pill">{tTag(tag, locale)}</li>)}
      </ul>
    )}

    {organizer.body?.trim() && (
      <div class="community-detail-body">
        <div set:html={await renderMarkdownHtml(cleanBody)} />
      </div>
    )}

    {youtubeIds.map(id => (
      <div class="community-detail-video">
        <YouTubeEmbed videoId={id} title={data.name} />
      </div>
    ))}

    <EditEntryPoint text={t('communities.edit_description', locale)} href={`/admin/communities/${organizer.id}`} />

    {mediaItems.length > 0 && (
      <section class="community-detail-section">
        <MediaGallery media={mediaItems} name={data.name} />
      </section>
    )}

    {locations.length > 0 && (
      <section class="community-detail-section community-locations">
        <h2>{t('communities.locations', locale)}</h2>
        <div class="community-locations-layout">
          <PinMap
            class="community-locations-map"
            pins={locations.map((loc, i) => ({
              lat: loc.lat,
              lng: loc.lng,
              label: String.fromCharCode(65 + i),
              popup: `<strong>${escapeHtml(loc.name)}</strong>`,
            }))}
          />
          <div class="community-locations-list">
            {locations.map((loc, i) => (
              <div class="community-location-card">
                <div class="community-location-letter">{String.fromCharCode(65 + i)}</div>
                <div class="community-location-info">
                  <strong>{loc.name}</strong>
                  {loc.address && <div class="community-location-address">{loc.address}</div>}
                  {loc.phone && <div class="community-location-phone"><a href={`tel:${loc.phone.replace(/[^+\d]/g, '')}`}>{loc.phone}</a></div>}
                  <div class="community-location-links">
                    {loc.social_links.filter(l => l.platform === 'booking').map(l => (
                      <a href={l.url} target="_blank" rel="noopener noreferrer" class="community-social-pill">{t('social.booking', locale)}</a>
                    ))}
                    {loc.google_maps_url && (
                      <a href={loc.google_maps_url} target="_blank" rel="noopener noreferrer" class="community-social-pill">{t('social.directions', locale)}</a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {upcomingEvents.length > 0 && (
      <section class="community-detail-section">
        <h2>{t('communities.upcoming_events', locale)}</h2>
        <div class="community-events-grid">
          {upcomingEvents.map(event => (
            <a href={paths.event(event.id, locale)} class="community-event-compact">
              <div class="community-event-thumb">
                {eventCoverKey(event.data) ? (
                  <img src={imageUrl(eventCoverKey(event.data)!, { width: 80, height: 80, fit: 'cover' })} alt="" />
                ) : (
                  <span>🚲</span>
                )}
              </div>
              <div class="community-event-body">
                <span class="community-event-name">{event.data.name}</span>
                <span class="community-event-meta">
                  {formatDateRange(event.data.start_date, event.data.end_date, locale)}
                  {event.data.distances && ` · ${event.data.distances}`}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {pastEvents.length > 0 && (
      <section class="community-detail-section">
        <h2>{t('communities.past_events', locale)}</h2>
        <div class="community-events-grid" id="past-events-grid">
          {pastEvents.map((event, i) => (
            <a
              href={paths.event(event.id, locale)}
              class={`community-event-compact past${i >= PAST_EVENTS_INITIAL ? ' community-event-hidden' : ''}`}
            >
              <div class="community-event-thumb">
                {eventCoverKey(event.data) ? (
                  <img src={imageUrl(eventCoverKey(event.data)!, { width: 80, height: 80, fit: 'cover' })} alt="" />
                ) : (
                  <span>🚲</span>
                )}
              </div>
              <div class="community-event-body">
                <span class="community-event-name">{event.data.name}</span>
                <span class="community-event-meta">
                  {formatDateRange(event.data.start_date, event.data.end_date, locale)}
                  {event.data.distances && ` · ${event.data.distances}`}
                </span>
              </div>
            </a>
          ))}
        </div>
        {pastEvents.length > PAST_EVENTS_INITIAL && (
          <button class="community-show-all-btn" id="show-all-past-events" type="button">
            {t('communities.show_all_events', locale, { count: pastEvents.length })}
          </button>
        )}
      </section>
    )}
  </article>

  <p class="community-go-back">
    <a href={paths.communities(locale)} class="go-back-button">&#x21A9; {t('communities.go_back', locale)}</a>
  </p>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('show-all-past-events');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const grid = document.getElementById('past-events-grid');
        if (!grid) return;
        const hidden = grid.querySelectorAll('.community-event-hidden');
        hidden.forEach(el => el.classList.remove('community-event-hidden'));
        btn.remove();
      });
    });
  </script>
</Base>
