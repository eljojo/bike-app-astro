---
export const prerender = true;
// src/views/videos/index.astro
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { videoPosterUrl } from '@/lib/video-service';
import { imageUrl } from '@/lib/image-service';
import { getCityConfig } from '@/lib/config/city-config';
import { paths, routeSlug } from '@/lib/paths';
import { t } from '@/i18n';

const config = getCityConfig();
const locale = Astro.currentLocale;

const routes = await getCollection('routes');
const routesWithVideos = routes
  .filter(r => r.data.status === 'published')
  .filter(r => r.data.media.some(m => m.type === 'video'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title={`${t('videos.title', locale)} | ${config.display_name}`}>
  <h1>&#x1F3A5; {t('videos.title', locale)}</h1>

  {routesWithVideos.map(route => {
    const videos = route.data.media.filter(m => m.type === 'video');
    return (
      <section>
        <h2><a href={paths.route(routeSlug(route, locale), locale)}>{route.data.name}</a></h2>
        <ul class="videos-list-internal">
          {videos.map(video => (
            <li>
              <a href={paths.video(video.handle, locale)} title={video.title}>
                <img src={video.poster_key ? imageUrl(video.poster_key, { width: 300 }) : videoPosterUrl(video.key)} alt={video.title || 'Video'} />
              </a>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Base>
