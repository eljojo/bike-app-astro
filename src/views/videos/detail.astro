---
// src/views/videos/detail.astro
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { videoPlaybackSources, videoPosterUrl, videoDisplaySize, videoFallbackUrl } from '@/lib/video-service';
import { getCityConfig } from '@/lib/city-config';
import { t } from '@/i18n';
import { paths, routeSlug } from '@/lib/paths';

const config = getCityConfig();
const locale = Astro.currentLocale;

export const prerender = true;
export async function getStaticPaths() {
  const routes = await getCollection('routes');
  const results: { params: { handle: string }; props: Record<string, unknown> }[] = [];

  for (const route of routes) {
    if (route.data.status !== 'published') continue;
    const videos = route.data.media.filter(m => m.type === 'video');
    for (const video of videos) {
      const otherVideos = videos.filter(v => v.handle !== video.handle);
      results.push({
        params: { handle: video.handle },
        props: { video, route, otherVideos },
      });
    }
  }

  return results;
}

const { video, route, otherVideos } = Astro.props;
const sources = videoPlaybackSources(video.key);
const title = video.title || 'Video';
---

<Base title={`${title} | ${config.display_name}`}>
  <h1>{title}</h1>
  <div class="video-show main-video">
    <video
      controls
      preload="metadata"
      poster={video.poster_key ? videoPosterUrl(video.poster_key) : undefined}
      disablepictureinpicture
    >
      {sources.map(s => <source src={s.src} type={s.type} />)}
      <p><a href={videoFallbackUrl(video.key)}>{title}</a></p>
    </video>
  </div>

  {otherVideos.length > 0 && (
    <div>
      <h3>{t('videos.other', locale, { name: route.data.name })}</h3>
      <ul class="videos-list-internal">
        {otherVideos.map(v => (
          <li>
            <a href={paths.video(v.handle)} title={v.title}>
              {v.poster_key ? (
                <img src={videoPosterUrl(v.poster_key)} alt={v.title || 'Video'} />
              ) : (
                <span>{v.title || 'Video'}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p style="margin-top: 2em;">
    <a href={paths.route(routeSlug(route, locale), locale)} class="go-back-button">&#x21A9; {t('route.go_back_to', locale, { name: route.data.name })}</a>
  </p>
</Base>
