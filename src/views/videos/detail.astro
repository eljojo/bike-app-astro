---
// src/views/videos/detail.astro
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { videoPlaybackSources, videoPosterUrl, videoDisplaySize, videoFallbackUrl } from '@/lib/media/video-service';
import { getCityConfig } from '@/lib/config/city-config';
import { t, localePath } from '@/i18n';
import { paths, routeSlug } from '@/lib/paths';
import { videoJsonLd, breadcrumbJsonLd } from '@/lib/json-ld';

const config = getCityConfig();
const locale = Astro.currentLocale;

export const prerender = true;
export async function getStaticPaths() {
  const routes = await getCollection('routes');
  const results: { params: { handle: string }; props: Record<string, unknown> }[] = [];

  for (const route of routes) {
    if (route.data.status !== 'published') continue;
    const videos = route.data.media.filter(m => m.type === 'video');
    for (const video of videos) {
      const otherVideos = videos.filter(v => v.handle !== video.handle);
      results.push({
        params: { handle: video.handle },
        props: { video, route, otherVideos },
      });
    }
  }

  return results;
}

const { video, route, otherVideos } = Astro.props;
const sources = videoPlaybackSources(video.key);
const title = video.title || 'Video';
const posterUrl = videoPosterUrl(video.key);
const mp4Url = videoFallbackUrl(video.key);
const description = video.caption || `${title} — ${t('route.bike_route', locale)} ${route.data.name}, ${config.display_name}`;

const jsonLd = videoJsonLd({
  title,
  description,
  handle: video.handle,
  posterUrl,
  contentUrl: mp4Url,
  duration: video.duration,
  width: video.width,
  height: video.height,
});

const breadcrumbs = breadcrumbJsonLd([
  { name: t('nav.home', locale), url: `${config.url}${localePath('/', locale)}` },
  { name: route.data.name, url: `${config.url}${paths.route(routeSlug(route, locale), locale)}` },
  { name: title, url: `${config.url}${paths.video(video.handle, locale)}` },
]);

const ogVideo = { url: mp4Url, type: 'video/mp4', width: video.width, height: video.height };
---

<Base
  title={`${title} | ${config.display_name}`}
  description={description}
  ogImage={posterUrl}
  ogImageAlt={title}
  ogType="video.other"
  ogVideo={ogVideo}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <h1>{title}</h1>
  <div class="video-show main-video">
    <video
      controls
      preload="metadata"
      poster={videoPosterUrl(video.key)}
      disablepictureinpicture
    >
      {sources.map(s => <source src={s.src} type={s.type} />)}
      <p><a href={videoFallbackUrl(video.key)}>{title}</a></p>
    </video>
  </div>

  {otherVideos.length > 0 && (
    <div>
      <h3>{t('videos.other', locale, { name: route.data.name })}</h3>
      <ul class="videos-list-internal">
        {otherVideos.map(v => (
          <li>
            <a href={paths.video(v.handle)} title={v.title}>
              <img src={videoPosterUrl(v.key)} alt={v.title || 'Video'} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p style="margin-top: 2em;">
    <a href={paths.route(routeSlug(route, locale), locale)} class="go-back-button">&#x21A9; {t('route.go_back_to', locale, { name: route.data.name })}</a>
  </p>
  <script>import '@/lib/media/hls-player';</script>
</Base>
